</head>
<body>
<div id="root"><div id="splash" style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;background:#f0f2f5"><div style="width:56px;height:56px;border-radius:16px;background:linear-gradient(135deg,#3b82f6,#1d4ed8);display:flex;align-items:center;justify-content:center;margin-bottom:12px"><span style="color:#fff;font-weight:900;font-size:24px">S</span></div><div style="font-size:16px;font-weight:700;color:#1e293b">札幌店 タスク管理</div><div style="margin-top:16px;width:32px;height:32px;border:3px solid #e2e8f0;border-top-color:#3b82f6;border-radius:50%;animation:sp .8s linear infinite"></div><div id="splash-status" style="margin-top:12px;font-size:11px;color:#94a3b8">読み込み中...</div><style>@keyframes sp{to{transform:rotate(360deg)}}</style></div></div>
<script>
(function(){
  var CV='spk-v460';
  if(localStorage.getItem('sw_cache_ver')!==CV){
    if('caches' in window){caches.keys().then(function(k){k.forEach(function(n){caches.delete(n);});});}
    if('serviceWorker' in navigator){navigator.serviceWorker.getRegistrations().then(function(rs){rs.forEach(function(r){r.unregister();});});}
    localStorage.setItem('sw_cache_ver',CV);
    setTimeout(function(){location.reload(true);},500);
  }else{
    if('serviceWorker' in navigator){navigator.serviceWorker.register('/sw.js?v=460').then(function(r){r.update();}).catch(function(){});}
  }
})();
</script>
<script>
var ss=document.getElementById('splash-status');
function splashMsg(t){if(ss)ss.textContent=t;}
splashMsg('ライブラリ読込中...');
</script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/react/18.2.0/umd/react.production.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/react-dom/18.2.0/umd/react-dom.production.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/babel-standalone/7.23.9/babel.min.js"></script>
<!-- encoding-japanese: 遅延ロード（CSVインポート時のみ） -->
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
<script>splashMsg('アプリ準備中...');</script>
<script>
function showErr(title,detail){
  var d=document.createElement("div");
  d.style.cssText="position:fixed;top:0;left:0;right:0;background:#fee2e2;color:#991b1b;padding:12px;font-size:12px;z-index:99999;white-space:pre-wrap;max-height:300px;overflow:auto";
  d.textContent=title+"\n"+detail;
  document.body.appendChild(d);
}
window.onerror=function(msg,src,line,col,err){
  showErr("[JS Error] "+msg,"Source: "+(src||"unknown")+"\nLine: "+line+" Col: "+col+(err&&err.stack?"\n"+err.stack:""));
};
window.addEventListener("unhandledrejection",function(e){
  var r=e.reason;
  if(r&&r.message&&r.message.indexOf("SyntaxError")>=0){showErr("[Babel Compile Error]",r.message);}
  console.error("Unhandled promise:",r);
});
</script>
<script type="text/babel">
const {useState,useMemo,useCallback,useEffect,useRef}=React;

/* ===== Supabase 設定 ===== */
const SUPABASE_URL = "https://ckrxttbnawkclshczsia.supabase.co";
const SUPABASE_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImNrcnh0dGJuYXdrY2xzaGN6c2lhIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzE4Nzg1NTAsImV4cCI6MjA4NzQ1NDU1MH0.kDC_UDVWvcrS97wzqQ3NXP79ewjgYwF4vSFdV7y06S8";
const SB_ENABLED = !!(SUPABASE_URL && SUPABASE_KEY);
let sb = null;
if(SB_ENABLED){
  sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);
}

/* ===== 駐車場用 Supabase (別プロジェクト) ===== */
const PARKING_SB_URL = "https://rkrvjpipvpybkmqadmrb.supabase.co";
const PARKING_SB_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJrcnZqcGlwdnB5YmttcWFkbXJiIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzI4MjI4MjQsImV4cCI6MjA4ODM5ODgyNH0.Jq_yIfAp1gsXdOtigwEwMb43iPD188PRKKdwc0D4tU4";
let sbParking = null;
try{ sbParking = window.supabase.createClient(PARKING_SB_URL, PARKING_SB_KEY); }catch(e){}

/* ===== Supabase DB ヘルパー ===== */
function dbLog(op,ok,detail){console.log(`[DB ${ok?"✓":"✗"}] ${op}`,detail||"");}
const DB = {
  // --- 予約 ---
  async fetchReservations(){if(!sb)return[];const{data,error}=await sb.from("reservations").select("*");if(error){dbLog("fetchRes",false,error.message);return[];}dbLog("fetchRes",true,data.length+"件");return(data||[]).map(DB._fromDbRes);},
  async upsertReservations(arr){if(!sb||!arr.length)return;const rows=arr.map(DB._toDbRes);await DB._retryOp(async()=>{const{error}=await sb.from("reservations").upsert(rows,{onConflict:"id"});if(error)throw new Error(error.message);dbLog("upsertRes",true,arr.length+"件保存");},"upsertRes");},
  async deleteReservations(ids){if(!sb||!ids.length)return;const{error}=await sb.from("reservations").delete().in("id",ids);if(error)dbLog("deleteRes",false,error.message);else dbLog("deleteRes",true,ids.length+"件削除");},
  async syncToReservation(resId,fields){if(!sb||!resId||!Object.keys(fields).length)return;try{const{error}=await sb.from("reservations").update(fields).eq("id",resId);if(error)dbLog("syncToRes",false,resId+": "+error.message);else dbLog("syncToRes",true,resId+" "+Object.keys(fields).join(","));}catch(e){dbLog("syncToRes",false,e.message);}},
  async updateReservationField(resId,changes){
    if(!sb||!resId)return;
    try{
      const colMap={lendTime:"lend_time",returnTime:"return_time",delTime:"del_time",colTime:"col_time",
        delPlace:"del_place",colPlace:"col_place",vehicle:"vehicle",insurance:"insurance",
        optB:"opt_b",optC:"opt_c",optUSB:"opt_usb",visitType:"visit_type",returnType:"return_type",
        lendDate:"lend_date",returnDate:"return_date",flight:"flight",people:"people",price:"price"};
      const dbChanges={};
      Object.entries(changes).forEach(([k,v])=>{const col=colMap[k]||k;dbChanges[col]=v;});
      const{error}=await sb.from("reservations").update(dbChanges).eq("id",resId);
      if(error)dbLog("updateResField",false,error.message);
      else dbLog("updateResField",true,resId);
    }catch(e){console.error("[updateResField]",e);}
  },
  _toDbRes(r){return{id:r.id,ota:r.ota,name:r.name,lend_date:r.lendDate,lend_time:r.lendTime,return_date:r.returnDate,return_time:r.returnTime,people:r.people,vehicle:r.vehicle,insurance:r.insurance,tel:r.tel,mail:r.mail,price:r.price,status:r.status,visit_type:r.visitType,return_type:r.returnType,del_time:r.delTime||"",del_place:r.delPlace||"",col_time:r.colTime||"",col_place:r.colPlace||"",flight:r.flight||"",opt_b:+(r.optB||0),opt_c:+(r.optC||0),opt_j:+(r.optJ||0),opt_usb:!!r.optUSB,opt_parasol:!!r.optParasol};},
  _fromDbRes(d){return{id:d.id,ota:d.ota,name:d.name,lendDate:norm(d.lend_date),lendTime:d.lend_time,returnDate:norm(d.return_date),returnTime:d.return_time,people:d.people,vehicle:d.vehicle,insurance:d.insurance,tel:d.tel,mail:d.mail,price:Number(d.price)||0,status:d.status,visitType:d.visit_type,returnType:d.return_type,delTime:d.del_time,delPlace:d.del_place,colTime:d.col_time,colPlace:d.col_place,flight:d.flight,optB:+(d.opt_b||0),optC:+(d.opt_c||0),optJ:+(d.opt_j||0),optUSB:d.opt_usb,optParasol:d.opt_parasol,prefecture:d.prefecture||""};},
  // --- 配車（LS併用で車両変更保護） ---
  _fleetLsKey:"spk_fleet",
  _fleetLsSave(f){try{localStorage.setItem(DB._fleetLsKey,JSON.stringify(f));}catch(e){}},
  _fleetLsLoad(){try{const s=localStorage.getItem(DB._fleetLsKey);return s?JSON.parse(s):{};}catch(e){return{};}},
  async fetchFleet(){if(!sb){return DB._fleetLsLoad();}const{data,error}=await sb.from("fleet").select("*");if(error){dbLog("fetchFleet",false,error.message);return DB._fleetLsLoad();}const f={};(data||[]).forEach(r=>f[r.reservation_id]=r.vehicle_code);dbLog("fetchFleet",true,Object.keys(f).length+"件");DB._fleetLsSave(f);return f;},
  async upsertFleet(fleet){DB._fleetLsSave(fleet);if(!sb)return;const rows=Object.entries(fleet).map(([k,v])=>({reservation_id:k,vehicle_code:v}));if(rows.length){await DB._retryOp(async()=>{const{error}=await sb.from("fleet").upsert(rows,{onConflict:"reservation_id"});if(error)throw new Error(error.message);dbLog("upsertFleet",true,rows.length+"件");},"upsertFleet");}},
  async updateFleetOne(resId,code){if(!sb)return;const{error}=await sb.from("fleet").upsert({reservation_id:resId,vehicle_code:code},{onConflict:"reservation_id"});if(error)dbLog("updateFleet1",false,error.message);},
  async deleteFleetOne(resId){if(!sb)return;const{error}=await sb.from("fleet").delete().eq("reservation_id",resId);if(error)dbLog("deleteFleet1",false,error.message);},
  // --- タスク（localStorage併用で確実に保存） ---
  _lsKey(date){return"spk_tasks_"+date;},
  _lsSave(tasks,date){try{localStorage.setItem(DB._lsKey(date),JSON.stringify(tasks));}catch(e){}},
  _lsLoad(date){try{const s=localStorage.getItem(DB._lsKey(date));return s?JSON.parse(s):null;}catch(e){return null;}},
  _pendingSave:0,
  _hasChangedCol:null, // null=未チェック, true=あり, false=なし
  // --- 保存失敗リトライ（最大3回、指数バックオフ） ---
  async _retryOp(fn,label,maxRetry=3){
    for(let i=0;i<maxRetry;i++){
      try{const r=await fn();return r;}
      catch(e){
        if(i<maxRetry-1){const d=1000*Math.pow(2,i);console.warn(`[DB] ${label} retry ${i+1}/${maxRetry} in ${d}ms`,e.message);await new Promise(r=>setTimeout(r,d));}
        else{console.error(`[DB] ${label} 最終失敗`,e.message);throw e;}
      }
    }
  },
  async fetchTasks(date){
    if(!sb){return DB._lsLoad(date)||[];}
    const{data,error}=await sb.from("tasks").select("*").eq("date",date).order("sort_order");
    if(error){dbLog("fetchTasks",false,error.message);return DB._lsLoad(date)||[];}
    const tasks=(data||[]).map(DB._fromDbTask);
    // ★ 保存中の場合はlocalStorageを上書きしない（保存中のデータが消えるのを防ぐ）
    if(tasks.length&&DB._pendingSave<=0)DB._lsSave(tasks,date);
    // ★ changed_jsonカラムの存在を自動検出（初回のみ）
    if(DB._hasChangedCol===null&&data&&data.length>0){
      DB._hasChangedCol="changed_json" in data[0];
      dbLog("changed_col_detect",true,DB._hasChangedCol?"あり":"なし");
    }
    return tasks;
  },
  // 3段階保存: full → mid(changed_json付きmin) → bare(changed_jsonなしmin)
  _toDbTaskBare(t,date,i){return{_id:t._id,date:date,type:t.type||"",time:t.time||"",name:t.name||"",assignee:t.assignee||"",done:!!t.done,memo:DB._encodeMemo(t),reservation_id:t.reservationId||"",ota:t.ota||"",tel:t.tel||"",mail:t.mail||"",assigned_vehicle:t.assignedVehicle||"",plate_no:t.plateNo||"",people:t.people||0,place:t.place||"",vehicle:t.vehicle||"",insurance:t.insurance||"",insurance_change:t.insuranceChange||"",flight:t.flight||"",return_date:t.returnDate||"",return_time:t.returnTime||"",return_type:t.returnType||"",col_place:t.colPlace||"",sort_order:i};},
  _toDbTaskMin(t,date,i){const b=DB._toDbTaskBare(t,date,i);b.changed_json=JSON.stringify(t._changed||{});b.assignee_custom=!!t._assigneeCustom;b.time_changed=!!t._timeChanged;return b;},
  _dbSaveOk:true,
  // ★ DB保存（changed_json含むフル保存→bareフォールバック）
  async _upsertWithFallback(rows,label){
    if(!sb||!rows.length)return;
    // 1) changed_json含む保存（opt_*等の追加カラムは除外）
    const cjRows=rows.map(r=>{const b={...r};delete b.opt_b;delete b.opt_c;delete b.opt_j;delete b.opt_usb;delete b.opt_parasol;delete b.yakkan;delete b.line;delete b.payment;delete b.assignee_custom;delete b.time_changed;return b;});
    const{error}=await sb.from("tasks").upsert(cjRows,{onConflict:"_id"});
    if(!error){DB._dbSaveOk=true;return;}
    dbLog(label+"-cj",false,error.message);
    // 2) bare保存（changed_jsonも除外）
    const bareRows=cjRows.map(r=>{const b={...r};delete b.changed_json;return b;});
    const{error:e2}=await sb.from("tasks").upsert(bareRows,{onConflict:"_id"});
    if(!e2){DB._dbSaveOk=true;return;}
    dbLog(label+"-bare",false,e2.message);DB._dbSaveOk=false;
  },
  async upsertTasks(tasks,date){
    DB._lsSave(tasks,date);
    if(!sb||!tasks.length)return;
    DB._pendingSave++;
    try{
      const rows=tasks.map((t,i)=>DB._toDbTask(t,date,i));
      await DB._upsertWithFallback(rows,"upsertTasks");
    }finally{DB._pendingSave--;}
  },
  async updateTask(t,date){
    const ls=DB._lsLoad(date);
    let sortIdx=t._sortOrder||0;
    if(ls){const idx=ls.findIndex(x=>x._id===t._id);if(idx>=0){sortIdx=idx;ls[idx]=t;DB._lsSave(ls,date);}else{sortIdx=ls.length;ls.push(t);DB._lsSave(ls,date);}}
    else{DB._lsSave([t],date);}
    if(!sb)return;
    DB._pendingSave++;
    try{
      const row=DB._toDbTask(t,date,sortIdx);
      await DB._upsertWithFallback([row],"updateTask");
      dbLog("updateTask",true,t._id+" assignee="+t.assignee);
    }catch(e){dbLog("updateTask",false,e.message);}
    finally{DB._pendingSave--;}
  },
  async deleteTasks(date){try{localStorage.removeItem(DB._lsKey(date));}catch(e){} if(!sb)return;const{error}=await sb.from("tasks").delete().eq("date",date);if(error)dbLog("deleteTasks",false,error.message);},
  async deleteTask(id,date){if(!sb)return;const{error}=await sb.from("tasks").delete().eq("_id",id);if(error)dbLog("deleteTask",false,error.message);else dbLog("deleteTask",true,id);try{const ls=DB._lsLoad(date);if(ls){const next=ls.filter(t=>t._id!==id);localStorage.setItem(DB._lsKey(date),JSON.stringify(next));}}catch(e){}},
  async deleteTasksByReservation(resId){if(!sb||!resId)return;const{error}=await sb.from("tasks").delete().eq("reservation_id",resId);if(error)dbLog("deleteTasksByRes",false,error.message);else dbLog("deleteTasksByRes",true,resId);},
  async fetchTasksRange(fromDate,toDate){if(!sb)return[];const{data,error}=await sb.from("tasks").select("*").gte("date",fromDate).lte("date",toDate).order("date",{ascending:false}).order("sort_order");if(error){dbLog("fetchTasksRange",false,error.message);return[];}return(data||[]).map(r=>({...DB._fromDbTask(r),_date:r.date}));},
  // ★ B/C/J数量をmemoに埋め込み（確実にDB保存される）
  _BCJ_TAG:"\n##BCJ:",
  _encodeMemo(t){const base=(t.memo||"").split("\n##BCJ:")[0];const b=+(t.opts?.b||0),c=+(t.opts?.c||0),j=+(t.opts?.j||0);if(b||c||j)return base+"\n##BCJ:"+b+","+c+","+j;return base;},
  _decodeMemo(memo){if(!memo||!memo.includes("\n##BCJ:"))return{memo:memo||"",b:0,c:0,j:0};const parts=memo.split("\n##BCJ:");const counts=(parts[1]||"0,0,0").split(",").map(Number);return{memo:parts[0],b:counts[0]||0,c:counts[1]||0,j:counts[2]||0};},
  _toDbTask(t,date,i){const b=DB._toDbTaskBare(t,date,i);b.changed_json=JSON.stringify({...(t._changed||{}),_optB:+(t.opts?.b||0),_optC:+(t.opts?.c||0),_optJ:+(t.opts?.j||0),_ssTime:t._ssTime||"",_ssTimeAt:t._ssTimeAt||"",_ssPlace:t._ssPlace||"",_ssPlaceAt:t._ssPlaceAt||"",_timeChange:t.timeChange||"",_placeSource:t._placeSource||"",_manualTimeAt:t._manualTimeAt||"",_manualPlaceAt:t._manualPlaceAt||"",_typeChange:t.typeChange||"",_manual:!!t.manual});return b;},
  _fromDbTask(d){const md=DB._decodeMemo(d.memo);const cj=(()=>{try{const p=JSON.parse(d.changed_json||"{}");return Object.keys(p).length?p:null;}catch(e){return null;}})();const oB=(cj&&cj._optB!==undefined?cj._optB:0)||md.b||(d.opt_b?1:0);const oC=(cj&&cj._optC!==undefined?cj._optC:0)||md.c||(d.opt_c?1:0);const oJ=(cj&&cj._optJ!==undefined?cj._optJ:0)||md.j||(d.opt_j?1:0);const ssTime=cj&&cj._ssTime||"";const ssTimeAt=cj&&cj._ssTimeAt||"";const ssPlace=cj&&cj._ssPlace||"";const ssPlaceAt=cj&&cj._ssPlaceAt||"";const timeChange=cj&&cj._timeChange||"";const placeSource=cj&&cj._placeSource||"";const manualTimeAt=cj&&cj._manualTimeAt||"";const manualPlaceAt=cj&&cj._manualPlaceAt||"";const typeChange=cj&&cj._typeChange||"";const isManualTask=cj&&cj._manual;const ch=cj||{};delete ch._optB;delete ch._optC;delete ch._optJ;delete ch._ssTime;delete ch._ssTimeAt;delete ch._ssPlace;delete ch._ssPlaceAt;delete ch._timeChange;delete ch._placeSource;delete ch._manualTimeAt;delete ch._manualPlaceAt;delete ch._typeChange;delete ch._manual;return{_id:d._id,type:d.type,time:d.time,name:d.name,assignee:d.assignee,done:d.done,memo:md.memo,reservationId:d.reservation_id,ota:d.ota,tel:d.tel,mail:d.mail,assignedVehicle:d.assigned_vehicle,plateNo:d.plate_no,people:d.people,place:d.place,vehicle:d.vehicle,insurance:d.insurance,insuranceChange:d.insurance_change,flight:d.flight,returnDate:norm(d.return_date),returnTime:d.return_time,returnType:d.return_type,colPlace:d.col_place,opts:{b:oB,c:oC,j:oJ,usb:d.opt_usb,parasol:d.opt_parasol},yakkan:d.yakkan,line:d.line,payment:d.payment,_sortOrder:d.sort_order,_changed:ch,_ssTime:ssTime,_ssTimeAt:ssTimeAt,_ssPlace:ssPlace,_ssPlaceAt:ssPlaceAt,timeChange:timeChange,_placeSource:placeSource,_manualTimeAt:manualTimeAt,_manualPlaceAt:manualPlaceAt,typeChange:typeChange,manual:!!isManualTask};},
  // --- スタッフ ---
  _staffLsKey:"spk_staff_backup",
  _staffLsSave(arr){try{localStorage.setItem(DB._staffLsKey,JSON.stringify(arr));}catch(e){}},
  _staffLsLoad(){try{const s=localStorage.getItem(DB._staffLsKey);return s?JSON.parse(s):null;}catch(e){return null;}},
  async fetchStaff(){if(!sb)return DB._staffLsLoad();const{data,error}=await sb.from("staff").select("*").order("sort_order");if(error){dbLog("fetchStaff",false,error.message);return DB._staffLsLoad();}dbLog("fetchStaff",true,data.length+"件");
    // カラム存在チェック
    const hasWageCols=data.length>0&&data[0].hasOwnProperty("hourly_wage");
    DB._staffHasWageCols=hasWageCols;
    if(!hasWageCols&&data.length>0)console.warn("[fetchStaff] ⚠️ staffテーブルにhourly_wageカラムなし");
    const dbStaff=(data||[]).map(s=>({name:s.name,type:s.type,memo:s.memo||"",hourlyWage:s.hourly_wage||0,transportCost:s.transport_cost||0,monthlySalary:s.monthly_salary||0}));
    // DB側にhourly_wage等カラムがない場合、localStorageの値をマージ→差異あればDBに自動プッシュ
    const lsStaff=DB._staffLsLoad();
    let needPush=false;
    if(lsStaff&&lsStaff.length>0){
      const lsMap={};lsStaff.forEach(s=>{lsMap[s.name]=s;});
      dbStaff.forEach(s=>{const ls=lsMap[s.name];if(ls){
        if(!s.hourlyWage&&ls.hourlyWage){s.hourlyWage=ls.hourlyWage;needPush=true;}
        if(!s.transportCost&&ls.transportCost){s.transportCost=ls.transportCost;needPush=true;}
        if(!s.monthlySalary&&ls.monthlySalary){s.monthlySalary=ls.monthlySalary;needPush=true;}
      }});
    }
    DB._staffLsSave(dbStaff);
    // LSから補完したデータがあればDBに自動保存（他デバイスにも反映）
    if(needPush&&hasWageCols){console.log("[staffSync] LS→DB push: wage data merged");DB.saveStaff(dbStaff).catch(e=>console.error("[staffSync]",e));}
    return dbStaff;},
  _staffHasWageCols:null, // null=未確認, true=あり, false=なし
  async saveStaff(arr){DB._staffLsSave(arr);if(!sb)return;
    const rows=arr.map((s,i)=>({name:s.name,type:s.type,memo:s.memo||"",sort_order:i,active:true,hourly_wage:s.hourlyWage||0,transport_cost:s.transportCost||0,monthly_salary:s.monthlySalary||0}));
    const{error}=await sb.from("staff").upsert(rows,{onConflict:"name"});
    if(error){
      dbLog("saveStaff",false,error.message);
      // カラム不在エラーの場合、給与カラムなしでリトライ
      if(error.message&&(error.message.includes("hourly_wage")||error.message.includes("transport_cost")||error.message.includes("monthly_salary")||error.message.includes("column"))){
        DB._staffHasWageCols=false;
        console.warn("[saveStaff] 給与カラムなし→カラムなしで再保存");
        const rows2=arr.map((s,i)=>({name:s.name,type:s.type,memo:s.memo||"",sort_order:i,active:true}));
        const{error:e2}=await sb.from("staff").upsert(rows2,{onConflict:"name"});
        if(e2)dbLog("saveStaff(retry)",false,e2.message);
        else dbLog("saveStaff(retry)",true,arr.length+"件(給与カラムなし)");
      }
    }else{DB._staffHasWageCols=true;dbLog("saveStaff",true,arr.length+"件保存");}
  },
  async deleteStaff(name){if(!sb)return;const{error}=await sb.from("staff").delete().eq("name",name);if(error)dbLog("deleteStaff",false,error.message);else dbLog("deleteStaff",true,name);},
  // --- 車両 ---
  async fetchVehicles(){if(!sb)return null;const{data,error}=await sb.from("vehicles").select("*");if(error){dbLog("fetchVehicles",false,error.message);return null;}dbLog("fetchVehicles",true,data.length+"件");
    // code重複修正: 同じcodeがあればナンバーを付加してユニーク化
    const seen={};let needFix=false;const mapped=(data||[]).map(v=>{let c=v.code;if(seen[c]){const no=(v.plate_no||"").replace(/[^0-9a-zA-Z]/g,"");c=c+(no||v.id);needFix=true;}seen[c]=true;return{id:"v"+v.id,code:c,name:v.name,no:v.plate_no,type:v.type,seats:v.seats,insuranceVeh:!!v.insurance_veh,year:v.year||"",equip:v.equip||"",insPrice:v.ins_price||""};});
    if(needFix){DB.saveVehicles(mapped);dbLog("fetchVehicles","fix","重複code修正");}
    return mapped;},
  async saveVehicles(arr){if(!sb)return;const rows=arr.map(v=>({code:v.code,name:v.name,plate_no:v.no,type:v.type,seats:v.seats,insurance_veh:!!v.insuranceVeh,year:v.year||"",equip:v.equip||"",ins_price:v.insPrice||""}));const{error}=await sb.from("vehicles").upsert(rows,{onConflict:"code"});if(error)dbLog("saveVehicles",false,error.message);else dbLog("saveVehicles",true,arr.length+"件保存");
  },
  async deleteVehicle(code){if(!sb)return;const{error}=await sb.from("vehicles").delete().eq("code",code);if(error)dbLog("deleteVehicle",false,error.message);else dbLog("deleteVehicle",true,code);},
  // --- シフト ---
  async fetchShifts(){if(!sb)return null;const{data}=await sb.from("shifts").select("*");const s={};(data||[]).forEach(r=>{if(!s[r.date])s[r.date]=[];s[r.date].push({name:r.staff_name,symbol:r.symbol,start:r.start_time,end:r.end_time,memo:r.memo});});return s;},
  async saveShift(date,staffName,shift){if(!sb)return;await sb.from("shifts").upsert({date,staff_name:staffName,symbol:shift.symbol||"",start_time:shift.start||"",end_time:shift.end||"",memo:shift.memo||""},{onConflict:"date,staff_name"});},
  async saveShiftsForDate(date,shifts){if(!sb)return;const rows=shifts.map(s=>({date,staff_name:s.name,symbol:s.symbol||"",start_time:s.start||"",end_time:s.end||"",memo:s.memo||""}));await sb.from("shifts").upsert(rows,{onConflict:"date,staff_name"});},
  async deleteShift(date,staffName){if(!sb)return;const{error}=await sb.from("shifts").delete().eq("date",date).eq("staff_name",staffName);if(error)dbLog("deleteShift",false,error.message);else dbLog("deleteShift",true,date+"/"+staffName);},
  async deleteShiftsMonth(ym){if(!sb)return;const{error}=await sb.from("shifts").delete().like("date",ym+"-%");if(error)dbLog("deleteShiftsMonth",false,error.message);else dbLog("deleteShiftsMonth",true,ym);},
  // --- 勤怠 ---
  async fetchAttendance(){if(!sb)return{};try{const{data,error}=await sb.from("spk_attendance").select("*");if(error){console.warn("[attendance] fetch error (テーブル未作成?):",error.message);return{};}const a={};(data||[]).forEach(r=>{const k=r.date+"_"+r.staff_name;a[k]={date:r.date,name:r.staff_name,start:r.start_time||"",end:r.end_time||"",approved:!!r.approved,memo:r.memo||"",absent:!!r.absent};});return a;}catch(e){console.warn("[attendance]",e);return{};}},
  async saveAttendance(rec){if(!sb)return;try{await sb.from("spk_attendance").upsert({date:rec.date,staff_name:rec.name,start_time:rec.start||"",end_time:rec.end||"",approved:rec.approved||false,memo:rec.memo||"",absent:!!rec.absent},{onConflict:"date,staff_name"});}catch(e){console.warn("[att save]",e);}},
  async saveAttendanceBatch(recs){if(!sb)return;try{const rows=recs.map(r=>({date:r.date,staff_name:r.name,start_time:r.start||"",end_time:r.end||"",approved:r.approved||false,memo:r.memo||"",absent:!!r.absent}));await sb.from("spk_attendance").upsert(rows,{onConflict:"date,staff_name"});}catch(e){console.warn("[att batch]",e);}},
  // --- 打刻 ---
  SLACK_PUNCH_WEBHOOK:"",// ← Slack Incoming Webhook URL を設定
  async sendPunchSlack(storeName,staffName,type,reqTime,nowTime){try{if(!DB.SLACK_PUNCH_WEBHOOK)return;await fetch(DB.SLACK_PUNCH_WEBHOOK,{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({text:`⚠️ *打刻仮申請あり*\n店舗: ${storeName}　スタッフ: ${staffName}\n種別: ${type==="in"?"出勤":"退勤"}　申請時刻: *${reqTime}*（打刻時点: ${nowTime}）\n給与計算タブで確認・承認してください`})});}catch(e){}},
  async punchIn(staffName,timeStr,isProvisional){if(!sb)return;try{const today=new Date().toLocaleDateString("sv-SE",{timeZone:"Asia/Tokyo"});const now=timeStr||new Date().toLocaleTimeString("ja-JP",{hour:"2-digit",minute:"2-digit",hour12:false,timeZone:"Asia/Tokyo"});const{data}=await sb.from("spk_attendance").select("*").eq("date",today).eq("staff_name",staffName).maybeSingle();if(data&&data.start_time){throw new Error("既に出勤打刻済みです");}await sb.from("spk_attendance").upsert({date:today,staff_name:staffName,start_time:now,end_time:data?.end_time||"",approved:!isProvisional,memo:isProvisional?"仮申請":"打刻",absent:false},{onConflict:"date,staff_name"});}catch(e){throw e;}},
  async punchOut(staffName,timeStr,isProvisional){if(!sb)return;try{const today=new Date().toLocaleDateString("sv-SE",{timeZone:"Asia/Tokyo"});const now=timeStr||new Date().toLocaleTimeString("ja-JP",{hour:"2-digit",minute:"2-digit",hour12:false,timeZone:"Asia/Tokyo"});const{data}=await sb.from("spk_attendance").select("*").eq("date",today).eq("staff_name",staffName).maybeSingle();if(data?.end_time){throw new Error("既に退勤打刻済みです");}await sb.from("spk_attendance").upsert({date:today,staff_name:staffName,start_time:data?.start_time||"",end_time:now,approved:!isProvisional,memo:isProvisional?"仮申請":"打刻",absent:false},{onConflict:"date,staff_name"});}catch(e){throw e;}},
  async getTodayPunch(staffName){if(!sb)return null;try{const today=new Date().toLocaleDateString("sv-SE",{timeZone:"Asia/Tokyo"});const{data}=await sb.from("spk_attendance").select("*").eq("date",today).eq("staff_name",staffName).maybeSingle();return data?{start:data.start_time||"",end:data.end_time||"",approved:!!data.approved}:null;}catch(e){return null;}},
  // --- 申し送りBOX ---
  async fetchMemos(fromDate){if(!sb)return[];try{const{data}=await sb.from("spk_memos").select("*").gte("target_date",fromDate).order("created_at",{ascending:true});return data||[];}catch(e){return[];}},
  async postMemo(content,targetDate,imageUrl){if(!sb||(!(content||"").trim()&&!imageUrl))return;const row={content:(content||"").trim(),target_date:targetDate,done:false};if(imageUrl)row.image_url=imageUrl;await sb.from("spk_memos").insert(row);},
  async toggleMemoDone(id,done){if(!sb)return;await sb.from("spk_memos").update({done:!done}).eq("id",id);},
  async deleteMemo(id){if(!sb)return;await sb.from("spk_memos").delete().eq("id",id);},
  async uploadMemoImage(file){
    if(!sb)throw new Error("no sb");
    const compressed=await new Promise((resolve)=>{
      const reader=new FileReader();
      reader.onload=(e)=>{
        const img=new Image();
        img.onload=()=>{
          const canvas=document.createElement("canvas");
          let w=img.width,h=img.height,max=1200;
          if(w>max){h=Math.round(h*max/w);w=max;}
          canvas.width=w;canvas.height=h;
          canvas.getContext("2d").drawImage(img,0,0,w,h);
          canvas.toBlob(resolve,"image/jpeg",0.75);
        };
        img.src=e.target.result;
      };
      reader.readAsDataURL(file);
    });
    const fname="spk/"+Date.now()+".jpg";
    const{error}=await sb.storage.from("memo-images").upload(fname,compressed,{contentType:"image/jpeg",upsert:false});
    if(error)throw error;
    const{data:{publicUrl}}=sb.storage.from("memo-images").getPublicUrl(fname);
    return publicUrl;
  },
  // --- メンテナンス ---
  async fetchMaintenance(){if(!sb)return[];const{data,error}=await sb.from("maintenance").select("*");if(error){dbLog("fetchMaint",false,error.message);return[];}dbLog("fetchMaint",true,(data||[]).length+"件");return(data||[]).map(m=>({id:m.id,vehicleCode:m.vehicle_code,startDate:m.start_date,endDate:m.end_date,label:m.label||""}));},
  async saveMaintenance(arr){if(!sb)return;const rows=arr.map(m=>({id:m.id,vehicle_code:m.vehicleCode,start_date:m.startDate,end_date:m.endDate,label:m.label||""}));if(rows.length){const{error}=await sb.from("maintenance").upsert(rows,{onConflict:"id"});if(error)dbLog("saveMaint",false,error.message);else dbLog("saveMaint",true,rows.length+"件");}},
  async deleteMaintenance(id){if(!sb)return;const{error}=await sb.from("maintenance").delete().eq("id",id);if(error)dbLog("delMaint",false,error.message);else dbLog("delMaint",true,id);},
  async clearAllMaintenance(){if(!sb)return;await sb.from("maintenance").delete().neq("id","__never__");},
  // --- 場所 ---
  async upsertPlaces(places){if(!sb)return;const rows=Object.entries(places).map(([k,v])=>({reservation_id:k,del_place:v.delPlace||"",col_place:v.colPlace||""}));if(rows.length)await sb.from("places").upsert(rows,{onConflict:"reservation_id"});},
  async fetchPlaces(){if(!sb)return{};const{data}=await sb.from("places").select("*");const p={};(data||[]).forEach(r=>p[r.reservation_id]={delPlace:r.del_place,colPlace:r.col_place});return p;},
  // --- じゃらん決済 ---
  _jalanPayLS:"spk_jalan_payment",
  jalanPayLsSave(d){try{localStorage.setItem(DB._jalanPayLS,JSON.stringify(d));}catch(e){}},
  jalanPayLsLoad(){try{const s=localStorage.getItem(DB._jalanPayLS);return s?JSON.parse(s):{};}catch(e){return{};}},
  async fetchJalanPayment(){if(!sb){return DB.jalanPayLsLoad();}const{data,error}=await sb.from("jalan_payment").select("*");if(error){dbLog("fetchJalanPay",false,error.message);return DB.jalanPayLsLoad();}dbLog("fetchJalanPay",true,(data||[]).length+"件");const m={};(data||[]).forEach(r=>{m[r.reservation_id]={category:r.category||"売上",payStatus:r.pay_status||"未完了",sendDate:r.send_date||"",refundDate:r.refund_date||"",content:r.content||"",linkUrl:r.link_url||"",adjustedPrice:r.adjusted_price||""};});DB.jalanPayLsSave(m);return m;},
  async saveJalanPayment(resId,d){DB.jalanPayLsSave({...DB.jalanPayLsLoad(),[resId]:d});if(!sb)return;const row={reservation_id:resId,category:d.category||"売上",pay_status:d.payStatus||"未完了",send_date:d.sendDate||"",refund_date:d.refundDate||"",content:d.content||"",link_url:d.linkUrl||"",adjusted_price:d.adjustedPrice||""};const{error}=await sb.from("jalan_payment").upsert(row,{onConflict:"reservation_id"});if(error)dbLog("saveJalanPay",false,error.message);else dbLog("saveJalanPay",true,resId);},
  // --- resOpts (B/C/Jオプション) DB保存 ---
  async fetchResOpts(){if(!sb)return null;try{const{data}=await sb.from("app_settings").select("value").eq("key","res_opts").single();return data?JSON.parse(data.value):null;}catch(e){return null;}},
  async saveResOpts(opts){if(!sb)return;try{await sb.from("app_settings").upsert({key:"res_opts",value:JSON.stringify(opts)},{onConflict:"key"});}catch(e){console.warn("[saveResOpts]",e);}},
  // --- 認証 ---
  async checkPassword(pw){if(!sb)return true;const{data}=await sb.from("app_settings").select("value").eq("key","team_password").single();return data&&data.value===pw;},
  // --- 駐車場 (別Supabase) ---
  parking:{
    async fetch(){if(!sbParking)return null;try{const{data,error}=await sbParking.from("parking_state").select("data").eq("id",1).single();if(error||!data||!data.data||Object.keys(data.data).length===0)return null;return data.data;}catch(e){return null;}},
    _saveTimer:null,
    save(stateData){if(!sbParking)return;clearTimeout(DB.parking._saveTimer);DB.parking._saveTimer=setTimeout(async()=>{try{await sbParking.from("parking_state").update({data:stateData,updated_at:new Date().toISOString()}).eq("id",1);}catch(e){console.log("Parking save error",e);}},500);},
    LS_KEY:"parking-mgr-v1",
    LS_BK:"parking-mgr-bk",
    lsLoad(){try{const r=localStorage.getItem(DB.parking.LS_KEY);return r?JSON.parse(r):null;}catch(e){return null;}},
    lsLoadBackup(){try{const r=localStorage.getItem(DB.parking.LS_BK);return r?JSON.parse(r):null;}catch(e){return null;}},
    lsSave(d){try{
      // 駐車中が1台以上ある場合のみバックアップを更新（空データで上書き防止）
      const parked=d&&d.spots?d.spots.filter(s=>s.carId).length:0;
      if(parked>0){localStorage.setItem(DB.parking.LS_BK,JSON.stringify(d));}
      localStorage.setItem(DB.parking.LS_KEY,JSON.stringify(d));
    }catch(e){}},
  },
  // --- HANDYMAN Fleet (store_id=sapporo) ---
  hm:{
    STORE:'sapporo',
    async fetchCars(){if(!sb)return[];const{data,error}=await sb.from("cars").select("*").eq("store_id",DB.hm.STORE);if(error){dbLog("hm.cars",false,error.message);return[];}return data||[];},
    async saveCar(car){if(!sb)throw new Error("DB未接続");const{error}=await sb.from("cars").upsert(car,{onConflict:"id"});if(error){dbLog("hm.saveCar",false,error.message);throw new Error(error.message);}},
    async deleteCar(id){if(!sb)return;await sb.from("cars").delete().eq("id",id);},
    async fetchCarData(){if(!sb)return[];const{data,error}=await sb.from("car_data").select("*").eq("store_id",DB.hm.STORE);if(error){dbLog("hm.carData",false,error.message);return[];}return data||[];},
    async saveCarData(rec){if(!sb)throw new Error("DB未接続");const{error}=await sb.from("car_data").upsert(rec,{onConflict:"id"});if(error){dbLog("hm.saveCD",false,error.message);throw new Error(error.message);}},
    async deleteCarData(id){if(!sb)return;await sb.from("car_data").delete().eq("id",id);},
    async fetchLogs(){if(!sb)return[];const{data,error}=await sb.from("logs").select("*").eq("store_id",DB.hm.STORE).order("date",{ascending:false});if(error){dbLog("hm.logs",false,error.message);return[];}return data||[];},
    async saveLog(log){if(!sb)throw new Error("DB未接続");const{error}=await sb.from("logs").upsert(log,{onConflict:"id"});if(error){dbLog("hm.saveLog",false,error.message);throw new Error(error.message);}},
    async deleteLog(id){if(!sb)return;await sb.from("logs").delete().eq("id",id);},
    async fetchClasses(){if(!sb)return[];const{data,error}=await sb.from("classes").select("*").eq("store_id",DB.hm.STORE);if(error){dbLog("hm.classes",false,error.message);return[];}return data||[];},
    async saveClass(cls){if(!sb)return;const{error}=await sb.from("classes").upsert(cls,{onConflict:"id"});if(error)dbLog("hm.saveCls",false,error.message);},
