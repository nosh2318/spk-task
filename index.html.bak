};
function detectParse(rows){for(let i=0;i<Math.min(rows.length,10);i++){for(const[k,cfg]of Object.entries(OTA)){if(cfg.det(rows[i])){const hd=rows[i],data=[];let totalValid=0,skippedOther=0;const skipSPK=!!cfg.skipSPKFilter;
for(let j=i+1;j<rows.length;j++){if(rows[j].length<3||!rows[j][0])continue;try{const p=cfg.parse(rows[j],hd);if(p&&p.lendDate&&p.status!=="cancelled"){totalValid++;
if(!skipSPK){const rowText=rows[j].join(",").toUpperCase();if(!rowText.includes("札幌")){skippedOther++;continue;}}p.delTime=p.delTime||p.lendTime;p.colTime=p.colTime||p.returnTime;p.delPlace=p.delPlace||"";p.colPlace=p.colPlace||"";if(!p.id){p.id="NOID_"+k+"_"+Date.now()+"_"+j;console.warn("[CSV] 予約番号なし→自動ID:",p.id,p.name);}data.push(p);}}catch(e){}}
return{ota:k,data,totalValid,skippedOther};}}}return null;}

/* ===== リピーター検知エンジン ===== */
function buildRepeaterMap(reservations){
  // 電話番号 or メールアドレスでグルーピング
  const telMap={};const mailMap={};
  reservations.forEach(r=>{
    const tel=(r.tel||"").replace(/[-\s\(\)]/g,"").trim();
    const mail=(r.mail||"").trim().toLowerCase();
    if(tel&&tel.length>=5){if(!telMap[tel])telMap[tel]=[];telMap[tel].push(r);}
    if(mail&&mail.includes("@")){if(!mailMap[mail])mailMap[mail]=[];mailMap[mail].push(r);}
  });
  // Union-Find でグループ化（電話 or メールどちらか一致で同一顧客）
  const parent={};
  const find=x=>{if(!parent[x])parent[x]=x;return parent[x]===x?x:(parent[x]=find(parent[x]));};
  const union=(a,b)=>{const pa=find(a),pb=find(b);if(pa!==pb)parent[pb]=pa;};
  reservations.forEach(r=>{
    const tel=(r.tel||"").replace(/[-\s\(\)]/g,"").trim();
    const mail=(r.mail||"").trim().toLowerCase();
    if(tel&&tel.length>=5&&telMap[tel]){telMap[tel].forEach(r2=>{if(r2.id!==r.id)union(r.id,r2.id);});}
    if(mail&&mail.includes("@")&&mailMap[mail]){mailMap[mail].forEach(r2=>{if(r2.id!==r.id)union(r.id,r2.id);});}
  });
  // グループに集約
  const groups={};
  reservations.forEach(r=>{const g=find(r.id);if(!groups[g])groups[g]=[];groups[g].push(r);});
  // 2回以上 = リピーター
  const repeaterGroups={};
  Object.entries(groups).forEach(([gid,members])=>{if(members.length>=2)repeaterGroups[gid]=members;});
  // 各予約IDがリピーターかどうかの高速ルックアップ
  const isRepeater={};const repeaterGroupOf={};
  Object.entries(repeaterGroups).forEach(([gid,members])=>{
    members.forEach(r=>{isRepeater[r.id]=true;repeaterGroupOf[r.id]=gid;});
  });
  return{repeaterGroups,isRepeater,repeaterGroupOf,groups};
}

/* ===== 顧客リストコンポーネント ===== */
function CustomerList({data}){
  const[search,setSearch]=useState("");
  const[sortBy,setSortBy]=useState("count"); // "count"|"name"|"recent"
  const{repeaterGroups}=useMemo(()=>buildRepeaterMap(data),[data]);
  // 顧客リスト: グループごとに代表名・連絡先・利用回数・利用元を集計
  const customers=useMemo(()=>{
    return Object.entries(repeaterGroups).map(([gid,members])=>{
      const sorted=[...members].sort((a,b)=>(a.lendDate||"").localeCompare(b.lendDate||""));
      const names=[...new Set(members.map(m=>m.name).filter(Boolean))];
      const tels=[...new Set(members.map(m=>(m.tel||"").replace(/[-\s\(\)]/g,"").trim()).filter(t=>t.length>=5))];
      const mails=[...new Set(members.map(m=>(m.mail||"").trim().toLowerCase()).filter(m=>m.includes("@")))];
      const otas=members.map(m=>m.ota);
      const otaCounts={};otas.forEach(o=>{otaCounts[o]=(otaCounts[o]||0)+1;});
      const firstDate=sorted[0]?.lendDate||"";
      const lastDate=sorted[sorted.length-1]?.lendDate||"";
      const totalSpend=members.reduce((s,m)=>s+(m.price||0),0);
      return{gid,names,tels,mails,count:members.length,otaCounts,firstDate,lastDate,totalSpend,members:sorted};
    });
  },[repeaterGroups]);
  const filtered=useMemo(()=>{
    let list=customers;
    if(search){const s=search.toLowerCase();list=list.filter(c=>c.names.some(n=>n.toLowerCase().includes(s))||c.tels.some(t=>t.includes(s))||c.mails.some(m=>m.includes(s)));}
    if(sortBy==="count")list=[...list].sort((a,b)=>b.count-a.count);
    else if(sortBy==="name")list=[...list].sort((a,b)=>(a.names[0]||"").localeCompare(b.names[0]||""));
    else if(sortBy==="recent")list=[...list].sort((a,b)=>(b.lastDate||"").localeCompare(a.lastDate||""));
    return list;
  },[customers,search,sortBy]);
  const allCount=data.length;const repCount=Object.values(repeaterGroups).reduce((s,g)=>s+g.length,0);
  const[expanded,setExpanded]=useState(null);
  return <div>
    <div style={{display:"flex",gap:8,flexWrap:"wrap",marginBottom:12}}>
      <div style={{flex:"1 1 160px",background:"linear-gradient(135deg,#7c3aed,#6d28d9)",borderRadius:10,padding:"12px 16px",color:"#fff"}}>
        <div style={{fontSize:10,opacity:0.8}}>リピーター顧客数</div>
        <div style={{fontSize:24,fontWeight:800}}>{customers.length}<span style={{fontSize:11,fontWeight:400,marginLeft:4}}>組</span></div>
      </div>
      <div style={{flex:"1 1 160px",background:"linear-gradient(135deg,#2563eb,#1d4ed8)",borderRadius:10,padding:"12px 16px",color:"#fff"}}>
        <div style={{fontSize:10,opacity:0.8}}>リピーター予約数</div>
        <div style={{fontSize:24,fontWeight:800}}>{repCount}<span style={{fontSize:11,fontWeight:400,marginLeft:4}}>/ {allCount}件</span></div>
      </div>
      <div style={{flex:"1 1 160px",background:"linear-gradient(135deg,#059669,#047857)",borderRadius:10,padding:"12px 16px",color:"#fff"}}>
        <div style={{fontSize:10,opacity:0.8}}>リピーター率</div>
        <div style={{fontSize:24,fontWeight:800}}>{allCount>0?Math.round(repCount/allCount*100):0}<span style={{fontSize:11,fontWeight:400,marginLeft:4}}>%</span></div>
      </div>
    </div>
    <div style={{display:"flex",gap:6,marginBottom:10,alignItems:"center",flexWrap:"wrap"}}>
      <input value={search} onChange={e=>setSearch(e.target.value)} placeholder="名前・電話・メールで検索" style={{flex:1,minWidth:160,padding:"6px 10px",border:"1px solid #d1d5db",borderRadius:6,fontSize:11}}/>
      <select value={sortBy} onChange={e=>setSortBy(e.target.value)} style={{padding:"6px 8px",border:"1px solid #d1d5db",borderRadius:6,fontSize:11}}>
        <option value="count">利用回数順</option><option value="recent">最近順</option><option value="name">名前順</option>
      </select>
      <div style={{fontSize:10,color:"#64748b"}}>{filtered.length}件</div>
    </div>
    <div style={{display:"flex",flexDirection:"column",gap:6}}>
      {filtered.map(c=>{
        const isOpen=expanded===c.gid;
        return <div key={c.gid} style={{background:"#fff",border:"1px solid #e5e7eb",borderRadius:8,overflow:"hidden"}}>
          <div onClick={()=>setExpanded(isOpen?null:c.gid)} style={{display:"flex",alignItems:"center",gap:8,padding:"8px 12px",cursor:"pointer",background:isOpen?"#f8fafc":"#fff"}}>
            <div style={{background:"#7c3aed",color:"#fff",borderRadius:"50%",width:28,height:28,display:"flex",alignItems:"center",justifyContent:"center",fontSize:13,fontWeight:800,flexShrink:0}}>{c.count}</div>
            <div style={{flex:1,minWidth:0}}>
              <div style={{fontWeight:700,fontSize:12,color:"#1e293b"}}>{c.names.join(" / ")}</div>
              <div style={{fontSize:10,color:"#64748b",display:"flex",gap:8,flexWrap:"wrap"}}>
                {c.tels.length>0&&<span>📞 {c.tels.join(", ")}</span>}
                {c.mails.length>0&&<span>✉️ {c.mails.join(", ")}</span>}
              </div>
            </div>
            <div style={{display:"flex",gap:3,flexWrap:"wrap"}}>
              {Object.entries(c.otaCounts).map(([ota,cnt])=>{const o=OTA[ota];return o?<span key={ota} style={{background:o.bg,color:o.c,padding:"1px 5px",borderRadius:4,fontSize:9,fontWeight:700,border:"1px solid "+o.c+"33"}}>{o.key}×{cnt}</span>:null;})}
            </div>
            <div style={{textAlign:"right",flexShrink:0}}>
              <div style={{fontSize:10,fontWeight:600,color:"#059669"}}>¥{c.totalSpend.toLocaleString()}</div>
              <div style={{fontSize:8,color:"#94a3b8"}}>{c.firstDate?c.firstDate.slice(5):""}〜{c.lastDate?c.lastDate.slice(5):""}</div>
            </div>
            <span style={{fontSize:10,color:"#94a3b8"}}>{isOpen?"▲":"▼"}</span>
          </div>
          {isOpen&&<div style={{borderTop:"1px solid #e5e7eb",padding:"8px 12px",background:"#fafbfc"}}>
            <table style={{width:"100%",fontSize:10,borderCollapse:"collapse"}}>
              <thead><tr style={{background:"#f1f5f9"}}>{["#","貸出日","返却日","名前","OTA","TEL","MAIL","金額","クラス","補償"].map((h,i)=><th key={i} style={{padding:"3px 6px",textAlign:"left",fontWeight:600,fontSize:9,borderBottom:"1px solid #e2e8f0"}}>{h}</th>)}</tr></thead>
              <tbody>{c.members.map((m,i)=><tr key={m.id} style={{background:i%2===0?"#fff":"#f9fafb"}}>
                <td style={{padding:"3px 6px",color:"#7c3aed",fontWeight:700}}>{i+1}</td>
                <td style={{padding:"3px 6px"}}>{m.lendDate||"-"}</td>
                <td style={{padding:"3px 6px"}}>{m.returnDate||"-"}</td>
                <td style={{padding:"3px 6px",fontWeight:600}}>{m.name}</td>
                <td style={{padding:"3px 6px"}}><OBadge ota={m.ota}/></td>
                <td style={{padding:"3px 6px",fontSize:9}}>{m.tel||"-"}</td>
                <td style={{padding:"3px 6px",fontSize:9}}>{m.mail||"-"}</td>
                <td style={{padding:"3px 6px",color:"#059669",fontWeight:600}}>¥{(m.price||0).toLocaleString()}</td>
                <td style={{padding:"3px 6px"}}>{m.vehicle||"-"}</td>
                <td style={{padding:"3px 6px"}}>{m.insurance||"-"}</td>
              </tr>)}</tbody>
            </table>
          </div>}
        </div>;
      })}
      {filtered.length===0&&<div style={{textAlign:"center",padding:24,color:"#94a3b8",fontSize:12}}>リピーター顧客はまだいません</div>}
    </div>
  </div>;
}

