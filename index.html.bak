<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes">
<title>札幌店 タスク管理</title>
<link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin>
<link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
<link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/react/18.2.0/umd/react.production.min.js" as="script" crossorigin>
<link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/react-dom/18.2.0/umd/react-dom.production.min.js" as="script" crossorigin>
<link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/babel-standalone/7.23.9/babel.min.js" as="script" crossorigin>
<link rel="preload" href="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js" as="script" crossorigin>
<link href="https://cdnjs.cloudflare.com/ajax/libs/tailwindcss/2.2.19/tailwind.min.css" rel="stylesheet">
<!-- Leaflet loaded on demand -->
<style>
*{box-sizing:border-box;-webkit-tap-highlight-color:transparent;-webkit-user-select:text;user-select:text}
html,body{height:100%;overflow:hidden}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI','Hiragino Kaku Gothic ProN',sans-serif;margin:0;background:#f3f4f6}
::-webkit-scrollbar{height:5px;width:5px}
::-webkit-scrollbar-thumb{background:#cbd5e1;border-radius:3px}
.fade-in{animation:fadeIn .25s ease}
@keyframes fadeIn{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:translateY(0)}}
.tl-bar{position:absolute;top:3px;bottom:3px;border-radius:4px;cursor:pointer;display:flex;align-items:center;padding:0 4px;overflow:hidden;white-space:nowrap;font-size:9px;font-weight:600;transition:opacity .2s;z-index:2}
.tl-bar:hover{opacity:.85;z-index:3}
.top-nav{display:none;position:sticky;top:0;left:0;right:0;z-index:100;background:#1e293b;padding:4px 6px env(safe-area-inset-top,4px);box-shadow:0 2px 8px rgba(0,0,0,.12);overflow-x:auto;-webkit-overflow-scrolling:touch}
.top-nav button{flex-shrink:0;display:inline-flex;align-items:center;gap:3px;padding:6px 10px;border:none;background:transparent;cursor:pointer;font-size:11px;color:#94a3b8;transition:all .15s;border-radius:8px;font-weight:600;white-space:nowrap}
.top-nav button.active{background:#2563eb;color:#fff}
.top-nav button .ico{font-size:16px}
.sidebar{width:56px;min-width:56px;background:#1e293b;display:flex;flex-direction:column;align-items:center;padding-top:8px;gap:2px}
.sidebar button{width:44px;height:44px;border-radius:10px;border:none;background:transparent;cursor:pointer;display:flex;flex-direction:column;align-items:center;justify-content:center;color:#94a3b8;font-size:9px;gap:1px;transition:all .15s}
.sidebar button:hover{background:#334155;color:#e2e8f0}
.sidebar button.active{background:#2563eb;color:#fff}
.sidebar button .ico{font-size:18px}
@media(max-width:768px){.sidebar{display:none!important}.top-nav{display:flex!important}.top-nav.hide-on-top{display:none!important}.main-area{padding-top:0!important}.sync-desktop{display:none!important}}
@media(min-width:769px){.top-nav{display:none!important}.sidebar{display:flex!important}.sidebar.hide-on-top{display:none!important}}
.op-fullscreen{position:fixed;inset:0;z-index:200;background:#f3f4f6;display:flex;flex-direction:column}
.op-fullscreen .op-header{background:linear-gradient(135deg,#1e40af,#2563eb);padding:8px 12px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0}
.op-fullscreen .op-body{flex:1;overflow:auto;padding:8px}
@media(max-width:768px){.op-fullscreen .op-body{padding:4px}}
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.3);display:flex;align-items:center;justify-content:center;z-index:300;padding:12px}
.modal-box{background:#fff;border-radius:16px;box-shadow:0 20px 60px rgba(0,0,0,.15);width:100%;overflow-y:auto}
.input-s{border:1px solid #d1d5db;border-radius:8px;padding:5px 8px;font-size:12px;width:100%}
.btn-primary{background:#2563eb;color:#fff;border:none;border-radius:8px;padding:6px 16px;font-size:12px;font-weight:700;cursor:pointer}
.btn-primary:hover{background:#1d4ed8}
.btn-danger{background:#dc2626;color:#fff;border:none;border-radius:8px;padding:6px 16px;font-size:12px;font-weight:700;cursor:pointer}
.btn-ghost{background:none;border:1px solid #d1d5db;border-radius:8px;padding:6px 16px;font-size:12px;cursor:pointer;color:#374151}
.shift-grid{position:relative;overflow:auto;max-height:400px}
.shift-grid table{border-collapse:collapse}
.shift-grid th,.shift-grid td{border:1px solid #d1d5db}
.shift-grid thead th{position:sticky;top:0;z-index:2}
.shift-col{position:sticky;left:0;z-index:3;background:#fff}
.shift-col-header{position:sticky;left:0;z-index:4;background:#D2B48C}
@keyframes spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.5}}
</style>
