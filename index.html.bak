function toLD(dt){return dt.getFullYear()+"-"+String(dt.getMonth()+1).padStart(2,"0")+"-"+String(dt.getDate()).padStart(2,"0");}
function fmtD(d){if(!d)return"";const s=String(d);const dt=new Date(s.length===10?s+"T00:00:00":s);if(isNaN(dt))return d;const w=["日","月","火","水","木","金","土"];return`${dt.getMonth()+1}/${dt.getDate()}(${w[dt.getDay()]})`;}
function fmtFull(d){if(!d)return"";const s=String(d);const dt=new Date(s.length===10?s+"T00:00:00":s);if(isNaN(dt))return d;const w=["日","月","火","水","木","金","土"];return`${dt.getFullYear()}年${dt.getMonth()+1}月${dt.getDate()}日(${w[dt.getDay()]})`;}
function dOff(b,n){const d=new Date(b+"T00:00:00");d.setDate(d.getDate()+n);return d.getFullYear()+"-"+String(d.getMonth()+1).padStart(2,"0")+"-"+String(d.getDate()).padStart(2,"0");}
function norm(d){if(!d)return"";const s=String(d).replace(/\//g,"-");const m=s.match(/^(\d{4})-(\d{1,2})-(\d{1,2})/);if(m)return m[1]+"-"+m[2].padStart(2,"0")+"-"+m[3].padStart(2,"0");if(s.length<=10)return s;const dt=new Date(s);if(isNaN(dt))return s.substring(0,10);return toLD(dt);}
function sD(a,b){return norm(a)===norm(b);}
// 車両重複チェック: targetVcに対してresIdの期間と1日でもかぶる予約があるか
function checkVehicleConflict(targetVc,resId,data,fleet){
  const res=data.find(r=>r.id===resId);if(!res)return null;
  const ld=norm(res.lendDate),rd=norm(res.returnDate);
  const conflict=data.find(r=>r.id!==resId&&r.status!=="cancelled"&&fleet[r.id]===targetVc&&norm(r.lendDate)<=rd&&norm(r.returnDate)>=ld);
  return conflict||null;
}
function toYM(d){const s=String(d);const dt=new Date(s.length===10?s+"T00:00:00":s);return`${dt.getFullYear()}-${String(dt.getMonth()+1).padStart(2,"0")}`;}
function daysInMonth(ym){const[y,m]=ym.split("-").map(Number);return new Date(y,m,0).getDate();}
function ymLabel(ym){const[y,m]=ym.split("-").map(Number);return`${y}年${m}月`;}
function ymOff(ym,n){const[y,m]=ym.split("-").map(Number);const d=new Date(y,m-1+n,1);return`${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,"0")}`;}
let _id=0;function uid(){return"t"+(++_id);}
let _vid=100;function vuid(){return"v"+(++_vid);}
// ★ 手動タスク判定: 自動生成タスクは必ずreservationIdを持つ。手動追加は常に空。
function isManual(t){return!!t.manual||!t.reservationId;}

/* ===== Googleスプレッドシートから場所データ取得 ===== */
const PLACE_SHEET_CSV="https://docs.google.com/spreadsheets/d/e/2PACX-1vSsixHeH7WvPEhA0BqOhFcun6DgBAeB9z11ikzRgXQcB_OxKKwWT8uCvl6Fb551nYlRmBGLj0e7OcGi/pub?gid=854005754&single=true&output=csv";
function parsePlaceCSV(text){
  const lines=[];let cur="";let inQ=false;
  for(let i=0;i<text.length;i++){
    const c=text[i];
    if(c==='"'){if(inQ&&text[i+1]==='"'){cur+='"';i++;}else{inQ=!inQ;}}
    else if(c===","&&!inQ){lines.length===0?lines.push([cur]):lines[lines.length-1].push(cur);cur="";}
    else if((c==="\n"||(c==="\r"&&text[i+1]==="\n"))&&!inQ){
      if(c==="\r")i++;
      if(lines.length===0){lines.push([cur]);lines.push([]);}else{lines[lines.length-1].push(cur);lines.push([]);}
      cur="";
    }else{cur+=c;}
  }
  if(cur||lines.length>0){if(lines.length===0)lines.push([cur]);else lines[lines.length-1].push(cur);}
  return lines.filter(r=>r.some(c=>c.trim()));
}
async function fetchPlaceData(targetResIds){
  const resp=await fetch(PLACE_SHEET_CSV);
  if(!resp.ok)throw new Error("CSV取得失敗: "+resp.status);
  const text=await resp.text();
  const rows=parsePlaceCSV(text);
  if(rows.length<2)throw new Error("データが空です");
  // I列(index8)=DEL場所, L列(index11)=COL場所, 予約番号を探す
  const header=rows[0];
  let resCol=-1;
  header.forEach((h,i)=>{if(h.includes("予約番号")||h.includes("予約ID")||h.includes("Reservation"))resCol=i;});
  if(resCol<0){
    // ヘッダーに見つからない場合、予約IDパターンで列を推定
    for(let ci=0;ci<header.length;ci++){
      const sample=rows.slice(1,Math.min(6,rows.length)).map(r=>r[ci]||"");
      if(sample.some(s=>/^[A-Z0-9]{8,}$/.test(s.trim()))){resCol=ci;break;}
    }
  }
  if(resCol<0)throw new Error("予約番号の列が見つかりません");
  const delPlaceCol=8; // I列
  const colPlaceCol=11; // L列
  const targetSet=new Set(targetResIds);
  const tsCol=1; // B列=回答日時
  // ★ 同じ予約番号が複数行ある場合、B列の回答日時が最新の行を採用
  const bestRow={};
  rows.slice(1).forEach(r=>{
    const rid=(r[resCol]||"").trim();
    if(!rid||!targetSet.has(rid))return;
    const ts=(r[tsCol]||"").trim();
    if(!bestRow[rid]||ts>bestRow[rid].ts){bestRow[rid]={ts,row:r};}
  });
  const result={};
  Object.entries(bestRow).forEach(([rid,{row:r}])=>{
    const del=(r[delPlaceCol]||"").trim();
    const col=(r[colPlaceCol]||"").trim();
    result[rid]={delPlace:del,colPlace:col};
  });
  return result;
}

/* ===== スプレッドシートからDEL/COL時間データ取得 ===== */
async function fetchTimeData(targetResIds){
  const resp=await fetch(PLACE_SHEET_CSV);
  if(!resp.ok)throw new Error("CSV取得失敗: "+resp.status);
  const text=await resp.text();
  const rows=parsePlaceCSV(text);
  if(rows.length<2)throw new Error("データが空です");
  const header=rows[0];
  let resCol=-1;
  header.forEach((h,i)=>{if(h.includes("予約番号")||h.includes("予約ID")||h.includes("Reservation"))resCol=i;});
  if(resCol<0){
    for(let ci=0;ci<header.length;ci++){
      const sample=rows.slice(1,Math.min(6,rows.length)).map(r=>r[ci]||"");
      if(sample.some(s=>/^[A-Z0-9]{8,}$/.test(s.trim()))){resCol=ci;break;}
    }
  }
  if(resCol<0)throw new Error("予約番号の列が見つかりません");
  const delTimeCol=7;  // H列(index7) = DEL時間
  const colTimeCol=10; // K列(index10) = COL時間
  const targetSet=new Set(targetResIds);
  const tsCol=1; // B列=回答日時
  // ★ 同じ予約番号が複数行ある場合、B列の回答日時が最新の行を採用
  const bestRow={};
  rows.slice(1).forEach(r=>{
    const rid=(r[resCol]||"").trim();
    if(!rid||!targetSet.has(rid))return;
    const ts=(r[tsCol]||"").trim();
    if(!bestRow[rid]||ts>bestRow[rid].ts){bestRow[rid]={ts,row:r};}
  });
  const result={};
  Object.entries(bestRow).forEach(([rid,{row:r}])=>{
    const delT=(r[delTimeCol]||"").trim();
    const colT=(r[colTimeCol]||"").trim();
    result[rid]={delTime:delT,colTime:colT};
  });
  return result;
}

/* ===== じゃらん決済スプレッドシートから支払データ取得（GAS Web App版） ===== */
const JALAN_PAY_GAS_URL="https://script.google.com/macros/s/AKfycbxvMj4o9meskzVpKdnfdIylzsvfr1z_NLElyA17tedIYlAYKnevf5G568vO2ijFo2yLug/exec";
async function fetchJalanPaySheetData(targetResIds){
  const resp=await fetch(JALAN_PAY_GAS_URL);
  if(!resp.ok)throw new Error("GAS取得失敗: "+resp.status);
  const rows=await resp.json();
  if(!rows||!rows.length)throw new Error("データが空です");
  const targetSet=new Set(targetResIds);
  const result={};
  rows.forEach(r=>{
    const rid=(r.rid||"").trim();
    if(!rid||!targetSet.has(rid))return;
    const payDate=(r.payDate||"").trim();
    const amount=(r.amount||"").trim();
    // 支払日が入っていれば完了（CXLも完了扱い）
    if(payDate){
      result[rid]={adjustedPrice:amount||"0",payStatus:"完了",payDate:payDate};
    }
  });
  return result;
}

/* ===== タスク生成 ===== */
function generateTasks(reservations,date,fleet,vehicles){
  const tasks=[];
  const tomorrow=dOff(date,1);
  reservations.forEach(r=>{
    const fv=fleet[r.id];const veh=fv?vehicles.find(v=>v.code===fv):null;
    const base={reservationId:r.id,ota:r.ota,tel:r.tel||"",mail:r.mail||"",done:false,assignee:"",memo:"",assignedVehicle:fv||"",plateNo:veh?veh.no:"",insuranceChange:"",opts:{b:+(r.optB||0),c:+(r.optC||0),j:+(r.optJ||0),usb:!!r.optUSB,parasol:!!r.optParasol},yakkan:false,line:false,payment:false};
    if(sD(r.lendDate,date)){tasks.push({...base,_id:"d-"+r.id,type:"DEL",time:r.delTime||r.lendTime,name:r.name,people:r.people,place:r.delPlace||"",vehicle:r.vehicle,insurance:r.insurance,flight:r.flight,returnDate:r.returnDate,returnTime:r.returnTime,returnType:"COL",colPlace:r.colPlace||""});}
    if(sD(r.returnDate,date)){const place=r.colPlace||"";tasks.push({...base,_id:"c-"+r.id,type:"COL",time:r.colTime||r.returnTime,name:r.name,people:r.people,place,vehicle:r.vehicle,insurance:r.insurance,flight:""});}
  });
  // 洗車タスク: 翌日DELの予約ごとに1つ（予約単位で生成）
  reservations.forEach(r=>{
    if(!sD(r.lendDate,tomorrow))return;
    if(r.status==="cancelled")return;
    const fv=fleet[r.id];const veh=fv?vehicles.find(v=>v.code===fv):null;
    tasks.push({_id:"w-"+r.id,type:"洗車",time:"",name:`翌日出発: ${r.name}`,people:0,place:"",vehicle:veh?veh.type:r.vehicle,insurance:"",flight:"",reservationId:r.id,ota:r.ota||"",tel:"",mail:"",done:false,assignee:"",memo:`${fmtD(tomorrow)} DEL ${r.delTime||r.lendTime||""} ${r.name}`,assignedVehicle:fv||"",plateNo:veh?veh.no:"",insuranceChange:"",opts:{b:+(r.optB||0),c:+(r.optC||0),j:+(r.optJ||0),usb:!!r.optUSB,parasol:!!r.optParasol},yakkan:false,line:false,payment:false,returnDate:"",returnTime:"",returnType:"",colPlace:""});
  });
  return tasks.sort((a,b)=>{
    // 洗車は最後にまとめる
    if(a.type==="洗車"&&b.type!=="洗車")return 1;
    if(a.type!=="洗車"&&b.type==="洗車")return -1;
    return(a.time||"").localeCompare(b.time||"");
  });
}

/* ===== 自動配車ロジック ===== */
function autoAssign(reservations,vehicles,existingFleet,maintenance){
  const fleet={...existingFleet};
  const maints=maintenance||[];
  const sorted=[...reservations].sort((a,b)=>norm(a.lendDate).localeCompare(norm(b.lendDate)));
  const _reasons={}; // 未配車理由のログ
  // ★ 既存配車の重複検出（日程変更で重複が発生したケース）
  const existingConflicts=new Set();
  sorted.forEach(r=>{
    if(!fleet[r.id])return;
    const vc=fleet[r.id];
    const rL=norm(r.lendDate),rR=norm(r.returnDate);
    const conflict=sorted.find(o=>o.id!==r.id&&fleet[o.id]===vc&&norm(o.lendDate)<=rR&&norm(o.returnDate)>=rL);
    if(conflict&&!existingConflicts.has(r.id)){
      // 後の予約の配車を解除（先の予約を優先）
      const laterRes=norm(r.lendDate)>norm(conflict.lendDate)?r:conflict;
      if(!existingConflicts.has(laterRes.id)){
        existingConflicts.add(laterRes.id);
        const vn=vehicles.find(v=>v.code===vc);
        _reasons[laterRes.id]=`重複: ${vn?vn.name:vc}は${laterRes.id===r.id?conflict.name:r.name}と期間重複`;
        delete fleet[laterRes.id];
        console.warn("[autoAssign] 既存重複検出→配車解除:",laterRes.name,vc);
      }
    }
  });
  sorted.forEach(r=>{
    if(fleet[r.id])return; // 既に割当済み
    const cls=r.vehicle; // 予約のクラス
    const rL=norm(r.lendDate),rR=norm(r.returnDate);
    const candidates=vehicles.filter(v=>v.type===cls&&!v.insuranceVeh);
    if(candidates.length===0){
      _reasons[r.id]=`クラス"${cls}"の車両が登録されていません`;
      return;
    }
    let tried=[];
    for(const v of candidates){
      // メンテナンス期間と重複する車両は除外
      const inMaint=maints.some(m=>{
        if(m.vehicleCode!==v.code)return false;
        const mL=norm(m.startDate),mR=norm(m.endDate);
        return rL<=mR&&rR>=mL;
      });
      if(inMaint){tried.push(`${v.code}:メンテ中`);continue;}
      // この車両がこの期間に空いているかチェック
      const conflictRes=sorted.find(other=>{
        if(other.id===r.id)return false;
        if(fleet[other.id]!==v.code)return false;
        const oL=norm(other.lendDate),oR=norm(other.returnDate);
        return rL<=oR&&rR>=oL; // 期間重複
      });
      if(conflictRes){tried.push(`${v.code}:${conflictRes.name||conflictRes.id}と重複`);continue;}
      fleet[r.id]=v.code;break;
    }
    if(!fleet[r.id]){
      _reasons[r.id]=`${cls}クラス全${candidates.length}台が使用中(${tried.join(", ")})`;
    }
  });
  if(Object.keys(_reasons).length>0){
  }
  fleet._unassignedReasons=_reasons;
  return fleet;
}

function OBadge({ota}){const o=OTA[ota];if(!o)return null;return <span style={{background:o.bg,color:o.c,padding:"1px 6px",borderRadius:4,fontSize:10,fontWeight:700,border:`1px solid ${o.c}22`}}>{o.key}</span>;}

/* Google Maps リンク生成 */
function mapsUrl(place){if(!place)return "";return "https://www.google.com/maps/search/?api=1&query="+encodeURIComponent(place+" 札幌");}
function PlaceLink({place,style}){if(!place||place==="—"||place==="-")return <span style={style}>{place||""}</span>;const skip=!place.trim()||place.trim().length<2||/^(なし|無し|無|ー+|-+|FALSE|false|0)$/.test(place.trim());if(skip)return <span style={style}>{place}</span>;return <a href={mapsUrl(place)} target="_blank" rel="noopener noreferrer" style={{...style,color:"#2563eb",textDecoration:"underline",cursor:"pointer"}} title={`Googleマップで「${place}」を検索`}>{place}</a>;}
function EditablePlace({value,field,mark:markFn,task,updFn}){
  const[editing,setEditing]=React.useState(false);
  const[draft,setDraft]=React.useState(value||"");
  React.useEffect(()=>{setDraft(value||"");},[value]);
  const hasLink=value&&value.trim()&&value.trim().length>=2&&!/^(なし|無し|無|ー+|-+|FALSE|false|0|—)$/.test(value.trim());
  const labels={place:"場所",colPlace:"返却場所"};
  const save=()=>{setEditing(false);if(draft!==(value||"")){const flagKey=field==="colPlace"?"_manualColPlace":"_manualPlace";updFn(task._id,markFn({...task,[field]:draft,[flagKey]:true},field),(labels[field]||"場所")+"を変更");}};
  if(editing)return <div style={{position:"fixed",top:0,left:0,right:0,bottom:0,background:"rgba(0,0,0,.4)",zIndex:9999,display:"flex",alignItems:"center",justifyContent:"center",padding:20}} onClick={e=>{if(e.target===e.currentTarget)save();}}>
    <div style={{background:"#fff",borderRadius:12,padding:16,width:"100%",maxWidth:400,boxShadow:"0 8px 30px rgba(0,0,0,.2)"}}>
      <div style={{fontSize:12,fontWeight:700,color:"#1e293b",marginBottom:8}}>{labels[field]||"場所"}を編集</div>
      <div style={{fontSize:10,color:"#64748b",marginBottom:8}}>{task.name||""}</div>
      <input autoFocus value={draft} onChange={e=>setDraft(e.target.value)} onKeyDown={e=>{if(e.key==="Enter")save();}} style={{border:"2px solid #3b82f6",background:"#eff6ff",fontSize:14,width:"100%",padding:"10px 12px",borderRadius:8,outline:"none",boxSizing:"border-box"}} placeholder="場所を入力"/>
      <div style={{display:"flex",gap:8,marginTop:12,justifyContent:"flex-end"}}>
        <button onClick={()=>{setDraft(value||"");setEditing(false);}} style={{padding:"6px 16px",borderRadius:6,border:"1px solid #d1d5db",background:"#fff",fontSize:12,cursor:"pointer",color:"#64748b"}}>キャンセル</button>
        <button onClick={save} style={{padding:"6px 16px",borderRadius:6,border:"none",background:"#2563eb",color:"#fff",fontSize:12,fontWeight:700,cursor:"pointer"}}>保存</button>
      </div>
    </div>
  </div>;
  return <div style={{display:"flex",alignItems:"center",gap:2,width:"100%",minHeight:18}}>
    {hasLink?<><a href={mapsUrl(value)} target="_blank" rel="noopener noreferrer" style={{fontSize:9,color:"#2563eb",textDecoration:"underline",cursor:"pointer",flex:1,minWidth:0,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}} title={`Googleマップで「${value}」を検索`}>{value}</a><button onClick={()=>setEditing(true)} style={{background:"none",border:"none",cursor:"pointer",fontSize:9,color:"#94a3b8",padding:0,lineHeight:1,flexShrink:0}}>✏️</button></>:<span style={{fontSize:9,color:value?"#334155":"#ccc",flex:1,cursor:"text"}} onClick={()=>setEditing(true)}>{value||"-"}</span>}
  </div>;
}

/* ==========================================
   CSV取込
   ========================================== */
function CSVPanel({onImport,onUpdatePlaces,dataCount,pendingPlaces,onSetPendingPlaces,files,setFiles,logs,setLogs,placeLogs,setPlaceLogs}){
  const handle=(e,k)=>{const f=e.target.files?.[0];if(!f)return;readFile(f,text=>{const rows=parseCSV(text);let res;if(k){const cfg=OTA[k];if(cfg){const skipSPK=!!cfg.skipSPKFilter;for(let i=0;i<Math.min(rows.length,10);i++){if(cfg.det(rows[i])){const hd=rows[i],data=[];let totalValid=0,skippedOther=0;for(let j=i+1;j<rows.length;j++){if(rows[j].length<3||!rows[j][0])continue;try{const p=cfg.parse(rows[j],hd);if(p&&p.lendDate&&p.status!=="cancelled"){totalValid++;if(!skipSPK){const rowText=rows[j].join(",").toUpperCase();if(!rowText.includes("札幌")){skippedOther++;continue;}}p.delTime=p.delTime||p.lendTime;p.colTime=p.colTime||p.returnTime;p.delPlace=p.delPlace||"";p.colPlace=p.colPlace||"";data.push(p);}}catch(e){}}res={ota:k,data,totalValid,skippedOther};break;}}}}if(!res)res=detectParse(rows);if(!res){setLogs(p=>[...p,{t:"err",m:`${f.name}: 検出失敗`}]);return;}const now=new Date();const ts=`${now.getMonth()+1}/${now.getDate()} ${String(now.getHours()).padStart(2,"0")}:${String(now.getMinutes()).padStart(2,"0")}`;setFiles(p=>({...p,[res.ota]:{name:f.name,data:res.data,importedAt:ts}}));const isOfficial=OTA[res.ota]?.skipSPKFilter;const skipMsg=res.skippedOther>0?` (他店舗${res.skippedOther}件除外)`:"";const countLabel=isOfficial?`${res.data.length}件 (OTA${res.totalValid-res.data.length}件除外)`:`札幌${res.data.length}件${skipMsg}`;
    // 月別内訳を生成
    const monthBreak={};let totalPrice=0;res.data.forEach(r=>{const ym=r.returnDate?r.returnDate.substring(0,7):"不明";monthBreak[ym]=(monthBreak[ym]||0)+1;totalPrice+=(r.price||0);});
    const monthStr=Object.entries(monthBreak).sort(([a],[b])=>a.localeCompare(b)).map(([ym,cnt])=>`${ym.replace("-","/")}:${cnt}件`).join(" / ");
    setLogs(p=>[...p,{t:"ok",m:`[${ts}] ${f.name} → ${OTA[res.ota].name} ${countLabel} ¥${totalPrice.toLocaleString()} 【全期間】${monthStr}`}]);});};
  const total=Object.values(files).reduce((s,f)=>s+f.data.length,0);
  return <div style={{maxWidth:960,margin:"0 auto"}}>
    <div className="bg-white rounded-xl shadow-sm border border-gray-200 p-4 mb-4">
      <h3 className="text-base font-bold mb-1">Step 1: CSVアップロード</h3>
      <p className="text-xs text-gray-500 mb-3">各OTAのCSVを選択（Shift_JIS / UTF-8 自動判別）</p>
      <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(100px,1fr))",gap:8}}>
        {Object.entries(OTA).map(([k,cfg])=>{const up=files[k];return <label key={k} className="flex flex-col items-center p-3 rounded-xl border-2 border-dashed cursor-pointer transition hover:shadow-md" style={{borderColor:up?cfg.c:"#d1d5db",background:up?cfg.bg:"#fff"}}>
          <div className="w-8 h-8 rounded-full text-white flex items-center justify-center text-sm font-bold mb-1" style={{background:cfg.c}}>{k}</div>
          <span className="font-semibold text-xs">{cfg.name}</span>
          {up?<><div className="text-xs font-bold mt-1" style={{color:cfg.c}}>{up.data.length}件</div><div style={{fontSize:8,color:"#64748b",marginTop:1}}>{up.importedAt}</div></>:<span className="text-xs text-gray-400 mt-1">選択</span>}
          <input type="file" accept=".csv,.txt" className="hidden" onChange={e=>handle(e,k)} />
        </label>;})}
      </div>
    </div>
    {logs.length>0&&<div className="bg-white rounded-xl shadow-sm border border-gray-200 p-3 mb-4">{logs.map((l,i)=><div key={i} className="text-xs px-2 py-1 rounded mb-1" style={{background:l.t==="err"?"#fef2f2":"#f0fdf4",color:l.t==="err"?"#b91c1c":"#15803d"}}>{l.t==="err"?"✗":"✓"} {l.m}</div>)}</div>}
    {total>0&&(()=>{
      const rawD=Object.values(files).flatMap(f=>f.data);
      // ★ 重複ID解消: price>0の予約を優先（楽天price=0 vs RC正しいprice の問題対策）
      const dmap=new Map();let dupCnt=0;
      rawD.forEach(r=>{const ex=dmap.get(r.id);if(ex){dupCnt++;if((Number(r.price)||0)>(Number(ex.price)||0))dmap.set(r.id,r);}else dmap.set(r.id,r);});
      const allD=[...dmap.values()];
      const mBreak={};let tPrice=0;
      allD.forEach(r=>{const ym=r.returnDate?r.returnDate.substring(0,7):"不明";mBreak[ym]=(mBreak[ym]||{cnt:0,sum:0});mBreak[ym].cnt++;mBreak[ym].sum+=(r.price||0);tPrice+=(r.price||0);});
      const sortedM=Object.entries(mBreak).sort(([a],[b])=>a.localeCompare(b));
      return <div className="bg-white rounded-xl shadow-sm border border-gray-200 p-4">
      <div className="flex items-center gap-2 mb-3 flex-wrap">{Object.entries(files).map(([k,f])=><div key={k} className="flex items-center gap-1"><OBadge ota={k}/><span className="text-xs font-bold">{f.data.length}件</span></div>)}<span className="text-gray-400">→</span><span className="text-base font-black text-blue-700">合計 {allD.length}件 / ¥{tPrice.toLocaleString()}</span>{dupCnt>0&&<span className="text-xs text-amber-600 font-bold">（重複{dupCnt}件→price優先で統合）</span>}</div>
      <div style={{fontSize:10,color:"#475569",marginBottom:8,padding:"6px 8px",background:"#f8fafc",borderRadius:6}}>📅 返却月別: {sortedM.map(([ym,d])=><span key={ym} style={{marginRight:8}}><b>{ym.replace("-","/")}</b>:{d.cnt}件(¥{d.sum.toLocaleString()})</span>)}</div>
      <button onClick={()=>onImport(allD)} className="btn-primary" style={{padding:"10px 24px",fontSize:14}}>統合してタスクを生成 →</button>
    </div>;})()}
    <div className="bg-white rounded-xl shadow-sm border border-gray-200 p-4 mt-4">
      <h3 className="text-base font-bold mb-1" style={{display:"flex",alignItems:"center",gap:8}}><span style={{background:"#4f46e5",color:"#fff",borderRadius:"50%",width:24,height:24,display:"inline-flex",alignItems:"center",justifyContent:"center",fontSize:12,fontWeight:700}}>2</span>場所CSV取込</h3>
      <p className="text-xs text-gray-500 mb-3">予約番号でお届け場所・回収場所を一括更新 → OPシートにGoogleマップリンク付きで表示されます<br/>CSVフォーマット: 予約番号, お届け場所, 回収場所{dataCount===0&&<span style={{color:"#b45309",fontWeight:600}}><br/>※ Step 1のCSV取込後にマッチングされます（先に読み込みも可能）</span>}</p>
      <div className="flex items-center gap-3 flex-wrap">
        <label className="px-4 py-2 rounded-lg text-xs font-semibold border-2 border-dashed border-indigo-300 bg-indigo-50 text-indigo-700 cursor-pointer hover:bg-indigo-100"><span>📍 場所CSVを選択</span><input type="file" accept=".csv,.txt,.tsv" className="hidden" onChange={e=>{
          const f=e.target.files?.[0];if(!f)return;
          readFile(f,text=>{
            const rows=parseCSV(text);if(rows.length<2){setPlaceLogs([{t:"err",m:"CSVが空です"}]);return;}
            // ヘッダー行を自動検出（最初の10行以内で「予約番号」を含む行を探す）
            let hdIdx=-1,hd=null;
            for(let hi=0;hi<Math.min(rows.length,10);hi++){
              if(rows[hi].some(h=>h&&(h.includes("予約番号")||h==="ID"||h==="id"))){hdIdx=hi;hd=rows[hi];break;}
            }
            if(!hd){setPlaceLogs([{t:"err",m:"「予約番号」列が見つかりません"}]);return;}
            const idxId=hd.findIndex(h=>h.includes("予約番号")||h==="ID"||h==="id");
            const idxDel=hd.findIndex(h=>h.includes("届け")||(h.includes("場所")&&!h.includes("回収")&&!h.includes("返却")));
            const idxCol=hd.findIndex(h=>h.includes("回収")||h.includes("返却場所"));
            if(idxId<0){setPlaceLogs([{t:"err",m:"「予約番号」列が見つかりません"}]);return;}
            const places={};let cnt=0;
            for(let i=hdIdx+1;i<rows.length;i++){
              const r=rows[i];const rid=r[idxId]?.trim();if(!rid)continue;
              const del=idxDel>=0?r[idxDel]?.trim()||"":"";
              const col=idxCol>=0?r[idxCol]?.trim()||"":"";
              if(del||col){places[rid]={delPlace:del,colPlace:col};cnt++;}
            }
            if(cnt===0){setPlaceLogs([{t:"err",m:"有効なデータがありません"}]);return;}
            const now2=new Date();const ts2=`${now2.getMonth()+1}/${now2.getDate()} ${String(now2.getHours()).padStart(2,"0")}:${String(now2.getMinutes()).padStart(2,"0")}`;
            onSetPendingPlaces(places);
            if(dataCount>0){const result=onUpdatePlaces(places);setPlaceLogs([{t:"ok",m:`[${ts2}] ${f.name}: ${cnt}件読込 → ${result.matched}件マッチ, ${result.unmatched}件未マッチ`}]);}
            else{setPlaceLogs([{t:"ok",m:`[${ts2}] ${f.name}: ${cnt}件読込済み（Step 1のCSV取込後に自動マッチングされます）`}]);}
          });
        }}/></label>
        <span className="text-xs text-gray-400">予約番号 + お届け場所 + 回収場所</span>
      </div>
      {placeLogs.length>0&&<div className="mt-2">{placeLogs.map((l,i)=><div key={i} className="text-xs px-2 py-1 rounded mb-1" style={{background:l.t==="err"?"#fef2f2":"#f0fdf4",color:l.t==="err"?"#b91c1c":"#15803d"}}>{l.t==="err"?"✗":"✓"} {l.m}</div>)}</div>}
      {pendingPlaces&&Object.keys(pendingPlaces).length>0&&dataCount===0&&<div className="mt-2 px-2 py-1 rounded text-xs" style={{background:"#fef3c7",color:"#92400e"}}>📍 場所データ {Object.keys(pendingPlaces).length}件 読込済み — Step 1のインポート待ち</div>}
    </div>
  </div>;
}

/* ==========================================
   車両管理画面
   ========================================== */
function VehicleManager({vehicles,onVehiclesChange,vehicleClasses,onDeleteVehicle,highlightVehicle}){
  const[editId,setEditId]=useState(null);
  const[form,setForm]=useState({name:"",no:"",type:"A",seats:5,insuranceVeh:false,year:"",equip:"",insPrice:""});
  const[addMode,setAddMode]=useState(false);

  const startEdit=(v)=>{setEditId(v.id);setForm({name:v.name,no:v.no,type:v.type,seats:v.seats,insuranceVeh:!!v.insuranceVeh,year:v.year||"",equip:v.equip||"",insPrice:v.insPrice||""});};
  const save=()=>{
    if(editId){
      if(!window.confirm("車両情報を保存しますか？"))return;
      onVehiclesChange(vehicles.map(v=>v.id===editId?{...v,name:form.name,no:form.no,type:form.type,seats:+form.seats,insuranceVeh:!!form.insuranceVeh,year:form.year,equip:form.equip,insPrice:form.insPrice}:v));
      setEditId(null);
    }
  };
  const addNew=()=>{
    if(!window.confirm("新規車両を登録しますか？"))return;
    const prefix=form.name.replace(/[\s-]/g,"").substring(0,3).toUpperCase()||"NEW";
    const noStr=(form.no||"").replace(/[^0-9a-zA-Z]/g,"");
    const code=prefix+(noStr||Date.now().toString(36).slice(-4));
    if(vehicles.some(v=>v.code===code)){alert("同じ車種・ナンバーの車両が既に登録されています");return;}
    onVehiclesChange([...vehicles,{id:vuid(),code,name:form.name,no:form.no,type:form.type,seats:+form.seats,insuranceVeh:!!form.insuranceVeh,year:form.year,equip:form.equip,insPrice:form.insPrice}]);
    setForm({name:"",no:"",type:"A",seats:5,insuranceVeh:false,year:"",equip:"",insPrice:""});setAddMode(false);
  };
  const remove=(id)=>{if(!window.confirm("この車両を削除しますか？"))return;const v=vehicles.find(x=>x.id===id);onVehiclesChange(vehicles.filter(x=>x.id!==id));if(v&&onDeleteVehicle)onDeleteVehicle(v.code);};

  const grouped=useMemo(()=>{
    return vehicleClasses.map(vc=>({...vc,items:vehicles.filter(v=>v.type===vc.type)}));
  },[vehicles,vehicleClasses]);

  return <div style={{maxWidth:800,margin:"0 auto"}}>
    <div className="flex items-center justify-between mb-3">
      <h3 className="text-base font-bold text-gray-800">車両登録管理</h3>
      <button onClick={()=>{setAddMode(true);setEditId(null);setForm({name:"",no:"",type:"A",seats:5,insuranceVeh:false,year:"",equip:"",insPrice:""});}} className="btn-primary">＋ 車両追加</button>
    </div>

    {(addMode||editId)&&<div className="bg-blue-50 border border-blue-200 rounded-xl p-4 mb-4">
      <h4 className="font-bold text-sm mb-2 text-blue-800">{editId?"車両を編集":"新規車両登録"}</h4>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr 80px",gap:8}}>
        <div><label className="text-xs text-gray-600">クラス</label><select value={form.type} onChange={e=>setForm({...form,type:e.target.value})} className="input-s">{vehicleClasses.map(c=><option key={c.type} value={c.type}>{c.type}クラス</option>)}</select></div>
        <div><label className="text-xs text-gray-600">車種</label><input value={form.name} onChange={e=>setForm({...form,name:e.target.value})} className="input-s" placeholder="ヴェルファイア"/></div>
        <div><label className="text-xs text-gray-600">ナンバー</label><input value={form.no} onChange={e=>setForm({...form,no:e.target.value})} className="input-s" placeholder="7673"/></div>
        <div><label className="text-xs text-gray-600">定員</label><input type="number" value={form.seats} onChange={e=>setForm({...form,seats:e.target.value})} className="input-s"/></div>
      </div>
      <div style={{display:"grid",gridTemplateColumns:"80px 1fr 120px",gap:8,marginTop:6}}>
        <div><label className="text-xs text-gray-600">年式</label><input value={form.year} onChange={e=>setForm({...form,year:e.target.value})} className="input-s" placeholder="2024"/></div>
        <div><label className="text-xs text-gray-600">装備</label><input value={form.equip} onChange={e=>setForm({...form,equip:e.target.value})} className="input-s" placeholder="ナビ,ETC,バックカメラ"/></div>
        <div><label className="text-xs text-gray-600">保険事業価格</label><input value={form.insPrice} onChange={e=>setForm({...form,insPrice:e.target.value})} className="input-s" placeholder="¥15,000"/></div>
      </div>
      <div style={{marginTop:6}}>
        <label style={{display:"flex",alignItems:"center",gap:6,cursor:"pointer",fontSize:12}}>
          <input type="checkbox" checked={form.insuranceVeh} onChange={e=>setForm({...form,insuranceVeh:e.target.checked})}/>
          <span style={{fontWeight:700,color:form.insuranceVeh?"#7c3aed":"#64748b"}}>🛡️ 保険事業車両</span>
          <span style={{fontSize:10,color:"#94a3b8"}}>（CSV自動配車の対象外）</span>
        </label>
      </div>
      <div className="flex gap-2 mt-3">
        {editId?<button onClick={save} className="btn-primary">保存</button>:<button onClick={addNew} className="btn-primary">登録</button>}
        <button onClick={()=>{setEditId(null);setAddMode(false);}} className="btn-ghost">キャンセル</button>
      </div>
    </div>}

    {grouped.map(g=><div key={g.type} className="mb-3">
      <div className="flex items-center gap-2 mb-1">
        <span className="text-xs font-bold text-white px-2 py-0.5 rounded" style={{background:"#2563eb"}}>{g.type}</span>
        <span className="text-xs text-gray-600 font-semibold">{g.label}</span>
        <span className="text-xs text-gray-400">({g.items.length}台)</span>
      </div>
      {g.items.length===0?<div className="text-xs text-gray-400 pl-4 mb-2">車両未登録</div>:
      <div className="bg-white rounded-lg border border-gray-200 overflow-hidden mb-2">
        <table style={{width:"100%",borderCollapse:"collapse",fontSize:12}}>
          <thead><tr style={{background:"#f8fafc"}}><th className="px-3 py-1.5 text-left text-xs font-semibold text-gray-500 border-b">車種</th><th className="px-3 py-1.5 text-left text-xs font-semibold text-gray-500 border-b">ナンバー</th><th className="px-3 py-1.5 text-center text-xs font-semibold text-gray-500 border-b">定員</th><th className="px-3 py-1.5 text-center text-xs font-semibold text-gray-500 border-b">年式</th><th className="px-3 py-1.5 text-left text-xs font-semibold text-gray-500 border-b">装備</th><th className="px-3 py-1.5 text-right text-xs font-semibold text-gray-500 border-b">保険価格</th><th className="px-3 py-1.5 text-right text-xs font-semibold text-gray-500 border-b">操作</th></tr></thead>
          <tbody>{g.items.map(v=><tr key={v.id} ref={highlightVehicle===v.code?(el)=>{if(el)el.scrollIntoView({behavior:"smooth",block:"center"});}:undefined} className="border-b border-gray-100 hover:bg-blue-50" style={highlightVehicle===v.code?{background:"#dbeafe",animation:"fadeIn .5s ease"}:{}}>
            <td className="px-3 py-1.5 font-semibold">{v.name}{v.insuranceVeh&&<span style={{fontSize:8,fontWeight:700,marginLeft:4,padding:"1px 4px",borderRadius:3,background:"#ede9fe",color:"#7c3aed"}}>🛡️保険</span>}</td>
            <td className="px-3 py-1.5 font-mono font-bold" style={{color:"#2563eb"}}>{v.no}</td>
            <td className="px-3 py-1.5 text-center">{v.seats}名</td>
            <td className="px-3 py-1.5 text-center" style={{fontSize:11,color:"#64748b"}}>{v.year||"-"}</td>
            <td className="px-3 py-1.5" style={{fontSize:10,color:"#475569",maxWidth:120,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{v.equip||"-"}</td>
            <td className="px-3 py-1.5 text-right" style={{fontSize:11,fontWeight:v.insPrice?700:400,color:v.insPrice?"#7c3aed":"#94a3b8"}}>{v.insPrice||"-"}</td>
            <td className="px-3 py-1.5 text-right">
              <button onClick={()=>startEdit(v)} className="text-xs text-blue-600 hover:underline mr-2">編集</button>
              <button onClick={()=>remove(v.id)} className="text-xs text-red-500 hover:underline">削除</button>
            </td>
          </tr>)}</tbody>
        </table>
      </div>}
    </div>)}
    <div className="text-xs text-gray-400 mt-4">合計: {vehicles.length}台</div>
  </div>;
}

/* ==========================================
   車両タブ（マスター＋整備管理）
   ========================================== */
function VehicleTab(props){
  var _subTab=useState("master");
  var subTab=_subTab[0];
  var setSubTab=_subTab[1];

  return React.createElement("div",null,
    React.createElement("div",{style:{display:"flex",gap:8,marginBottom:12,borderBottom:"1px solid #e2e8f0",paddingBottom:8}},
      React.createElement("button",{onClick:function(){setSubTab("master");},style:{padding:"8px 12px",fontSize:13,fontWeight:subTab==="master"?700:500,color:subTab==="master"?"#2563eb":"#64748b",background:"none",border:"none",cursor:"pointer",borderBottom:subTab==="master"?"2px solid #2563eb":"none"}},"マスター"),
      React.createElement("button",{onClick:function(){setSubTab("fleet");},style:{padding:"8px 12px",fontSize:13,fontWeight:subTab==="fleet"?700:500,color:subTab==="fleet"?"#2563eb":"#64748b",background:"none",border:"none",cursor:"pointer",borderBottom:subTab==="fleet"?"2px solid #2563eb":"none"}},"整備管理")
    ),
    subTab==="master"&&React.createElement(VehicleManager,{vehicles:props.vehicles||[],onVehiclesChange:props.onVehiclesChange,vehicleClasses:props.vehicleClasses||[],onDeleteVehicle:props.onDeleteVehicle,highlightVehicle:props.highlightVehicle}),
    subTab==="fleet"&&React.createElement(FleetManager,{cars:props.hmCars||[],carData:props.hmCarData||[],logs:props.hmLogs||[],classes:props.hmClasses||[],hmReload:props.hmReload})
  );
}

/* ==========================================
   HANDYMAN 整備管理（5機能＋コスト集計）
   ========================================== */
function FleetManager(p){
  var E=React.createElement;
  var _v=useState("list");var view=_v[0];var setView=_v[1];
  var _sel=useState(null);var selCar=_sel[0];var setSelCar=_sel[1];
  var _mi=useState("");var miIn=_mi[0];var setMiIn=_mi[1];
  var _oi=useState("");var oiIn=_oi[0];var setOiIn=_oi[1];
  var _iv=useState("");var ivIn=_iv[0];var setIvIn=_iv[1];
  var _ins=useState("");var insIn=_ins[0];var setInsIn=_ins[1];
  var _sav=useState(false);var busy=_sav[0];var setBusy=_sav[1];
  // 整備記録入力用
  var _ld=useState(new Date().toISOString().slice(0,10));var logDate=_ld[0];var setLogDate=_ld[1];
  var _lc=useState("");var logCost=_lc[0];var setLogCost=_lc[1];
  var _ldesc=useState("");var logDesc=_ldesc[0];var setLogDesc=_ldesc[1];
  var _lcat=useState("oil");var logCat=_lcat[0];var setLogCat=_lcat[1];
  var COST_CATS=[{v:"inspection",l:"車検"},{v:"semi_annual",l:"半年点検"},{v:"repair",l:"修理"},{v:"oil",l:"オイル交換"},{v:"other",l:"その他"}];
  var catLabel=function(v){var f=COST_CATS.filter(function(c){return c.v===v});return f.length?f[0].l:v||""}
  // 集計期間選択
  var _yr=useState(new Date().getFullYear());var filterYear=_yr[0];var setFilterYear=_yr[1];

  var cars=p.cars||[];var carData=p.carData||[];var logs=p.logs||[];
  var today=new Date().toISOString().slice(0,10);

  // 保存通知用（画面中央にポップアップ）
  var _msg=useState("");var saveMsg=_msg[0];var setSaveMsg=_msg[1];
  var showMsg=function(text,isErr){setSaveMsg(text);setTimeout(function(){setSaveMsg("")},isErr?6000:2500)};
  var save=function(fn){setBusy(true);return Promise.resolve().then(function(){return fn()}).then(function(){if(p.hmReload)return p.hmReload()}).then(function(){showMsg("登録完了",false)}).catch(function(e){console.error("HM save:",e);showMsg("保存エラー: "+String(e&&e.message||e),true)}).finally(function(){setBusy(false)})};

  // --- ヘルパー ---
  var sortDesc=function(arr){return arr.slice().sort(function(a,b){return(b.date||"").localeCompare(a.date||"")})};
  var cdFilter=function(carId,type){return(carData).filter(function(d){return d&&d.car_id===carId&&d.type===type})};
  var latestCD=function(carId,type){var items=sortDesc(cdFilter(carId,type));return items.length?items[0]:null};
  var getMileage=function(cid){var m=latestCD(cid,"mileage");return m?Number(m.value||0):0};
  // オイル交換間隔は全車両共通（car_id="__global__"に保存）
  var getOilInterval=function(){var items=(carData).filter(function(d){return d&&d.car_id==="__global__"&&d.type==="oil_interval"});if(!items.length)return 5000;var sorted=sortDesc(items);return Number(sorted[0].value||0)||5000};
  var getLastOil=function(cid){return latestCD(cid,"oil_change")};
  var getNextOil=function(cid){var last=getLastOil(cid);var iv=getOilInterval();return last?Number(last.value||0)+iv:iv};
  var getInsurance=function(cid){var m=latestCD(cid,"insurance");return m?Number(m.value||0):0};
  var totalInsurance=function(){var t=0;cars.forEach(function(c){t+=getInsurance(c.id)});return t};
  var carLogs=function(cid){return(logs).filter(function(l){return l&&l.car_id===cid})};

  // 月別集計: {YYYY-MM: amount}
  var monthlyCost=function(logArr){var m={};(logArr||[]).forEach(function(l){var ym=(l.date||"").slice(0,7);if(ym){m[ym]=(m[ym]||0)+Number(l.cost||0)}});return m};
  // 年間集計
  var yearlyCost=function(logArr,yr){var t=0;(logArr||[]).forEach(function(l){if((l.date||"").slice(0,4)===String(yr)){t+=Number(l.cost||0)}});return t};

  // --- 保存処理 ---
  var saveMileage=function(){if(!selCar||!miIn)return;var km=Number(miIn);if(km<=0)return;save(function(){return DB.hm.saveCarData({id:crypto.randomUUID(),store_id:"sapporo",car_id:selCar.id,type:"mileage",date:today,value:km,memo:""})}).then(function(){setMiIn("")})};
  var saveOil=function(){if(!selCar||!oiIn)return;var km=Number(oiIn);if(km<=0)return;save(function(){return DB.hm.saveCarData({id:crypto.randomUUID(),store_id:"sapporo",car_id:selCar.id,type:"oil_change",date:today,value:km,memo:""})}).then(function(){setOiIn("")})};
  var saveIv=function(){if(!ivIn)return;var km=Number(ivIn);if(km<=0)return;save(function(){return DB.hm.saveCarData({id:crypto.randomUUID(),store_id:"sapporo",car_id:"__global__",type:"oil_interval",date:today,value:km,memo:""})}).then(function(){setIvIn("")})};
  var saveSt=function(st){if(!selCar)return;var u={id:selCar.id,store_id:selCar.store_id||"sapporo",name:selCar.name||"",plate:selCar.plate||"",class_id:selCar.class_id||"",status:st};save(function(){return DB.hm.saveCar(u)}).then(function(){setSelCar(u)})};
  var saveIns=function(){if(!selCar||!insIn)return;var v=Number(insIn);if(v<=0)return;save(function(){return DB.hm.saveCarData({id:crypto.randomUUID(),store_id:"sapporo",car_id:selCar.id,type:"insurance",date:today,value:v,memo:""})}).then(function(){setInsIn("")})};
  var saveLog=function(){if(!selCar||!logDate||!logCost||!logDesc.trim())return;var c=Number(logCost);if(c<=0)return;save(function(){return DB.hm.saveLog({id:crypto.randomUUID(),store_id:"sapporo",car_id:selCar.id,date:logDate,type:logCat||"other",description:logDesc||"",cost:c,mileage:getMileage(selCar.id)})}).then(function(){setLogCost("");setLogDesc("")})};
  var delLog=function(id){if(!window.confirm("削除しますか？"))return;save(function(){return DB.hm.deleteLog(id)})};

  // --- 共通パーツ ---
  var navBtn=function(id,label){return E("button",{key:id,onClick:function(){setView(id)},style:{padding:"6px 14px",fontSize:12,fontWeight:view===id?700:500,background:view===id?"#2563eb":"#f1f5f9",color:view===id?"#fff":"#64748b",border:"none",borderRadius:6,cursor:"pointer"}},label)};
  // 通知ポップアップ（画面中央に大きく表示、全画面で常に見える）
  var isErr=saveMsg&&saveMsg.indexOf("エラー")>=0;
  var msgPopup=saveMsg?E("div",{style:{position:"fixed",top:0,left:0,right:0,bottom:0,display:"flex",alignItems:"center",justifyContent:"center",zIndex:99999,pointerEvents:"none"}},
    E("div",{style:{background:isErr?"#fee2e2":"#dcfce7",color:isErr?"#991b1b":"#15803d",border:"2px solid "+(isErr?"#f87171":"#4ade80"),borderRadius:12,padding:"20px 40px",fontSize:18,fontWeight:800,boxShadow:"0 8px 30px rgba(0,0,0,0.2)",textAlign:"center",pointerEvents:"auto"}},
      E("div",{style:{fontSize:28,marginBottom:4}},isErr?"❌":"✅"),
      saveMsg
    )
  ):null;
  var nav=E("div",{style:{display:"flex",gap:6,marginBottom:14,flexWrap:"wrap"}},navBtn("list","車両一覧"),navBtn("summary","コスト集計"));
  var statusBadge=function(s){var bg=s==="active"?"#f0fdf4":s==="repair"?"#fee2e2":s==="waiting"?"#fef3c7":"#dbeafe";var fg=s==="active"?"#15803d":s==="repair"?"#991b1b":s==="waiting"?"#92400e":"#1e40af";var lb=s==="active"?"稼働中":s==="repair"?"修理中":s==="waiting"?"修理待機中":"見積中";return E("span",{style:{fontSize:10,padding:"2px 8px",borderRadius:4,background:bg,color:fg,fontWeight:600}},lb)};
  var section=function(bg,border,title,children){return E("div",{style:{background:bg,border:"1px solid "+border,borderRadius:8,padding:12,marginBottom:10}},E("div",{style:{fontSize:13,fontWeight:700,marginBottom:8}},title),children)};
  var card=function(bg,border,fg,val,label){return E("div",{style:{background:bg,border:"1px solid "+border,borderRadius:8,padding:14,textAlign:"center",minWidth:120}},E("div",{style:{fontSize:22,fontWeight:700,color:fg}},val),E("div",{style:{fontSize:11,color:fg,marginTop:4}},label))};

  // ========== 車両一覧 ==========
  if(view==="list"){
    var tIns=totalInsurance();
    var allYearlyList=yearlyCost(logs,filterYear);
    return E("div",{style:{maxWidth:1000,margin:"0 auto"}},msgPopup,nav,

      // 全車両サマリー（保険合計＋整備費合計）
      E("div",{style:{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(150px,1fr))",gap:8,marginBottom:12}},
        E("div",{style:{background:"#f0fdf4",border:"1px solid #86efac",borderRadius:8,padding:12,textAlign:"center"}},
          E("div",{style:{fontSize:10,color:"#15803d",fontWeight:600}},"保険 月額合計"),
          E("div",{style:{fontSize:20,fontWeight:800,color:"#15803d"}},"¥"+tIns.toLocaleString())
        ),
        E("div",{style:{background:"#fefce8",border:"1px solid #fde68a",borderRadius:8,padding:12,textAlign:"center"}},
          E("div",{style:{fontSize:10,color:"#92400e",fontWeight:600}},"保険 年間合計"),
          E("div",{style:{fontSize:20,fontWeight:800,color:"#92400e"}},"¥"+(tIns*12).toLocaleString())
        ),
        E("div",{style:{background:"#fee2e2",border:"1px solid #fca5a5",borderRadius:8,padding:12,textAlign:"center"}},
          E("div",{style:{fontSize:10,color:"#991b1b",fontWeight:600}},"整備費 年間合計("+filterYear+")"),
          E("div",{style:{fontSize:20,fontWeight:800,color:"#991b1b"}},"¥"+allYearlyList.toLocaleString())
        ),
        E("div",{style:{background:"#dbeafe",border:"1px solid #93c5fd",borderRadius:8,padding:12,textAlign:"center"}},
          E("div",{style:{fontSize:10,color:"#1e40af",fontWeight:600}},"管理車両数"),
          E("div",{style:{fontSize:20,fontWeight:800,color:"#1e40af"}},cars.length+"台")
        )
      ),

      // オイル交換間隔（全車共通）
      E("div",{style:{background:"#fff7ed",border:"1px solid #fed7aa",borderRadius:8,padding:10,marginBottom:12,display:"flex",alignItems:"center",gap:8,flexWrap:"wrap"}},
        E("span",{style:{fontSize:12,fontWeight:600,color:"#9a3412"}},"オイル交換間隔（全車共通）: "+getOilInterval().toLocaleString()+"km"),
        E("input",{type:"number",value:ivIn,onChange:function(e){setIvIn(e.target.value)},placeholder:"新しい間隔(km)",className:"input-s",style:{maxWidth:140,fontSize:11}}),
        E("button",{onClick:saveIv,className:"btn-ghost",style:{fontSize:11,padding:"4px 10px"},disabled:busy},"変更")
      ),

      // 車両リスト
      E("div",{style:{display:"grid",gap:8}},
        cars.map(function(c){
          if(!c||!c.id)return null;
          var mil=getMileage(c.id);var ins=getInsurance(c.id);var cost=yearlyCost(carLogs(c.id),filterYear);
          return E("div",{key:c.id,style:{background:"white",border:"1px solid #e2e8f0",borderRadius:8,padding:12,cursor:"pointer"},onClick:function(){setSelCar(c);setView("detail")}},
            E("div",{style:{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:6}},
              E("div",null,E("span",{style:{fontWeight:700,fontSize:14}},c.name||""),E("span",{style:{fontSize:11,color:"#64748b",marginLeft:8}},c.plate||"")),
              statusBadge(c.status||"active")
            ),
            E("div",{style:{display:"flex",gap:16,fontSize:11,color:"#475569"}},
              E("span",null,"走行: "+(mil?mil.toLocaleString()+"km":"未記録")),
              E("span",null,"保険: "+(ins?"¥"+ins.toLocaleString()+"/月":"未設定")),
              E("span",null,"整備("+filterYear+"): ¥"+cost.toLocaleString())
            )
          );
        }),
        cars.length===0&&E("div",{style:{textAlign:"center",color:"#94a3b8",padding:40,fontSize:13}},"HANDYMANのcarsテーブルに車両を登録してください")
      ),
    );
  }

  // ========== 車両詳細 ==========
  if(view==="detail"&&selCar){
    var cid=selCar.id;
    var milHist=sortDesc(cdFilter(cid,"mileage"));
    var oilHist=sortDesc(cdFilter(cid,"oil_change"));
    var insHist=sortDesc(cdFilter(cid,"insurance"));
    var myLogs=sortDesc(carLogs(cid));
    var myMonthly=monthlyCost(carLogs(cid));
    var myYearly=yearlyCost(carLogs(cid),filterYear);
    var monthKeys=Object.keys(myMonthly).sort().reverse();
    var curMileage=getMileage(cid);
    var curIns=getInsurance(cid);
    var lastOil=getLastOil(cid);

    // 種別ごとの小計
    var catTotals={};COST_CATS.forEach(function(c){catTotals[c.v]=0});
    myLogs.forEach(function(l){if((l.date||"").slice(0,4)===String(filterYear)){catTotals[l.type||"other"]=(catTotals[l.type||"other"]||0)+Number(l.cost||0)}});

    // セクションヘッダー共通
    var secHead=function(emoji,title,badge){return E("div",{style:{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:8}},E("div",{style:{fontSize:13,fontWeight:700}},emoji+" "+title),badge||null)};
    // 小テーブルヘッダー
    var tblHead=function(cols){return E("thead",null,E("tr",{style:{background:"#f1f5f9",borderBottom:"2px solid #cbd5e1"}},cols.map(function(c,i){return E("th",{key:i,style:{padding:"5px 8px",fontSize:11,fontWeight:600,textAlign:c.align||"left",color:"#475569"}},c.label)})))};

    return E("div",{style:{maxWidth:800,margin:"0 auto"}},msgPopup,
      // ヘッダー
      E("div",{style:{background:"white",border:"1px solid #e2e8f0",borderRadius:10,padding:14,marginBottom:14,display:"flex",alignItems:"center",gap:10,flexWrap:"wrap"}},
        E("button",{onClick:function(){setView("list")},className:"btn-ghost",style:{padding:"5px 12px",fontSize:12}},"← 一覧へ"),
        E("div",{style:{flex:1}},
          E("div",{style:{display:"flex",alignItems:"center",gap:8}},
            E("span",{style:{fontSize:18,fontWeight:800}},selCar.name||""),
            E("span",{style:{fontSize:13,color:"#64748b"}},selCar.plate||""),
            statusBadge(selCar.status||"active")
          ),
          E("div",{style:{display:"flex",gap:16,fontSize:11,color:"#64748b",marginTop:4}},
            E("span",null,"走行: "+(curMileage?curMileage.toLocaleString()+"km":"未記録")),
            E("span",null,"保険: "+(curIns?"¥"+curIns.toLocaleString()+"/月":"未設定")),
            E("span",null,"整備("+filterYear+"): ¥"+myYearly.toLocaleString())
          )
        )
      ),

      // ③ ステータス
      section("#f8f4ff","#d8b4fe","③ 車両ステータス",
        E("div",{style:{display:"flex",gap:8,alignItems:"center"}},
          E("select",{value:selCar.status||"active",onChange:function(e){saveSt(e.target.value)},className:"input-s",style:{maxWidth:200},disabled:busy},
            E("option",{value:"active"},"稼働中"),E("option",{value:"repair"},"修理中"),E("option",{value:"waiting"},"修理待機中"),E("option",{value:"estimating"},"見積中")
          ),
          busy&&E("span",{style:{fontSize:11,color:"#94a3b8"}},"保存中...")
        )
      ),

      // ① 走行距離
      E("div",{style:{background:"#eff6ff",border:"1px solid #93c5fd",borderRadius:8,padding:12,marginBottom:10}},
        secHead("①","走行距離管理",curMileage?E("span",{style:{fontSize:14,fontWeight:800,color:"#1e40af"}},curMileage.toLocaleString()+"km"):null),
        E("div",{style:{display:"flex",gap:8,alignItems:"center",marginBottom:10}},
          E("input",{type:"number",value:miIn,onChange:function(e){setMiIn(e.target.value)},placeholder:"現在の走行距離（km）",className:"input-s",style:{maxWidth:200}}),
          E("button",{onClick:saveMileage,className:"btn-primary",disabled:busy},"記録")
        ),
        milHist.length>0?E("div",null,
          E("div",{style:{fontSize:11,fontWeight:600,color:"#1e40af",marginBottom:4}},"記録履歴（"+milHist.length+"件）"),
          E("table",{style:{width:"100%",borderCollapse:"collapse",fontSize:11,background:"#fff",borderRadius:4}},
            tblHead([{label:"日付"},{label:"走行距離",align:"right"}]),
            E("tbody",null,milHist.map(function(m,i){return E("tr",{key:m.id||i,style:{borderBottom:"1px solid #e2e8f0"}},
              E("td",{style:{padding:"5px 8px"}},m.date||""),
              E("td",{style:{padding:"5px 8px",textAlign:"right",fontWeight:600}},Number(m.value||0).toLocaleString()+"km")
            )}))
          )
        ):E("div",{style:{fontSize:11,color:"#94a3b8",padding:8,textAlign:"center"}},"まだ記録がありません")
      ),

      // ② オイル交換
      E("div",{style:{background:"#fff7ed",border:"1px solid #fed7aa",borderRadius:8,padding:12,marginBottom:10}},
        secHead("②","オイル交換管理",null),
        // ステータスボックス
        E("div",{style:{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:8,marginBottom:10}},
          E("div",{style:{background:"#fefce8",borderRadius:6,padding:8,textAlign:"center"}},
            E("div",{style:{fontSize:10,color:"#92400e"}},"最終交換"),
            E("div",{style:{fontSize:13,fontWeight:700}},lastOil?Number(lastOil.value||0).toLocaleString()+"km":"未記録"),
            lastOil?E("div",{style:{fontSize:10,color:"#78716c"}},lastOil.date||""):null
          ),
          E("div",{style:{background:"#fff7ed",borderRadius:6,padding:8,textAlign:"center"}},
            E("div",{style:{fontSize:10,color:"#92400e"}},"次回交換目安"),
            E("div",{style:{fontSize:13,fontWeight:700,color:"#ea580c"}},getNextOil(cid).toLocaleString()+"km")
          ),
          E("div",{style:{background:"#f0fdf4",borderRadius:6,padding:8,textAlign:"center"}},
            E("div",{style:{fontSize:10,color:"#15803d"}},"交換間隔（全車共通）"),
            E("div",{style:{fontSize:13,fontWeight:700}},getOilInterval().toLocaleString()+"km")
          )
        ),
        // 入力欄
        E("div",{style:{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10,marginBottom:8}},
          E("div",null,
            E("div",{style:{fontSize:11,color:"#78716c",marginBottom:4}},"交換時の走行距離を記録"),
            E("div",{style:{display:"flex",gap:4}},
              E("input",{type:"number",value:oiIn,onChange:function(e){setOiIn(e.target.value)},placeholder:"km",className:"input-s"}),
              E("button",{onClick:saveOil,className:"btn-primary",disabled:busy},"記録")
            )
          ),
          E("div",null,
            E("div",{style:{fontSize:11,color:"#78716c",marginBottom:4}},"交換間隔を変更"),
            E("div",{style:{display:"flex",gap:4}},
              E("input",{type:"number",value:ivIn,onChange:function(e){setIvIn(e.target.value)},placeholder:"例:5000",className:"input-s"}),
              E("button",{onClick:saveIv,className:"btn-ghost",disabled:busy},"変更")
            )
          )
        ),
        // 履歴
        oilHist.length>0?E("div",null,
          E("div",{style:{fontSize:11,fontWeight:600,color:"#9a3412",marginBottom:4}},"交換履歴（"+oilHist.length+"件）"),
          E("table",{style:{width:"100%",borderCollapse:"collapse",fontSize:11,background:"#fff",borderRadius:4}},
            tblHead([{label:"日付"},{label:"交換時走行距離",align:"right"}]),
            E("tbody",null,oilHist.map(function(o,i){return E("tr",{key:o.id||i,style:{borderBottom:"1px solid #e2e8f0"}},
              E("td",{style:{padding:"5px 8px"}},o.date||""),
              E("td",{style:{padding:"5px 8px",textAlign:"right",fontWeight:600}},Number(o.value||0).toLocaleString()+"km")
            )}))
          )
        ):E("div",{style:{fontSize:11,color:"#94a3b8",padding:8,textAlign:"center"}},"まだ交換記録がありません")
      ),

      // ④ 保険金額
      E("div",{style:{background:"#f0fdf4",border:"1px solid #86efac",borderRadius:8,padding:12,marginBottom:10}},
        secHead("④","保険金額",curIns?E("span",{style:{fontSize:14,fontWeight:800,color:"#15803d"}},"¥"+curIns.toLocaleString()+"/月"):null),
        E("div",{style:{display:"flex",gap:8,alignItems:"center",marginBottom:10}},
          E("input",{type:"number",value:insIn,onChange:function(e){setInsIn(e.target.value)},placeholder:"月額（円）",className:"input-s",style:{maxWidth:180}}),
          E("button",{onClick:saveIns,className:"btn-primary",disabled:busy},"登録")
        ),
        // 現在の保険情報
        curIns?E("div",{style:{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8,marginBottom:8}},
          E("div",{style:{background:"#dcfce7",borderRadius:6,padding:10,textAlign:"center"}},
            E("div",{style:{fontSize:10,color:"#15803d"}},"月額"),
            E("div",{style:{fontSize:16,fontWeight:800,color:"#15803d"}},"¥"+curIns.toLocaleString())
          ),
          E("div",{style:{background:"#fefce8",borderRadius:6,padding:10,textAlign:"center"}},
            E("div",{style:{fontSize:10,color:"#92400e"}},"年額"),
            E("div",{style:{fontSize:16,fontWeight:800,color:"#92400e"}},"¥"+(curIns*12).toLocaleString())
          )
        ):E("div",{style:{fontSize:11,color:"#94a3b8",padding:8,textAlign:"center"}},"保険金額が未設定です"),
        // 変更履歴
        insHist.length>1?E("div",null,
          E("div",{style:{fontSize:11,fontWeight:600,color:"#15803d",marginBottom:4}},"変更履歴（"+insHist.length+"件）"),
          E("table",{style:{width:"100%",borderCollapse:"collapse",fontSize:11,background:"#fff",borderRadius:4}},
            tblHead([{label:"日付"},{label:"月額",align:"right"},{label:"年額",align:"right"}]),
            E("tbody",null,insHist.map(function(h,i){var v=Number(h.value||0);return E("tr",{key:h.id||i,style:{borderBottom:"1px solid #e2e8f0"}},
              E("td",{style:{padding:"5px 8px"}},h.date||""),
              E("td",{style:{padding:"5px 8px",textAlign:"right",fontWeight:600}},"¥"+v.toLocaleString()),
              E("td",{style:{padding:"5px 8px",textAlign:"right",color:"#64748b"}},"¥"+(v*12).toLocaleString())
            )}))
          )
        ):null
      ),

      // ⑤ 整備記録
      E("div",{style:{background:"#fef2f2",border:"1px solid #fecaca",borderRadius:8,padding:12,marginBottom:10}},
        secHead("⑤","整備記録",E("span",{style:{fontSize:14,fontWeight:800,color:"#991b1b"}},"年間("+filterYear+"): ¥"+myYearly.toLocaleString())),
        E("div",{style:{fontSize:11,color:"#991b1b",marginBottom:6}},"1項目ごとに 種別・日付・金額・詳細 を入力（複数回登録可）"),
        E("div",{style:{display:"grid",gridTemplateColumns:"110px 120px 110px 1fr",gap:6,marginBottom:8}},
          E("select",{value:logCat,onChange:function(e){setLogCat(e.target.value)},className:"input-s"},
            COST_CATS.map(function(c){return E("option",{key:c.v,value:c.v},c.l)})
          ),
          E("input",{type:"date",value:logDate,onChange:function(e){setLogDate(e.target.value)},className:"input-s"}),
          E("input",{type:"number",value:logCost,onChange:function(e){setLogCost(e.target.value)},placeholder:"金額（円）",className:"input-s"}),
          E("input",{value:logDesc,onChange:function(e){setLogDesc(e.target.value)},placeholder:"詳細（必須）",className:"input-s"})
        ),
        E("button",{onClick:saveLog,className:"btn-primary",disabled:busy||!logDesc.trim()},"整備記録を追加"),

        // 種別ごとの年間小計
        E("div",{style:{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(90px,1fr))",gap:4,marginTop:12,marginBottom:8}},
          COST_CATS.map(function(c){return E("div",{key:c.v,style:{background:"#fff",border:"1px solid #fecaca",borderRadius:4,padding:6,textAlign:"center"}},
            E("div",{style:{fontSize:10,color:"#64748b"}},c.l),
            E("div",{style:{fontSize:12,fontWeight:700,color:catTotals[c.v]>0?"#991b1b":"#cbd5e1"}},"¥"+(catTotals[c.v]||0).toLocaleString())
          )})
        ),

        // 月別集計
        monthKeys.length>0?E("div",{style:{marginTop:8,marginBottom:12}},
          E("div",{style:{fontSize:11,fontWeight:600,color:"#991b1b",marginBottom:4}},"月別集計"),
          E("div",{style:{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(90px,1fr))",gap:4}},
            monthKeys.map(function(ym){return E("div",{key:ym,style:{background:"#fff",border:"1px solid #e2e8f0",borderRadius:4,padding:6,textAlign:"center",fontSize:11}},
              E("div",{style:{color:"#64748b"}},ym),E("div",{style:{fontWeight:700}},"¥"+myMonthly[ym].toLocaleString())
            )})
          )
        ):null,

        // 履歴一覧
        myLogs.length>0?E("div",{style:{marginTop:8}},
          E("div",{style:{fontSize:11,fontWeight:600,color:"#991b1b",marginBottom:4}},"整備履歴（"+myLogs.length+"件）"),
          E("table",{style:{width:"100%",borderCollapse:"collapse",fontSize:11,background:"#fff",borderRadius:4}},
            tblHead([{label:"日付"},{label:"種別"},{label:"金額",align:"right"},{label:"詳細"},{label:"",align:"right"}]),
            E("tbody",null,myLogs.map(function(l,i){return E("tr",{key:l.id||i,style:{borderBottom:"1px solid #f1f5f9"}},
              E("td",{style:{padding:"5px 8px"}},l.date||""),
              E("td",{style:{padding:"5px 8px"}},E("span",{style:{fontSize:10,padding:"2px 8px",borderRadius:4,background:l.type==="inspection"?"#dbeafe":l.type==="repair"?"#fee2e2":l.type==="semi_annual"?"#fef3c7":l.type==="oil"?"#fff7ed":"#f1f5f9",color:l.type==="inspection"?"#1e40af":l.type==="repair"?"#991b1b":l.type==="semi_annual"?"#92400e":l.type==="oil"?"#9a3412":"#475569",fontWeight:600}},catLabel(l.type))),
              E("td",{style:{padding:"5px 8px",textAlign:"right",fontWeight:700}},"¥"+Number(l.cost||0).toLocaleString()),
              E("td",{style:{padding:"5px 8px",color:"#475569",maxWidth:200,overflow:"hidden",textOverflow:"ellipsis"}},l.description||""),
              E("td",{style:{padding:"5px 8px",textAlign:"right"}},E("button",{onClick:function(){delLog(l.id)},style:{fontSize:10,color:"#dc2626",background:"none",border:"none",cursor:"pointer"}},"削除"))
            )}))
          )
        ):E("div",{style:{fontSize:11,color:"#94a3b8",padding:12,textAlign:"center"}},"まだ整備記録がありません。上のフォームから追加してください。")
      )
    );
  }

  // ========== コスト集計 ==========
  if(view==="summary"){
    var tIns=totalInsurance();
    var yearOpts=[];for(var yi=2024;yi<=2027;yi++){yearOpts.push(yi)}
    var allLogsYear=(logs||[]).filter(function(l){return(l.date||"").slice(0,4)===String(filterYear)});
    var allYearly=yearlyCost(logs,filterYear);

    // カテゴリ別年間集計
    var yearCatTotals={};COST_CATS.forEach(function(c){yearCatTotals[c.v]=0});
    allLogsYear.forEach(function(l){yearCatTotals[l.type||"other"]=(yearCatTotals[l.type||"other"]||0)+Number(l.cost||0)});

    // 月別＋カテゴリ別集計 {YYYY-MM: {total:N, inspection:N, repair:N, ...}}
    var monthCatData={};
    allLogsYear.forEach(function(l){
      var ym=(l.date||"").slice(0,7);if(!ym)return;
      if(!monthCatData[ym]){monthCatData[ym]={total:0};COST_CATS.forEach(function(c){monthCatData[ym][c.v]=0})}
      monthCatData[ym].total+=Number(l.cost||0);
      monthCatData[ym][l.type||"other"]=(monthCatData[ym][l.type||"other"]||0)+Number(l.cost||0);
    });
    var allMonthKeys=Object.keys(monthCatData).sort();

    // カテゴリ色
    var catColor=function(v){return v==="inspection"?"#1e40af":v==="semi_annual"?"#92400e":v==="repair"?"#991b1b":v==="oil"?"#9a3412":"#475569"};
    var catBg=function(v){return v==="inspection"?"#dbeafe":v==="semi_annual"?"#fef3c7":v==="repair"?"#fee2e2":v==="oil"?"#fff7ed":"#f1f5f9"};

    return E("div",{style:{maxWidth:1100,margin:"0 auto"}},msgPopup,nav,

      // 年度切替
      E("div",{style:{display:"flex",gap:8,alignItems:"center",marginBottom:14}},
        E("span",{style:{fontSize:12,fontWeight:600}},"年度:"),
        yearOpts.map(function(y){return E("button",{key:y,onClick:function(){setFilterYear(y)},style:{padding:"5px 14px",fontSize:12,fontWeight:filterYear===y?700:400,background:filterYear===y?"#2563eb":"#f1f5f9",color:filterYear===y?"#fff":"#64748b",border:"none",borderRadius:6,cursor:"pointer"}},String(y))})
      ),

      // サマリーカード（上段）
      E("div",{style:{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(140px,1fr))",gap:10,marginBottom:10}},
        card("#f0fdf4","#86efac","#15803d","¥"+tIns.toLocaleString(),"保険 月額合計"),
        card("#fefce8","#fde68a","#92400e","¥"+(tIns*12).toLocaleString(),"保険 年間合計"),
        card("#fee2e2","#fca5a5","#991b1b","¥"+allYearly.toLocaleString(),"整備 年間合計("+filterYear+")"),
        card("#dbeafe","#93c5fd","#1e40af",cars.length+"台","管理車両数")
      ),

      // カテゴリ別年間サマリー
      E("div",{style:{display:"grid",gridTemplateColumns:"repeat("+COST_CATS.length+",1fr)",gap:6,marginBottom:14}},
        COST_CATS.map(function(c){return E("div",{key:c.v,style:{background:catBg(c.v),border:"1px solid #e2e8f0",borderRadius:6,padding:8,textAlign:"center"}},
          E("div",{style:{fontSize:10,color:catColor(c.v),fontWeight:600}},c.l),
          E("div",{style:{fontSize:15,fontWeight:800,color:catColor(c.v)}},"¥"+(yearCatTotals[c.v]||0).toLocaleString())
        )})
      ),

      // 保険内訳（車両別）
      E("div",{style:{background:"#f0fdf4",border:"1px solid #86efac",borderRadius:8,padding:12,marginBottom:12}},
        E("div",{style:{fontSize:13,fontWeight:700,marginBottom:8}},"保険内訳（車両別）"),
        E("table",{style:{width:"100%",borderCollapse:"collapse",fontSize:12}},
          E("thead",null,E("tr",{style:{borderBottom:"2px solid #86efac",background:"#f0fdf4"}},
            E("th",{style:{padding:"6px 8px",textAlign:"left"}},"車両"),E("th",{style:{padding:"6px 8px",textAlign:"right"}},"月額"),E("th",{style:{padding:"6px 8px",textAlign:"right"}},"年額"))),
          E("tbody",null,
            cars.map(function(c){var iv=getInsurance(c.id);return E("tr",{key:c.id,style:{borderBottom:"1px solid #e2e8f0"}},
              E("td",{style:{padding:"6px 8px",fontWeight:600}},(c.name||"")+" "+(c.plate||"")),
              E("td",{style:{padding:"6px 8px",textAlign:"right"}},iv?"¥"+iv.toLocaleString():"未設定"),
              E("td",{style:{padding:"6px 8px",textAlign:"right"}},iv?"¥"+(iv*12).toLocaleString():"-")
            )}),
            E("tr",{style:{borderTop:"2px solid #15803d",fontWeight:700,background:"#dcfce7"}},
              E("td",{style:{padding:"8px"}},"合計"),
              E("td",{style:{padding:"8px",textAlign:"right",fontSize:14}},"¥"+tIns.toLocaleString()),
              E("td",{style:{padding:"8px",textAlign:"right",fontSize:14}},"¥"+(tIns*12).toLocaleString())
            )
          )
        )
      ),

      // 整備費内訳（車両別 × カテゴリ別）
      E("div",{style:{background:"#fef2f2",border:"1px solid #fecaca",borderRadius:8,padding:12,marginBottom:12}},
        E("div",{style:{fontSize:13,fontWeight:700,marginBottom:8}},"整備費内訳（車両別 / "+filterYear+"年）"),
        E("div",{style:{overflowX:"auto"}},
          E("table",{style:{width:"100%",borderCollapse:"collapse",fontSize:11,minWidth:600}},
            E("thead",null,E("tr",{style:{borderBottom:"2px solid #fca5a5",background:"#fef2f2"}},
              E("th",{style:{padding:"6px 8px",textAlign:"left",fontSize:12}},"車両"),
              COST_CATS.map(function(c){return E("th",{key:c.v,style:{padding:"6px 8px",textAlign:"right",color:catColor(c.v),fontSize:11}},c.l)}),
              E("th",{style:{padding:"6px 8px",textAlign:"right",fontSize:12,fontWeight:800}},"合計"),
              E("th",{style:{padding:"6px 8px",textAlign:"right"}},"件数")
            )),
            E("tbody",null,
              cars.map(function(c){
                var cl=carLogs(c.id).filter(function(l){return(l.date||"").slice(0,4)===String(filterYear)});
                var ct={};COST_CATS.forEach(function(cat){ct[cat.v]=0});
                var total=0;
                cl.forEach(function(l){ct[l.type||"other"]=(ct[l.type||"other"]||0)+Number(l.cost||0);total+=Number(l.cost||0)});
                return E("tr",{key:c.id,style:{borderBottom:"1px solid #e2e8f0"}},
                  E("td",{style:{padding:"6px 8px",fontWeight:600}},(c.name||"")),
                  COST_CATS.map(function(cat){return E("td",{key:cat.v,style:{padding:"6px 8px",textAlign:"right",color:ct[cat.v]>0?catColor(cat.v):"#cbd5e1"}},ct[cat.v]>0?"¥"+ct[cat.v].toLocaleString():"-")}),
                  E("td",{style:{padding:"6px 8px",textAlign:"right",fontWeight:700,fontSize:12}},total>0?"¥"+total.toLocaleString():"-"),
                  E("td",{style:{padding:"6px 8px",textAlign:"right",color:"#64748b"}},cl.length+"件")
                );
              }),
              E("tr",{style:{borderTop:"2px solid #991b1b",fontWeight:700,background:"#fee2e2"}},
                E("td",{style:{padding:"8px"}},"全車両合計"),
                COST_CATS.map(function(c){return E("td",{key:c.v,style:{padding:"8px",textAlign:"right",color:catColor(c.v),fontWeight:700}},"¥"+(yearCatTotals[c.v]||0).toLocaleString())}),
                E("td",{style:{padding:"8px",textAlign:"right",fontSize:14,fontWeight:800}},"¥"+allYearly.toLocaleString()),
                E("td",{style:{padding:"8px",textAlign:"right"}},allLogsYear.length+"件")
              )
            )
          )
        )
      ),

      // 月別推移（カテゴリ内訳付き）
      E("div",{style:{background:"#f8fafc",border:"1px solid #e2e8f0",borderRadius:8,padding:12}},
        E("div",{style:{fontSize:13,fontWeight:700,marginBottom:10}},"月別整備費（"+filterYear+"年）"),
        allMonthKeys.length>0?E("div",{style:{overflowX:"auto"}},
          E("table",{style:{width:"100%",borderCollapse:"collapse",fontSize:11,minWidth:500}},
            E("thead",null,E("tr",{style:{borderBottom:"2px solid #cbd5e1",background:"#f1f5f9"}},
              E("th",{style:{padding:"6px 8px",textAlign:"left",fontSize:12}},"月"),
              COST_CATS.map(function(c){return E("th",{key:c.v,style:{padding:"6px 8px",textAlign:"right",color:catColor(c.v),fontSize:11}},c.l)}),
              E("th",{style:{padding:"6px 8px",textAlign:"right",fontSize:12,fontWeight:800}},"月合計")
            )),
            E("tbody",null,
              allMonthKeys.map(function(ym){
                var md=monthCatData[ym];
                return E("tr",{key:ym,style:{borderBottom:"1px solid #e2e8f0"}},
                  E("td",{style:{padding:"6px 8px",fontWeight:600,fontSize:12}},ym),
                  COST_CATS.map(function(c){return E("td",{key:c.v,style:{padding:"6px 8px",textAlign:"right",color:(md[c.v]||0)>0?catColor(c.v):"#cbd5e1"}},(md[c.v]||0)>0?"¥"+(md[c.v]).toLocaleString():"-")}),
                  E("td",{style:{padding:"6px 8px",textAlign:"right",fontWeight:700,fontSize:13,color:"#991b1b"}},"¥"+(md.total||0).toLocaleString())
                );
              }),
              E("tr",{style:{borderTop:"2px solid #475569",fontWeight:700,background:"#e2e8f0"}},
                E("td",{style:{padding:"8px",fontSize:12}},"年間合計"),
                COST_CATS.map(function(c){return E("td",{key:c.v,style:{padding:"8px",textAlign:"right",color:catColor(c.v),fontWeight:700}},"¥"+(yearCatTotals[c.v]||0).toLocaleString())}),
                E("td",{style:{padding:"8px",textAlign:"right",fontSize:14,fontWeight:800,color:"#991b1b"}},"¥"+allYearly.toLocaleString())
              )
            )
          )
        ):E("div",{style:{textAlign:"center",color:"#94a3b8",padding:20,fontSize:12}},"まだ整備記録がありません")
      )
    );
  }

  // デフォルト（fallback）
  return E("div",{style:{maxWidth:1000,margin:"0 auto"}},msgPopup,nav,E("div",{style:{textAlign:"center",padding:40,color:"#94a3b8"}},"ビューを選択してください"));
}

/* ==========================================
   PASガード（パスコード認証）
   ========================================== */
function PASGuard({children,label}){
  const PAS_CODE="2318";
  // 毎回入力必須（セッション保持なし）
  const[unlocked,setUnlocked]=useState(false);
  const[input,setInput]=useState("");
  const[err,setErr]=useState("");
  const unlock=()=>{
    if(input===PAS_CODE){
      setUnlocked(true);setErr("");
    }else{setErr("パスコードが違います");setInput("");}
  };
  if(unlocked)return children;
  return <div style={{maxWidth:400,margin:"40px auto",textAlign:"center"}}>
    <div style={{background:"#fff",borderRadius:16,padding:32,border:"1px solid #e2e8f0",boxShadow:"0 2px 8px rgba(0,0,0,.06)"}}>
      <div style={{fontSize:32,marginBottom:12}}>🔒</div>
      <div style={{fontSize:16,fontWeight:800,color:"#1e293b",marginBottom:4}}>{label||"この画面はロックされています"}</div>
      <div style={{fontSize:12,color:"#64748b",marginBottom:20}}>閲覧にはパスコードが必要です</div>
      <input type="password" inputMode="numeric" maxLength={4} value={input} onChange={e=>setInput(e.target.value.replace(/\D/g,""))} onKeyDown={e=>e.key==="Enter"&&unlock()} placeholder="4桁のパスコード" style={{width:"100%",padding:"12px",border:"1.5px solid #d1d5db",borderRadius:10,fontSize:20,textAlign:"center",letterSpacing:8,boxSizing:"border-box",marginBottom:8}}/>
      {err&&<div style={{color:"#dc2626",fontSize:12,fontWeight:600,marginBottom:8}}>{err}</div>}
      <button onClick={unlock} disabled={input.length<4} style={{width:"100%",padding:"12px",background:input.length>=4?"linear-gradient(135deg,#1e40af,#2563eb)":"#94a3b8",color:"#fff",border:"none",borderRadius:10,fontSize:14,fontWeight:700,cursor:input.length>=4?"pointer":"not-allowed"}}>認証</button>
    </div>
  </div>;
}

/* ==========================================
   じゃらん決済確認
   ========================================== */
function JalanPayment({data,jalanPay,onJalanPayChange}){
  const[editId,setEditId]=useState(null);
  const[form,setForm]=useState({});
  const[sheetLoading,setSheetLoading]=useState(false);
  const jData=useMemo(()=>data.filter(r=>r.ota==="J").sort((a,b)=>(b.lendDate||"").localeCompare(a.lendDate||"")),[data]);
  // FIX-4: 他端末のじゃらん決済変更を反映（タブ復帰+30秒ポーリング）
  useEffect(()=>{
    const refresh=async()=>{try{const jp=await DB.fetchJalanPayment();if(jp&&Object.keys(jp).length){Object.entries(jp).forEach(([id,d])=>{if(JSON.stringify(jalanPay[id])!==JSON.stringify(d))onJalanPayChange(id,d);});}}catch(e){}};
    const onVis=()=>{if(document.visibilityState==="visible")refresh();};
    document.addEventListener("visibilitychange",onVis);
    const timer=setInterval(()=>{if(document.visibilityState==="visible")refresh();},30000);
    return()=>{document.removeEventListener("visibilitychange",onVis);clearInterval(timer);};
  },[]);
  const startEdit=(id)=>{setEditId(id);setForm(jalanPay[id]||{category:"売上",payStatus:"未完了",sendDate:"",refundDate:"",content:"",linkUrl:"",adjustedPrice:""});};
  const saveEdit=()=>{if(!editId)return;onJalanPayChange(editId,form);setEditId(null);};
  const cancelEdit=()=>{setEditId(null);setForm({});};
  const summary=useMemo(()=>{const done=jData.filter(r=>(jalanPay[r.id]?.payStatus)==="完了").length;return{total:jData.length,done,undone:jData.length-done};},[jData,jalanPay]);
  const cardS={background:"#fff",borderRadius:14,border:"1px solid #e2e8f0",boxShadow:"0 1px 3px rgba(0,0,0,.05)"};
  // ★ スプレッドシートから支払データを一括取得
  const fetchFromSheet=async()=>{
    const resIds=jData.map(r=>r.id);
    if(!resIds.length){alert("じゃらん予約がありません");return;}
    setSheetLoading(true);
    try{
      const payMap=await fetchJalanPaySheetData(resIds);
      const matched=Object.keys(payMap).length;
      if(!matched){setSheetLoading(false);alert("該当する予約番号がスプレッドシートに見つかりませんでした");return;}
      let updated=0;
      Object.entries(payMap).forEach(([rid,pd])=>{
        const existing=jalanPay[rid]||{};
        onJalanPayChange(rid,{...existing,adjustedPrice:pd.adjustedPrice,payStatus:pd.payStatus});
        updated++;
      });
      alert(`${matched}件中 ${updated}件の支払データを反映しました`);
    }catch(e){alert("取得エラー: "+e.message);}
    setSheetLoading(false);
  };

  return <div style={{maxWidth:800,margin:"0 auto"}}>
    <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:12}}>
      <h3 style={{fontSize:16,fontWeight:800,margin:0}}>じゃらん決済確認</h3>
      <div style={{display:"flex",gap:8,fontSize:11,fontWeight:700,alignItems:"center"}}>
        <button onClick={fetchFromSheet} disabled={sheetLoading} style={{padding:"4px 12px",borderRadius:8,background:sheetLoading?"#94a3b8":"#7c3aed",color:"#fff",border:"none",fontSize:11,fontWeight:700,cursor:sheetLoading?"not-allowed":"pointer"}}>{sheetLoading?"取得中...":"📊 スプレッドシート取得"}</button>
        <span style={{padding:"2px 10px",borderRadius:10,background:"#f0fdf4",color:"#059669"}}>完了 {summary.done}</span>
        <span style={{padding:"2px 10px",borderRadius:10,background:"#fef2f2",color:"#dc2626"}}>未完了 {summary.undone}</span>
      </div>
    </div>
    {jData.length===0&&<div style={{...cardS,padding:24,textAlign:"center",color:"#94a3b8",fontSize:13}}>じゃらんの予約データがありません</div>}
    {jData.length>0&&<div style={{...cardS,overflow:"hidden"}}>
      <div style={{overflowX:"auto"}}><table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
        <thead><tr style={{background:"#fdf2f8"}}>
          {["予約番号","予約者","貸出日","請求金額","差引請求金額","分類","支払確認","送付日","返金日","予約内容","リンク","操作"].map(h=><th key={h} style={{padding:"6px 8px",textAlign:"left",fontWeight:700,fontSize:10,color:"#9d174d",borderBottom:"2px solid #fbcfe8",whiteSpace:"nowrap"}}>{h}</th>)}
        </tr></thead>
        <tbody>{jData.map((r,ri)=>{
          const p=jalanPay[r.id]||{};
          const isDone=p.payStatus==="完了";
          const isEdit=editId===r.id;
          return <tr key={r.id} style={{background:isDone?"#f0fdf4":ri%2===0?"#fff":"#fafbfc",borderBottom:"1px solid #f1f5f9"}}>
            <td style={{padding:"4px 8px",fontFamily:"monospace",fontSize:9,fontWeight:600}}>{r.id}</td>
            <td style={{padding:"4px 8px",fontWeight:600}}>{r.name}</td>
            <td style={{padding:"4px 8px",fontSize:10,color:"#475569"}}>{r.lendDate||"-"}</td>
            <td style={{padding:"4px 8px",fontWeight:700,color:"#1e40af"}}>¥{(r.price||0).toLocaleString()}</td>
            {isEdit?<>
              <td style={{padding:"2px 4px"}}><input type="number" value={form.adjustedPrice||""} onChange={e=>setForm(f=>({...f,adjustedPrice:e.target.value}))} placeholder="金額" style={{fontSize:10,padding:"2px 4px",borderRadius:4,border:"1px solid #d1d5db",width:80}}/></td>
              <td style={{padding:"2px 4px"}}><select value={form.category||"売上"} onChange={e=>setForm(f=>({...f,category:e.target.value}))} style={{fontSize:10,padding:"2px 4px",borderRadius:4,border:"1px solid #d1d5db"}}><option>売上</option><option>立替</option></select></td>
              <td style={{padding:"2px 4px"}}><select value={form.payStatus||"未完了"} onChange={e=>setForm(f=>({...f,payStatus:e.target.value}))} style={{fontSize:10,padding:"2px 4px",borderRadius:4,border:"1px solid #d1d5db"}}><option>完了</option><option>未完了</option></select></td>
              <td style={{padding:"2px 4px"}}><input type="date" value={form.sendDate||""} onChange={e=>setForm(f=>({...f,sendDate:e.target.value}))} style={{fontSize:10,padding:"2px 4px",borderRadius:4,border:"1px solid #d1d5db",width:110}}/></td>
              <td style={{padding:"2px 4px"}}><input type="date" value={form.refundDate||""} onChange={e=>setForm(f=>({...f,refundDate:e.target.value}))} style={{fontSize:10,padding:"2px 4px",borderRadius:4,border:"1px solid #d1d5db",width:110}}/></td>
              <td style={{padding:"2px 4px"}}><input value={form.content||""} onChange={e=>setForm(f=>({...f,content:e.target.value}))} placeholder="予約内容" style={{fontSize:10,padding:"2px 4px",borderRadius:4,border:"1px solid #d1d5db",width:100}}/></td>
              <td style={{padding:"2px 4px"}}><input value={form.linkUrl||""} onChange={e=>setForm(f=>({...f,linkUrl:e.target.value}))} placeholder="URL" style={{fontSize:10,padding:"2px 4px",borderRadius:4,border:"1px solid #d1d5db",width:80}}/></td>
              <td style={{padding:"2px 4px",whiteSpace:"nowrap"}}><button onClick={saveEdit} style={{fontSize:10,padding:"2px 8px",borderRadius:4,border:"none",background:"#2563eb",color:"#fff",fontWeight:700,cursor:"pointer",marginRight:4}}>保存</button><button onClick={cancelEdit} style={{fontSize:10,padding:"2px 8px",borderRadius:4,border:"1px solid #d1d5db",background:"#fff",cursor:"pointer"}}>取消</button></td>
            </>:<>
              <td style={{padding:"4px 8px",fontWeight:700,color:p.adjustedPrice?"#7c3aed":"#94a3b8"}}>{p.adjustedPrice?("¥"+Number(p.adjustedPrice).toLocaleString()):"-"}</td>
              <td style={{padding:"4px 8px"}}><span style={{fontSize:10,fontWeight:600,padding:"1px 6px",borderRadius:4,background:p.category==="立替"?"#fef3c7":"#dbeafe",color:p.category==="立替"?"#92400e":"#1d4ed8"}}>{p.category||"売上"}</span></td>
              <td style={{padding:"4px 8px"}}><span style={{fontSize:10,fontWeight:700,padding:"1px 6px",borderRadius:4,background:isDone?"#dcfce7":"#fef2f2",color:isDone?"#166534":"#dc2626"}}>{isDone?"完了":"未完了"}</span></td>
              <td style={{padding:"4px 8px",fontSize:10,color:"#64748b"}}>{p.sendDate||"-"}</td>
              <td style={{padding:"4px 8px",fontSize:10,color:"#64748b"}}>{p.refundDate||"-"}</td>
              <td style={{padding:"4px 8px",fontSize:10,color:"#64748b",maxWidth:100,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{p.content||"-"}</td>
              <td style={{padding:"4px 8px",fontSize:10}}>{p.linkUrl?<a href={p.linkUrl} target="_blank" rel="noreferrer" style={{color:"#2563eb"}}>🔗</a>:"-"}</td>
              <td style={{padding:"4px 8px"}}><button onClick={()=>startEdit(r.id)} style={{fontSize:10,padding:"2px 8px",borderRadius:4,border:"1px solid #d1d5db",background:"#fff",cursor:"pointer",fontWeight:600}}>編集</button></td>
            </>}
          </tr>;
        })}</tbody>
      </table></div>
    </div>}
  </div>;
}

/* ==========================================
   スタッフ管理
   ========================================== */
function StaffManager({staff,onStaffChange,onDeleteStaff}){
  const[editId,setEditId]=useState(null);
  const[form,setForm]=useState({name:"",type:"アルバイト",memo:"",hourlyWage:1100,transportCost:500,monthlySalary:0});
  const[adding,setAdding]=useState(false);
  const[editOrigName,setEditOrigName]=useState("");

  const save=()=>{
    if(!form.name.trim())return;
    if(!window.confirm(adding?"新規登録を実行しますか？":"変更を保存しますか？"))return;
    const entry={name:form.name.trim(),type:form.type,memo:form.memo,hourlyWage:Number(form.hourlyWage)||0,transportCost:Number(form.transportCost)||0,monthlySalary:Number(form.monthlySalary)||0};
    if(adding){
      onStaffChange([...staff,entry]);setAdding(false);
    }else if(editId!==null){
      const oldName=editOrigName;
      const updated=[...staff];updated[editId]=entry;
      onStaffChange(updated);
      if(oldName&&oldName!==entry.name&&onDeleteStaff)onDeleteStaff(oldName);
      setEditId(null);setEditOrigName("");
    }
    setForm({name:"",type:"アルバイト",memo:"",hourlyWage:1100,transportCost:500,monthlySalary:0});
  };

  const startEdit=(i)=>{setEditId(i);setEditOrigName(staff[i].name);setForm({...staff[i]});setAdding(false);};
  const startAdd=()=>{setForm({name:"",type:"アルバイト",memo:"",hourlyWage:1100,transportCost:500,monthlySalary:0});setAdding(true);setEditId(null);};
  const remove=(i)=>{if(window.confirm(`${staff[i].name} を削除しますか？`)){const name=staff[i].name;onStaffChange(staff.filter((_,j)=>j!==i));if(onDeleteStaff)onDeleteStaff(name);}};
  const cancel=()=>{setAdding(false);setEditId(null);setForm({name:"",type:"アルバイト",memo:"",hourlyWage:1100,transportCost:500,monthlySalary:0});};

  const showModal=adding||editId!==null;
  const cardS={background:"#fff",borderRadius:14,padding:16,border:"1px solid #e2e8f0",marginBottom:10,boxShadow:"0 1px 3px rgba(0,0,0,.05)"};
  const fmtCur=n=>n?("¥"+Number(n).toLocaleString()):"¥0";

  return <div style={{maxWidth:640,margin:"0 auto"}}>
    <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:14}}>
      <h3 style={{fontSize:16,fontWeight:800,margin:0}}>スタッフ ({staff.length})</h3>
      <button onClick={startAdd} style={{padding:"6px 14px",borderRadius:8,background:"#2563eb",color:"#fff",border:"none",fontSize:12,fontWeight:700,cursor:"pointer"}}>＋ 追加</button>
    </div>

    {staff.map((s,i)=>{
      const isP=s.type==="アルバイト";const isR=s.type==="正社員";
      return <div key={i} style={cardS}>
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:8}}>
          <div style={{display:"flex",alignItems:"center",gap:8}}>
            <span style={{fontSize:15,fontWeight:800}}>{s.name}</span>
            <span style={{fontSize:10,fontWeight:700,padding:"2px 10px",borderRadius:12,background:isP?"#fef3c7":"#dbeafe",color:isP?"#92400e":"#1d4ed8"}}>{s.type}</span>
          </div>
          <div style={{display:"flex",gap:8}}>
            <span onClick={()=>startEdit(i)} style={{fontSize:12,color:"#2563eb",fontWeight:600,cursor:"pointer"}}>編集</span>
            <span onClick={()=>remove(i)} style={{fontSize:12,color:"#dc2626",fontWeight:600,cursor:"pointer"}}>削除</span>
          </div>
        </div>
        {isP&&<div style={{fontSize:13,color:"#374151"}}>
          <div style={{display:"flex",justifyContent:"space-between",padding:"4px 0",borderBottom:"1px solid #f1f5f9"}}>
            <span style={{color:"#64748b"}}>時給</span><span style={{fontWeight:700}}>{fmtCur(s.hourlyWage)}</span>
          </div>
          <div style={{display:"flex",justifyContent:"space-between",padding:"4px 0"}}>
            <span style={{color:"#64748b"}}>交通費 / 回</span><span style={{fontWeight:700}}>{fmtCur(s.transportCost)}</span>
          </div>
        </div>}
        {isR&&<div style={{fontSize:13,color:"#374151"}}>
          <div style={{display:"flex",justifyContent:"space-between",padding:"4px 0",borderBottom:"1px solid #f1f5f9"}}>
            <span style={{color:"#64748b"}}>月給</span><span style={{fontWeight:700}}>{fmtCur(s.monthlySalary)}</span>
          </div>
          <div style={{display:"flex",justifyContent:"space-between",padding:"4px 0"}}>
            <span style={{color:"#64748b"}}>交通費 / 回</span><span style={{fontWeight:700}}>{fmtCur(s.transportCost)}</span>
          </div>
        </div>}
      </div>;
    })}

    {/* 編集・追加モーダル */}
    {showModal&&<div className="modal-overlay" onClick={cancel}><div className="modal-box" style={{maxWidth:380,padding:24}} onClick={e=>e.stopPropagation()}>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:16}}>
        <h4 style={{fontSize:16,fontWeight:800,margin:0}}>{adding?"スタッフ追加":"スタッフ編集"}</h4>
        <button onClick={cancel} style={{background:"none",border:"none",fontSize:18,color:"#94a3b8",cursor:"pointer"}}>✕</button>
      </div>
      <div style={{marginBottom:12}}>
        <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:4}}>氏名</label>
        <input value={form.name} onChange={e=>setForm(p=>({...p,name:e.target.value}))} placeholder="名前を入力" style={{width:"100%",padding:"10px 12px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:14,boxSizing:"border-box"}} autoFocus/>
      </div>
      <div style={{marginBottom:12}}>
        <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:4}}>雇用形態</label>
        <select value={form.type} onChange={e=>setForm(p=>({...p,type:e.target.value}))} style={{width:"100%",padding:"10px 12px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:14,background:"#fff"}}>
          <option>アルバイト</option><option>正社員</option>
        </select>
      </div>
      {form.type==="アルバイト"&&<>
        <div style={{marginBottom:12}}>
          <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:4}}>時給(¥)</label>
          <input type="number" value={form.hourlyWage||""} onChange={e=>setForm(p=>({...p,hourlyWage:e.target.value}))} placeholder="1100" style={{width:"100%",padding:"10px 12px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:14,boxSizing:"border-box"}}/>
        </div>
        <div style={{marginBottom:12}}>
          <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:4}}>交通費/回(¥)</label>
          <input type="number" value={form.transportCost||""} onChange={e=>setForm(p=>({...p,transportCost:e.target.value}))} placeholder="500" style={{width:"100%",padding:"10px 12px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:14,boxSizing:"border-box"}}/>
        </div>
      </>}
      {form.type==="正社員"&&<>
        <div style={{marginBottom:12}}>
          <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:4}}>月給(¥)</label>
          <input type="number" value={form.monthlySalary||""} onChange={e=>setForm(p=>({...p,monthlySalary:e.target.value}))} placeholder="280000" style={{width:"100%",padding:"10px 12px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:14,boxSizing:"border-box"}}/>
        </div>
        <div style={{marginBottom:12}}>
          <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:4}}>交通費/回(¥)</label>
          <input type="number" value={form.transportCost||""} onChange={e=>setForm(p=>({...p,transportCost:e.target.value}))} placeholder="0" style={{width:"100%",padding:"10px 12px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:14,boxSizing:"border-box"}}/>
        </div>
      </>}
      {/* 削除ボタン（編集時のみ） */}
      {editId!==null&&<button onClick={()=>{remove(editId);cancel();}} style={{width:"100%",padding:"10px",borderRadius:10,border:"none",background:"#fef2f2",color:"#dc2626",fontSize:13,fontWeight:700,cursor:"pointer",marginBottom:12}}>この登録を削除</button>}
      <div style={{display:"flex",gap:8}}>
        <button onClick={cancel} style={{flex:"0 0 auto",padding:"10px 16px",borderRadius:10,border:"1px solid #e2e8f0",background:"#fff",fontSize:13,fontWeight:600,color:"#64748b",cursor:"pointer"}}>キャンセル</button>
        <button onClick={save} disabled={!form.name.trim()} style={{flex:1,padding:"10px 16px",borderRadius:10,border:"none",background:form.name.trim()?"#2563eb":"#94a3b8",fontSize:13,fontWeight:700,color:"#fff",cursor:form.name.trim()?"pointer":"not-allowed"}}>保存</button>
      </div>
    </div></div>}
  </div>;
}

/* ==========================================
   申し送りBOX
   ========================================== */
function MemoBox({today}){
  const tomorrow=dOff(today,1);
  const[memos,setMemos]=React.useState([]);
  const[text,setText]=React.useState("");
  const[posting,setPosting]=React.useState(false);
  const[open,setOpen]=React.useState(false);
  const[listOpen,setListOpen]=React.useState(false);
  const[editId,setEditId]=React.useState(null);
  const[editText,setEditText]=React.useState("");
  const[imgPreview,setImgPreview]=React.useState("");
  const[imgFile,setImgFile]=React.useState(null);
  const[imgUploading,setImgUploading]=React.useState(false);
  const[lightbox,setLightbox]=React.useState("");
  const fileRef=React.useRef(null);
  const chRef=React.useRef(null);
  const load=()=>DB.fetchMemos(today).then(d=>setMemos(d||[])).catch(()=>{});
  React.useEffect(()=>{
    load();
    if(sb){chRef.current=sb.channel("spk-memos-top").on("postgres_changes",{event:"*",schema:"public",table:"spk_memos"},load).subscribe();}
    const iv=setInterval(load,30000);
    return()=>{clearInterval(iv);if(chRef.current)sb.removeChannel(chRef.current);};
  },[today]);
  const selectImg=(e)=>{
    const f=e.target.files[0];if(!f)return;
    setImgFile(f);
    const r=new FileReader();r.onload=(ev)=>setImgPreview(ev.target.result);r.readAsDataURL(f);
    e.target.value="";
  };
  const clearImg=()=>{setImgFile(null);setImgPreview("");};
  const post=async()=>{
    if(!text.trim()&&!imgFile)return;
    setPosting(true);
    let uploadedUrl="";
    if(imgFile){
      setImgUploading(true);
      try{uploadedUrl=await DB.uploadMemoImage(imgFile);}
      catch(e){alert("画像アップロード失敗: "+e.message);setImgUploading(false);setPosting(false);return;}
      setImgUploading(false);
    }
    await DB.postMemo(text.trim(),tomorrow,uploadedUrl).catch(()=>{});
    setText("");clearImg();setPosting(false);load();
  };
  const toggle=(id,done)=>DB.toggleMemoDone(id,done).then(load).catch(()=>{});
  const del=(id)=>{if(!window.confirm("削除しますか？"))return;DB.deleteMemo(id).then(load).catch(()=>{});};
  const startEdit=(m)=>{setEditId(m.id);setEditText(m.content);};
  const saveEdit=async(id)=>{if(!editText.trim())return;await sb.from("spk_memos").update({content:editText.trim()}).eq("id",id).catch(()=>{});setEditId(null);setEditText("");load();};
  const cancelEdit=()=>{setEditId(null);setEditText("");};
  const todayList=memos.filter(m=>m.target_date===today);
  const tomList=memos.filter(m=>m.target_date===tomorrow);
  const todayUndone=todayList.filter(m=>!m.done);
  const tomUndone=tomList.filter(m=>!m.done);
  const MemoRow=({m,redStyle})=>{
    const isEditing=editId===m.id;
    if(isEditing)return(
      <div style={{marginBottom:4,padding:"7px 10px",borderRadius:8,background:"#fffbeb",border:"2px solid #f59e0b"}}>
        <textarea value={editText} onChange={e=>setEditText(e.target.value)} rows={3}
          style={{width:"100%",border:"1px solid #fde68a",borderRadius:6,padding:"6px 8px",fontSize:12,background:"#fff",outline:"none",resize:"vertical",boxSizing:"border-box"}}/>
        <div style={{display:"flex",gap:6,marginTop:5,justifyContent:"flex-end"}}>
          <button onClick={cancelEdit} style={{fontSize:10,padding:"3px 10px",borderRadius:6,border:"1px solid #d1d5db",background:"#fff",cursor:"pointer",color:"#6b7280"}}>キャンセル</button>
          <button onClick={()=>saveEdit(m.id)} disabled={!editText.trim()} style={{fontSize:10,padding:"3px 10px",borderRadius:6,border:"none",background:"#f59e0b",color:"#fff",fontWeight:700,cursor:"pointer"}}>保存</button>
        </div>
      </div>
    );
    return(
      <div style={{display:"flex",gap:6,alignItems:"flex-start",padding:"6px 10px",borderRadius:8,
        background:m.done?"#f9fafb":redStyle?"#fef2f2":"#fffbeb",
        border:"1px solid "+(m.done?"#e5e7eb":redStyle?"#fecaca":"#fde68a"),
        marginBottom:4,opacity:m.done?0.5:1}}>
        <span style={{fontSize:12,flexShrink:0,marginTop:1}}>{m.done?"✅":redStyle?"🔴":"📌"}</span>
        <div style={{flex:1,minWidth:0}}>
          <div style={{fontSize:12,fontWeight:m.done?400:600,color:m.done?"#9ca3af":redStyle?"#7f1d1d":"#1c1917",
            lineHeight:1.4,wordBreak:"break-all",textDecoration:m.done?"line-through":"none",whiteSpace:"pre-wrap"}}>{m.content}</div>
          {m.image_url&&<img src={m.image_url} onClick={()=>setLightbox(m.image_url)}
            style={{marginTop:5,maxWidth:"100%",maxHeight:120,borderRadius:6,cursor:"pointer",objectFit:"cover",opacity:m.done?0.5:1}}
            alt="添付画像"/>}
        </div>
        <div style={{display:"flex",gap:3,flexShrink:0,alignSelf:"flex-start"}}>
          {!m.done&&<button onClick={()=>startEdit(m)} style={{fontSize:9,padding:"2px 6px",borderRadius:6,border:"1px solid #d1d5db",background:"#fff",cursor:"pointer",color:"#6b7280"}}>✏️</button>}
          <button onClick={()=>toggle(m.id,m.done)} style={{fontSize:9,padding:"2px 7px",borderRadius:6,
            border:"1px solid "+(m.done?"#d1d5db":redStyle?"#fecaca":"#fde68a"),
            background:"#fff",cursor:"pointer",color:m.done?"#6b7280":redStyle?"#dc2626":"#92400e",whiteSpace:"nowrap"}}>
            {m.done?"戻す":"済み"}
          </button>
          <button onClick={()=>del(m.id)} style={{fontSize:9,padding:"2px 5px",borderRadius:6,border:"1px solid #e5e7eb",background:"#f9fafb",cursor:"pointer",color:"#9ca3af"}}>✕</button>
        </div>
      </div>
    );
  };
  return(
    <div style={{marginBottom:16}}>
      {/* ライトボックス */}
      {lightbox&&<div onClick={()=>setLightbox("")} style={{position:"fixed",inset:0,background:"rgba(0,0,0,.85)",zIndex:9999,display:"flex",alignItems:"center",justifyContent:"center",padding:16}}>
        <img src={lightbox} style={{maxWidth:"100%",maxHeight:"90vh",borderRadius:8,objectFit:"contain"}} alt="拡大"/>
        <button onClick={()=>setLightbox("")} style={{position:"absolute",top:16,right:16,background:"rgba(255,255,255,.2)",border:"none",color:"#fff",borderRadius:99,width:32,height:32,fontSize:16,cursor:"pointer"}}>✕</button>
      </div>}
      {todayUndone.length>0&&(
        <div style={{marginBottom:8,padding:"10px 12px",borderRadius:12,background:"#fef2f2",border:"2px solid #fecaca"}}>
          <div style={{fontSize:10,fontWeight:800,color:"#dc2626",marginBottom:6}}>🔴 本日の Handover（未対応）</div>
          {todayUndone.map(m=><MemoRow key={m.id} m={m} redStyle={true}/>)}
        </div>
      )}
      <div style={{marginBottom:8,borderRadius:12,border:"1px solid #e2e8f0",background:"#fff",overflow:"hidden",boxShadow:"0 1px 3px rgba(0,0,0,.05)"}}>
        <div onClick={()=>setOpen(o=>!o)} style={{background:"#f8fafc",padding:"10px 14px",display:"flex",alignItems:"center",gap:8,cursor:"pointer",userSelect:"none"}}>
          <span style={{fontSize:16}}>✏️</span>
          <span style={{fontSize:13,fontWeight:700,color:"#1e293b"}}>Handover を書く</span>
          <span style={{marginLeft:"auto",fontSize:11,color:"#94a3b8",fontWeight:700}}>{open?"▲":"▼"}</span>
        </div>
        {open&&<div style={{padding:"10px 12px",borderTop:"1px solid #e2e8f0"}}>
          <textarea value={text} onChange={e=>setText(e.target.value)} rows={3}
            placeholder={"例：216決済必要\n明日コーナン買い出し\n山田さん10時出勤変更"}
            style={{width:"100%",border:"1px solid #e2e8f0",borderRadius:8,padding:"8px 10px",fontSize:12,background:"#fff",outline:"none",resize:"vertical",boxSizing:"border-box",marginBottom:6}}/>
          {/* 画像プレビュー */}
          {imgPreview&&<div style={{position:"relative",display:"inline-block",marginBottom:8}}>
            <img src={imgPreview} style={{maxHeight:100,maxWidth:"100%",borderRadius:6,objectFit:"cover"}} alt="preview"/>
            <button onClick={clearImg} style={{position:"absolute",top:-6,right:-6,width:18,height:18,borderRadius:99,background:"#ef4444",border:"none",color:"#fff",fontSize:10,cursor:"pointer",display:"flex",alignItems:"center",justifyContent:"center",lineHeight:1}}>✕</button>
          </div>}
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center"}}>
            <div>
              <input ref={fileRef} type="file" accept="image/*" onChange={selectImg} style={{display:"none"}}/>
              <button onClick={()=>fileRef.current.click()} style={{fontSize:11,padding:"5px 10px",borderRadius:8,border:"1px solid #d1d5db",background:"#fff",cursor:"pointer",color:"#6b7280",display:"flex",alignItems:"center",gap:4}}>
                📷 {imgFile?"変更":"写真を添付"}
              </button>
            </div>
            <button onClick={post} disabled={(!text.trim()&&!imgFile)||posting}
              style={{padding:"7px 18px",borderRadius:8,border:"none",
                background:(text.trim()||imgFile)?"#f59e0b":"#d1d5db",
                color:"#fff",fontWeight:700,fontSize:12,cursor:(text.trim()||imgFile)?"pointer":"default"}}>
              {imgUploading?"アップロード中...":posting?"投稿中...":"投稿"}
            </button>
          </div>
        </div>}
      </div>
      {tomList.length>0&&<div style={{marginBottom:8,borderRadius:12,border:"1px solid #e2e8f0",background:"#fff",overflow:"hidden",boxShadow:"0 1px 3px rgba(0,0,0,.05)"}}>
        <div onClick={()=>setListOpen(o=>!o)} style={{background:"#f8fafc",padding:"10px 14px",display:"flex",alignItems:"center",gap:8,cursor:"pointer",userSelect:"none"}}>
          <span style={{fontSize:14}}>📌</span>
          <span style={{fontSize:13,fontWeight:700,color:"#1e293b"}}>明日の Handover</span>
          <span style={{marginLeft:"auto",display:"flex",alignItems:"center",gap:6}}>
            <span style={{background:"#f59e0b",color:"#fff",borderRadius:99,fontSize:9,fontWeight:700,padding:"2px 8px"}}>{tomList.length}件</span>
            <span style={{fontSize:11,color:"#94a3b8",fontWeight:700}}>{listOpen?"▲":"▼"}</span>
          </span>
        </div>
        {listOpen&&<div style={{padding:"8px 12px",borderTop:"1px solid #e2e8f0"}}>
          {tomList.map(m=><MemoRow key={m.id} m={m} redStyle={false}/>)}
        </div>}
      </div>}
    </div>
  );
}
function PunchClock({staff}){
  const partTime=staff.filter(s=>s.type==="アルバイト");
  const [selName,setSelName]=React.useState("");
  const [punch,setPunch]=React.useState(null);
  const [loading,setLoading]=React.useState(false);
  const [msg,setMsg]=React.useState(null);
  const getNowHHMM=()=>new Date().toLocaleTimeString("ja-JP",{hour:"2-digit",minute:"2-digit",hour12:false,timeZone:"Asia/Tokyo"});
  const origTimeRef=React.useRef("");
  const [inputTime,setInputTime]=React.useState(getNowHHMM);
  const isModified=inputTime!==origTimeRef.current&&origTimeRef.current!=="";

  React.useEffect(()=>{
    if(!selName)return;
    setPunch(null);setMsg(null);
    const t=getNowHHMM();origTimeRef.current=t;setInputTime(t);
    DB.getTodayPunch(selName).then(p=>setPunch(p||{start:"",end:"",approved:false}));
  },[selName]);

  const doAction=async(type)=>{
    if(!selName)return;
    setLoading(true);setMsg(null);
    const nowActual=getNowHHMM();
    try{
      if(type==="in") await DB.punchIn(selName,inputTime,isModified);
      else await DB.punchOut(selName,inputTime,isModified);
      if(isModified) await DB.sendPunchSlack("札幌",selName,type,inputTime,nowActual);
      const p=await DB.getTodayPunch(selName);
      setPunch(p||{start:"",end:"",approved:false});
      setMsg({text:isModified?`仮申請しました（${inputTime}）管理者が確認後に受領されます`:(type==="in"?`出勤打刻しました（${inputTime}）`:`退勤打刻しました（${inputTime}）`),ok:true});
    }catch(e){
      setMsg({text:e.message||"エラーが発生しました",ok:false});
    }finally{setLoading(false);}
  };

  const today=new Date().toLocaleDateString("ja-JP",{month:"long",day:"numeric",weekday:"short",timeZone:"Asia/Tokyo"});
  const hasPunchIn=punch&&punch.start;
  const hasPunchOut=punch&&punch.end;

  return <div style={{maxWidth:400,margin:"0 auto",padding:"24px 16px"}}>
    <div style={{textAlign:"center",marginBottom:24}}>
      <div style={{fontSize:13,color:"#94a3b8",fontWeight:600}}>{today}</div>
      <div style={{fontSize:28,fontWeight:900,color:"#1e293b",marginTop:4}}>出退勤 打刻</div>
      <div style={{fontSize:11,color:"#94a3b8",marginTop:4}}>自己申告制・自動受領</div>
    </div>
    <div style={{marginBottom:20}}>
      <div style={{fontSize:12,fontWeight:700,color:"#64748b",marginBottom:8}}>名前を選択</div>
      <div style={{display:"flex",gap:8,flexWrap:"wrap"}}>
        {partTime.map(s=><button key={s.name} onClick={()=>setSelName(s.name)} style={{
          padding:"10px 18px",borderRadius:24,fontSize:13,fontWeight:700,border:"2px solid",cursor:"pointer",transition:"all .15s",
          borderColor:selName===s.name?"#2563eb":"#e2e8f0",
          background:selName===s.name?"#2563eb":"#fff",
          color:selName===s.name?"#fff":"#374151"
        }}>{s.name}</button>)}
      </div>
    </div>
    {selName&&punch&&<div style={{background:"#f8fafc",borderRadius:14,padding:16,marginBottom:20,border:"1px solid #e2e8f0"}}>
      <div style={{fontSize:12,fontWeight:700,color:"#64748b",marginBottom:10}}>{selName} さんの本日の打刻</div>
      <div style={{display:"flex",gap:12}}>
        <div style={{flex:1,textAlign:"center",background:hasPunchIn?"#dcfce7":"#f1f5f9",borderRadius:10,padding:"10px 8px"}}>
          <div style={{fontSize:10,color:"#64748b",fontWeight:600,marginBottom:4}}>出勤</div>
          <div style={{fontSize:hasPunchIn?20:14,fontWeight:800,color:hasPunchIn?"#059669":"#cbd5e1"}}>{hasPunchIn?punch.start:"--:--"}</div>
        </div>
        <div style={{flex:1,textAlign:"center",background:hasPunchOut?"#fee2e2":"#f1f5f9",borderRadius:10,padding:"10px 8px"}}>
          <div style={{fontSize:10,color:"#64748b",fontWeight:600,marginBottom:4}}>退勤</div>
          <div style={{fontSize:hasPunchOut?20:14,fontWeight:800,color:hasPunchOut?"#dc2626":"#cbd5e1"}}>{hasPunchOut?punch.end:"--:--"}</div>
        </div>
      </div>
      {punch.approved&&<div style={{textAlign:"center",marginTop:10,fontSize:11,color:"#059669",fontWeight:700}}>✅ 受領済（自己申告）</div>}
      {!punch.approved&&(punch.start||punch.end)&&<div style={{textAlign:"center",marginTop:10,fontSize:11,color:"#d97706",fontWeight:700}}>🕐 申請中（管理者確認待ち）</div>}
    </div>}
    {selName&&punch&&!(hasPunchIn&&hasPunchOut)&&<div style={{marginBottom:16,background:isModified?"#fffbeb":"#f8fafc",borderRadius:12,padding:"12px 14px",border:`1px solid ${isModified?"#fcd34d":"#e2e8f0"}`,transition:"all .2s"}}>
      <div style={{fontSize:11,fontWeight:700,color:isModified?"#92400e":"#64748b",marginBottom:6}}>{isModified?"⚠️ 時刻を変更中 → 仮申請になります":"⏰ 打刻時刻"}</div>
      <input type="time" value={inputTime} onChange={e=>setInputTime(e.target.value)} style={{
        width:"100%",padding:"10px 12px",fontSize:20,fontWeight:800,
        border:`2px solid ${isModified?"#f59e0b":"#cbd5e1"}`,borderRadius:10,
        color:isModified?"#92400e":"#1e293b",background:"#fff",textAlign:"center",cursor:"pointer"
      }}/>
      {isModified&&<div style={{fontSize:10,color:"#d97706",textAlign:"center",marginTop:4,fontWeight:700}}>管理者の承認後に受領済になります</div>}
    </div>}
    {selName&&punch&&<div style={{display:"flex",gap:12,flexDirection:"column"}}>
      {!hasPunchIn&&<button onClick={()=>doAction("in")} disabled={loading} style={{
        padding:"20px",borderRadius:16,fontSize:18,fontWeight:900,border:"none",cursor:loading?"wait":"pointer",
        background:isModified?"linear-gradient(135deg,#d97706,#f59e0b)":"linear-gradient(135deg,#059669,#10b981)",color:"#fff",
        boxShadow:isModified?"0 4px 14px rgba(217,119,6,.3)":"0 4px 14px rgba(5,150,105,.3)",opacity:loading?.6:1,transition:"all .2s"
      }}>{isModified?"🟡 出勤申請（仮）":"🟢 出勤打刻"}</button>}
      {hasPunchIn&&!hasPunchOut&&<button onClick={()=>doAction("out")} disabled={loading} style={{
        padding:"20px",borderRadius:16,fontSize:18,fontWeight:900,border:"none",cursor:loading?"wait":"pointer",
        background:isModified?"linear-gradient(135deg,#d97706,#f59e0b)":"linear-gradient(135deg,#dc2626,#ef4444)",color:"#fff",
        boxShadow:isModified?"0 4px 14px rgba(217,119,6,.3)":"0 4px 14px rgba(220,38,38,.3)",opacity:loading?.6:1,transition:"all .2s"
      }}>{isModified?"🟡 退勤申請（仮）":"🔴 退勤打刻"}</button>}
      {hasPunchIn&&hasPunchOut&&<div style={{textAlign:"center",padding:16,background:"#f0fdf4",borderRadius:14,border:"2px solid #bbf7d0"}}>
        <div style={{fontSize:16,fontWeight:800,color:"#059669"}}>✅ 本日の打刻完了</div>
        <div style={{fontSize:12,color:"#64748b",marginTop:4}}>{punch.start} 〜 {punch.end}</div>
      </div>}
    </div>}
    {msg&&<div style={{marginTop:16,padding:"12px 16px",borderRadius:10,fontSize:13,fontWeight:700,
      background:msg.ok?"#f0fdf4":"#fef2f2",color:msg.ok?"#059669":"#dc2626",
      border:`1px solid ${msg.ok?"#bbf7d0":"#fecaca"}`}}>{msg.text}</div>}
    {!selName&&<div style={{textAlign:"center",color:"#94a3b8",fontSize:13,marginTop:24}}>名前を選択してください</div>}
  </div>;
}

/* ==========================================
   勤怠管理
   ========================================== */
function AttendanceManager({shifts,staff,today,attendance,onAttendanceChange}){
  const WK=["日","月","火","水","木","金","土"];
  const todayYM=toYM(today);
  const[viewYM,setViewYM]=useState(todayYM);
  const[selStaff,setSelStaff]=useState(staff[0]?.name||"");
  const[subTab,setSubTab]=useState("budget"); // "budget" | "actual" | "detail"
  const[editDay,setEditDay]=useState(null);
  const[staffFilter,setStaffFilter]=useState("all"); // "all"|"part"|"full"
  const dim=daysInMonth(viewYM);
  const[vy,vmo]=viewYM.split("-").map(Number);

  const[syncing,setSyncing]=useState(false);
  const[lastSync,setLastSync]=useState(null);

  // マウント時＋手動同期: DBから最新のシフト＋勤怠を再取得
  const forceSync=React.useCallback(async()=>{
    setSyncing(true);
    try{
      const[shDB,attDB]=await Promise.all([DB.fetchShifts(),DB.fetchAttendance()]);
      if(shDB){
        // 親のshiftsを直接更新（setShiftsSync相当）
        window.__spkForceShifts&&window.__spkForceShifts(shDB);
      }
      if(attDB)onAttendanceChange(attDB);
      setLastSync(new Date());
    }catch(e){console.error("[forceSync]",e);}
    setSyncing(false);
  },[onAttendanceChange]);

  React.useEffect(()=>{forceSync();},[]);

  // 実働時間計算ヘルパー
  const calcHours=(start,end)=>{
    if(!start||!end)return 0;
    const[sh,sm]=start.split(":").map(Number);
    const[eh,em]=end.split(":").map(Number);
    const diff=(eh*60+em)-(sh*60+sm);
    return diff>0?Math.round(diff/60*10)/10:0;
  };

  // 全スタッフの月間データ生成
  const allStaffData=useMemo(()=>{
    const result={};
    staff.forEach(s=>{
      const days=[];
      for(let d=1;d<=dim;d++){
        const ds=viewYM+"-"+String(d).padStart(2,"0");
        const dow=new Date(vy,vmo-1,d).getDay();
        const sh=(shifts[ds]||[]).find(x=>x.name===s.name);
        const attKey=ds+"_"+s.name;
        const att=attendance[attKey]||null;
        days.push({date:ds,day:d,dow,shift:sh,att});
      }
      // 予算（シフトベース）
      let budgetDays=0,budgetHours=0;
      days.forEach(d=>{
        if(d.shift&&d.shift.symbol!=="公"&&d.shift.symbol!=="希"&&d.shift.symbol!=="有"){
          budgetDays++;budgetHours+=calcHours(d.shift.start||"09:00",d.shift.end||"18:00");
        }
      });
      const isP=s.type==="アルバイト";
      const budgetWage=isP?(s.hourlyWage||0)*budgetHours:(s.monthlySalary||0);
      const budgetTransport=(s.transportCost||0)*budgetDays;
      // 実績（勤怠承認ベース）— 欠勤は出勤0扱い
      let actualDays=0,actualHours=0,absentDays=0;
      days.forEach(d=>{
        if(d.att&&d.att.approved){
          if(d.att.absent){absentDays++;return;}
          if(d.att.memo&&d.att.memo.startsWith("協議中"))return; // 協議中はカウントしない
          actualDays++;actualHours+=calcHours(d.att.start,d.att.end);
        }
      });
      const actualWage=isP?(s.hourlyWage||0)*actualHours:(s.monthlySalary||0);
      const actualTransport=(s.transportCost||0)*actualDays;
      result[s.name]={days,budgetDays,budgetHours,budgetWage:Math.round(budgetWage),budgetTransport,budgetTotal:Math.round(budgetWage)+budgetTransport,
        actualDays,actualHours,actualWage:Math.round(actualWage),actualTransport,actualTotal:Math.round(actualWage)+actualTransport,isP,absentDays};
    });
    return result;
  },[staff,shifts,attendance,viewYM,dim,vy,vmo]);

  // シフトから勤怠レコード自動生成（シフト変更時にも反映）
  // 注意: attendanceをrefで参照し、依存配列に入れないことで無限ループを防止
  const genAttFromShifts=React.useCallback((curAtt)=>{
    const toCreate=[];
    const toUpdate=[];
    staff.forEach(s=>{
      for(let d=1;d<=dim;d++){
        const ds=viewYM+"-"+String(d).padStart(2,"0");
        const sh=(shifts[ds]||[]).find(x=>x.name===s.name);
        const attKey=ds+"_"+s.name;
        const att=curAtt[attKey]||null;
        if(sh&&!att){
          toCreate.push({date:ds,name:s.name,start:sh.start||"09:00",end:sh.end||"18:00",approved:false,memo:""});
        }else if(sh&&att&&!att.approved){
          const newStart=sh.start||"09:00";const newEnd=sh.end||"18:00";
          if(att.start!==newStart||att.end!==newEnd){
            toUpdate.push({...att,start:newStart,end:newEnd});
          }
        }
      }
    });
    if(toCreate.length>0||toUpdate.length>0){
      const next={...curAtt};
      toCreate.forEach(r=>{next[r.date+"_"+r.name]=r;});
      toUpdate.forEach(r=>{next[r.date+"_"+r.name]=r;});
      onAttendanceChange(next);
      if(toCreate.length>0)DB.saveAttendanceBatch(toCreate).catch(e=>console.error("[genAtt] create error:",e));
      if(toUpdate.length>0)DB.saveAttendanceBatch(toUpdate).catch(e=>console.error("[genAtt] update error:",e));
    }
  },[shifts,staff,viewYM,dim,onAttendanceChange]);
  // shiftsが変わったら最新のattendanceで自動生成を実行
  React.useEffect(()=>{genAttFromShifts(attendance);},[shifts,viewYM]);

  const approve=async(date,name)=>{
    if(!window.confirm("受領を実行しますか？"))return;
    const key=date+"_"+name;const cur=attendance[key];if(!cur)return;
    const updated={...cur,approved:true};
    onAttendanceChange({...attendance,[key]:updated});
    try{await DB.saveAttendance(updated);}catch(e){console.error("[approve] save error:",e);}
  };
  const approveAll=async(name)=>{
    if(!window.confirm("全受領を実行しますか？"))return;
    const d=allStaffData[name];if(!d)return;
    const next={...attendance};const batch=[];
    d.days.forEach(day=>{
      if(day.att&&!day.att.approved){
        const key=day.date+"_"+name;
        const updated={...day.att,approved:true};
        next[key]=updated;batch.push(updated);
      }
    });
    onAttendanceChange(next);if(batch.length)try{await DB.saveAttendanceBatch(batch);}catch(e){console.error("[approveAll] save error:",e);}
  };
  const saveEdit=async()=>{
    if(!editDay)return;
    if(!window.confirm("保存を実行しますか？"))return;
    const key=editDay.date+"_"+editDay.name;
    const origMemo=attendance[key]?.memo||"";
    const isKyogi=origMemo.startsWith("協議中");
    const memo=isKyogi?"打刻":(editDay.memo||"");
    const approved=isKyogi?true:(attendance[key]?.approved||false);
    const updated={date:editDay.date,name:editDay.name,start:editDay.start,end:editDay.end,approved,memo,absent:!!editDay.absent};
    onAttendanceChange({...attendance,[key]:updated});
    try{await DB.saveAttendance(updated);}catch(e){console.error("[saveEdit] save error:",e);}
    setEditDay(null);
  };

  // 予算総額（フィルター連動）
  const filteredStaff=useMemo(()=>staff.filter(s=>staffFilter==="all"?true:staffFilter==="part"?s.type==="アルバイト":s.type==="正社員"),[staff,staffFilter]);
  const budgetGrandTotal=useMemo(()=>{
    let payTotal=0,transTotal=0,actualRef=0;
    filteredStaff.forEach(s=>{const d=allStaffData[s.name];if(d){payTotal+=d.budgetWage;transTotal+=d.budgetTransport;actualRef+=d.actualTotal;}});
    return{payTotal,transTotal,grandTotal:payTotal+transTotal,actualRef};
  },[allStaffData,filteredStaff]);

  const cardS={background:"#fff",borderRadius:14,padding:16,border:"1px solid #e2e8f0",marginBottom:12,boxShadow:"0 1px 3px rgba(0,0,0,.05)"};
  const boxS=(bg)=>({background:bg||"#f0f9ff",borderRadius:10,padding:"10px 14px",textAlign:"center",flex:1});

  // 給与カラム不在チェック
  const wageColsMissing=DB._staffHasWageCols===false;

  return <div style={{maxWidth:640,margin:"0 auto"}}>
    {/* 給与カラム不在の警告 */}
    {wageColsMissing&&<div style={{background:"#fef2f2",border:"2px solid #dc2626",borderRadius:10,padding:12,marginBottom:12}}>
      <div style={{fontSize:13,fontWeight:800,color:"#dc2626",marginBottom:4}}>⚠️ 給与データがDBに未設定</div>
      <div style={{fontSize:11,color:"#991b1b",lineHeight:1.6}}>
        Supabase staffテーブルに給与カラムがありません。<br/>
        Supabase &gt; SQL Editor で以下を実行してください：
      </div>
      <div style={{background:"#1e293b",color:"#22d3ee",padding:8,borderRadius:6,fontSize:10,fontFamily:"monospace",marginTop:6,lineHeight:1.8,overflowX:"auto",whiteSpace:"pre"}}>
{`ALTER TABLE staff ADD COLUMN IF NOT EXISTS hourly_wage INTEGER DEFAULT 0;
ALTER TABLE staff ADD COLUMN IF NOT EXISTS transport_cost INTEGER DEFAULT 0;
ALTER TABLE staff ADD COLUMN IF NOT EXISTS monthly_salary INTEGER DEFAULT 0;`}
      </div>
      <div style={{fontSize:10,color:"#991b1b",marginTop:6}}>実行後にアプリをリロードすると給与データが自動同期されます。</div>
    </div>}
    <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:12}}>
      <h3 style={{fontSize:16,fontWeight:800,margin:0}}>給与計算</h3>
      <button onClick={forceSync} disabled={syncing} style={{padding:"4px 12px",borderRadius:8,fontSize:11,fontWeight:700,border:"1px solid #e2e8f0",background:syncing?"#f1f5f9":"#fff",color:syncing?"#94a3b8":"#2563eb",cursor:syncing?"wait":"pointer"}}>
        {syncing?"同期中...":"🔄 同期"}
      </button>
    </div>
    {lastSync&&<div style={{fontSize:9,color:"#94a3b8",textAlign:"right",marginTop:-10,marginBottom:6}}>最終同期: {lastSync.toLocaleTimeString()}</div>}
    {/* 月選択 */}
    <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:12}}>
      <button onClick={()=>setViewYM(ymOff(viewYM,-1))} style={{padding:"4px 10px",fontSize:16,background:"#f1f5f9",border:"1px solid #e2e8f0",borderRadius:6,cursor:"pointer",fontWeight:700,color:"#2563eb"}}>&lt;</button>
      <div style={{fontSize:16,fontWeight:900,color:"#1e293b"}}>{ymLabel(viewYM)}</div>
      <button onClick={()=>setViewYM(ymOff(viewYM,1))} style={{padding:"4px 10px",fontSize:16,background:"#f1f5f9",border:"1px solid #e2e8f0",borderRadius:6,cursor:"pointer",fontWeight:700,color:"#2563eb"}}>&gt;</button>
    </div>
    {/* サブタブ */}
    <div style={{display:"flex",gap:0,marginBottom:14,background:"#f1f5f9",borderRadius:10,padding:3}}>
      {[{id:"budget",l:"予算（シフト）"},{id:"actual",l:"実績（勤怠）"},{id:"detail",l:"給与明細"}].map(t=>
        <button key={t.id} onClick={()=>setSubTab(t.id)} style={{flex:1,padding:"7px 0",borderRadius:8,fontSize:12,fontWeight:700,border:"none",cursor:"pointer",
          background:subTab===t.id?"#fff":"transparent",color:subTab===t.id?"#1e293b":"#94a3b8",
          boxShadow:subTab===t.id?"0 1px 3px rgba(0,0,0,.1)":"none"}}>{t.l}</button>
      )}
    </div>

    {/* スタッフ種別フィルター */}
    <div style={{display:"flex",gap:4,marginBottom:10}}>
      {[{id:"all",l:"全員"},{id:"part",l:"アルバイト"},{id:"full",l:"正社員"}].map(f=>
        <button key={f.id} onClick={()=>setStaffFilter(f.id)} style={{padding:"4px 12px",borderRadius:16,fontSize:11,fontWeight:700,border:"none",cursor:"pointer",
          background:staffFilter===f.id?"#1e293b":"#f1f5f9",color:staffFilter===f.id?"#fff":"#64748b"}}>{f.l}</button>)}
    </div>

    {/* ====== 予算（シフト）タブ ====== */}
    {subTab==="budget"&&<div>
      {staff.filter(s=>staffFilter==="all"?true:staffFilter==="part"?s.type==="アルバイト":s.type==="正社員").map(s=>{
        const d=allStaffData[s.name];if(!d)return null;
        const isP=d.isP;
        return <div key={s.name} style={cardS}>
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:10}}>
            <div style={{display:"flex",alignItems:"center",gap:8}}>
              <span style={{fontSize:14,fontWeight:800}}>{s.name}</span>
              <span style={{fontSize:10,fontWeight:700,padding:"2px 10px",borderRadius:12,background:isP?"#fef3c7":"#dbeafe",color:isP?"#92400e":"#1d4ed8"}}>{s.type}</span>
            </div>
            <span style={{fontSize:11,color:"#64748b"}}>{d.budgetDays}日 / {d.budgetHours.toFixed(1)}h</span>
          </div>
          <div style={{display:"flex",gap:8}}>
            <div style={boxS("#f0f9ff")}>
              <div style={{fontSize:18,fontWeight:900,color:"#1e40af"}}>¥{d.budgetWage.toLocaleString()}</div>
              <div style={{fontSize:10,color:"#64748b",fontWeight:600}}>支給</div>
              {isP&&<div style={{fontSize:9,color:"#94a3b8"}}>¥{(s.hourlyWage||0).toLocaleString()}×{d.budgetHours.toFixed(1)}h</div>}
            </div>
            <div style={boxS("#fffbeb")}>
              <div style={{fontSize:18,fontWeight:900,color:"#d97706"}}>¥{d.budgetTransport.toLocaleString()}</div>
              <div style={{fontSize:10,color:"#64748b",fontWeight:600}}>交通費</div>
              <div style={{fontSize:9,color:"#94a3b8"}}>¥{(s.transportCost||0).toLocaleString()}×{d.budgetDays}日</div>
            </div>
            <div style={boxS("#f8fafc")}>
              <div style={{fontSize:18,fontWeight:900,color:"#1e293b"}}>¥{d.budgetTotal.toLocaleString()}</div>
              <div style={{fontSize:10,color:"#64748b",fontWeight:600}}>合計</div>
            </div>
          </div>
        </div>;
      })}
      {/* 予算総額 */}
      <div style={{...cardS,background:"#f0f4ff",border:"2px solid #bfdbfe"}}>
        <div style={{display:"flex",alignItems:"baseline",justifyContent:"space-between",marginBottom:8}}>
          <span style={{fontSize:14,fontWeight:900}}>予算 総額</span>
          <span style={{fontSize:24,fontWeight:900,color:"#dc2626"}}>¥{budgetGrandTotal.grandTotal.toLocaleString()}</span>
        </div>
        <div style={{display:"flex",justifyContent:"space-between",fontSize:12,color:"#475569",marginBottom:2}}>
          <span>支給計</span><span style={{fontWeight:700}}>¥{budgetGrandTotal.payTotal.toLocaleString()}</span>
          <span>交通費計</span><span style={{fontWeight:700,color:"#d97706"}}>¥{budgetGrandTotal.transTotal.toLocaleString()}</span>
        </div>
        <div style={{display:"flex",justifyContent:"space-between",fontSize:12,color:"#475569",borderTop:"1px solid #dbeafe",paddingTop:4,marginTop:4}}>
          <span>実績 参考</span><span style={{fontWeight:700}}>¥{budgetGrandTotal.actualRef.toLocaleString()}</span>
        </div>
        <div style={{display:"flex",justifyContent:"space-between",fontSize:12}}>
          <span style={{color:"#475569"}}>差異</span>
          <span style={{fontWeight:900,color:budgetGrandTotal.grandTotal-budgetGrandTotal.actualRef>=0?"#dc2626":"#059669"}}>¥{(budgetGrandTotal.grandTotal-budgetGrandTotal.actualRef>=0?"-":"")}{Math.abs(budgetGrandTotal.grandTotal-budgetGrandTotal.actualRef).toLocaleString()}</span>
        </div>
      </div>
    </div>}

    {/* ====== 実績（勤怠）タブ ====== */}
    {subTab==="actual"&&<div>
      {/* スタッフ選択 */}
      <div style={{display:"flex",gap:6,flexWrap:"wrap",marginBottom:12}}>
        {staff.filter(s=>staffFilter==="all"?true:staffFilter==="part"?s.type==="アルバイト":s.type==="正社員").map(s=><button key={s.name} onClick={()=>setSelStaff(s.name)} style={{
          padding:"6px 14px",borderRadius:20,fontSize:12,fontWeight:700,border:"none",cursor:"pointer",transition:"all .15s",
          background:selStaff===s.name?"#1e293b":"#f1f5f9",color:selStaff===s.name?"#fff":"#64748b"
        }}>{s.name}</button>)}
      </div>
      {(()=>{
        const sd=allStaffData[selStaff];if(!sd)return null;
        const unapproved=sd.days.filter(d=>d.shift&&d.att&&!d.att.approved).length;
        return <>
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:10}}>
            <div style={{fontSize:13,fontWeight:700}}>{selStaff} ー {ymLabel(viewYM)}</div>
            {unapproved>0?
              <button onClick={()=>approveAll(selStaff)} style={{padding:"5px 14px",borderRadius:8,background:"#059669",color:"#fff",border:"none",fontSize:11,fontWeight:700,cursor:"pointer"}}>全受領 ({sd.days.filter(d=>d.shift).length}件)</button>:
              <span style={{padding:"5px 14px",borderRadius:8,background:"#f0fdf4",color:"#059669",fontSize:11,fontWeight:700}}>全受領済 ✅</span>
            }
          </div>
          {sd.days.map(d=>{
            const isHoliday=d.dow===0;const isSat=d.dow===6;
            const rowBg=isHoliday?"#fef2f2":isSat?"#eff6ff":"#fff";
            const dayColor=isHoliday?"#dc2626":isSat?"#2563eb":"#374151";
            const hasShift=!!d.shift;const att=d.att;const isApproved=att&&att.approved;const isAbsent=att&&att.absent;
            const isKyogi=att&&att.memo&&att.memo.startsWith("協議中");
            const kyogiDetail=isKyogi?att.memo.replace(/^協議中:/,""):"";
            const timeStr=isAbsent?"欠勤":att?(att.start+"〜"+att.end):(hasShift?(d.shift.start+"〜"+d.shift.end):"ー");
            return <div key={d.date} style={{borderBottom:"1px solid #f1f5f9",background:isKyogi?"#fffbeb":isAbsent?"#fef2f2":rowBg}}>
              <div style={{display:"flex",alignItems:"center",padding:"8px 12px",gap:8}}>
                <div style={{width:30,textAlign:"center"}}>
                  <div style={{fontSize:14,fontWeight:800,color:dayColor}}>{d.day}</div>
                  <div style={{fontSize:9,color:dayColor,fontWeight:600}}>{WK[d.dow]}</div>
                </div>
                <div style={{flex:1,fontSize:13,color:isKyogi?"#92400e":isAbsent?"#dc2626":hasShift?"#374151":"#d1d5db",fontWeight:hasShift?600:400}}>{timeStr}</div>
                {hasShift&&<div style={{display:"flex",gap:6}}>
                  {isKyogi&&<span style={{padding:"4px 8px",borderRadius:6,background:"#f59e0b",color:"#fff",fontSize:10,fontWeight:700}}>協議中</span>}
                  {!isKyogi&&isAbsent&&<span style={{padding:"4px 8px",borderRadius:6,background:"#dc2626",color:"#fff",fontSize:10,fontWeight:700}}>欠勤</span>}
                  {!isKyogi&&!isAbsent&&(isApproved?
                    <span style={{padding:"4px 10px",borderRadius:6,background:"#059669",color:"#fff",fontSize:10,fontWeight:700}}>{att&&att.memo==="打刻"?"🕐打刻":"受領済"}</span>:
                    <button onClick={()=>approve(d.date,selStaff)} style={{padding:"4px 10px",borderRadius:6,background:"#dcfce7",color:"#059669",border:"1px solid #bbf7d0",fontSize:10,fontWeight:700,cursor:"pointer"}}>受領</button>
                  )}
                  <button onClick={()=>setEditDay({date:d.date,name:selStaff,start:att?.start||d.shift.start||"09:00",end:att?.end||d.shift.end||"18:00",memo:att?.memo||"",absent:att?.absent||false})} style={{padding:"4px 10px",borderRadius:6,background:isKyogi?"#f59e0b":"#f1f5f9",color:isKyogi?"#fff":"#64748b",border:isKyogi?"none":"1px solid #e2e8f0",fontSize:10,fontWeight:700,cursor:"pointer"}}>{isKyogi?"解決":"編集"}</button>
                </div>}
              </div>
              {isKyogi&&<div style={{padding:"4px 12px 8px 52px",fontSize:11,color:"#92400e",fontWeight:600}}>📝 {kyogiDetail}</div>}
            </div>;
          })}
        </>;
      })()}
    </div>}

    {/* ====== 給与明細タブ ====== */}
    {subTab==="detail"&&<div>
      {staff.filter(s=>staffFilter==="all"?true:staffFilter==="part"?s.type==="アルバイト":s.type==="正社員").map(s=>{
        const d=allStaffData[s.name];if(!d)return null;
        const si=s;const isP=d.isP;
        return <div key={s.name} style={cardS}>
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:10}}>
            <div style={{display:"flex",alignItems:"center",gap:8}}>
              <span style={{fontSize:14,fontWeight:800}}>{s.name}</span>
              <span style={{fontSize:10,fontWeight:700,padding:"2px 10px",borderRadius:12,background:isP?"#fef3c7":"#dbeafe",color:isP?"#92400e":"#1d4ed8"}}>{s.type}</span>
            </div>
            <span style={{fontSize:11,color:"#64748b"}}>{d.actualDays}日 / {d.actualHours.toFixed(1)}h{d.absentDays>0?<span style={{color:"#dc2626",fontWeight:700}}> (欠勤{d.absentDays})</span>:""}</span>
          </div>
          <div style={{fontSize:13}}>
            {isP?<>
              <div style={{display:"flex",justifyContent:"space-between",padding:"6px 0",borderBottom:"1px solid #f1f5f9"}}>
                <span style={{color:"#64748b"}}>時給</span><span style={{fontWeight:600}}>¥{(si.hourlyWage||0).toLocaleString()} × {d.actualHours.toFixed(1)}h</span>
              </div>
              <div style={{display:"flex",justifyContent:"space-between",padding:"6px 0",borderBottom:"1px solid #f1f5f9"}}>
                <span style={{color:"#64748b"}}>基本給</span><span style={{fontWeight:700}}>¥{d.actualWage.toLocaleString()}</span>
              </div>
            </>:<>
              <div style={{display:"flex",justifyContent:"space-between",padding:"6px 0",borderBottom:"1px solid #f1f5f9"}}>
                <span style={{color:"#64748b"}}>月給</span><span style={{fontWeight:700}}>¥{(si.monthlySalary||0).toLocaleString()}</span>
              </div>
            </>}
            <div style={{display:"flex",justifyContent:"space-between",padding:"6px 0",borderBottom:"1px solid #f1f5f9"}}>
              <span style={{color:"#64748b"}}>交通費 (¥{(si.transportCost||0).toLocaleString()}×{d.actualDays}日)</span>
              <span style={{fontWeight:600,color:"#d97706"}}>¥{d.actualTransport.toLocaleString()}</span>
            </div>
            <div style={{display:"flex",justifyContent:"space-between",padding:"8px 0",marginTop:4,borderTop:"2px solid #e2e8f0"}}>
              <span style={{fontWeight:900,fontSize:14}}>支給額</span>
              <span style={{fontWeight:900,fontSize:18,color:"#1e40af"}}>¥{d.actualTotal.toLocaleString()}</span>
            </div>
          </div>
        </div>;
      })}
    </div>}

    {/* 編集モーダル */}
    {editDay&&<div className="modal-overlay" onClick={()=>setEditDay(null)}><div className="modal-box" style={{maxWidth:320,padding:20}} onClick={e=>e.stopPropagation()}>
      <h4 style={{fontSize:14,fontWeight:800,margin:"0 0 14px"}}>{editDay.name} — {fmtD(editDay.date)}</h4>
      {editDay.memo&&editDay.memo.startsWith("協議中")&&<div style={{background:"#fffbeb",border:"1px solid #f59e0b",borderRadius:10,padding:"10px 12px",marginBottom:14}}>
        <div style={{fontSize:11,fontWeight:700,color:"#b45309",marginBottom:4}}>📝 スタッフからの修正リクエスト</div>
        <div style={{fontSize:12,color:"#92400e"}}>{editDay.memo.replace(/^協議中:/,"")}</div>
        <div style={{fontSize:10,color:"#b45309",marginTop:6}}>↓ 時間を修正して「解決・保存」すると承認済みになります</div>
      </div>}
      {/* 欠勤チェック */}
      <div style={{marginBottom:14}}>
        <label style={{display:"flex",alignItems:"center",gap:8,cursor:"pointer",padding:"10px 12px",borderRadius:10,border:editDay.absent?"2px solid #dc2626":"1px solid #e2e8f0",background:editDay.absent?"#fef2f2":"#fff"}}>
          <input type="checkbox" checked={!!editDay.absent} onChange={e=>setEditDay(p=>({...p,absent:e.target.checked}))} style={{width:18,height:18,accentColor:"#dc2626"}}/>
          <div>
            <div style={{fontSize:13,fontWeight:700,color:editDay.absent?"#dc2626":"#374151"}}>欠勤</div>
            <div style={{fontSize:10,color:"#94a3b8"}}>出勤カウント0・時間0扱い</div>
          </div>
        </label>
      </div>
      {/* 時間入力（欠勤でない場合のみ） */}
      {!editDay.absent&&<>
        <div style={{marginBottom:10}}>
          <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:4}}>開始時間</label>
          <input type="time" value={editDay.start} onChange={e=>setEditDay(p=>({...p,start:e.target.value}))} style={{width:"100%",padding:"8px 10px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:14,boxSizing:"border-box"}}/>
        </div>
        <div style={{marginBottom:10}}>
          <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:4}}>終了時間</label>
          <input type="time" value={editDay.end} onChange={e=>setEditDay(p=>({...p,end:e.target.value}))} style={{width:"100%",padding:"8px 10px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:14,boxSizing:"border-box"}}/>
        </div>
      </>}
      <div style={{marginBottom:14}}>
        <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:4}}>メモ</label>
        <input value={editDay.memo||""} onChange={e=>setEditDay(p=>({...p,memo:e.target.value}))} placeholder="備考" style={{width:"100%",padding:"8px 10px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:13,boxSizing:"border-box"}}/>
      </div>
      <div style={{display:"flex",gap:8}}>
        <button onClick={()=>setEditDay(null)} style={{flex:"0 0 auto",padding:"8px 14px",borderRadius:8,border:"1px solid #e2e8f0",background:"#fff",fontSize:12,fontWeight:600,color:"#64748b",cursor:"pointer"}}>キャンセル</button>
        <button onClick={saveEdit} style={{flex:1,padding:"8px 14px",borderRadius:8,border:"none",background:editDay.memo&&editDay.memo.startsWith("協議中")?"#f59e0b":"#2563eb",fontSize:12,fontWeight:700,color:"#fff",cursor:"pointer"}}>{editDay.memo&&editDay.memo.startsWith("協議中")?"✅ 解決・保存":"保存"}</button>
      </div>
    </div></div>}
  </div>;
}

/* ==========================================
   出勤簿（月次カレンダー+ CSV取込）
   ========================================== */
function ShiftCalendar({shifts,onShiftsChange,today,staff,sbSaveShift,reservations}){
  const todayYM=toYM(today);const[viewYM,setViewYM]=useState(todayYM);const WK=["日","月","火","水","木","金","土"];
  const SYMBOLS=["●","希","公","有","出",""];
  const SHIFT_OPTIONS=[
    {s:"●",label:"出勤",color:"#2563eb",bg:"#D4EBFA"},
    {s:"公",label:"公休",color:"#64748b",bg:"#E8E8E8"},
    {s:"希",label:"希望休",color:"#f59e0b",bg:"#FFF3CD"},
    {s:"有",label:"有給",color:"#059669",bg:"#D1FAE5"},
    {s:"出",label:"出張",color:"#7c3aed",bg:"#D4EDDA"},
  ];
  const maxYM=ymOff(todayYM,3);const dim=daysInMonth(viewYM);const[y,mo]=viewYM.split("-").map(Number);
  const getShift=(date)=>shifts[date]||[];
  const regularStaff=staff.filter(s=>s.type==="正社員");const partTimeStaff=staff.filter(s=>s.type==="アルバイト");
  const[cellEdit,setCellEdit]=useState(null); // {dateStr,name,type,symbol,start,end,isNew}

  // 日本の祝日判定（簡易版）
  const jpHolidays=useMemo(()=>{
    const hSet=new Set();
    const addH=(m,d)=>hSet.add(`${viewYM.split("-")[0]}-${String(m).padStart(2,"0")}-${String(d).padStart(2,"0")}`);
    const yr=Number(viewYM.split("-")[0]);
    addH(1,1);addH(1,13);addH(2,11);addH(2,23);addH(3,20);addH(4,29);addH(5,3);addH(5,4);addH(5,5);addH(5,6);
    addH(7,21);addH(8,11);addH(9,15);addH(9,23);addH(10,13);addH(11,3);addH(11,23);
    // 振替休日: 祝日が日曜なら翌月曜
    const all=[...hSet];all.forEach(ds=>{if(new Date(ds).getDay()===0){
      const nd=new Date(ds);nd.setDate(nd.getDate()+1);hSet.add(nd.toISOString().slice(0,10));
    }});
    return hSet;
  },[viewYM]);
  const isHoliday=(ds)=>jpHolidays.has(ds);

  // Supabase同期付きシフト更新
  const updateShifts=(next)=>{onShiftsChange(next);if(sbSaveShift){Object.entries(next).forEach(([date,arr])=>{if(arr!==shifts[date]){
    const newNames=new Set(arr.map(s=>s.name));
    const prev=shifts[date]||[];
    prev.forEach(s=>{if(!newNames.has(s.name))DB.deleteShift(date,s.name);});
    arr.forEach(s=>sbSaveShift(date,s.name,s));
  }});}};
  const _onSC=updateShifts;

  // セルタップ → 編集モーダル表示
  const handleCellClick=(dateStr,name,type)=>{
    const cur=getShift(dateStr);const existing=cur.find(s=>s.name===name);
    if(existing){
      setCellEdit({dateStr,name,type,symbol:existing.symbol||"●",start:existing.start||"09:00",end:existing.end||"18:00",isNew:false});
    }else{
      setCellEdit({dateStr,name,type,symbol:type==="正社員"?"●":"",start:"09:00",end:"18:00",isNew:true});
    }
  };

  // セル編集保存
  const saveCellEdit=()=>{
    if(!cellEdit)return;
    if(!window.confirm("保存を実行しますか？"))return;
    const{dateStr,name,type,symbol,start,end,isNew}=cellEdit;
    const cur=getShift(dateStr);
    const entry={name,type,symbol:type==="正社員"?symbol:"",start,end};
    if(isNew){
      _onSC({...shifts,[dateStr]:[...cur,entry]});
    }else{
      _onSC({...shifts,[dateStr]:cur.map(s=>s.name===name?entry:s)});
    }
    setCellEdit(null);
  };

  // セル削除
  const deleteCellEdit=()=>{
    if(!cellEdit)return;
    if(!window.confirm("削除を実行しますか？"))return;
    const{dateStr,name}=cellEdit;
    const cur=getShift(dateStr);
    _onSC({...shifts,[dateStr]:cur.filter(s=>s.name!==name)});
    DB.deleteShift(dateStr,name);
    setCellEdit(null);
  };

  const[bulkMode,setBulkMode]=useState(false);
  const[bulkNames,setBulkNames]=useState([]);
  const[bulkDows,setBulkDows]=useState([1,2,3,4,5]);
  const[bulkStart,setBulkStart]=useState("09:00");
  const[bulkEnd,setBulkEnd]=useState("18:00");
  const[bulkOverwrite,setBulkOverwrite]=useState(false);
  const[bulkSymbol,setBulkSymbol]=useState("●");
  const bulkTargetDays=useMemo(()=>{
    let count=0;
    for(let d=1;d<=dim;d++){const dow=new Date(y,mo-1,d).getDay();if(bulkDows.includes(dow))count++;}
    return count;
  },[dim,y,mo,bulkDows]);
  const applyBulk=()=>{
    if(bulkNames.length===0){alert("スタッフを選択してください");return;}
    const dowLabels=bulkDows.map(d=>WK[d]).join("・");
    if(!window.confirm(`${bulkNames.join("・")} の ${dowLabels} に一括登録します。\n時間: ${bulkStart}〜${bulkEnd}\nよろしいですか？`))return;
    const next={...shifts};
    let registered=0,skipped=0;
    bulkNames.forEach(bulkName=>{
      for(let d=1;d<=dim;d++){
        const ds=`${viewYM}-${String(d).padStart(2,"0")}`;
        const dow=new Date(y,mo-1,d).getDay();
        if(bulkDows.includes(dow)){
          const cur=next[ds]||[];
          const existing=cur.find(s=>s.name===bulkName);
          if(existing&&!bulkOverwrite){skipped++;continue;}
          const type=staff.find(s=>s.name===bulkName)?.type||"正社員";
          const entry={name:bulkName,type,symbol:type==="正社員"?bulkSymbol:"",start:bulkStart,end:bulkEnd};
          if(existing&&bulkOverwrite){
            next[ds]=cur.map(s=>s.name===bulkName?entry:s);registered++;
          }else if(!existing){
            next[ds]=[...cur,entry];registered++;
          }
        }
      }
    });
    _onSC(next);setBulkMode(false);
    alert(`✅ 一括登録完了\n登録: ${registered}件${skipped>0?`\nスキップ（既存）: ${skipped}件`:""}`);
  };
  const applyBulkDelete=async()=>{
    if(bulkNames.length===0){alert("スタッフを選択してください");return;}
    const dowLabels=bulkDows.map(d=>WK[d]).join("・");
    if(!window.confirm(`${bulkNames.join("・")} の ${dowLabels} のシフトを削除します。よろしいですか？`))return;
    const next={...shifts};
    let delCount=0;
    const delPromises=[];
    bulkNames.forEach(bulkName=>{
      for(let d=1;d<=dim;d++){
        const ds=`${viewYM}-${String(d).padStart(2,"0")}`;
        const dow=new Date(y,mo-1,d).getDay();
        if(bulkDows.includes(dow)){
          const cur=next[ds]||[];
          const had=cur.some(s=>s.name===bulkName);
          next[ds]=cur.filter(s=>s.name!==bulkName);
          if(had){delPromises.push(DB.deleteShift(ds,bulkName));delCount++;}
        }
      }
    });
    onShiftsChange(next);setBulkMode(false);
    try{await Promise.all(delPromises);}catch(e){console.error("bulkDelete error",e);}
    alert(`✅ 一括削除完了（${delCount}件削除）`);
  };

  // ③ 全スタッフ全シフト一括削除（月単位）
  const clearAllShifts=async()=>{
    if(!window.confirm(`⚠️ ${ymLabel(viewYM)}の全スタッフのシフトを全て削除します。\nこの操作は取り消せません。よろしいですか？`))return;
    if(!window.confirm(`本当に削除しますか？（2回目の確認）`))return;
    // まずローカル状態を即座にクリア
    const next={...shifts};
    let delCount=0;
    for(let d=1;d<=dim;d++){
      const ds=`${viewYM}-${String(d).padStart(2,"0")}`;
      const cur=next[ds]||[];
      delCount+=cur.length;
      next[ds]=[];
    }
    onShiftsChange(next);
    // DBから一括削除（完了を待つ）
    try{
      await DB.deleteShiftsMonth(viewYM);
    }catch(e){console.error("deleteShiftsMonth error",e);}
    alert(`✅ ${ymLabel(viewYM)}の全シフトを削除しました（${delCount}件）`);
  };

  const canPrev=viewYM>todayYM;const canNext=viewYM<maxYM;

  // CSV取込
  const handleCSVUpload=(e)=>{
    const f=e.target.files?.[0];if(!f)return;
    readFile(f,text=>{
      const rows=parseCSV(text);
      if(rows.length<2){alert("CSVフォーマットが無効です");return;}
      const headerRow=rows[0];const dateOffset={};
      for(let i=1;i<headerRow.length;i++){
        const h=headerRow[i];const m=h.match(/(\d+)\/(\d+)/);
        if(m){const ymd=`${y}-${String(m[1]).padStart(2,"0")}-${String(m[2]).padStart(2,"0")}`;dateOffset[i]=ymd;}
      }
      const next={...shifts};
      for(let ri=1;ri<rows.length;ri++){
        const row=rows[ri];
        if(!row[0]||row[0]==="人員")continue;
        const staffName=row[0];const staffItem=staff.find(s=>s.name===staffName);if(!staffItem)continue;
        for(let ci=1;ci<row.length;ci++){
          const val=row[ci]?.trim()||"";if(!val)continue;const dateStr=dateOffset[ci];if(!dateStr)continue;
          const cur=next[dateStr]||[];if(cur.find(s=>s.name===staffName))continue;
          let start="09:00",end="18:00",symbol="";
          const timeMatch=val.match(/(\d{1,2}):(\d{2})-(\d{1,2}):(\d{2})/);
          if(timeMatch){start=`${String(timeMatch[1]).padStart(2,"0")}:${timeMatch[2]}`;end=`${String(timeMatch[3]).padStart(2,"0")}:${timeMatch[4]}`;}
          if(staffItem.type==="正社員"){symbol=val==="●"||val===""?"●":val;}
          next[dateStr]=[...cur,{name:staffName,type:staffItem.type,symbol,start,end}];
        }
      }
      _onSC(next);alert("シフトCSVを取込みました");
    });
  };

  const calcHeadcount=(dateStr)=>{
    const shfts=getShift(dateStr);
    return shfts.filter(s=>{
      if(s.type==="正社員")return s.symbol==="●";
      return!!(s.start&&s.end);
    }).length;
  };

  const dates=[];for(let d=1;d<=dim;d++)dates.push(`${viewYM}-${String(d).padStart(2,"0")}`);

  // タスク数取得（予約データから算出）
  const monthTasks=useMemo(()=>{
    if(!reservations||!reservations.length)return{};
    const byDate={};
    const ensure=(d)=>{if(!byDate[d])byDate[d]={洗車:0,DEL:0,COL:0,total:0};};
    reservations.forEach(r=>{
      if(r.status==="cancelled")return;
      // 出発日のタスク
      if(r.lendDate){
        ensure(r.lendDate);
        const vt=(r.visitType||"").toUpperCase();
        if(vt==="DEL"){byDate[r.lendDate].DEL++;}
        byDate[r.lendDate].total++;
      }
      // 返却日のタスク
      if(r.returnDate){
        ensure(r.returnDate);
        const rt=(r.returnType||"").toUpperCase();
        if(rt==="COL"){byDate[r.returnDate].COL++;}
        byDate[r.returnDate].total++;
      }
      // 洗車（出発前日）
      if(r.lendDate){
        const prev=new Date(r.lendDate);prev.setDate(prev.getDate()-1);
        const prevDs=prev.toISOString().slice(0,10);
        ensure(prevDs);byDate[prevDs].洗車++;byDate[prevDs].total++;
      }
    });
    return byDate;
  },[reservations]);

  // セル表示内容を取得
  const getCellDisplay=(shift,type)=>{
    if(!shift)return null;
    if(type==="正社員"){
      return shift.symbol||"";
    }
    // アルバイト: 時間を短縮表示
    if(shift.start&&shift.end){
      const s=shift.start.replace(/^0/,"");const e=shift.end.replace(/^0/,"");
      return <span style={{fontSize:7,lineHeight:"1.1"}}>{s}<br/>{e}</span>;
    }
    return "";
  };

  // セル背景色 — 平日:白 土曜:青 日曜:赤 祝日:薄黄
  const getBaseBg=(dow,ds)=>{
    if(isHoliday(ds))return "#FFFDE7"; // 祝日=薄黄
    if(dow===0)return "#FFEBEE"; // 日曜=薄赤
    if(dow===6)return "#E3F2FD"; // 土曜=薄青
    return "#FFFFFF"; // 平日=白
  };
  // 背景色は常に曜日ベース（平日=白、土曜=青、日曜=赤、祝日=薄黄色）
  const getCellBg=(shift,dow,ds)=>getBaseBg(dow,ds);

  return <div className="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div className="px-4 py-3 border-b border-gray-200 flex items-center justify-between flex-wrap gap-2" style={{background:"#D2B48C"}}>
      <div className="flex items-center gap-2">
        <button onClick={()=>canPrev&&setViewYM(ymOff(viewYM,-1))} className="px-2 py-1 bg-white border border-gray-300 rounded text-sm hover:bg-gray-50" style={{opacity:canPrev?1:.4}}>◀</button>
        <h3 className="text-base font-bold" style={{margin:0}}>{ymLabel(viewYM)}</h3>
        <button onClick={()=>canNext&&setViewYM(ymOff(viewYM,1))} className="px-2 py-1 bg-white border border-gray-300 rounded text-sm hover:bg-gray-50" style={{opacity:canNext?1:.4}}>▶</button>
        {viewYM!==todayYM&&<button onClick={()=>setViewYM(todayYM)} className="px-2 py-1 bg-blue-50 border border-blue-200 rounded text-xs font-semibold text-blue-700">今月</button>}
      </div>
      <div className="flex items-center gap-2">
        <button onClick={clearAllShifts} className="px-3 py-1 rounded-lg text-xs font-semibold border" style={{background:"#991b1b",color:"#fff"}}>全削除</button>
        <button onClick={()=>{setBulkNames([]);setBulkDows([1,2,3,4,5]);setBulkMode("delete");}} className="px-3 py-1 rounded-lg text-xs font-semibold border" style={{background:"#dc2626",color:"#fff"}}>一括削除</button>
        <button onClick={()=>{setBulkNames([]);setBulkDows([1,2,3,4,5]);setBulkSymbol("●");setBulkStart("09:00");setBulkEnd("18:00");setBulkOverwrite(false);setBulkMode("set");}} className="px-3 py-1 rounded-lg text-xs font-semibold border" style={{background:"#2563eb",color:"#fff"}}>一括設定</button>
        <label className="px-3 py-1 rounded-lg text-xs font-semibold border border-blue-300 bg-blue-50 text-blue-700 cursor-pointer hover:bg-blue-100"><span>CSV</span><input type="file" accept=".csv,.txt" className="hidden" onChange={handleCSVUpload}/></label>
      </div>
    </div>
    {/* 一括モーダル */}
    {bulkMode&&<div className="modal-overlay" onClick={()=>setBulkMode(false)}><div className="modal-box" style={{maxWidth:380,padding:24}} onClick={e=>e.stopPropagation()}>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:16}}>
        <h4 style={{fontSize:16,fontWeight:800,margin:0}}>{bulkMode==="delete"?"一括削除":"一括設定"}</h4>
        <button onClick={()=>setBulkMode(false)} style={{background:"none",border:"none",fontSize:18,color:"#94a3b8",cursor:"pointer"}}>✕</button>
      </div>
      <div style={{marginBottom:14}}>
        <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:6}}>スタッフ（複数選択可）</label>
        <div style={{display:"flex",gap:4,flexWrap:"wrap",marginBottom:6}}>
          <button onClick={()=>setBulkNames(staff.map(s=>s.name))} style={{padding:"4px 10px",borderRadius:6,fontSize:11,fontWeight:700,border:"1px solid #e2e8f0",background:bulkNames.length===staff.length?"#2563eb":"#f8fafc",color:bulkNames.length===staff.length?"#fff":"#64748b",cursor:"pointer"}}>全員</button>
          <button onClick={()=>setBulkNames(regularStaff.map(s=>s.name))} style={{padding:"4px 10px",borderRadius:6,fontSize:11,fontWeight:600,border:"1px solid #e2e8f0",background:"#f8fafc",color:"#1d4ed8",cursor:"pointer"}}>正社員</button>
          <button onClick={()=>setBulkNames(partTimeStaff.map(s=>s.name))} style={{padding:"4px 10px",borderRadius:6,fontSize:11,fontWeight:600,border:"1px solid #e2e8f0",background:"#f8fafc",color:"#92400e",cursor:"pointer"}}>アルバイト</button>
          <button onClick={()=>setBulkNames([])} style={{padding:"4px 10px",borderRadius:6,fontSize:11,fontWeight:600,border:"1px solid #e2e8f0",background:"#f8fafc",color:"#94a3b8",cursor:"pointer"}}>解除</button>
        </div>
        <div style={{maxHeight:120,overflowY:"auto",border:"1px solid #e2e8f0",borderRadius:8,padding:4}}>
          {staff.map(s=>{const sel=bulkNames.includes(s.name);return <label key={s.name} style={{display:"flex",alignItems:"center",gap:6,padding:"4px 6px",cursor:"pointer",borderRadius:4,background:sel?"#eff6ff":"transparent"}}>
            <input type="checkbox" checked={sel} onChange={()=>setBulkNames(p=>p.includes(s.name)?p.filter(n=>n!==s.name):[...p,s.name])} style={{width:14,height:14}}/>
            <span style={{fontSize:12,fontWeight:sel?700:400}}>{s.name}</span>
            <span style={{fontSize:9,color:s.type==="正社員"?"#1d4ed8":"#92400e",fontWeight:600}}>({s.type})</span>
          </label>;})}
        </div>
        {bulkNames.length>0&&<div style={{fontSize:11,color:"#2563eb",fontWeight:600,marginTop:4}}>{bulkNames.length}名選択中</div>}
      </div>
      <div style={{marginBottom:14}}>
        <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:6}}>曜日</label>
        <div style={{display:"flex",gap:6}}>
          {WK.map((w,i)=>{const isSun=i===0;const isSat=i===6;return <button key={i} onClick={()=>setBulkDows(p=>p.includes(i)?p.filter(x=>x!==i):[...p,i])} style={{
            width:38,height:38,borderRadius:8,fontSize:13,fontWeight:700,border:"none",cursor:"pointer",transition:"all .15s",
            background:bulkDows.includes(i)?"#2563eb":"#f1f5f9",color:bulkDows.includes(i)?"#fff":isSun?"#dc2626":isSat?"#2563eb":"#94a3b8"
          }}>{w}</button>;})}
        </div>
      </div>
      {bulkMode==="set"&&<>
        {bulkNames.length>0&&bulkNames.some(bn=>staff.find(s=>s.name===bn)?.type==="正社員")&&<div style={{marginBottom:14}}>
          <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:6}}>シフト種別（正社員）</label>
          <div style={{display:"flex",gap:4,flexWrap:"wrap"}}>
            {SHIFT_OPTIONS.map(o=><button key={o.s} onClick={()=>setBulkSymbol(o.s)} style={{
              padding:"6px 10px",borderRadius:8,fontSize:11,fontWeight:700,border:"2px solid",cursor:"pointer",
              background:bulkSymbol===o.s?o.color:"#fff",color:bulkSymbol===o.s?"#fff":o.color,borderColor:bulkSymbol===o.s?o.color:"#e2e8f0"
            }}>{o.s} {o.label}</button>)}
          </div>
        </div>}
        <div style={{display:"flex",gap:12,marginBottom:14}}>
          <div style={{flex:1}}>
            <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:4}}>開始</label>
            <input type="time" value={bulkStart} onChange={e=>setBulkStart(e.target.value)} style={{width:"100%",padding:"8px 10px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:14}}/>
          </div>
          <div style={{flex:1}}>
            <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:4}}>終了</label>
            <input type="time" value={bulkEnd} onChange={e=>setBulkEnd(e.target.value)} style={{width:"100%",padding:"8px 10px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:14}}/>
          </div>
        </div>
        <label style={{display:"flex",alignItems:"center",gap:8,fontSize:12,color:"#374151",marginBottom:16,cursor:"pointer"}}>
          <input type="checkbox" checked={bulkOverwrite} onChange={e=>setBulkOverwrite(e.target.checked)} style={{width:16,height:16}}/>
          既存シフトを上書き
        </label>
      </>}
      <div style={{textAlign:"center",padding:"8px 0",background:bulkMode==="delete"?"#fef2f2":"#f8fafc",borderRadius:8,marginBottom:14,fontSize:13,color:"#64748b"}}>
        対象: <span style={{fontWeight:900,color:bulkMode==="delete"?"#dc2626":"#1e293b",fontSize:16}}>{bulkNames.length}</span> 名 × <span style={{fontWeight:900,color:bulkMode==="delete"?"#dc2626":"#1e293b",fontSize:16}}>{bulkTargetDays}</span> 日 = <span style={{fontWeight:900,color:bulkMode==="delete"?"#dc2626":"#1e293b",fontSize:16}}>{bulkNames.length*bulkTargetDays}</span> 件
      </div>
      <div style={{display:"flex",gap:8}}>
        <button onClick={()=>setBulkMode(false)} style={{flex:"0 0 auto",padding:"10px 16px",borderRadius:10,border:"1px solid #e2e8f0",background:"#fff",fontSize:13,fontWeight:600,color:"#64748b",cursor:"pointer"}}>キャンセル</button>
        {bulkMode==="delete"?
          <button onClick={applyBulkDelete} disabled={bulkNames.length===0} style={{flex:1,padding:"10px 16px",borderRadius:10,border:"none",background:bulkNames.length>0?"#dc2626":"#94a3b8",fontSize:13,fontWeight:700,color:"#fff",cursor:bulkNames.length>0?"pointer":"not-allowed"}}>一括削除 ({bulkTargetDays}日)</button>:
          <button onClick={applyBulk} disabled={bulkNames.length===0} style={{flex:1,padding:"10px 16px",borderRadius:10,border:"none",background:bulkNames.length>0?"#2563eb":"#94a3b8",fontSize:13,fontWeight:700,color:"#fff",cursor:bulkNames.length>0?"pointer":"not-allowed"}}>一括設定 ({bulkTargetDays}件)</button>
        }
      </div>
    </div></div>}

    {/* シフト表（改良版） */}
    <div style={{maxHeight:600,overflowX:"auto",overflowY:"auto",position:"relative",WebkitOverflowScrolling:"touch"}}>
      <table style={{borderCollapse:"collapse",fontSize:10,minWidth:"100%"}}>
        <thead>
          <tr style={{background:"#D2B48C",position:"sticky",top:0,zIndex:3}}>
            <th style={{position:"sticky",left:0,zIndex:5,width:72,minWidth:72,padding:"6px 4px",textAlign:"center",fontWeight:700,borderRight:"2px solid #b8976a",background:"#D2B48C",fontSize:10}}>名前</th>
            {dates.map(ds=>{const dt=new Date(ds);const dow=dt.getDay();const day=dt.getDate();const isToday=ds===today;const hol=isHoliday(ds);
            const bgc=isToday?"#FFFF99":hol?"#FFFDE7":dow===0?"#FFCDD2":dow===6?"#BBDEFB":"#D2B48C";
            const txtC=hol?"#e65100":dow===0?"#c62828":dow===6?"#1565c0":"#78716c";
            return <th key={ds} style={{minWidth:42,width:42,padding:"4px 1px",textAlign:"center",fontWeight:700,fontSize:9,background:bgc,borderRight:"1px solid #b8976a",borderBottom:"1px solid #b8976a",boxShadow:isToday?"inset 0 0 0 2px #f59e0b":"none"}}>
              <div style={{lineHeight:1.2}}>{day}</div>
              <div style={{fontSize:8,color:txtC}}>{WK[dow]}{hol?"*":""}</div>
            </th>;})}
          </tr>
        </thead>
        <tbody>
          {/* 正社員 */}
          {regularStaff.length>0&&<tr><td colSpan={dates.length+1} style={{background:"#eff6ff",padding:"3px 8px",fontSize:9,fontWeight:700,color:"#1d4ed8",borderBottom:"1px solid #bfdbfe"}}>正社員</td></tr>}
          {regularStaff.map(st=><tr key={st.name}>
            <td style={{position:"sticky",left:0,zIndex:2,width:72,minWidth:72,padding:"4px 6px",fontWeight:600,fontSize:10,background:"#fff",borderRight:"2px solid #e5e7eb",borderBottom:"1px solid #e5e7eb",whiteSpace:"nowrap"}}>
              <span style={{fontSize:8,fontWeight:700,padding:"1px 4px",borderRadius:3,background:"#dbeafe",color:"#1d4ed8",marginRight:2}}>社</span>{st.name}
            </td>
            {dates.map(ds=>{
              const shift=getShift(ds).find(s=>s.name===st.name);const dow=new Date(ds).getDay();
              const bg=getCellBg(shift,dow,ds);const isToday=ds===today;
              return <td key={ds} onClick={()=>handleCellClick(ds,st.name,"正社員")} style={{
                minWidth:42,width:42,padding:"2px",textAlign:"center",fontSize:11,fontWeight:700,background:bg,
                borderRight:"1px solid #e5e7eb",borderBottom:"1px solid #e5e7eb",cursor:"pointer",
                boxShadow:isToday?"inset 0 0 0 2px #f59e0b":"none",
                color:shift?.symbol==="●"?"#1d4ed8":shift?.symbol==="公"?"#64748b":shift?.symbol==="希"?"#d97706":shift?.symbol==="有"?"#059669":shift?.symbol==="出"?"#7c3aed":"#d1d5db",
                height:36,verticalAlign:"middle"
              }}>{shift?shift.symbol:<span style={{color:"#e5e7eb",fontSize:14}}>+</span>}</td>;
            })}
          </tr>)}

          {/* アルバイト */}
          {partTimeStaff.length>0&&<tr><td colSpan={dates.length+1} style={{background:"#fffbeb",padding:"3px 8px",fontSize:9,fontWeight:700,color:"#92400e",borderBottom:"1px solid #fde68a"}}>アルバイト</td></tr>}
          {partTimeStaff.map(st=><tr key={st.name}>
            <td style={{position:"sticky",left:0,zIndex:2,width:72,minWidth:72,padding:"4px 6px",fontWeight:600,fontSize:10,background:"#fff",borderRight:"2px solid #e5e7eb",borderBottom:"1px solid #e5e7eb",whiteSpace:"nowrap"}}>
              <span style={{fontSize:8,fontWeight:700,padding:"1px 4px",borderRadius:3,background:"#fef3c7",color:"#92400e",marginRight:2}}>ア</span>{st.name}
            </td>
            {dates.map(ds=>{
              const shift=getShift(ds).find(s=>s.name===st.name);const dow=new Date(ds).getDay();
              const bg=getCellBg(shift,dow,ds);const isToday=ds===today;
              return <td key={ds} onClick={()=>handleCellClick(ds,st.name,"アルバイト")} style={{
                minWidth:42,width:42,padding:"1px",textAlign:"center",background:bg,
                borderRight:"1px solid #e5e7eb",borderBottom:"1px solid #e5e7eb",cursor:"pointer",
                boxShadow:isToday?"inset 0 0 0 2px #f59e0b":"none",
                height:36,verticalAlign:"middle"
              }}>{shift?getCellDisplay(shift,"アルバイト"):<span style={{color:"#e5e7eb",fontSize:14}}>+</span>}</td>;
            })}
          </tr>)}

          {/* 人員合計行 */}
          <tr style={{fontWeight:700,background:"#D2B48C"}}>
            <td style={{position:"sticky",left:0,zIndex:2,width:72,minWidth:72,padding:"4px 6px",fontSize:10,fontWeight:700,background:"#D2B48C",borderRight:"2px solid #b8976a",borderBottom:"1px solid #b8976a"}}>人員</td>
            {dates.map(ds=>{const hc=calcHeadcount(ds);return <td key={ds} style={{minWidth:42,width:42,padding:"3px 1px",textAlign:"center",fontSize:11,fontWeight:800,background:"#D2B48C",borderRight:"1px solid #b8976a",borderBottom:"1px solid #b8976a",color:hc===0?"#b8976a":"#1e293b"}}>{hc}</td>;})}
          </tr>
          {/* タスク数合計行 */}
          <tr style={{fontWeight:700,background:"#f0fdf4"}}>
            <td style={{position:"sticky",left:0,zIndex:2,width:72,minWidth:72,padding:"4px 6px",fontSize:10,fontWeight:700,background:"#f0fdf4",borderRight:"2px solid #d1d5db",borderBottom:"1px solid #d1d5db"}}>タスク</td>
            {dates.map(ds=>{const tc=monthTasks[ds];const total=tc?tc.total:0;const hc=calcHeadcount(ds);
              const ratio=hc>0?total/hc:0;const rBg=total===0?"#f0fdf4":ratio>3?"#fecaca":ratio>2?"#fed7aa":"#f0fdf4";
              return <td key={ds} style={{minWidth:42,width:42,padding:"2px 1px",textAlign:"center",fontSize:10,fontWeight:800,background:rBg,borderRight:"1px solid #d1d5db",borderBottom:"1px solid #d1d5db",color:total===0?"#d1d5db":"#1e293b"}}>{total||""}</td>;})}
          </tr>
          {/* タスク内訳行（SPK: DEL/COL/洗車のみ） */}
          {[{key:"洗車",label:"洗車",color:"#795548",bg:"#FFFDE7"},{key:"DEL",label:"DEL",color:"#0891b2",bg:"#ecfeff"},{key:"COL",label:"COL",color:"#0d9488",bg:"#f0fdfa"}].map(cat=>
          <tr key={cat.key} style={{background:cat.bg}}>
            <td style={{position:"sticky",left:0,zIndex:2,width:72,minWidth:72,padding:"3px 6px",fontSize:8,fontWeight:700,background:cat.bg,borderRight:"2px solid #d1d5db",borderBottom:"1px solid #e5e7eb",color:cat.color}}>{cat.label}</td>
            {dates.map(ds=>{const tc=monthTasks[ds];const cnt=tc?tc[cat.key]:0;
              return <td key={ds} style={{minWidth:42,width:42,padding:"1px",textAlign:"center",fontSize:9,fontWeight:700,background:cat.bg,borderRight:"1px solid #e5e7eb",borderBottom:"1px solid #e5e7eb",color:cnt?cat.color:"#e5e7eb"}}>{cnt||""}</td>;})}
          </tr>)}
        </tbody>
      </table>
    </div>

    {/* サマリーテーブル */}
    <div className="px-4 py-3 border-t border-gray-200 bg-gray-50 overflow-x-auto">
      <div style={{fontSize:11,fontWeight:700,color:"#374151",marginBottom:6}}>月間サマリー</div>
      <table style={{fontSize:10,borderCollapse:"collapse",width:"100%"}}>
        <thead><tr style={{background:"#e5e7eb"}}>
          <th style={{padding:"5px 8px",textAlign:"left",fontWeight:700,border:"1px solid #d1d5db",minWidth:80}}>名前</th>
          <th style={{padding:"5px 6px",textAlign:"center",fontWeight:700,border:"1px solid #d1d5db",minWidth:40,color:"#2563eb"}}>出勤</th>
          <th style={{padding:"5px 6px",textAlign:"center",fontWeight:700,border:"1px solid #d1d5db",minWidth:40,color:"#64748b"}}>公休</th>
          <th style={{padding:"5px 6px",textAlign:"center",fontWeight:700,border:"1px solid #d1d5db",minWidth:40,color:"#d97706"}}>希望休</th>
          <th style={{padding:"5px 6px",textAlign:"center",fontWeight:700,border:"1px solid #d1d5db",minWidth:40,color:"#059669"}}>有給</th>
          <th style={{padding:"5px 6px",textAlign:"center",fontWeight:700,border:"1px solid #d1d5db",minWidth:40,color:"#7c3aed"}}>出張</th>
          <th style={{padding:"5px 6px",textAlign:"center",fontWeight:700,border:"1px solid #d1d5db",minWidth:40}}>合計</th>
        </tr></thead>
        <tbody>
          {staff.map(s=>{
            const staffSymCounts={};let workDays=0;
            const isP=s.type==="アルバイト";
            dates.forEach(ds=>{
              const sShift=getShift(ds).find(sh=>sh.name===s.name);
              if(!sShift)return;
              if(sShift.symbol){
                staffSymCounts[sShift.symbol]=(staffSymCounts[sShift.symbol]||0)+1;
              }else if(isP&&sShift.start&&sShift.end){
                workDays++;
              }
            });
            const symWork=staffSymCounts["●"]||0;
            const totalWork=symWork+workDays;
            const total=totalWork+(staffSymCounts["公"]||0)+(staffSymCounts["希"]||0)+(staffSymCounts["有"]||0)+(staffSymCounts["出"]||0);
            return <tr key={s.name} style={{background:isP?"#fffbeb":"#fff",borderBottom:"1px solid #d1d5db"}}>
              <td style={{padding:"4px 8px",border:"1px solid #d1d5db",fontWeight:600,fontSize:10}}>
                <span style={{fontSize:8,fontWeight:700,padding:"1px 4px",borderRadius:3,background:isP?"#fef3c7":"#dbeafe",color:isP?"#92400e":"#1d4ed8",marginRight:4}}>{isP?"ア":"社"}</span>{s.name}
              </td>
              <td style={{padding:"4px 6px",border:"1px solid #d1d5db",textAlign:"center",fontWeight:totalWork>0?700:400,color:totalWork>0?"#1d4ed8":"#d1d5db"}}>{totalWork}</td>
              <td style={{padding:"4px 6px",border:"1px solid #d1d5db",textAlign:"center",color:(staffSymCounts["公"]||0)>0?"#64748b":"#d1d5db"}}>{staffSymCounts["公"]||0}</td>
              <td style={{padding:"4px 6px",border:"1px solid #d1d5db",textAlign:"center",color:(staffSymCounts["希"]||0)>0?"#d97706":"#d1d5db"}}>{staffSymCounts["希"]||0}</td>
              <td style={{padding:"4px 6px",border:"1px solid #d1d5db",textAlign:"center",color:(staffSymCounts["有"]||0)>0?"#059669":"#d1d5db"}}>{staffSymCounts["有"]||0}</td>
              <td style={{padding:"4px 6px",border:"1px solid #d1d5db",textAlign:"center",color:(staffSymCounts["出"]||0)>0?"#7c3aed":"#d1d5db"}}>{staffSymCounts["出"]||0}</td>
              <td style={{padding:"4px 6px",border:"1px solid #d1d5db",textAlign:"center",fontWeight:700}}>{total}</td>
            </tr>;
          })}
        </tbody>
      </table>
    </div>

    {/* セル編集モーダル（日毎のシフト内容設定） */}
    {cellEdit&&<div className="modal-overlay" onClick={()=>setCellEdit(null)}><div className="modal-box" style={{maxWidth:340,padding:0,borderRadius:16,overflow:"hidden"}} onClick={e=>e.stopPropagation()}>
      {/* ヘッダー */}
      <div style={{background:"#D2B48C",padding:"14px 20px",display:"flex",justifyContent:"space-between",alignItems:"center"}}>
        <div>
          <div style={{fontSize:14,fontWeight:800,color:"#1e293b"}}>{cellEdit.name}</div>
          <div style={{fontSize:12,color:"#78716c"}}>{fmtD(cellEdit.dateStr)} ({WK[new Date(cellEdit.dateStr).getDay()]})</div>
        </div>
        <button onClick={()=>setCellEdit(null)} style={{background:"none",border:"none",fontSize:18,color:"#78716c",cursor:"pointer",padding:4}}>✕</button>
      </div>
      <div style={{padding:"16px 20px"}}>
        {/* シフト種別選択（正社員のみ） */}
        {cellEdit.type==="正社員"&&<div style={{marginBottom:16}}>
          <label style={{fontSize:11,color:"#64748b",fontWeight:700,display:"block",marginBottom:8}}>出勤内容</label>
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:6}}>
            {SHIFT_OPTIONS.map(o=>{
              const sel=cellEdit.symbol===o.s;
              return <button key={o.s} onClick={()=>setCellEdit({...cellEdit,symbol:o.s})} style={{
                padding:"10px 8px",borderRadius:10,fontSize:12,fontWeight:700,border:"2px solid",cursor:"pointer",transition:"all .15s",
                background:sel?o.color:"#fff",color:sel?"#fff":o.color,borderColor:sel?o.color:"#e2e8f0",
                display:"flex",alignItems:"center",justifyContent:"center",gap:6
              }}><span style={{fontSize:16}}>{o.s}</span> {o.label}</button>;
            })}
          </div>
        </div>}
        {/* 時間設定（出勤・出張の場合、またはアルバイト） */}
        {(cellEdit.type==="アルバイト"||cellEdit.symbol==="●"||cellEdit.symbol==="出")&&<div style={{marginBottom:16}}>
          <label style={{fontSize:11,color:"#64748b",fontWeight:700,display:"block",marginBottom:8}}>勤務時間</label>
          <div style={{display:"flex",gap:10,alignItems:"center"}}>
            <input type="time" value={cellEdit.start} onChange={e=>setCellEdit({...cellEdit,start:e.target.value})} style={{flex:1,padding:"10px 10px",borderRadius:10,border:"1px solid #e2e8f0",fontSize:15,textAlign:"center"}}/>
            <span style={{color:"#94a3b8",fontWeight:700,fontSize:14}}>〜</span>
            <input type="time" value={cellEdit.end} onChange={e=>setCellEdit({...cellEdit,end:e.target.value})} style={{flex:1,padding:"10px 10px",borderRadius:10,border:"1px solid #e2e8f0",fontSize:15,textAlign:"center"}}/>
          </div>
        </div>}
        {/* ボタン */}
        <div style={{display:"flex",gap:8,marginTop:8}}>
          <button onClick={saveCellEdit} style={{flex:1,padding:"12px 16px",borderRadius:12,border:"none",background:"#2563eb",fontSize:13,fontWeight:700,color:"#fff",cursor:"pointer"}}>
            {cellEdit.isNew?"登録":"保存"}
          </button>
          {!cellEdit.isNew&&<button onClick={deleteCellEdit} style={{padding:"12px 16px",borderRadius:12,border:"1px solid #fecaca",background:"#fef2f2",fontSize:13,fontWeight:700,color:"#dc2626",cursor:"pointer"}}>削除</button>}
          <button onClick={()=>setCellEdit(null)} style={{padding:"12px 16px",borderRadius:12,border:"1px solid #e2e8f0",background:"#fff",fontSize:13,fontWeight:600,color:"#64748b",cursor:"pointer"}}>戻る</button>
        </div>
      </div>
    </div></div>}
  </div>;
}

/* ==========================================
   新規予約登録フォーム（手動 + CSV自動配車）
   ========================================== */
function ReservationForm({onAdd,onBulkAdd,vehicles,vehicleClasses,onClose,prefill}){
  const init=prefill||{name:"",people:1,delPlace:"",colPlace:"",vehicle:"A",vehicleCode:"",insurance:"免責",lendDate:"",returnDate:"",lendTime:"09:00",returnTime:"18:00",id:"M"+Date.now(),ota:"O",flight:""};
  const[f,setF]=useState(init);
  const[mode,setMode]=useState("manual"); // manual / csv
  const[csvResult,setCsvResult]=useState(null);
  const[csvLogs,setCsvLogs]=useState([]);

  const upF=(k,v)=>setF(p=>({...p,[k]:v}));

  // CSV取込（配車は手動）
  const handleCSV=(e)=>{
    const file=e.target.files?.[0];if(!file)return;
    readFile(file,text=>{
      const rows=parseCSV(text);
      const res=detectParse(rows);
      if(!res){setCsvLogs([{t:"err",m:"CSV形式を検出できません"}]);return;}
      const skipMsg=res.skippedOther>0?` (他店舗${res.skippedOther}件除外)`:"";
      setCsvLogs([{t:"ok",m:`${OTA[res.ota].name} 札幌${res.data.length}件${skipMsg}`}]);
      setCsvResult({data:res.data,fleet:{},ota:res.ota});
    });
  };
  const commitCSV=()=>{if(csvResult)onBulkAdd(csvResult.data,csvResult.fleet);};

  const submit=()=>{
    const r={...f,id:f.id||"M"+Date.now(),ota:f.ota||"O",status:"confirmed",visitType:"DEL",returnType:"COL",delTime:f.lendTime,colTime:f.returnTime,delPlace:f.delPlace||"",colPlace:f.colPlace||""};
    onAdd(r,f.vehicleCode);
  };

  return <div className="modal-overlay" onClick={onClose}><div className="modal-box" style={{maxWidth:560,maxHeight:"90vh"}} onClick={e=>e.stopPropagation()}>
    <div style={{padding:"16px 20px",borderBottom:"1px solid #e5e7eb"}}>
      <div className="flex items-center justify-between">
        <h3 className="font-bold text-base">新規予約登録</h3>
        <button onClick={onClose} className="text-gray-400 hover:text-gray-600 text-lg">✕</button>
      </div>
      <div className="flex gap-2 mt-2">
        <button onClick={()=>setMode("manual")} className="px-3 py-1 rounded-lg text-xs font-bold" style={{background:mode==="manual"?"#2563eb":"#f1f5f9",color:mode==="manual"?"#fff":"#374151"}}>手動入力</button>
        <button onClick={()=>setMode("csv")} className="px-3 py-1 rounded-lg text-xs font-bold" style={{background:mode==="csv"?"#2563eb":"#f1f5f9",color:mode==="csv"?"#fff":"#374151"}}>CSV一括取込</button>
      </div>
    </div>

    <div style={{padding:"12px 20px",overflowY:"auto",maxHeight:"calc(90vh - 120px)"}}>
      {mode==="csv"?<div>
        <p className="text-xs text-gray-500 mb-2">CSVをアップロードして予約を一括登録します（配車は配車表から手動で行います）</p>
        <label className="flex flex-col items-center p-6 rounded-xl border-2 border-dashed border-blue-300 bg-blue-50 cursor-pointer hover:bg-blue-100 transition mb-3">
          <span style={{fontSize:28}}>📄</span>
          <span className="text-sm font-semibold text-blue-700 mt-1">CSVファイルを選択</span>
          <input type="file" accept=".csv,.txt" className="hidden" onChange={handleCSV}/>
        </label>
        {csvLogs.map((l,i)=><div key={i} className="text-xs px-2 py-1 rounded mb-1" style={{background:l.t==="err"?"#fef2f2":"#f0fdf4",color:l.t==="err"?"#b91c1c":"#15803d"}}>{l.t==="err"?"✗":"✓"} {l.m}</div>)}
        {csvResult&&<div className="mt-3">
          <div className="text-sm font-bold mb-2">配車プレビュー（{csvResult.data.length}件）</div>
          <div style={{maxHeight:300,overflowY:"auto"}} className="border rounded-lg">
            <table style={{width:"100%",borderCollapse:"collapse",fontSize:10}}><thead><tr style={{background:"#f1f5f9"}}>
              <th className="px-2 py-1 text-left border-b">予約者</th><th className="px-2 py-1 text-left border-b">クラス</th><th className="px-2 py-1 text-left border-b">貸出</th><th className="px-2 py-1 text-left border-b">返却</th><th className="px-2 py-1 text-left border-b">状態</th>
            </tr></thead><tbody>
              {csvResult.data.map((r,i)=><tr key={i} className="border-b border-gray-100">
                <td className="px-2 py-1 font-semibold">{r.name}</td>
                <td className="px-2 py-1">{r.vehicle}</td>
                <td className="px-2 py-1">{fmtD(r.lendDate)} {r.lendTime}</td>
                <td className="px-2 py-1">{fmtD(r.returnDate)} {r.returnTime}</td>
                <td className="px-2 py-1"><span style={{color:"#f59e0b",fontWeight:700}}>未配車</span></td>
              </tr>)}
            </tbody></table>
          </div>
          <button onClick={commitCSV} className="btn-primary mt-3 w-full" style={{padding:10}}>この内容で一括登録（配車は配車表で手動）</button>
        </div>}
      </div>:
      <div className="space-y-3">
        <div style={{display:"grid",gridTemplateColumns:"1fr 80px",gap:8}}>
          <div><label className="text-xs text-gray-500">予約者名</label><input value={f.name} onChange={e=>upF("name",e.target.value)} className="input-s" placeholder="タケモト ショウタ"/></div>
          <div><label className="text-xs text-gray-500">人数</label><input type="number" value={f.people} onChange={e=>upF("people",+e.target.value)} className="input-s"/></div>
        </div>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
          <div><label className="text-xs text-gray-500">貸出日</label><input type="date" value={f.lendDate} onChange={e=>upF("lendDate",e.target.value)} className="input-s"/></div>
          <div><label className="text-xs text-gray-500">貸出時間</label><input value={f.lendTime} onChange={e=>upF("lendTime",e.target.value)} className="input-s" placeholder="09:00"/></div>
        </div>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
          <div><label className="text-xs text-gray-500">返却日</label><input type="date" value={f.returnDate} onChange={e=>upF("returnDate",e.target.value)} className="input-s"/></div>
          <div><label className="text-xs text-gray-500">返却時間</label><input value={f.returnTime} onChange={e=>upF("returnTime",e.target.value)} className="input-s" placeholder="18:00"/></div>
        </div>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
          <div><label className="text-xs text-gray-500">予約車種（クラス）</label><select value={f.vehicle} onChange={e=>upF("vehicle",e.target.value)} className="input-s">{vehicleClasses.map(c=><option key={c.type} value={c.type}>{c.type}クラス — {c.label}</option>)}</select></div>
          <div><label className="text-xs text-gray-500">車両（ナンバー）</label><select value={f.vehicleCode} onChange={e=>upF("vehicleCode",e.target.value)} className="input-s"><option value="">未定（配車表で手動）</option>{vehicles.filter(v=>v.type===f.vehicle).map(v=><option key={v.id} value={v.code}>{v.name} ({v.no})</option>)}</select></div>
        </div>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
          <div><label className="text-xs text-gray-500">補償プラン</label><select value={f.insurance} onChange={e=>upF("insurance",e.target.value)} className="input-s"><option>免責</option><option>NOC</option></select></div>
          <div><label className="text-xs text-gray-500">OTA（予約先）</label><select value={f.ota} onChange={e=>upF("ota",e.target.value)} className="input-s">{Object.entries(OTA).map(([k,o])=><option key={k} value={k}>{o.name}</option>)}<option value="direct">直接予約</option></select></div>
        </div>
        <div><label className="text-xs text-gray-500">予約番号</label><input value={f.id} onChange={e=>upF("id",e.target.value)} className="input-s"/></div>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
          <div><label className="text-xs text-gray-500">お届け場所</label><input value={f.delPlace} onChange={e=>upF("delPlace",e.target.value)} className="input-s" placeholder="新千歳空港 etc."/></div>
          <div><label className="text-xs text-gray-500">回収場所</label><input value={f.colPlace} onChange={e=>upF("colPlace",e.target.value)} className="input-s" placeholder="新千歳空港 etc."/></div>
        </div>
        <div><label className="text-xs text-gray-500">到着便名</label><input value={f.flight||""} onChange={e=>upF("flight",e.target.value)} className="input-s" placeholder="ANA123"/></div>
        <button onClick={submit} className="btn-primary w-full" style={{padding:10,marginTop:8}}>予約を登録</button>
      </div>}
    </div>
  </div></div>;
}

/* ==========================================
   タイムテーブル
   ========================================== */
function TimeTable({tasks,staffCount}){
  const lend=tasks.filter(t=>["DEL","PU","来店"].includes(t.type));const ret=tasks.filter(t=>["COL","BD","返却"].includes(t.type));
  const rows=[{l:"人員",bg:"#e0e7ff",fg:"#4338ca",b:true,data:SLOTS.map(()=>staffCount),total:staffCount},{l:"貸出計",bg:"#dbeafe",fg:"#1e40af",b:true,w:true,data:SLOTS.map(s=>lend.filter(t=>t.time===s).length),total:lend.length},{l:"┗DEL",bg:"#eff6ff",fg:"#2563eb",data:SLOTS.map(s=>tasks.filter(t=>t.type==="DEL"&&t.time===s).length),total:tasks.filter(t=>t.type==="DEL").length},{l:"┗PU/来店",bg:"#f5f3ff",fg:"#6d28d9",data:SLOTS.map(s=>tasks.filter(t=>(t.type==="PU"||t.type==="来店")&&t.time===s).length),total:tasks.filter(t=>t.type==="PU"||t.type==="来店").length},{l:"返却計",bg:"#ffedd5",fg:"#c2410c",b:true,w:true,data:SLOTS.map(s=>ret.filter(t=>t.time===s).length),total:ret.length},{l:"┗COL",bg:"#fff7ed",fg:"#ea580c",data:SLOTS.map(s=>tasks.filter(t=>t.type==="COL"&&t.time===s).length),total:tasks.filter(t=>t.type==="COL").length},{l:"┗返却/BD",bg:"#fffbeb",fg:"#b45309",data:SLOTS.map(s=>tasks.filter(t=>(t.type==="返却"||t.type==="BD")&&t.time===s).length),total:tasks.filter(t=>t.type==="返却"||t.type==="BD").length},{l:"洗車/他",bg:"#f8fafc",fg:"#64748b",data:SLOTS.map(s=>tasks.filter(t=>!["DEL","PU","来店","COL","BD","返却"].includes(t.type)&&t.time===s).length),total:tasks.filter(t=>!["DEL","PU","来店","COL","BD","返却"].includes(t.type)).length}];
  return <div className="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden"><div style={{overflowX:"auto"}}><table style={{width:"100%",borderCollapse:"collapse",fontSize:10,whiteSpace:"nowrap"}}><thead><tr style={{background:"#f1f5f9"}}><th style={{position:"sticky",left:0,zIndex:2,background:"#f1f5f9",padding:"4px 5px",textAlign:"left",fontWeight:600,minWidth:60,borderBottom:"1px solid #e2e8f0",fontSize:9}}>TT</th><th style={{padding:"4px 2px",textAlign:"center",fontWeight:600,borderBottom:"1px solid #e2e8f0",fontSize:9}}>計</th>{SLOTS.map(s=><th key={s} style={{padding:"4px 2px",textAlign:"center",fontWeight:500,color:"#64748b",borderBottom:"1px solid #e2e8f0",minWidth:26,fontSize:8}}>{s}</th>)}</tr></thead><tbody>{rows.map((r,i)=><tr key={i}><td style={{position:"sticky",left:0,zIndex:2,background:r.bg,color:r.fg,padding:"2px 5px",fontWeight:r.b?700:500,fontSize:9}}>{r.l}</td><td style={{background:r.bg,color:r.fg,padding:"2px 2px",textAlign:"center",fontWeight:700,fontSize:9}}>{r.total||""}</td>{r.data.map((v,ci)=>{const over=r.w&&v>staffCount;return <td key={ci} style={{background:over?"#fecaca":r.bg,color:over?"#dc2626":v>0?r.fg:"#e2e8f0",padding:"2px",textAlign:"center",fontWeight:over||v>0?700:400,fontSize:9}}>{v||""}</td>;})}</tr>)}</tbody></table></div></div>;
}

/* ==========================================
   配車管理タイムライン（ガントチャート）
   ========================================== */
function FleetTimeline({data,fleet,onFleetChange,today,maintenance,onMaintenanceChange,vehicles,vehicleClasses,onAddReservation,onBulkAddReservation,onCancelReservation,onReassignVehicle,onUpdateReservation,unassignedReasons,onVehicleDetail}){
  const scrollRef=useRef(null);const[tooltip,setTooltip]=useState(null);const[viewMode,setViewMode]=useState("month");const[baseDate,setBaseDate]=useState(today);const[collapsed,setCollapsed]=useState(()=>window.innerWidth<=768?{unassignedAlert:true}:{});const[showMaintForm,setShowMaintForm]=useState(null);const[showResForm,setShowResForm]=useState(null);
  const[dragInfo,setDragInfo]=useState(null);const[dropTarget,setDropTarget]=useState(null);
  const WK=["日","月","火","水","木","金","土"];

  const dates=useMemo(()=>{const dt=new Date(baseDate+"T00:00:00");if(viewMode==="month"){const y=dt.getFullYear(),m=dt.getMonth();const days=new Date(y,m+1,0).getDate();return Array.from({length:days},(_,i)=>toLD(new Date(y,m,i+1)));}else if(viewMode==="week"){const d=new Date(baseDate+"T00:00:00");d.setDate(d.getDate()-d.getDay());return Array.from({length:7},(_,i)=>dOff(toLD(d),i));}else return[baseDate];},[baseDate,viewMode]);

  const[isMobile,setIsMobile]=useState(window.innerWidth<=768);
  useEffect(()=>{const h=()=>setIsMobile(window.innerWidth<=768);window.addEventListener("resize",h);return()=>window.removeEventListener("resize",h);},[]);
  const COL_W=viewMode==="month"?(isMobile?60:80):viewMode==="week"?(isMobile?100:140):600;const LEFT_W=isMobile?100:260;const ROW_H=30;const CLASS_H=28;
  const monthLabel=useMemo(()=>{const dt=new Date(baseDate+"T00:00:00");return`${dt.getFullYear()}年${dt.getMonth()+1}月`;},[baseDate]);

  // ★ 月別サマリー（出発・返却・洗車件数）
  const monthSummary=useMemo(()=>{
    const bd=new Date(baseDate+"T00:00:00");const y=bd.getFullYear(),m=bd.getMonth();
    const mStr=String(y)+"-"+String(m+1).padStart(2,"0");
    let dep=0,ret=0;
    data.forEach(r=>{
      if(r.status==="cancelled")return;
      if(r.lendDate&&r.lendDate.startsWith(mStr))dep++;
      if(r.returnDate&&r.returnDate.startsWith(mStr))ret++;
    });
    return{dep,ret,wash:dep};
  },[data,baseDate]);

  useEffect(()=>{if(scrollRef.current){const ti=dates.indexOf(today);if(ti>=0)scrollRef.current.scrollLeft=Math.max(0,(ti-2)*COL_W);}},[dates,today]);
  const goToday=()=>setBaseDate(today);
  const goPrev=()=>{const dt=new Date(baseDate+"T00:00:00");if(viewMode==="month")dt.setMonth(dt.getMonth()-1);else if(viewMode==="week")dt.setDate(dt.getDate()-7);else dt.setDate(dt.getDate()-1);setBaseDate(toLD(dt));};
  const goNext=()=>{const dt=new Date(baseDate+"T00:00:00");if(viewMode==="month")dt.setMonth(dt.getMonth()+1);else if(viewMode==="week")dt.setDate(dt.getDate()+7);else dt.setDate(dt.getDate()+1);setBaseDate(toLD(dt));};
  const toggleClass=(t)=>setCollapsed(p=>({...p,[t]:!p[t]}));

  const vehicleBars=useMemo(()=>{
    const bars={};vehicles.forEach(v=>{bars[v.code]=[];});
    data.forEach(r=>{const vc=fleet[r.id];if(!vc||!bars[vc])return;if(!r.lendDate||!r.returnDate)return;const ld=norm(r.lendDate),rd=norm(r.returnDate);if(!ld||!rd)return;const si=dates.indexOf(ld),ei=dates.indexOf(rd);if(si<0&&ei<0)return;const s=Math.max(si,0),e=Math.min(ei>=0?ei:dates.length-1,dates.length-1);bars[vc].push({type:"reservation",r,startI:s,endI:e,left:s*COL_W,width:(e-s+1)*COL_W-2});});
    (maintenance||[]).forEach(m=>{if(!bars[m.vehicleCode])return;const si=dates.indexOf(m.startDate),ei=dates.indexOf(m.endDate);if(si<0&&ei<0)return;const s=Math.max(si,0),e=Math.min(ei>=0?ei:dates.length-1,dates.length-1);bars[m.vehicleCode].push({type:"maintenance",m,startI:s,endI:e,left:s*COL_W,width:(e-s+1)*COL_W-2});});
    return bars;
  },[data,fleet,dates,maintenance,vehicles]);

  // 車両ごとの月別稼働率（表示期間の月の1日〜末日で計算）
  const utilRates=useMemo(()=>{
    const bd=new Date(baseDate+"T00:00:00");const y=bd.getFullYear(),m=bd.getMonth();
    const dim=new Date(y,m+1,0).getDate();
    const rates={};
    vehicles.forEach(v=>{
      // ★ 日単位のSetで重複カウントを防止
      const rentalDays=new Set();
      const maintDays=new Set();
      const ms=new Date(y,m,1),me=new Date(y,m,dim);
      // 予約による稼働日
      data.forEach(r=>{if(fleet[r.id]!==v.code)return;
        const ld=new Date(norm(r.lendDate)+"T00:00:00"),rd=new Date(norm(r.returnDate)+"T00:00:00");
        const s=ld>ms?ld:ms;const e=rd<me?rd:me;
        for(let d=new Date(s);d<=e;d.setDate(d.getDate()+1)){rentalDays.add(toLD(d));}
      });
      // メンテナンス日数 → 最大稼働日数から減算
      (maintenance||[]).forEach(mt=>{if(mt.vehicleCode!==v.code)return;
        const ld=new Date(norm(mt.startDate)+"T00:00:00"),rd=new Date(norm(mt.endDate)+"T00:00:00");
        const s=ld>ms?ld:ms;const e=rd<me?rd:me;
        for(let d=new Date(s);d<=e;d.setDate(d.getDate()+1)){maintDays.add(toLD(d));}
      });
      const days=rentalDays.size;
      const availDays=dim-maintDays.size;
      rates[v.code]={days,total:dim,maintDays:maintDays.size,availDays,pct:availDays>0?Math.min(Math.round(days/availDays*100),100):0};
    });
    return rates;
  },[data,fleet,vehicles,maintenance,baseDate]);

  // セルクリック → アクション選択
  const[cellAction,setCellAction]=useState(null);
  const handleCellClick=(vehicleCode,dateStr)=>{
    const existing=data.find(r=>fleet[r.id]===vehicleCode&&norm(r.lendDate)<=dateStr&&norm(r.returnDate)>=dateStr);
    if(existing){setTooltip({type:"reservation",...existing,vc:vehicleCode});return;}
    setCellAction({vehicleCode,date:dateStr});
  };
  const handleBarClick=(e,b)=>{e.stopPropagation();if(b.type==="reservation")setTooltip({type:"reservation",...b.r,vc:fleet[b.r.id]});else setTooltip({type:"maintenance",...b.m});};

  const addMaint=(vc,start,end,label)=>{const m={id:"m"+Date.now(),vehicleCode:vc,startDate:start,endDate:end,label};const next=[...(maintenance||[]),m];onMaintenanceChange(next);DB.saveMaintenance([m]);setShowMaintForm(null);};
  const removeMaint=(id)=>{onMaintenanceChange((maintenance||[]).filter(m=>m.id!==id));DB.deleteMaintenance(id);setTooltip(null);};

  // ドラッグ&ドロップで車両変更
  const handleDragStart=(e,resId)=>{e.dataTransfer.setData("text/plain",resId);e.dataTransfer.effectAllowed="move";setDragInfo(resId);};
  const handleDragEnd=()=>{setDragInfo(null);setDropTarget(null);};
  const handleDragOver=(e,vehicleCode)=>{
    if(!dragInfo)return;e.preventDefault();e.dataTransfer.dropEffect="move";
    const res=data.find(r=>r.id===dragInfo);if(!res)return;
    const curVc=fleet[dragInfo];if(curVc===vehicleCode){setDropTarget(null);return;}
    // 日付重複のみチェック（クラス制限なし）
    const conflict=checkVehicleConflict(vehicleCode,dragInfo,data,fleet);
    setDropTarget({vc:vehicleCode,ok:!conflict,conflict});
  };
  const handleDrop=(e,vehicleCode)=>{
    e.preventDefault();const resId=e.dataTransfer.getData("text/plain");if(!resId)return;
    setDragInfo(null);setDropTarget(null);
    const res=data.find(r=>r.id===resId);if(!res)return;
    const curVc=fleet[resId];if(curVc===vehicleCode)return;
    const curV=vehicles.find(v=>v.code===curVc);const targetV=vehicles.find(v=>v.code===vehicleCode);
    const conflict=checkVehicleConflict(vehicleCode,resId,data,fleet);
    if(conflict){alert((targetV?targetV.name:vehicleCode)+" は "+fmtD(conflict.lendDate)+"〜"+fmtD(conflict.returnDate)+" に「"+conflict.name+"」様の予約が入っているため変更できません。");return;}
    if(!window.confirm(res.name+" 様の配車を\n「"+(curV?curV.name:"未割当")+"」→「"+(targetV?targetV.name:vehicleCode)+"」\nに変更しますか？\n\n※OPシートの車両情報も同時に更新されます"))return;
    if(onReassignVehicle)onReassignVehicle(resId,vehicleCode);
    else onFleetChange({...fleet,[resId]:vehicleCode});
  };

  const groups=useMemo(()=>vehicleClasses.map(vc=>({...vc,items:vehicles.filter(v=>v.type===vc.type).sort((a,b)=>{const ins=(a.insuranceVeh?1:0)-(b.insuranceVeh?1:0);if(ins!==0)return ins;const idA=parseInt(String(a.id).replace(/\D/g,""))||0;const idB=parseInt(String(b.id).replace(/\D/g,""))||0;return idA-idB;})})).filter(g=>g.items.length>0),[vehicles,vehicleClasses]);

  return <div style={{display:"flex",flexDirection:"column",background:"#fff",borderRadius:12,boxShadow:"0 1px 3px rgba(0,0,0,.06)",border:"1px solid #e5e7eb",overflow:"hidden",height:"100%",minHeight:0}}>
    <div style={{padding:isMobile?"4px 6px":"8px 12px",background:"#f8fafc",borderBottom:"1px solid #e5e7eb",display:"flex",alignItems:"center",justifyContent:"space-between",flexWrap:"wrap",gap:isMobile?4:8,flexShrink:0}}>
      <div style={{display:"flex",alignItems:"center",gap:isMobile?2:8}}>
        <button onClick={goToday} style={{padding:isMobile?"2px 4px":"4px 8px",background:"#fff",border:"1px solid #d1d5db",borderRadius:4,fontSize:isMobile?9:12,fontWeight:600,cursor:"pointer"}}>今日</button>
        <button onClick={goPrev} style={{padding:isMobile?"2px 4px":"4px 8px",background:"#fff",border:"1px solid #d1d5db",borderRadius:4,fontSize:isMobile?10:14,cursor:"pointer"}}>◀</button>
        <button onClick={goNext} style={{padding:isMobile?"2px 4px":"4px 8px",background:"#fff",border:"1px solid #d1d5db",borderRadius:4,fontSize:isMobile?10:14,cursor:"pointer"}}>▶</button>
        <span style={{fontSize:isMobile?11:14,fontWeight:700,color:"#1e293b",marginLeft:2}}>{monthLabel}</span>
        <span style={{display:"inline-flex",gap:isMobile?4:8,marginLeft:isMobile?4:12,fontSize:isMobile?8:11,fontWeight:700}}>
          <span style={{background:"#dbeafe",color:"#1e40af",padding:"1px 6px",borderRadius:10,whiteSpace:"nowrap"}}>🚗出発 {monthSummary.dep}</span>
          <span style={{background:"#fef3c7",color:"#92400e",padding:"1px 6px",borderRadius:10,whiteSpace:"nowrap"}}>🔙返却 {monthSummary.ret}</span>
          <span style={{background:"#d1fae5",color:"#065f46",padding:"1px 6px",borderRadius:10,whiteSpace:"nowrap"}}>🧽洗車 {monthSummary.wash}</span>
        </span>
      </div>
      <div style={{display:"flex",alignItems:"center",gap:isMobile?2:8}}>
        <button onClick={()=>setShowResForm({})} style={{padding:isMobile?"2px 6px":"4px 8px",background:"#16a34a",color:"#fff",border:"none",borderRadius:4,fontSize:isMobile?9:12,fontWeight:700,cursor:"pointer"}}>＋予約</button>
        <div style={{display:"flex",border:"1px solid #d1d5db",borderRadius:4,overflow:"hidden"}}>{["day","week","month"].map(m=><button key={m} onClick={()=>setViewMode(m)} style={{padding:isMobile?"2px 4px":"4px 8px",fontSize:isMobile?9:12,fontWeight:600,background:viewMode===m?"#1e40af":"#fff",color:viewMode===m?"#fff":"#374151",border:"none",cursor:"pointer"}}>{m}</button>)}</div>
      </div>
    </div>

    {((unassigned)=>{const ua=data.filter(r=>r.status!=="cancelled"&&!fleet[r.id]&&r.returnDate&&r.returnDate>=today);return ua.length>0?<div style={{borderBottom:"1px solid #fca5a5",background:"#fef2f2",padding:isMobile?"4px 8px":"12px 16px",flexShrink:0,maxHeight:collapsed.unassignedAlert?36:isMobile?120:undefined,overflow:"hidden"}}>
      <div style={{display:"flex",alignItems:"center",gap:6,fontSize:isMobile?10:12,fontWeight:700,color:"#dc2626"}}>
        <span>⚠</span>
        <span>未配車 {ua.length}件</span>
        <button onClick={()=>setCollapsed(p=>({...p,unassignedAlert:!p.unassignedAlert}))} style={{marginLeft:"auto",background:"none",border:"none",cursor:"pointer",color:"#dc2626",fontSize:12,fontWeight:600}}>{collapsed.unassignedAlert?"▶":"▼"}</button>
      </div>
      {!collapsed.unassignedAlert&&<div style={{overflowX:"auto",marginTop:4}}>
        <table style={{fontSize:10,borderCollapse:"collapse",width:"100%"}}>
          <thead><tr style={{background:"#fee2e2"}}>
            <th style={{padding:"4px 6px",textAlign:"left",fontWeight:700,border:"1px solid #fca5a5"}}>OTA</th>
            <th style={{padding:"4px 6px",textAlign:"left",fontWeight:700,border:"1px solid #fca5a5"}}>予約番号</th>
            <th style={{padding:"4px 6px",textAlign:"left",fontWeight:700,border:"1px solid #fca5a5"}}>予約者名</th>
            <th style={{padding:"4px 6px",textAlign:"center",fontWeight:700,border:"1px solid #fca5a5"}}>クラス</th>
            <th style={{padding:"4px 6px",textAlign:"center",fontWeight:700,border:"1px solid #fca5a5"}}>貸出日</th>
            <th style={{padding:"4px 6px",textAlign:"center",fontWeight:700,border:"1px solid #fca5a5"}}>返却日</th>
            <th style={{padding:"4px 6px",textAlign:"left",fontWeight:700,border:"1px solid #fca5a5"}}>未配車理由</th>
            <th style={{padding:"4px 6px",textAlign:"center",fontWeight:700,border:"1px solid #fca5a5"}}>手動配車</th>
          </tr></thead>
          <tbody>
            {ua.map(r=>{
              const reason=(unassignedReasons||{})[r.id]||"";
              return <tr key={r.id} style={{background:"#fff5f5",borderBottom:"1px solid #fca5a5"}}>
              <td style={{padding:"4px 6px",border:"1px solid #fca5a5"}}><OBadge ota={r.ota}/></td>
              <td style={{padding:"4px 6px",border:"1px solid #fca5a5",fontFamily:"monospace",fontSize:9}}>{r.id}</td>
              <td style={{padding:"4px 6px",border:"1px solid #fca5a5"}}>{r.name}</td>
              <td style={{padding:"4px 6px",border:"1px solid #fca5a5",textAlign:"center"}}>{r.vehicle}</td>
              <td style={{padding:"4px 6px",border:"1px solid #fca5a5",textAlign:"center",fontSize:9}}>{fmtD(r.lendDate)}<br/>{r.lendTime}</td>
              <td style={{padding:"4px 6px",border:"1px solid #fca5a5",textAlign:"center",fontSize:9}}>{fmtD(r.returnDate)}<br/>{r.returnTime}</td>
              <td style={{padding:"4px 6px",border:"1px solid #fca5a5",fontSize:8,color:"#b91c1c",maxWidth:180}}>{reason||"不明"}</td>
              <td style={{padding:"4px 6px",border:"1px solid #fca5a5",textAlign:"center"}}>
                <select onChange={e=>{if(!e.target.value)return;if(onReassignVehicle)onReassignVehicle(r.id,e.target.value);else onFleetChange({...fleet,[r.id]:e.target.value});e.target.value="";}} style={{fontSize:9,border:"1px solid #d1d5db",borderRadius:4,padding:"2px 4px"}}>
                  <option value="">車両選択</option>
                  {vehicles.map(v=><option key={v.code} value={v.code}>{v.code}({v.type})</option>)}
                </select>
              </td>
            </tr>;})}
          </tbody>
        </table>
      </div>}
    </div>:null;})()}

    <div ref={scrollRef} style={{flex:1,overflow:"auto",position:"relative"}}>
      <table style={{borderCollapse:"collapse",minWidth:LEFT_W+dates.length*COL_W}}>
        <thead><tr style={{position:"sticky",top:0,zIndex:10}}>
          <th style={{position:"sticky",left:0,zIndex:11,width:LEFT_W,minWidth:LEFT_W,height:44,background:"#f1f5f9",borderBottom:"2px solid #94a3b8",borderRight:"2px solid #94a3b8",padding:"0 8px",textAlign:"left",fontSize:11,fontWeight:700,color:"#1e293b"}}>車両</th>
          {dates.map(d=>{const dt=new Date(d);const dow=dt.getDay();const isToday=d===today;return <th key={d} style={{width:COL_W,minWidth:COL_W,height:44,textAlign:"center",borderRight:"1px solid #cbd5e1",background:isToday?"#dbeafe":"#f1f5f9",borderBottom:"2px solid #94a3b8",padding:0}}><div style={{fontSize:isMobile?9:11,fontWeight:600,color:isToday?"#1d4ed8":"#334155"}}>{dt.getDate()}<span style={{fontSize:isMobile?8:9,fontWeight:dow===0||dow===6?700:400,color:dow===0?"#dc2626":dow===6?"#2563eb":"#64748b",marginLeft:1}}>{WK[dow]}</span></div></th>;})}
        </tr></thead>
        <tbody>
          {groups.map(g=><React.Fragment key={g.type}>
            <tr onClick={()=>toggleClass(g.type)} style={{cursor:"pointer",userSelect:"none"}}>
              <td style={{position:"sticky",left:0,zIndex:5,height:CLASS_H,background:"#f8fafc",borderBottom:"1px solid #e2e8f0",borderRight:"2px solid #94a3b8",padding:"0 6px"}}><span style={{fontSize:10,color:"#64748b",marginRight:3}}>{collapsed[g.type]?"▶":"▼"}</span><span style={{fontSize:isMobile?9:10,fontWeight:700,color:"#334155"}}>{isMobile?g.type:g.type+"クラス（"+g.label+"）"}</span></td>
              {dates.map(d=><td key={d} style={{height:CLASS_H,borderBottom:"1px solid #e2e8f0",background:"#f8fafc",borderRight:"1px solid #e2e8f0"}}/>)}
            </tr>
            {!collapsed[g.type]&&g.items.map(v=>{const bars=vehicleBars[v.code]||[];const isDT=dropTarget&&dropTarget.vc===v.code;const rowHL=isDT?(dropTarget.ok?"rgba(34,197,94,.15)":"rgba(239,68,68,.1)"):"transparent";return <tr key={v.id} onDragOver={e=>handleDragOver(e,v.code)} onDragLeave={()=>setDropTarget(null)} onDrop={e=>handleDrop(e,v.code)} style={{outline:isDT?(dropTarget.ok?"2px solid #22c55e":"2px dashed #ef4444"):"none"}}>
              <td style={{position:"sticky",left:0,zIndex:5,height:ROW_H,background:isDT?(dropTarget.ok?"#dcfce7":"#fef2f2"):"#fff",borderBottom:"1px solid #f1f5f9",borderRight:"2px solid #94a3b8",padding:isMobile?"0 4px":"0 10px",overflow:"hidden",whiteSpace:"nowrap",transition:"background .15s"}}>
                <span onClick={e=>{e.stopPropagation();if(onVehicleDetail)onVehicleDetail(v.code);}} style={{fontSize:isMobile?9:10,fontWeight:700,color:v.insuranceVeh?"#7c3aed":"#2563eb",cursor:"pointer",textDecoration:"underline",textDecorationStyle:"dotted",textUnderlineOffset:2}}>{v.no}{v.insuranceVeh&&isMobile?" 🛡️":""}</span>
                {!isMobile&&<span style={{fontSize:9,color:v.insuranceVeh?"#7c3aed":"#64748b",marginLeft:4}}>{v.name}</span>}
                {v.insuranceVeh&&!isMobile&&<span style={{fontSize:7,fontWeight:700,marginLeft:3,padding:"0 3px",borderRadius:3,background:"#ede9fe",color:"#7c3aed"}}>保険</span>}
                {(()=>{const u=utilRates[v.code];if(!u)return null;const pc=u.pct;const cl=pc>=80?"#dc2626":pc>=50?"#f59e0b":"#22c55e";return <span style={{fontSize:8,fontWeight:700,color:cl,marginLeft:4,background:pc>=80?"#fef2f2":pc>=50?"#fffbeb":"#f0fdf4",padding:"0 3px",borderRadius:3}}>{u.days}日{!isMobile&&" "+pc+"%"}</span>;})()}
              </td>
              {dates.map((d,di)=>{const isToday=d===today;return <td key={d} style={{position:"relative",height:ROW_H,borderBottom:"1px solid #f1f5f9",borderRight:"1px solid #e2e8f0",cursor:dragInfo?"copy":"pointer",background:isDT?rowHL:(isToday?"#eff6ff":"transparent"),padding:0,transition:"background .15s"}} onClick={()=>{if(!dragInfo)handleCellClick(v.code,d);}}>
                {di===0&&bars.map((b,bi)=>{const isRes=b.type==="reservation";const isDragging=dragInfo===b.r?.id;return <div key={bi} className="tl-bar" draggable={isRes} onDragStart={isRes?e=>handleDragStart(e,b.r.id):undefined} onDragEnd={handleDragEnd} onClick={e=>handleBarClick(e,b)} style={{left:b.left,width:Math.max(b.width,20),background:isRes?(isDragging?"#f87171":"#dc2626"):"#2563eb",color:"#fff",fontSize:9,fontWeight:600,boxShadow:isDragging?"0 4px 12px rgba(0,0,0,.3)":"0 1px 3px rgba(0,0,0,.2)",position:"absolute",top:3,bottom:3,zIndex:isDragging?10:2,opacity:isDragging?0.7:1,cursor:isRes?"grab":"pointer",transition:"opacity .15s, box-shadow .15s"}}><span style={{overflow:"hidden",textOverflow:"ellipsis"}}>{isRes?`${b.r.lendTime}-${b.r.returnTime} ${b.r.name} 様`:(b.m.label)}</span></div>;})}
              </td>;})}
            </tr>;})}
          </React.Fragment>)}
        </tbody>
      </table>
    </div>

    {cellAction&&<div className="modal-overlay" onClick={()=>setCellAction(null)}><div className="modal-box" style={{maxWidth:280,padding:20}} onClick={e=>e.stopPropagation()}>
      <h4 className="font-bold text-sm mb-3">{cellAction.vehicleCode} — {fmtD(cellAction.date)}</h4>
      <div className="space-y-2">
        <button onClick={()=>{const v=vehicles.find(x=>x.code===cellAction.vehicleCode);setShowResForm({vehicleCode:cellAction.vehicleCode,lendDate:cellAction.date,vehicle:v?.type||"A"});setCellAction(null);}} className="w-full py-2 bg-green-600 text-white rounded-lg text-sm font-bold hover:bg-green-700">新規予約を登録</button>
        <button onClick={()=>{setShowMaintForm(cellAction);setCellAction(null);}} className="w-full py-2 bg-blue-600 text-white rounded-lg text-sm font-bold hover:bg-blue-700">メンテナンス登録</button>
        <button onClick={()=>setCellAction(null)} className="w-full py-2 bg-gray-100 text-gray-600 rounded-lg text-sm font-semibold">キャンセル</button>
      </div>
    </div></div>}

    {tooltip&&tooltip.type==="reservation"&&<ReservationEditModal t={tooltip} fleet={fleet} vehicles={vehicles} vehicleClasses={vehicleClasses} data={data} onFleetChange={onFleetChange} onReassignVehicle={onReassignVehicle} onCancelReservation={onCancelReservation} onUpdateReservation={onUpdateReservation} onClose={()=>setTooltip(null)}/>}
    {tooltip&&tooltip.type!=="reservation"&&<div className="modal-overlay" style={{background:"rgba(0,0,0,.15)"}} onClick={()=>setTooltip(null)}><div className="modal-box" style={{maxWidth:340,padding:20}} onClick={e=>e.stopPropagation()}>
      <div className="flex items-center justify-between mb-2"><span className="font-bold text-sm">{tooltip.label}</span><button onClick={()=>setTooltip(null)} className="text-gray-400 hover:text-gray-600">✕</button></div>
      <div className="text-xs space-y-1 text-gray-600">
        <div>車両: {tooltip.vehicleCode}</div><div>期間: {fmtD(tooltip.startDate)} 〜 {fmtD(tooltip.endDate)}</div>
        <button onClick={()=>removeMaint(tooltip.id)} className="mt-2 w-full py-1.5 bg-red-50 text-red-600 rounded-lg text-xs font-bold hover:bg-red-100">メンテナンスを削除</button>
      </div>
    </div></div>}

    {showMaintForm&&<div className="modal-overlay" onClick={()=>setShowMaintForm(null)}><div className="modal-box" style={{maxWidth:320,padding:20}} onClick={e=>e.stopPropagation()}><h4 className="font-bold text-sm mb-3">メンテナンス登録</h4><MaintForm vehicleCode={showMaintForm.vehicleCode} startDate={showMaintForm.date} onAdd={addMaint} onClose={()=>setShowMaintForm(null)} vehicles={vehicles}/></div></div>}

    {showResForm&&<ReservationForm prefill={showResForm} onAdd={(r,vc)=>{onAddReservation(r,vc);setShowResForm(null);}} onBulkAdd={(rArr,fl)=>{onBulkAddReservation(rArr,fl);setShowResForm(null);}} vehicles={vehicles} vehicleClasses={vehicleClasses} onClose={()=>setShowResForm(null)}/>}
  </div>;
}

function ReservationEditModal({t,fleet,vehicles,vehicleClasses,data,onFleetChange,onReassignVehicle,onCancelReservation,onUpdateReservation,onClose}){
  const[f,setF]=useState({
    lendTime:t.lendTime||"",delTime:t.delTime||"",delPlace:t.delPlace||"",
    returnTime:t.returnTime||"",colTime:t.colTime||"",colPlace:t.colPlace||"",
    insurance:t.insurance||"",people:t.people||0,flight:t.flight||"",
    name:t.name||"",vehicle:t.vehicle||"",
    optB:!!t.optB,optC:!!t.optC,optJ:!!t.optJ,optUSB:!!t.optUSB,optParasol:!!t.optParasol
  });
  const[vc,setVc]=useState(t.vc||"");
  const[dirty,setDirty]=useState(false);
  const upF=(k,v)=>{setF(p=>({...p,[k]:v}));setDirty(true);};
  const TIME_OPTS=React.useMemo(()=>{const o=[""];for(let h=6;h<=22;h++)for(let m=0;m<60;m+=30){if(h===22&&m>0)break;o.push(`${String(h).padStart(2,"0")}:${String(m).padStart(2,"0")}`);}return o;},[]);
  const save=()=>{
    if(!dirty)return onClose();
    const changes={};
    if(f.lendTime!==t.lendTime)changes.lendTime=f.lendTime;
    if(f.delTime!==(t.delTime||""))changes.delTime=f.delTime;
    if(f.delPlace!==(t.delPlace||""))changes.delPlace=f.delPlace;
    if(f.returnTime!==t.returnTime)changes.returnTime=f.returnTime;
    if(f.colTime!==(t.colTime||""))changes.colTime=f.colTime;
    if(f.colPlace!==(t.colPlace||""))changes.colPlace=f.colPlace;
    if(f.insurance!==(t.insurance||""))changes.insurance=f.insurance;
    if(f.people!==(t.people||0))changes.people=f.people;
    if(f.flight!==(t.flight||""))changes.flight=f.flight;
    if(f.name!==t.name)changes.name=f.name;
    if(f.vehicle!==t.vehicle)changes.vehicle=f.vehicle;
    if(f.optB!==!!t.optB)changes.optB=f.optB;
    if(f.optC!==!!t.optC)changes.optC=f.optC;
    if(f.optJ!==!!t.optJ)changes.optJ=f.optJ;
    if(f.optUSB!==!!t.optUSB)changes.optUSB=f.optUSB;
    if(f.optParasol!==!!t.optParasol)changes.optParasol=f.optParasol;
    if(Object.keys(changes).length){onUpdateReservation(t.id,changes);alert("✅ 予約情報を更新しました");}
    onClose();
  };
  const handleVcChange=(e)=>{
    const newVc=e.target.value;
    if(!newVc){if(!window.confirm("配車を解除しますか？"))return;const nf={...fleet};delete nf[t.id];onFleetChange(nf);setVc("");/* 配車解除→OPシートタスクもクリア */if(onReassignVehicle){try{const _clearTasks=async(d)=>{if(!d)return;const tks=await DB.fetchTasks(d);if(!tks)return;tks.filter(tk=>tk.reservationId===t.id).forEach(tk=>{DB.updateTask({...tk,assignedVehicle:"",plateNo:""},d);});};const ld=norm(t.lendDate),rd=norm(t.returnDate);_clearTasks(ld);if(rd!==ld)_clearTasks(rd);_clearTasks(dOff(ld,-1));}catch(e){console.error("[fleet clear tasks]",e);}}return;}
    const conflict=checkVehicleConflict(newVc,t.id,data,fleet);
    if(conflict){const cv=vehicles.find(x=>x.code===newVc);alert((cv?cv.name:newVc)+" は期間重複のため変更できません。");return;}
    const targetV=vehicles.find(x=>x.code===newVc);
    if(!window.confirm("配車を「"+(targetV?targetV.name:newVc)+"」に変更しますか？"))return;
    if(onReassignVehicle)onReassignVehicle(t.id,newVc);else onFleetChange({...fleet,[t.id]:newVc});
    setVc(newVc);
  };
  const lbl={fontSize:10,color:"#64748b",fontWeight:600,marginBottom:1};
  const inpS={border:"1px solid #e2e8f0",borderRadius:5,padding:"4px 6px",fontSize:11,width:"100%"};
  return <div className="modal-overlay" style={{background:"rgba(0,0,0,.2)"}} onClick={onClose}><div className="modal-box" style={{maxWidth:400,padding:20,maxHeight:"80vh",overflowY:"auto"}} onClick={e=>e.stopPropagation()}>
    <div className="flex items-center justify-between mb-3"><span className="font-bold text-sm">{t.name}</span><button onClick={onClose} className="text-gray-400 hover:text-gray-600">✕</button></div>
    <div style={{fontSize:11,color:"#64748b",marginBottom:8}}><OBadge ota={t.ota}/> <span className="font-mono">{t.id}</span></div>
    <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8,marginBottom:8}}>
      <div><div style={lbl}>貸出日</div><div style={{...inpS,background:"#f8fafc",color:"#334155"}}>{fmtD(t.lendDate)}</div></div>
      <div><div style={lbl}>返却日</div><div style={{...inpS,background:"#f8fafc",color:"#334155"}}>{fmtD(t.returnDate)}</div></div>
    </div>
    <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8,marginBottom:8}}>
      <div><div style={lbl}>DEL時間</div><select value={f.delTime||f.lendTime} onChange={e=>upF("delTime",e.target.value)} style={inpS}>{TIME_OPTS.map(o=><option key={o} value={o}>{o||"-"}</option>)}{f.delTime&&!TIME_OPTS.includes(f.delTime)&&<option value={f.delTime}>{f.delTime}</option>}{f.lendTime&&!TIME_OPTS.includes(f.lendTime)&&!f.delTime&&<option value={f.lendTime}>{f.lendTime}</option>}</select></div>
      <div><div style={lbl}>COL時間</div><select value={f.colTime||f.returnTime} onChange={e=>upF("colTime",e.target.value)} style={inpS}>{TIME_OPTS.map(o=><option key={o} value={o}>{o||"-"}</option>)}{f.colTime&&!TIME_OPTS.includes(f.colTime)&&<option value={f.colTime}>{f.colTime}</option>}{f.returnTime&&!TIME_OPTS.includes(f.returnTime)&&!f.colTime&&<option value={f.returnTime}>{f.returnTime}</option>}</select></div>
    </div>
    <div style={{marginBottom:8}}><div style={lbl}>DEL場所</div><input value={f.delPlace} onChange={e=>upF("delPlace",e.target.value)} style={inpS} placeholder="配達場所を入力"/></div>
    <div style={{marginBottom:8}}><div style={lbl}>COL場所</div><input value={f.colPlace} onChange={e=>upF("colPlace",e.target.value)} style={inpS} placeholder="返却場所を入力"/></div>
    <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8,marginBottom:8}}>
      <div><div style={lbl}>クラス</div><select value={f.vehicle} onChange={e=>upF("vehicle",e.target.value)} style={inpS}>{vehicleClasses.map(c=><option key={c.type} value={c.type}>{c.type}</option>)}</select></div>
      <div><div style={lbl}>補償</div><select value={f.insurance} onChange={e=>upF("insurance",e.target.value)} style={inpS}><option value="">なし</option><option value="免責">免責</option><option value="NOC">NOC</option></select></div>
    </div>
    <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8,marginBottom:8}}>
      <div><div style={lbl}>人数</div><input type="number" value={f.people} onChange={e=>upF("people",parseInt(e.target.value)||0)} style={inpS} min={0}/></div>
      <div><div style={lbl}>フライト</div><input value={f.flight} onChange={e=>upF("flight",e.target.value)} style={inpS} placeholder="ANA059等"/></div>
    </div>
    <div style={{marginBottom:8}}><div style={lbl}>オプション</div>
      <div style={{display:"flex",gap:10,flexWrap:"wrap",padding:"6px 0",alignItems:"center"}}>
        {[{k:"optB",l:"B(ベビー)"},{k:"optC",l:"C(チャイルド)"},{k:"optJ",l:"J(ジュニア)"}].map(o=>
          <label key={o.k} style={{display:"flex",alignItems:"center",gap:3,fontSize:11,color:"#374151"}}>
            <span>{o.l}</span>
            <select value={+(f[o.k]||0)} onChange={e=>upF(o.k,+e.target.value)} style={{border:"1px solid #d1d5db",borderRadius:4,fontSize:11,padding:"1px 2px",width:36,textAlign:"center"}}>
              <option value={0}>-</option><option value={1}>1</option><option value={2}>2</option><option value={3}>3</option>
            </select>
          </label>
        )}
        {[{k:"optUSB",l:"USB"},{k:"optParasol",l:"パラソル"}].map(o=>
          <label key={o.k} style={{display:"flex",alignItems:"center",gap:3,fontSize:11,color:"#374151",cursor:"pointer"}}>
            <input type="checkbox" checked={!!f[o.k]} onChange={e=>upF(o.k,e.target.checked)} style={{width:13,height:13}}/>
            <span>{o.l}</span>
          </label>
        )}
      </div>
    </div>
    <div style={{marginBottom:8}}><div style={lbl}>配車</div>
      <select value={vc} onChange={handleVcChange} style={{...inpS,fontWeight:600,color:vc?"#1d4ed8":"#94a3b8"}}>
        <option value="">— 未割当 —</option>
        {vehicleClasses.map(cls=><optgroup key={cls.type} label={cls.type+"クラス"}>{vehicles.filter(v=>v.type===cls.type).map(v=><option key={v.code} value={v.code}>{v.name} ({v.no})</option>)}</optgroup>)}
      </select>
    </div>
    <div style={{display:"flex",gap:8,marginTop:12}}>
      <button onClick={save} style={{flex:1,padding:"8px 0",background:dirty?"#2563eb":"#e2e8f0",color:dirty?"#fff":"#64748b",border:"none",borderRadius:8,fontSize:12,fontWeight:700,cursor:"pointer"}}>{dirty?"💾 保存":"閉じる"}</button>
      <button onClick={()=>{if(window.confirm(`${t.name} 様の予約をキャンセルしますか？\n\n予約番号: ${t.id}\n\nこの操作は取り消せません。`)){onCancelReservation(t.id);onClose();}}} style={{padding:"8px 12px",background:"#fef2f2",color:"#dc2626",border:"1px solid #fecaca",borderRadius:8,fontSize:11,fontWeight:700,cursor:"pointer"}}>キャンセル</button>
    </div>
  </div></div>;
}

function MaintForm({vehicleCode,startDate,onAdd,onClose,vehicles}){
  const[start,setStart]=useState(startDate);const[end,setEnd]=useState(startDate);const[label,setLabel]=useState("メンテナンス");const v=vehicles.find(x=>x.code===vehicleCode);
  return <div className="space-y-3">
    <div className="text-xs text-gray-500">車両: <strong>{v?v.name:vehicleCode}</strong> ({v?v.no:""})</div>
    <div><label className="text-xs text-gray-500">ラベル</label><select value={label} onChange={e=>setLabel(e.target.value)} className="input-s"><option>メンテナンス</option><option>車検</option><option>修理</option><option>清掃</option><option>その他</option></select></div>
    <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
      <div><label className="text-xs text-gray-500">開始日</label><input type="date" value={start} onChange={e=>setStart(e.target.value)} className="input-s"/></div>
      <div><label className="text-xs text-gray-500">終了日</label><input type="date" value={end} onChange={e=>setEnd(e.target.value)} className="input-s"/></div>
    </div>
    <div className="flex justify-end gap-2"><button onClick={onClose} className="btn-ghost">キャンセル</button><button onClick={()=>onAdd(vehicleCode,start,end,label)} className="btn-primary">登録</button></div>
  </div>;
}

/* ==========================================
   OPシート（独立フルスクリーン）
   ========================================== */
function OPScreen({reservations,today,shifts,fleet,onFleetChange,onClose,onGoFleet,vehicles,staff,resOpts,sheetPlaces,onUpdateSheetPlaces,repeaterMap,jalanPay,cancelledIdsRef,onCancelReservation,onTaskChange}){
  const[dayOff,setDayOff]=useState(0);const selDate=dOff(today,dayOff);const[tasks,setTasks]=useState([]);
  const[editResId,setEditResId]=useState(null);
  const[editBlock,setEditBlock]=useState(null);
  const[washAddCat,setWashAddCat]=useState("");const[washAddVc,setWashAddVc]=useState("");const[washAddTime,setWashAddTime]=useState("");const[washAddMemo,setWashAddMemo]=useState("");
  useEffect(()=>{setEditResId(null);setEditBlock(null);},[dayOff]);
  const activeMembers=useMemo(()=>(shifts[selDate]||[]).filter(s=>s.type==="アルバイト"||s.symbol==="●").map(s=>s.name),[shifts,selDate]);
  const fleetRef=React.useRef(fleet);fleetRef.current=fleet;
  // fleet変更時にタスクの車種情報を同期 + LS/DB永続化
  useEffect(()=>{
    setTasks(prev=>{
      let changed=false;
      const next=prev.map(t=>{
        if(!t.reservationId)return t;
        const vc=fleet[t.reservationId];
        const vn=vc?vehicles.find(v=>v.code===vc):null;
        const updates={};
        // fleet変更（配車/解除）
        if(vc&&vc!==t.assignedVehicle){updates.assignedVehicle=vc;updates.plateNo=vn?vn.no:"";updates.vehicleNo=vn?vn.no:"";updates.vehicleName=vn?vn.name:"";}
        if(!vc&&t.assignedVehicle){updates.assignedVehicle="";updates.plateNo="";updates.vehicleNo="";updates.vehicleName="";}
        // 車両マスター変更（type/no変更）
        if(vn&&vc===t.assignedVehicle){
          if(vn.type!==t.vehicle)updates.vehicle=vn.type;
          if(vn.no!==t.plateNo){updates.plateNo=vn.no;updates.vehicleNo=vn.no;}
          if(vn.name!==t.vehicleName)updates.vehicleName=vn.name;
        }
        if(vn&&updates.assignedVehicle)updates.vehicle=vn.type;
        if(!Object.keys(updates).length)return t;
        changed=true;
        return{...t,...updates};
      });
      // ★ 変更があればLS/DBに即時保存（変更タスクのみ）
      if(changed&&next.length){
        DB._lsSave(next,selDate);
        next.forEach((nt,i)=>{
          const orig=prev[i];
          if(orig&&(nt.assignedVehicle!==orig.assignedVehicle||nt.vehicle!==orig.vehicle||nt.plateNo!==orig.plateNo)){
            DB.updateTask(nt,selDate);
          }
        });
        selfUpdateRef.current[selDate]=Date.now();
      }
      return changed?next:prev;
    });
  },[fleet,vehicles]);
  // タスクロード
  const selfUpdateRef=React.useRef({});// date→timestamp（日付ごとに管理）
  const loadTasks=React.useCallback(async(date,force)=>{
    // ★ 保存中は一切DB取得しない（上書き防止）
    if(pendingSaves.current>0){console.log("[loadTasks] 保存中スキップ");return;}
    // ★ 自分の変更直後はDBから取得せずLS復元（30秒に延長。DB反映遅延への対策）
    const lastUpdate=selfUpdateRef.current[date]||0;
    if(!force&&lastUpdate&&Date.now()-lastUpdate<30000){
      const lsData=DB._lsLoad(date);
      if(lsData&&lsData.length){setTasks(lsData);console.log("[loadTasks] LS復元",date,lsData.length+"件");return;}
    }
    // 1. DB(+localStorage)から取得
    const saved=await DB.fetchTasks(date);
    if(saved&&saved.length>0){
      const fl=fleetRef.current;
      const result=saved.map(t=>{
        if(!t.reservationId)return t;
        const vc=fl[t.reservationId];
        if(!vc&&!t.assignedVehicle)return t;
        if(vc===t.assignedVehicle)return t;
        if(!vc)return{...t,assignedVehicle:"",plateNo:""};
        const vn=vehicles.find(v=>v.code===vc);
        return{...t,assignedVehicle:vc,plateNo:vn?vn.no:"",vehicle:vn?vn.type:t.vehicle};
      });
      // ★ 新規予約のタスクを追加（DBにない予約IDのタスクを生成）
      // ただし表示のみ。DBへの自動保存はしない（不要な全件UPSERTを防止）
      const existingResIds=new Set(result.filter(t=>t.reservationId).map(t=>t.reservationId));
      const gen=generateTasks(reservations,date,fl,vehicles);
      const newTasks=gen.filter(g=>g.reservationId&&!existingResIds.has(g.reservationId));
      if(newTasks.length){
        newTasks.forEach(g=>{const sp=sheetPlaces[g.reservationId];if(sp&&!g.place){if(g.type==="DEL"&&sp.delPlace)g.place=sp.delPlace;if(g.type==="COL"&&sp.colPlace)g.place=sp.colPlace;}});
        const merged=[...result,...newTasks];
        DB._lsSave(merged,date);
        // ★ 新規タスクのみ個別にDB保存（既存タスクは上書きしない）
        newTasks.forEach((nt,i)=>DB.updateTask(nt,date));
        setTasks(merged);return;
      }
      setTasks(result);return;
    }
    // 2. DBにタスクなし→初回のみ自動生成
    const gen=generateTasks(reservations,date,fleetRef.current,vehicles);
    gen.forEach(g=>{
      if(!g.reservationId)return;
      const sp=sheetPlaces[g.reservationId];
      if(sp&&!g.place){if(g.type==="DEL"&&sp.delPlace)g.place=sp.delPlace;if(g.type==="COL"&&sp.colPlace)g.place=sp.colPlace;}
      if(sp&&g.type==="DEL"&&!g.colPlace&&sp.colPlace)g.colPlace=sp.colPlace;
    });
    setTasks(gen);
    if(gen.length)DB.upsertTasks(gen,date);
  },[reservations,vehicles]);
  useEffect(()=>{loadTasks(selDate);},[selDate,loadTasks]);
  // ★ 時間・場所を日付切替時＋5分間隔で自動取得
  useEffect(()=>{
    const doAutoFetch=async()=>{
      const resIds=[...new Set(tasks.filter(t=>t.reservationId).map(t=>t.reservationId))];
      if(!resIds.length)return;
      try{
        const[timeMap,placeMap]=await Promise.all([fetchTimeData(resIds),fetchPlaceData(resIds)]);
        if(Object.keys(timeMap).length||Object.keys(placeMap).length){
          selfUpdateRef.current[selDate]=Date.now();
          setTasks(prev=>{
            const upd=prev.map(t=>{
              if(!t.reservationId)return t;
              let changed=false;const next={...t};
              // 時間更新 → _ssTimeに保存（CSV元値t.timeは不変）
              const tm=timeMap[t.reservationId];
              if(tm&&!t.timeChange){
                let nw=null;
                if(t.type==="DEL"&&tm.delTime)nw=tm.delTime;
                if(t.type==="COL"&&tm.colTime)nw=tm.colTime;
                if(nw){
                  const norm=nw.replace(/^(\d):/,"0$1:").replace(/：/g,":").slice(0,5);
                  if(norm!==t._ssTime){next._ssTime=norm;next._ssTimeAt=new Date().toISOString();changed=true;}
                }
              }
              // 場所更新 → _ssPlaceに保存（CSV元値t.placeは不変）
              const p=placeMap[t.reservationId];
              if(p&&t._placeSource!=="manual"){
                let newPlace=null;
                if(t.type==="DEL"&&p.delPlace)newPlace=p.delPlace;
                if(t.type==="COL"&&p.colPlace)newPlace=p.colPlace;
                if(newPlace&&newPlace!==t._ssPlace){next._ssPlace=newPlace;next._ssPlaceAt=new Date().toISOString();changed=true;}
                if(t.type==="DEL"&&p.colPlace&&!t._manualColPlace){next.colPlace=p.colPlace;}
              }
              return changed?next:t;
            });
            DB._lsSave(upd,selDate);
            // ★ SS更新されたタスクをDBにも保存（changed_jsonに_ssTime/_ssPlace永続化）
            upd.forEach((t,i)=>{if(t!==prev[i])DB.updateTask(t,selDate);});
            return upd;
          });
          // 場所をplacesテーブルにも保存
          if(Object.keys(placeMap).length){
            if(onUpdateSheetPlaces)onUpdateSheetPlaces({...sheetPlaces,...placeMap});
            DB.upsertPlaces(placeMap);
          }
        }
      }catch(e){console.log("[autoFetch]",e.message);}
    };
    const t0=setTimeout(doAutoFetch,3000);
    const iv=setInterval(doAutoFetch,5*60*1000);
    return()=>{clearTimeout(t0);clearInterval(iv);};
  },[selDate,tasks.length]);
  // Realtimeでタスク更新を受信（他端末の変更を反映）
  useEffect(()=>{
    if(!sb)return;
    let debounce=null;
    const ch=sb.channel("tasks-"+selDate)
      .on("postgres_changes",{event:"*",schema:"public",table:"tasks",filter:"date=eq."+selDate},()=>{
        if(pendingSaves.current>0||Date.now()-(selfUpdateRef.current[selDate]||0)<5000){return;}
        clearTimeout(debounce);
        debounce=setTimeout(async()=>{
          const fresh=await DB.fetchTasks(selDate);
          if(fresh){
            DB._lsSave(fresh,selDate);
            setTasks(fresh);
          }
        },500);
      }).subscribe((status)=>{
        if(status==="CHANNEL_ERROR"||status==="TIMED_OUT"){
          setTimeout(()=>{try{ch.subscribe();}catch(e){}},3000);
        }
      });
    return()=>{clearTimeout(debounce);sb.removeChannel(ch);};
  },[selDate]);
  // タブ復帰・画面復帰時+30秒ポーリングでDBから最新データ再取得
  useEffect(()=>{
    const onVis=()=>{if(document.visibilityState==="visible")loadTasks(selDate);};
    document.addEventListener("visibilitychange",onVis);
    const timer=setInterval(()=>{if(document.visibilityState==="visible")loadTasks(selDate);},30000);
    return()=>{document.removeEventListener("visibilitychange",onVis);clearInterval(timer);};
  },[selDate,loadTasks]);
  const[saveStatus,setSaveStatus]=useState("ok"); // "ok"|"saving"|"error"
  const pendingSaves=React.useRef(0);
  const _topRefreshTimer=React.useRef(null);
  const _notifyTopChange=()=>{
    // デバウンス: 連続変更時は最後の変更から2秒後にTOP更新
    clearTimeout(_topRefreshTimer.current);
    _topRefreshTimer.current=setTimeout(()=>{if(onTaskChange)onTaskChange();},2000);
  };
  const _syncReservation=async(t)=>{
    if(!t.reservationId)return;
    const fields={};
    // ★ CSV元値保護: opts/insurance/vehicleのみ同期。手動の時間・場所変更はreservationsマスターに書き戻さない
    if(t.opts){fields.opt_b=+(t.opts.b||0);fields.opt_c=+(t.opts.c||0);fields.opt_j=+(t.opts.j||0);}
    if(t.insurance!==undefined)fields.insurance=t.insurance||"";
    // ★ 時間・場所はtasksテーブルのみに保持（reservationsのCSV元値を保護）
    // if(t._manualTime&&t.time){...} → 廃止: マスター書き戻し禁止
    // if(t._manualPlace&&t.place){...} → 廃止: マスター書き戻し禁止
    // Phase2: vehicle(クラス)同期（配車変更は反映が必要）
    if(t._vehicleChanged&&t.vehicle)fields.vehicle=t.vehicle;
    // Phase2: type変更→visit_type/return_type同期
    if(t._changed?.type&&t.type){if(["DEL","PU"].includes(t.type))fields.visit_type=t.type;if(t.type==="COL")fields.return_type=t.type;}
    if(Object.keys(fields).length===0)return;
    await DB.syncToReservation(t.reservationId,fields);
  };
  const savingIdsRef=React.useRef(new Set());
  const _save=async(id,t)=>{
    // 同一タスクの二重保存防止
    if(savingIdsRef.current.has(id)){console.warn("[_save] skip: already saving "+id);return;}
    savingIdsRef.current.add(id);
    selfUpdateRef.current[selDate]=Date.now();
    setTasks(ts=>{const next=ts.map(x=>x._id===id?t:x);DB._lsSave(next,selDate);return next;});
    pendingSaves.current++;setSaveStatus("saving");
    try{
      await DB.updateTask(t,selDate);
      await _syncReservation(t);
    }catch(e){console.error("[_save] DB error",e);setSaveStatus("error");}
    finally{savingIdsRef.current.delete(id);}
    pendingSaves.current--;
    setSaveStatus(DB._dbSaveOk?(pendingSaves.current>0?"saving":"ok"):"error");
    _notifyTopChange();
  };
  const upd=(id,t,label)=>{
    // ★ Mobile Safari対応: confirmダイアログの表示遅延を防止
    return new Promise(resolve=>{
      setTimeout(()=>{
        if(!window.confirm(`${label||"変更"}\nよろしいですか？`)){resolve(false);return;}
        _save(id,t);resolve(true);
      },50);
    });
  };
  const mark=(t,field)=>({...t,_changed:{...t._changed,[field]:true}});
  // 免許証アップロード状態チェック
  const[licenseStatus,setLicenseStatus]=useState({});// {reservationId: true/false}
  useEffect(()=>{
    const resIds=[...new Set(tasks.filter(t=>t.reservationId).map(t=>t.reservationId))];
    if(!resIds.length)return;
    const checkLicenses=async()=>{
      const results={};
      for(const rid of resIds){
        try{
          const resp=await fetch(SUPABASE_URL+"/storage/v1/object/list/licenses",{method:"POST",headers:{"apikey":SUPABASE_KEY,"Authorization":"Bearer "+SUPABASE_KEY,"Content-Type":"application/json"},body:JSON.stringify({prefix:rid,limit:1})});
          if(resp.ok){const files=await resp.json();results[rid]=files.length>0;}
        }catch(e){}
      }
      setLicenseStatus(results);
    };
    checkLicenses();
  },[tasks.length,selDate]);
  const confirmUpd=(id,t,label)=>upd(id,t,label);
  const add=async(t)=>{
    selfUpdateRef.current[selDate]=Date.now();
    setTasks(ts=>{const next=[...ts,t].sort((a,b)=>(a.time||"").localeCompare(b.time||""));DB._lsSave(next,selDate);return next;});
    // ★ 新規タスク1件のみDB保存
    pendingSaves.current++;setSaveStatus("saving");
    try{
      await DB.updateTask(t,selDate);
    }catch(e){console.error("[add] DB error",e);}
    pendingSaves.current--;
    setSaveStatus(DB._dbSaveOk?(pendingSaves.current>0?"saving":"ok"):"error");
    _notifyTopChange();
  };
  const TIME_OPTS=useMemo(()=>{const opts=[""];for(let h=6;h<=22;h++)for(let m=0;m<60;m+=5){if(h===22&&m>0)break;opts.push(`${String(h).padStart(2,"0")}:${String(m).padStart(2,"0")}`);}return opts;},[]);
  const assignVehicle=async(taskId,vehicleCode)=>{selfUpdateRef.current[selDate]=Date.now();const task=tasks.find(t=>t._id===taskId);if(!task)return;const v=vehicles.find(x=>x.code===vehicleCode);const updated={...task,assignedVehicle:vehicleCode,plateNo:v?v.no:""};setTasks(ts=>ts.map(x=>x._id===taskId?updated:x));await DB.updateTask(updated,selDate);if(task.reservationId){onFleetChange(prev=>{const nf={...(typeof prev==="object"?prev:fleetRef.current)};if(vehicleCode)nf[task.reservationId]=vehicleCode;else delete nf[task.reservationId];return nf;});}};
  // ★ 同期チェック: DBに直接クエリ（fetchTasksはLS副作用があるため使わない）
  const[syncInfo,setSyncInfo]=useState({status:"checking",detail:""});
  useEffect(()=>{
    if(!sb)return;
    const check=async()=>{
      try{
        const{data,error}=await sb.from("tasks").select("_id,memo").eq("date",selDate).order("sort_order");
        if(error){setSyncInfo({status:"error",detail:error.message});return;}
        const dbIds=(data||[]).map(t=>t._id).sort().join(",");
        const localIds=tasks.map(t=>t._id).sort().join(",");
        const dbMemos=(data||[]).map(t=>t._id+":"+(t.memo||"")).sort().join("|");
        const localMemos=tasks.map(t=>t._id+":"+DB._encodeMemo(t)).sort().join("|");
        if(dbIds===localIds&&dbMemos===localMemos){
          setSyncInfo({status:"synced",detail:"同期OK "+new Date().toLocaleTimeString("ja")});
        }else{
          setSyncInfo({status:"out_of_sync",detail:"DB差異: 画面"+tasks.length+"件/DB"+(data?.length||0)+"件"});
        }
      }catch(e){setSyncInfo({status:"error",detail:e.message});}
    };
    const timer=setInterval(check,15000);
    const t0=setTimeout(check,3000);
    return()=>{clearInterval(timer);clearTimeout(t0);};
  },[selDate,tasks]);
  const done=tasks.filter(t=>t.done).length;const staffCount=activeMembers.length;
  const WK=["日","月","火","水","木","金","土"];
  const dayButtons=useMemo(()=>{const arr=[];for(let i=0;i<=60;i++){const d=dOff(today,i);const ds=shifts[d]||[];const nextDay=dOff(d,1);const tc=reservations.filter(t=>sD(t.lendDate,d)||sD(t.returnDate,d)).length;const wc=reservations.filter(t=>sD(t.lendDate,nextDay)).length;if(ds.length>0||tc>0||wc>0||i<=2)arr.push({i,d,staff:ds.length,tc:tc+wc});}return arr;},[today,shifts,reservations]);
  const CONTENT_OPTIONS=["DEL","COL","洗車","送り","迎え","鍵入れ","回収","事前駐車","持ち帰り","乗り捨て","MTG","その他"];
  const[timeLoading,setTimeLoading]=useState(false);
  const updateTimes=async()=>{
    const resIds=[...new Set(tasks.filter(t=>t.reservationId).map(t=>t.reservationId))];
    if(!resIds.length){alert("予約がありません");return;}
    setTimeLoading(true);
    try{
      const timeMap=await fetchTimeData(resIds);
      const matched=Object.keys(timeMap).length;
      if(!matched){setTimeLoading(false);alert("該当する予約番号がスプレッドシートに見つかりませんでした");return;}
      selfUpdateRef.current[selDate]=Date.now();
      let updatedTasks;let updCount=0;
      setTasks(prev=>{
        updatedTasks=prev.map(t=>{
          if(!t.reservationId||!timeMap[t.reservationId])return t;
          const tm=timeMap[t.reservationId];
          let newTime=null;
          if(t.type==="DEL"&&tm.delTime)newTime=tm.delTime;
          if(t.type==="COL"&&tm.colTime)newTime=tm.colTime;
          if(!newTime)return t;
          const normalized=newTime.replace(/^(\d):/, "0$1:").replace(/：/g,":").slice(0,5);
          // ★ 手動変更(timeChange)がある場合はSS値だけ更新、表示は手動優先
          if(t.timeChange&&normalized===t._ssTime)return t;
          if(!t.timeChange&&normalized===t._ssTime)return t;
          updCount++;
          // ★ _ssTimeに保存。CSV元値(t.time)は不変
          return{...t,_ssTime:normalized,_ssTimeAt:new Date().toISOString()};
        });
        DB._lsSave(updatedTasks,selDate);
        return updatedTasks;
      });
      pendingSaves.current++;setSaveStatus("saving");
      // ★ 変更タスクのみ個別にDB保存
      const changedTasks=updatedTasks.filter(t=>t._ssTime);
      try{await Promise.all(changedTasks.map(t=>DB.updateTask(t,selDate)));}catch(e){console.error("[updateTimes]",e);}
      pendingSaves.current--;
      setSaveStatus(pendingSaves.current>0?"saving":"ok");
      alert(`${matched}件中 ${updCount}件の時間を更新しました`);
    }catch(e){alert("時間データ取得エラー: "+e.message);}
    setTimeLoading(false);
  };
  const[placeLoading,setPlaceLoading]=useState(false);
  const[lineModal,setLineModal]=useState(null);
  const updatePlaces=async()=>{
    const resIds=[...new Set(tasks.filter(t=>t.reservationId).map(t=>t.reservationId))];
    if(!resIds.length){alert("予約がありません");return;}
    setPlaceLoading(true);
    try{
      const placeMap=await fetchPlaceData(resIds);
      const matched=Object.keys(placeMap).length;
      if(!matched){setPlaceLoading(false);alert("該当する予約番号がスプレッドシートに見つかりませんでした");return;}
      selfUpdateRef.current[selDate]=Date.now();
      // ★ setState内ではLS保存のみ、DB保存は外で行う
      let updatedTasks;
      setTasks(prev=>{
        updatedTasks=prev.map(t=>{
          if(!t.reservationId||!placeMap[t.reservationId])return t;
          const p=placeMap[t.reservationId];
          let changed=false;const next={...t};
          // ★ _ssPlaceに保存。CSV元値(t.place)は不変。手動変更(_placeSource==="manual")は上書きしない
          if(t._placeSource!=="manual"){
            let newPlace=null;
            if(t.type==="DEL"&&p.delPlace)newPlace=p.delPlace;
            if(t.type==="COL"&&p.colPlace)newPlace=p.colPlace;
            if(newPlace&&newPlace!==t._ssPlace){next._ssPlace=newPlace;next._ssPlaceAt=new Date().toISOString();changed=true;}
          }
          if(t.type==="DEL"&&p.colPlace&&!t._manualColPlace){next.colPlace=p.colPlace;changed=true;}
          return changed?next:t;
        });
        DB._lsSave(updatedTasks,selDate);
        return updatedTasks;
      });
      // ★ 変更タスクのみ個別にDB保存
      pendingSaves.current++;setSaveStatus("saving");
      const changedPlaceTasks=updatedTasks.filter(t=>t._ssPlace||t.colPlace);
      try{await Promise.all(changedPlaceTasks.map(t=>DB.updateTask(t,selDate)));}catch(e){console.error("[updatePlaces]",e);}
      pendingSaves.current--;
      setSaveStatus(DB._dbSaveOk?(pendingSaves.current>0?"saving":"ok"):"error");
      if(onUpdateSheetPlaces)onUpdateSheetPlaces({...sheetPlaces,...placeMap});
      // ★ placesテーブルにも保存（他端末・リロード時にも場所情報を復元可能にする）
      DB.upsertPlaces(placeMap);
      alert(`${matched}件の予約の場所情報を更新しました`);
    }catch(e){alert("場所データ取得エラー: "+e.message);}
    setPlaceLoading(false);
  };
  // ソート
  const[sheetFilter,setSheetFilter]=useState("all"); // "all"|"del"|"col"|"wash"|"master"|"edit"
  const[sortKey,setSortKey]=useState(null);const[sortAsc,setSortAsc]=useState(true);
  const _sortVal=(t,key)=>{switch(key){case"time":return t.timeChange||t._ssTime||t.time||"99:99";case"csvTime":return t.csvTime||t.time||"99:99";case"type":return t.type||"";case"assignee":return t.assignee||"zzz";case"name":return t.name||"";case"vehicle":return t.assignedVehicle||"";case"done":return t.done?1:0;default:return"";}};
  const doSort=(arr,key,asc)=>{const dir=asc?1:-1;return[...arr].sort((a,b)=>{const va=_sortVal(a,key),vb=_sortVal(b,key);let r=typeof va==="number"?(va-vb)*dir:va.localeCompare(vb,"ja")*dir;if(r!==0)return r;/* 二次ソート: 時間順（同一値内の並び） */if(key!=="time"){const ta=a.timeChange||a._ssTime||a.time||"99:99",tb=b.timeChange||b._ssTime||b.time||"99:99";r=ta.localeCompare(tb);if(r!==0)return r;}/* 三次ソート: 内容順（DEL→COL→洗車→その他） */const typeOrder={"DEL":0,"COL":1,"洗車":2};const oa=typeOrder[a.type]??9,ob=typeOrder[b.type]??9;return oa-ob;});};
  const handleSort=(key)=>{
    let newKey,newAsc;
    if(sortKey===key){if(sortAsc){newKey=key;newAsc=false;}else{newKey=null;newAsc=true;}}
    else{newKey=key;newAsc=true;}
    setSortKey(newKey);setSortAsc(newAsc);
    // ★ ソート結果をtasks配列に反映してDB保存（sort_orderのみ更新）
    if(newKey){
      selfUpdateRef.current[selDate]=Date.now();
      const sorted=doSort(tasks,newKey,newAsc);
      setTasks(sorted);
      DB._lsSave(sorted,selDate);
      // sort_orderのみ個別更新（全フィールド上書きを回避）
      if(sb){sorted.forEach((t,i)=>{sb.from("tasks").update({sort_order:i}).eq("_id",t._id).then(()=>{}).catch(e=>console.error("sort update",e));});}
    }
  };
  const sortedTasks=useMemo(()=>{if(!sortKey)return tasks;return doSort(tasks,sortKey,sortAsc);},[tasks,sortKey,sortAsc]);
  const sortIcon=(key)=>sortKey===key?(sortAsc?"▲":"▼"):"";
  // ★ フィルター適用
  const filteredTasks=useMemo(()=>{const src=sortKey?doSort(tasks,sortKey,sortAsc):tasks;if(sheetFilter==="del")return src.filter(t=>t.type==="DEL");if(sheetFilter==="col")return src.filter(t=>t.type==="COL");if(sheetFilter==="wash")return src.filter(t=>t.type==="洗車");if(sheetFilter==="master"||sheetFilter==="edit"||sheetFilter==="all")return src;return src;},[tasks,sortKey,sortAsc,sheetFilter]);
  // 行移動
  const moveRow=(id,dir)=>{if(sortKey){alert("ソート中は手動並び替えできません。\nヘッダーを3回タップしてソート解除してください。");return;}selfUpdateRef.current[selDate]=Date.now();const idx=tasks.findIndex(t=>t._id===id);const ni=idx+dir;if(ni<0||ni>=tasks.length)return;const arr=[...tasks];[arr[idx],arr[ni]]=[arr[ni],arr[idx]];setTasks(arr);DB._lsSave(arr,selDate);if(sb){sb.from("tasks").update({sort_order:idx}).eq("_id",arr[idx]._id).then(()=>{}).catch(e=>{});sb.from("tasks").update({sort_order:ni}).eq("_id",arr[ni]._id).then(()=>{}).catch(e=>{});}};

  return <div className="op-fullscreen">
    <div className="op-header" style={{flexWrap:"wrap",gap:4,padding:"6px 10px"}}>
      <div style={{display:"flex",alignItems:"center",gap:6,minWidth:0,flex:"0 0 auto"}}>
        <button onClick={onClose} className="text-white text-lg font-bold hover:bg-white hover:bg-opacity-20 rounded" style={{padding:"0 4px",lineHeight:1}}>←</button>
        <span className="font-bold text-white" style={{fontSize:13,whiteSpace:"nowrap"}}>TOPへ戻る</span>
        <span className="text-blue-200" style={{fontSize:10,whiteSpace:"nowrap"}}>{fmtFull(selDate)} / 出勤{staffCount}名</span>
        {saveStatus==="saving"&&<span style={{fontSize:9,color:"#fbbf24",fontWeight:700}}>💾</span>}
        {saveStatus==="error"&&<span style={{fontSize:9,color:"#ef4444",fontWeight:700,cursor:"pointer"}} onClick={()=>{alert("⚠️ DB保存エラーが発生しています。\n\n変更はこの端末のローカルに保存済みですが、\n他の端末には反映されない可能性があります。\n\nページをリロードせず、しばらく待ってから再度変更してください。")}}>⚠️保存エラー</span>}
        {saveStatus==="ok"&&SB_ENABLED&&<span style={{fontSize:9,color:"#86efac"}}>✓</span>}
        <span onClick={()=>alert(syncInfo.detail)} style={{fontSize:8,fontWeight:700,padding:"1px 4px",borderRadius:3,cursor:"pointer",background:syncInfo.status==="synced"?"#d1fae5":syncInfo.status==="out_of_sync"?"#fee2e2":"#e0e7ff",color:syncInfo.status==="synced"?"#065f46":syncInfo.status==="out_of_sync"?"#991b1b":"#3730a3"}}>{syncInfo.status==="synced"?"🟢同期":syncInfo.status==="out_of_sync"?"🔴差異":syncInfo.status==="error"?"⚠️":"🔄"}</span>
      </div>
      <div style={{display:"flex",alignItems:"center",gap:4,marginLeft:"auto",flex:"0 0 auto"}}>
        <span className="text-blue-200" style={{fontSize:10}}>{done}/{tasks.length}</span>
        <div style={{width:40,height:5,background:"#1e3a8a",borderRadius:4,overflow:"hidden"}}><div style={{height:"100%",background:"#4ade80",borderRadius:4,width:`${tasks.length?done/tasks.length*100:0}%`}}/></div>
        <button onClick={()=>{const newTask={_id:uid(),type:"その他",time:"",name:"",people:0,place:"",vehicle:"",insurance:"",flight:"",reservationId:"",ota:"",tel:"",mail:"",done:false,assignee:"",memo:"",assignedVehicle:"",plateNo:"",insuranceChange:"",opts:{b:false,c:false,j:false,usb:false,parasol:false},yakkan:false,line:false,payment:false,returnDate:"",returnTime:"",returnType:"",colPlace:"",manual:true};add(newTask);}} className="px-2 py-1 bg-white text-blue-700 rounded text-xs font-bold shadow-sm">＋</button>
        <button onClick={updateTimes} disabled={timeLoading} className="px-2 py-1 rounded text-xs font-bold shadow-sm" style={{background:timeLoading?"#94a3b8":"#f0abfc",color:"#701a75",whiteSpace:"nowrap",fontSize:10}}>{timeLoading?"...":"⏰時間"}</button>
        <button onClick={updatePlaces} disabled={placeLoading} className="px-2 py-1 rounded text-xs font-bold shadow-sm" style={{background:placeLoading?"#94a3b8":"#fbbf24",color:"#78350f",whiteSpace:"nowrap",fontSize:10}}>{placeLoading?"...":"📍場所"}</button>
        <button id="op-reload-btn" onClick={async e=>{const btn=e.currentTarget;btn.disabled=true;btn.textContent="⏳";selfUpdateRef.current[selDate]=0;try{localStorage.removeItem(DB._lsKey(selDate));await loadTasks(selDate);}catch(ex){}btn.textContent="✅";btn.style.background="#d1fae5";setTimeout(()=>{btn.textContent="🔄";btn.style.background="#e0f2fe";btn.disabled=false;},1200);}} className="px-2 py-1 rounded text-xs font-bold shadow-sm" style={{background:"#e0f2fe",color:"#0369a1",whiteSpace:"nowrap",fontSize:10}}>🔄</button>
        {onGoFleet&&<button onClick={onGoFleet} className="px-2 py-1 rounded text-xs font-bold shadow-sm" style={{background:"#059669",color:"#fff",whiteSpace:"nowrap",fontSize:10}}>🚗配車表</button>}
      </div>
    </div>
    <div style={{padding:"4px 6px",background:"#fff",borderBottom:"1px solid #e5e7eb",overflowX:"auto",display:"flex",gap:3,flexShrink:0}}>
      {dayButtons.map(db=>{const sel=dayOff===db.i;const dt=new Date(db.d);return <button key={db.i} onClick={()=>setDayOff(db.i)} style={{flexShrink:0,padding:"3px 8px",borderRadius:6,fontSize:10,fontWeight:sel?700:500,background:sel?"#2563eb":"#f1f5f9",color:sel?"#fff":"#374151",border:"none",cursor:"pointer",minWidth:48,textAlign:"center"}}><div style={{fontWeight:700}}>{db.i===0?"今日":db.i===1?"明日":`${dt.getMonth()+1}/${dt.getDate()}`}</div><div style={{fontSize:8,opacity:.7}}>{WK[dt.getDay()]}</div>{db.tc>0&&<div style={{fontSize:7,background:sel?"rgba(255,255,255,.25)":"#dbeafe",color:sel?"#fff":"#1d4ed8",borderRadius:6,padding:"0 3px"}}>{db.tc}件</div>}</button>;})}
    </div>
    {activeMembers.length>0&&<div style={{padding:"3px 6px",background:"#f8fafc",borderBottom:"1px solid #e5e7eb",display:"flex",gap:3,flexWrap:"wrap",flexShrink:0}}><span style={{fontSize:9,color:"#64748b",fontWeight:600}}>出勤:</span>{activeMembers.map(name=>{const isReg=staff.find(x=>x.name===name)?.type==="正社員";return <span key={name} style={{fontSize:9,fontWeight:700,padding:"1px 5px",borderRadius:3,background:isReg?"#dbeafe":"#fef3c7",color:isReg?"#1d4ed8":"#92400e"}}>{name}</span>;})}</div>}
    {/* ★ フィルタータブ: サマリー/バス/ハイエース/DEL・COL/洗車/マスター */}
    <div style={{padding:"4px 6px",background:"#fff",borderBottom:"1px solid #e5e7eb",display:"flex",gap:4,flexShrink:0,overflowX:"auto"}}>
      {(()=>{const delCnt=tasks.filter(t=>t.type==="DEL").length;const colCnt=tasks.filter(t=>t.type==="COL").length;const washCnt=tasks.filter(t=>t.type==="洗車").length;const tabs=[{id:"all",label:"🗓 スケジュール",cnt:tasks.length},{id:"del",label:"🚗DEL",cnt:delCnt},{id:"col",label:"📦COL",cnt:colCnt},{id:"wash",label:"🧹洗車",cnt:washCnt},{id:"master",label:"📋マスター",cnt:null},{id:"edit",label:"✏️ 編集",cnt:null}];return tabs.map(tb=>{const sel=sheetFilter===tb.id;const editStyle=tb.id==="edit"?{background:sel?"#dc2626":"#fef2f2",color:sel?"#fff":"#dc2626",border:sel?"none":"1px solid #fca5a5"}:{};return <button key={tb.id} onClick={()=>setSheetFilter(tb.id)} style={{flexShrink:0,padding:"4px 10px",borderRadius:8,fontSize:11,fontWeight:sel?700:500,background:sel?"#1e40af":"#f1f5f9",color:sel?"#fff":"#374151",border:"none",cursor:"pointer",display:"flex",alignItems:"center",gap:4,...editStyle}}>{tb.label}{tb.cnt!==null&&<span style={{fontSize:9,background:sel?"rgba(255,255,255,.25)":"#dbeafe",color:sel?"#fff":"#1d4ed8",borderRadius:8,padding:"0 5px",fontWeight:700}}>{tb.cnt}</span>}</button>;});})()}
    </div>
    <div className="op-body">
      {/* ★ DEL/COL カード表示 */}
      {(sheetFilter==="del"||sheetFilter==="col")&&(()=>{
        const cardTasks=filteredTasks;
        const getVeh=(t)=>{if(t.vehicleName&&t.vehicleNo)return{name:t.vehicleName,no:t.vehicleNo};const vc=fleet[t.reservationId];if(!vc)return{name:"",no:""};const v=vehicles.find(x=>x.code===vc);return v?{name:v.name,no:v.no}:{name:"",no:""};};
        const doneCount=cardTasks.filter(t=>t.done).length;
        const headerLabel=sheetFilter==="del"?"🚗 DEL 配送":"📦 COL 回収";
        const headerColor=sheetFilter==="del"?"#1e40af":"#dc2626";
        return <div style={{padding:12}}>
          <div style={{background:"linear-gradient(135deg,"+headerColor+","+headerColor+"cc)",color:"#fff",borderRadius:12,padding:"14px 18px",marginBottom:12,display:"flex",justifyContent:"space-between",alignItems:"center"}}>
            <span style={{fontSize:16,fontWeight:800}}>{headerLabel} ({cardTasks.length}件)</span>
            <span style={{fontSize:13,fontWeight:600}}>完了 {doneCount}/{cardTasks.length}</span>
          </div>
          {cardTasks.length===0&&<div style={{textAlign:"center",padding:32,color:"#94a3b8",fontSize:13}}>タスクなし</div>}
          {cardTasks.map((t,i)=>{
            const tm=TASK_META[t.type]||TASK_META["その他"];
            const tOpts=t.opts||{};
            const place=t.place||"";
            const mapsUrl=place?"https://www.google.com/maps/search/"+encodeURIComponent(place):"";
            const vh=getVeh(t);
            return <div key={t._id} style={{background:t.done?"#f1f5f9":"#fff",border:"1px solid "+(t.done?"#e2e8f0":"#d1d5db"),borderRadius:10,padding:"12px 14px",marginBottom:8,opacity:t.done?.6:1}}>
              <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start"}}>
                <div style={{display:"flex",alignItems:"center",gap:8}}>
                  <input type="checkbox" checked={t.done||false} onChange={e=>{const v=e.target.checked;upd(t._id,{...t,done:v});}} style={{width:16,height:16,accentColor:headerColor}}/>
                  <span style={{background:tm.bg,color:tm.fg,padding:"2px 8px",borderRadius:4,fontSize:11,fontWeight:700}}>{t.type}</span>
                  {(()=>{const rT=t.timeChange||t._ssTime||t.time||"-";const orig=t.time||"";const changed=orig&&rT!==orig;return <><span style={{fontSize:15,fontWeight:700,color:changed?"#dc2626":"#1e293b"}}>{rT}</span>{changed&&<span style={{fontSize:9,color:"#9ca3af",marginLeft:2}}>←{orig}</span>}</>;})()}
                  <span style={{fontSize:15,fontWeight:600,color:"#334155"}}>{t.name||""}</span>
                </div>
                <div style={{textAlign:"right",flexShrink:0}}>
                  {t.people>0&&<span style={{fontSize:13,fontWeight:700,color:"#3b82f6"}}>{t.people}名</span>}
                  <span style={{fontSize:11,color:t.assignee?"#059669":"#94a3b8",marginLeft:6,fontWeight:600}}>{t.assignee||"未割当"}</span>
                </div>
              </div>
              <div style={{display:"flex",flexWrap:"wrap",gap:6,marginTop:6,alignItems:"center",fontSize:11,color:"#64748b"}}>
                <span style={{fontFamily:"monospace",fontSize:10}}>{t.reservationId||""}</span>
                {vh.name&&<span style={{fontWeight:700,color:"#1e293b"}}>{vh.name}</span>}
                {vh.no&&<span style={{fontWeight:700,color:"#2563eb"}}>{vh.no}</span>}
                {t.vehicle&&<span>{t.vehicle}</span>}
                {t.insurance&&<span style={{color:t.insurance==="NOC"?"#dc2626":"#059669",fontWeight:600}}>{t.insurance}</span>}
                {(()=>{const rP=(t._placeSource==="manual"?t.place:(t._ssPlace||t.place))||"";if(!rP)return null;const mu="https://www.google.com/maps/search/"+encodeURIComponent(rP);return <a href={mu} target="_blank" rel="noopener" style={{color:"#dc2626",textDecoration:"none",fontWeight:600}}>📍{rP}</a>;})()}
              </div>
              {(tOpts.b>0||tOpts.c>0||tOpts.j>0)&&<div style={{display:"flex",gap:4,marginTop:4}}>{tOpts.b>0&&<span style={{fontSize:9,background:"#fef3c7",color:"#92400e",padding:"1px 5px",borderRadius:4}}>B:{tOpts.b}</span>}{tOpts.c>0&&<span style={{fontSize:9,background:"#dbeafe",color:"#1d4ed8",padding:"1px 5px",borderRadius:4}}>C:{tOpts.c}</span>}{tOpts.j>0&&<span style={{fontSize:9,background:"#f0fdf4",color:"#059669",padding:"1px 5px",borderRadius:4}}>J:{tOpts.j}</span>}</div>}
              {t.memo&&<div style={{marginTop:4,fontSize:10,color:"#6b7280",background:"#f8fafc",padding:"3px 6px",borderRadius:4}}>{t.memo}</div>}
            </div>;
          })}
        </div>;
      })()}
      {/* ★ 洗車タブ（NHA仕様: カテゴリ選択・車両選択・手動追加/削除） */}
      {sheetFilter==="wash"&&(()=>{
        const isMob=window.innerWidth<=768;
        const sorted=tasks.filter(t=>t.type==="洗車");
        const autoWash=sorted.filter(t=>!t.manual);
        const manualWash=sorted.filter(t=>t.manual);
        const doneC=sorted.filter(t=>t.done).length;
        const addWashTask=()=>{
          if(!washAddCat){alert("カテゴリを選択してください");return;}
          if(!washAddVc){alert("車両を選択してください");return;}
          const veh=vehicles.find(v=>v.code===washAddVc);
          const newId="wash_manual_"+Date.now()+"_"+Math.random().toString(36).slice(2,6);
          const newTask={_id:newId,type:"洗車",time:washAddTime||"",name:washAddCat+(veh?" "+veh.name:""),memo:washAddMemo||(veh?veh.name+(veh.no?" ("+veh.no+")":""):""),people:0,place:"",vehicle:veh?veh.type:"",assignedVehicle:washAddVc,plateNo:veh?veh.no:"",reservationId:"",ota:"",tel:"",mail:"",done:false,assignee:"",flight:"",returnDate:"",returnTime:"",returnType:"",colPlace:"",insurance:"",opts:{b:0,c:0,j:0,usb:0},yakkan:false,line:false,payment:false,manual:true,timeChange:"",typeChange:"",_changed:{}};
          setTasks(ts=>{const next=[...ts,newTask];DB._lsSave(next,selDate);return next;});
          DB.upsertTasks([...tasks,newTask],selDate);
          setWashAddCat("");setWashAddVc("");setWashAddTime("");setWashAddMemo("");
        };
        const deleteWashTask=(id)=>{
          if(!window.confirm("この洗車タスクを削除しますか？"))return;
          setTasks(ts=>{const next=ts.filter(x=>x._id!==id);DB._lsSave(next,selDate);return next;});
          DB.deleteTask(id,selDate);
        };
        const renderWashRow=(t)=>{
          const vn=t.assignedVehicle?vehicles.find(v=>v.code===t.assignedVehicle):null;
          return <div key={t._id} style={{padding:isMob?"8px 10px":"6px 10px",borderBottom:"1px solid #f1f5f9",opacity:t.done?0.5:1}}>
            <div style={{display:"flex",alignItems:"center",gap:6,fontSize:isMob?13:11}}>
              <span style={{cursor:"pointer",fontSize:isMob?16:13,flexShrink:0}} onClick={()=>{upd(t._id,{...t,done:!t.done});}}>{t.done?"✅":"⬜"}</span>
              <span style={{fontWeight:700,flex:1,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{t.name||""}</span>
              {t.time&&<span style={{fontSize:isMob?11:10,fontWeight:800,color:"#1e293b",fontFamily:"monospace",background:"#f1f5f9",padding:"1px 6px",borderRadius:4,flexShrink:0}}>{t.time}</span>}
              {vn&&<span style={{color:"#059669",fontSize:isMob?10:9,fontWeight:600,flexShrink:0}}>🚗{vn.name}</span>}
              {t.plateNo&&<span style={{background:"#eff6ff",color:"#1e40af",fontSize:isMob?10:8,padding:"1px 4px",borderRadius:3,fontWeight:700,flexShrink:0}}>{t.plateNo}</span>}
              {t.vehicle&&!vn&&<span style={{color:"#64748b",fontSize:isMob?10:9,flexShrink:0}}>{t.vehicle}</span>}
              {t.assignee&&<span style={{color:"#7c3aed",fontWeight:700,fontSize:isMob?10:9,flexShrink:0}}>👤{t.assignee}</span>}
            </div>
            <div style={{display:"flex",alignItems:"center",gap:4,marginTop:3,fontSize:isMob?10:8,flexWrap:"wrap"}}>
              {t.reservationId&&<span style={{color:"#94a3b8",fontWeight:600}}>{t.reservationId}</span>}
              {t.memo&&<span style={{color:"#475569",fontWeight:600,background:"#fefce8",padding:"1px 4px",borderRadius:3}}>{t.memo}</span>}
              <span style={{flex:1}}></span>
              {t.manual&&<button onClick={()=>deleteWashTask(t._id)} style={{background:"#fef2f2",border:"1px solid #fecaca",borderRadius:4,fontSize:isMob?10:9,color:"#dc2626",fontWeight:700,padding:"2px 8px",cursor:"pointer",flexShrink:0}}>削除</button>}
            </div>
          </div>;
        };
        return <div style={{padding:isMob?4:8,display:"flex",flexDirection:"column",gap:8}}>
          {/* 洗車タスク追加 */}
          <div style={{background:"#fff",borderRadius:12,border:"2px solid #FFD54F",overflow:"hidden"}}>
            <div style={{padding:"8px 12px",background:"linear-gradient(135deg,#795548,#8D6E63)",color:"#fff",fontWeight:800,fontSize:13,display:"flex",alignItems:"center",gap:8}}>
              <span>🧽 洗車タスク</span>
              <span style={{fontSize:10,fontWeight:600,opacity:.7}}>完了 {doneC}/{sorted.length}</span>
            </div>
            <div style={{padding:"10px 12px",background:"#FFFDE7",borderBottom:"1px solid #FFD54F",display:"flex",flexDirection:"column",gap:8}}>
              <div style={{display:"flex",alignItems:"center",gap:6,flexWrap:"wrap"}}>
                <span style={{fontSize:11,fontWeight:800,color:"#5D4037",flexShrink:0}}>➕ 追加</span>
                <select value={washAddCat} onChange={e=>setWashAddCat(e.target.value)} style={{border:"1px solid #D7CCC8",borderRadius:6,padding:"4px 8px",fontSize:isMob?12:11,fontWeight:700,color:"#5D4037",background:"#fff",flex:"0 1 auto"}}>
                  <option value="">カテゴリ</option>
                  {["事前洗車","当日洗車","緊急洗車","引渡前洗車","返却後洗車"].map(c=><option key={c} value={c}>{c}</option>)}
                </select>
                <select value={washAddVc} onChange={e=>setWashAddVc(e.target.value)} style={{border:"1px solid #D7CCC8",borderRadius:6,padding:"4px 8px",fontSize:isMob?12:11,fontWeight:700,color:"#1e40af",background:"#fff",flex:"1 1 120px"}}>
                  <option value="">🚗 車両を選択</option>
                  {vehicles.filter(v=>v.active!==false).map(v=><option key={v.code} value={v.code}>{v.name}{v.no?" ("+v.no+")":""}</option>)}
                </select>
                <select value={washAddTime} onChange={e=>setWashAddTime(e.target.value)} style={{border:"1px solid #D7CCC8",borderRadius:6,padding:"4px 8px",fontSize:isMob?12:11,fontWeight:700,color:"#1e293b",background:"#fff",width:75,flexShrink:0}}>
                  <option value="">時間</option>
                  {TIME_OPTS.filter(o=>o).map(o=><option key={o} value={o}>{o}</option>)}
                </select>
              </div>
              <div style={{display:"flex",alignItems:"center",gap:6}}>
                <input value={washAddMemo} onChange={e=>setWashAddMemo(e.target.value)} placeholder="メモ（省略可）" style={{border:"1px solid #D7CCC8",borderRadius:6,padding:"4px 8px",fontSize:isMob?12:11,color:"#5D4037",background:"#fff",flex:1}}/>
                <button onClick={addWashTask} style={{background:washAddCat&&washAddVc?"linear-gradient(135deg,#795548,#8D6E63)":"#ccc",color:"#fff",border:"none",borderRadius:8,padding:"6px 16px",fontSize:isMob?12:11,fontWeight:800,cursor:washAddCat&&washAddVc?"pointer":"not-allowed",flexShrink:0}}>追加</button>
              </div>
            </div>
          </div>
          {/* 事前洗車（自動生成） */}
          {autoWash.length>0&&<div style={{background:"#fff",borderRadius:12,border:"1px solid #e2e8f0",overflow:"hidden"}}>
            <div style={{padding:"6px 12px",background:"#f8fafc",borderBottom:"1px solid #e2e8f0",display:"flex",alignItems:"center",gap:6}}>
              <span style={{fontWeight:800,fontSize:12,color:"#64748b"}}>📋 事前洗車（翌日出発車両）</span>
              <span style={{fontSize:10,fontWeight:600,color:"#94a3b8"}}>{autoWash.length}件</span>
            </div>
            {autoWash.map(renderWashRow)}
          </div>}
          {/* 手動追加した洗車 */}
          {manualWash.length>0&&<div style={{background:"#fff",borderRadius:12,border:"1px solid #FFD54F",overflow:"hidden"}}>
            <div style={{padding:"6px 12px",background:"#FFFDE7",borderBottom:"1px solid #FFD54F",display:"flex",alignItems:"center",gap:6}}>
              <span style={{fontWeight:800,fontSize:12,color:"#5D4037"}}>✏️ 手動追加した洗車</span>
              <span style={{fontSize:10,fontWeight:600,color:"#8D6E63"}}>{manualWash.length}件</span>
            </div>
            {manualWash.map(renderWashRow)}
          </div>}
          {sorted.length===0&&<div style={{background:"#fff",borderRadius:12,border:"1px solid #e2e8f0",padding:20,textAlign:"center",color:"#94a3b8",fontSize:12}}>洗車タスクなし — 上のボタンから追加できます</div>}
        </div>;
      })()}
      {/* ★ スケジュール: 時系列フラット表示（NHA仕様・洗車含む） */}
      {sheetFilter==="all"&&(()=>{
        const isMob=window.innerWidth<=768;
        const timedWash=tasks.filter(t=>t.type==="洗車"&&t.time);
        const untimedWash=tasks.filter(t=>t.type==="洗車"&&!t.time);
        const allSchedule=[...tasks.filter(t=>t.type!=="洗車"&&t.type!=="CXL"),...timedWash].sort((a,b)=>{const ta=a.timeChange||a._ssTime||a.time||"99:99";const tb=b.timeChange||b._ssTime||b.time||"99:99";return ta.localeCompare(tb);});
        const typeStyle=(tp)=>({DEL:{bg:"#dbeafe",c:"#1d4ed8",border:"#60a5fa"},COL:{bg:"#ffedd5",c:"#9a3412",border:"#fdba74"},"洗車":{bg:"#FFFDE7",c:"#795548",border:"#FFD54F"},"その他":{bg:"#f1f5f9",c:"#475569",border:"#cbd5e1"},CXL:{bg:"#f1f5f9",c:"#9ca3af",border:"#d1d5db"}})[tp]||{bg:"#f1f5f9",c:"#475569",border:"#cbd5e1"};
        return <div>
          <div style={{background:"#fff",borderRadius:8,border:"1px solid #e2e8f0",overflow:"hidden"}}>
            <div style={{background:"linear-gradient(135deg,#0f172a,#1e293b)",padding:"8px 12px",color:"#e2e8f0",fontWeight:800,fontSize:isMob?13:12,display:"flex",alignItems:"center",gap:8}}>
              <span>🗓 スケジュール</span>
              <span style={{fontSize:10,fontWeight:600,opacity:.7}}>{allSchedule.length}件{untimedWash.length>0?" + 時間未定洗車"+untimedWash.length+"件":""}</span>
            </div>
            {allSchedule.map(t=>{
              const ppl=parseInt(t.people)||0;
              const resolvedT=t.timeChange||t._ssTime||t.time||"--:--";
              const resolvedP=(t._placeSource==="manual"?t.place:(t._ssPlace||t.place))||"";
              const ts=typeStyle(t.type);
              const vn=t.assignedVehicle?vehicles.find(v=>v.code===t.assignedVehicle):null;
              const fleetVc=!vn&&t.reservationId?fleet[t.reservationId]:null;
              const fleetVeh=fleetVc?vehicles.find(v=>v.code===fleetVc):null;
              const dispVn=vn||fleetVeh;
              return <div key={t._id} onClick={()=>{if(t.reservationId){setEditResId(t.reservationId);setEditBlock(null);setSheetFilter("edit");}}} style={{display:"flex",alignItems:"stretch",gap:0,borderBottom:"1px solid #e2e8f0",cursor:t.reservationId?"pointer":"default",opacity:t.done?.5:1,background:t.done?"#fafafa":"#fff"}}>
                <div style={{width:isMob?56:52,flexShrink:0,display:"flex",alignItems:"center",justifyContent:"center",fontWeight:800,fontSize:isMob?13:12,color:"#334155",fontFamily:"monospace",background:"#f8fafc",borderRight:"1px solid #e2e8f0"}}>{resolvedT}</div>
                <div style={{width:isMob?48:44,flexShrink:0,display:"flex",alignItems:"center",justifyContent:"center",background:ts.bg,borderRight:"2px solid "+ts.border}}>
                  <span style={{fontSize:isMob?11:10,fontWeight:800,color:ts.c}}>{t.type}</span>
                </div>
                <div style={{flex:1,padding:isMob?"6px 10px":"5px 10px",minWidth:0}}>
                  <div style={{display:"flex",alignItems:"center",gap:6}}>
                    <span style={{fontWeight:700,fontSize:isMob?13:12,color:"#0f172a",overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{t.type==="洗車"?(t.name||"洗車"):(t.name||"名前なし")}</span>
                    {t.type==="洗車"&&t.memo&&<span style={{fontSize:isMob?10:9,color:"#795548",fontWeight:600,flexShrink:0}}>{t.memo}</span>}
                    {t.type!=="洗車"&&ppl>0&&<span style={{fontSize:isMob?11:10,fontWeight:700,color:"#7c3aed",flexShrink:0}}>{ppl}名</span>}
                    {t.done&&<span style={{flexShrink:0}}>✅</span>}
                  </div>
                  <div style={{display:"flex",alignItems:"center",gap:6,marginTop:2,flexWrap:"wrap"}}>
                    {resolvedP&&<span style={{fontSize:isMob?10:9,color:"#475569",fontWeight:600}}>📍{resolvedP}</span>}
                    {t.flight&&<span style={{fontSize:isMob?10:9,color:"#1565c0",fontWeight:600}}>✈{t.flight}</span>}
                    {dispVn&&<span style={{fontSize:isMob?10:9,color:"#059669",fontWeight:600}}>🚗{dispVn.name}({dispVn.no})</span>}
                    {!dispVn&&t.type!=="洗車"&&t.type!=="その他"&&<span style={{fontSize:isMob?9:8,color:"#dc2626",fontWeight:700}}>未配車</span>}
                    {t.assignee&&<span style={{fontSize:isMob?10:9,background:"#ede9fe",color:"#6d28d9",fontWeight:700,padding:"1px 6px",borderRadius:4}}>👤{t.assignee}</span>}
                    {!t.assignee&&t.type!=="洗車"&&<span style={{fontSize:isMob?9:8,color:"#f59e0b",fontWeight:700}}>担当未定</span>}
                  </div>
                </div>
              </div>;
            })}
            {untimedWash.length>0&&<div>
              <div style={{background:"#f8fafc",padding:"4px 12px",borderBottom:"1px solid #e2e8f0",display:"flex",alignItems:"center",gap:6}}>
                <span style={{fontSize:isMob?14:13,fontWeight:900,color:"#64748b"}}>🧽 洗車（時間未定）</span>
                <span style={{fontSize:9,color:"#94a3b8",fontWeight:600}}>{untimedWash.length}件</span>
                <div style={{flex:1,height:1,background:"#e2e8f0"}}/>
              </div>
              {untimedWash.map(t=>{
                const vn=t.assignedVehicle?vehicles.find(v=>v.code===t.assignedVehicle):null;
                return <div key={t._id} style={{display:"flex",alignItems:"center",gap:8,padding:isMob?"6px 12px":"4px 12px",borderBottom:"1px solid #f5f5f5",opacity:t.done?.5:1,fontSize:isMob?11:10}}>
                  <span style={{fontWeight:600,color:"#64748b",flex:1}}>{t.memo||t.name||""}</span>
                  {vn&&<span style={{color:"#059669",fontWeight:600,fontSize:isMob?10:9}}>🚗{vn.name}({vn.no})</span>}
                  {t.assignee&&<span style={{color:"#6d28d9",fontWeight:600,fontSize:isMob?10:9}}>👤{t.assignee}</span>}
                  {t.done&&<span>✅</span>}
                </div>;
              })}
            </div>}
          </div>
          {tasks.length===0&&<div style={{textAlign:"center",padding:32,color:"#94a3b8",fontSize:13}}>この日のタスクはありません</div>}
        </div>;
      })()}
      {/* ★ マスター表（参照専用+行タップ遷移） */}
      {sheetFilter==="master"&&(()=>{
        const resolvedT=(t)=>t.timeChange||t._ssTime||t.time;
        const resolvedP=(t)=>t._placeSource==="manual"?t.place:(t._ssPlace||t.place);
        return <div>
        <div style={{padding:"6px 12px",background:"#eff6ff",borderBottom:"1px solid #bfdbfe",display:"flex",alignItems:"center",gap:8}}>
          <span style={{fontSize:11,color:"#1d4ed8",fontWeight:700}}>📋 マスター表</span>
          <span style={{fontSize:10,color:"#64748b"}}>行タップで編集画面へ</span>
          <button onClick={()=>{setEditResId(null);setEditBlock(null);setSheetFilter("edit");}} style={{marginLeft:"auto",padding:"3px 10px",background:"#dc2626",color:"#fff",border:"none",borderRadius:6,fontSize:10,fontWeight:700,cursor:"pointer"}}>編集タブへ</button>
        </div>
        <div className="bg-white rounded-lg border border-gray-200 overflow-hidden mb-2"><div style={{overflowX:"auto"}}>
        <table style={{width:"100%",borderCollapse:"collapse",fontSize:10,whiteSpace:"nowrap"}}><thead><tr style={{background:"#f1f5f9"}}>
          {[{h:"#",k:null},{h:"✓",k:"done"},{h:"担当",k:"assignee"},{h:"時間",k:"time"},{h:"内容",k:"type"},{h:"予約者",k:"name"},{h:"場所",k:null},{h:"クラス",k:"vehicle"},{h:"車種",k:null},{h:"No.",k:null},{h:"B",k:null},{h:"C",k:null},{h:"J",k:null},{h:"補償",k:null},{h:"メモ",k:null},{h:"OTA",k:null},{h:"予約番号",k:null},{h:"変更",k:null}].map((col,i)=>{
            const w=i===0?28:i===1?30:i===2?52:i===3?50:i===4?44:i===5?100:i===6?120:i===7?32:i===8?60:i===9?50:i<=12?22:i===13?36:i===14?100:i===15?30:i===16?130:80;
            return <th key={i} onClick={col.k?()=>handleSort(col.k):undefined} style={{background:sortKey===col.k?"#dbeafe":"#f1f5f9",padding:"4px 2px",textAlign:"center",fontWeight:600,fontSize:8,color:col.k?"#1d4ed8":"#475569",borderBottom:"2px solid #cbd5e1",borderRight:"1px solid #e2e8f0",minWidth:w,maxWidth:w,cursor:col.k?"pointer":"default",userSelect:"none"}}>{col.h}{col.k?<span style={{fontSize:7,marginLeft:1}}>{sortIcon(col.k)}</span>:""}</th>;
          })}
        </tr></thead><tbody>
          {filteredTasks.map((t,ri)=>{
            const isLend=t.type==="DEL";const isWash=t.type==="洗車";const tm=TASK_META[t.type]||TASK_META["その他"];
            const tOpts=t.opts||{};const ch=t._changed||{};
            const liveOpts={b:+(tOpts.b||0),c:+(tOpts.c||0),j:+(tOpts.j||0)};
            const rowBg=t.done?"#f9fafb":isWash?"#FFFDE7":ri%2===0?"#fff":"#fafbfc";
            const rTime=resolvedT(t);const rPlace=resolvedP(t);
            const hasAlert=(isLend||t.type==="COL")&&(!rTime||!rPlace);
            const vn=t.assignedVehicle?vehicles.find(x=>x.code===t.assignedVehicle):null;
            const cellS={padding:"3px 4px",borderBottom:"1px solid #f1f5f9",borderRight:"1px solid #f1f5f9",opacity:t.done?0.4:1,verticalAlign:"middle",background:rowBg,cursor:t.reservationId?"pointer":"default"};
            const rowClick=()=>{if(!t.reservationId||isWash)return;setEditResId(t.reservationId);setEditBlock(null);setSheetFilter("edit");};
            return <tr key={t._id} onClick={rowClick} style={{background:hasAlert?"#fef2f2":"transparent"}}>
              <td style={{...cellS,textAlign:"center",fontSize:8,color:"#94a3b8"}}>{ri+1}</td>
              <td style={{...cellS,textAlign:"center"}}><span style={{fontSize:10}}>{t.done?"✅":""}</span></td>
              <td style={{...cellS,background:ch.assignee?"#fefce8":rowBg}}>{/* 担当はマスター表で直接変更可 */}
                <select value={activeMembers.includes(t.assignee)?t.assignee:["乗り捨て","無人"].includes(t.assignee)?t.assignee:t.assignee?"__custom":""} onClick={e=>e.stopPropagation()} onChange={e=>{e.stopPropagation();const v=e.target.value;if(v==="__other"){_save(t._id,mark({...t,_assigneeCustom:true,assignee:""},"assignee"));return;}setTimeout(()=>{if(!window.confirm("担当を「"+(v||"未割当")+"」に変更しますか？"))return;_save(t._id,mark({...t,assignee:v,_assigneeCustom:false},"assignee"));},50);}} style={{border:"none",background:"transparent",fontSize:9,width:"100%",padding:0,color:t.assignee?"#111":"#ccc",fontWeight:600}}>
                  <option value="">-</option>{activeMembers.map(m=><option key={m}>{m}</option>)}<option value="乗り捨て">乗り捨て</option><option value="無人">無人</option><option value="__other">その他...</option>{t.assignee&&!activeMembers.includes(t.assignee)&&!["乗り捨て","無人"].includes(t.assignee)&&<option value="__custom">{t.assignee}</option>}
                </select>
              </td>
              <td style={{...cellS,fontWeight:700,color:rTime?"#1d4ed8":"#ef4444",fontSize:9}}>{isWash?<select value={t.time||""} onClick={e=>e.stopPropagation()} onChange={e=>{e.stopPropagation();const v=e.target.value;setTimeout(()=>{if(!window.confirm("洗車時間を「"+(v||"未設定")+"」に変更しますか？"))return;_save(t._id,{...t,time:v});},50);}} style={{border:"none",background:"transparent",fontSize:9,width:"100%",padding:0,fontWeight:700,color:t.time?"#1d4ed8":"#ccc"}}>{TIME_OPTS.map(o=><option key={o} value={o}>{o||"-"}</option>)}</select>:<div>{rTime||"-"}{(()=>{const orig=t.time||"";const changed=rTime||"";if(orig&&changed&&orig!==changed)return <div style={{fontSize:7,color:"#dc2626",fontWeight:600,lineHeight:1}}>←{orig}</div>;return null;})()}</div>}</td>
              <td style={{...cellS,fontWeight:700,color:tm.c,fontSize:10}}>{t.typeChange?<span title={t.typeChange}>{t.type}<span style={{fontSize:7,color:"#f59e0b",marginLeft:2}}>*</span></span>:(t.type||"")}</td>
              <td style={{...cellS,fontWeight:600,color:"#0f172a"}}>{t.name||""}</td>
              <td style={{...cellS,fontSize:9,color:rPlace?"#111":"#ef4444"}}>{rPlace||"-"}</td>
              <td style={{...cellS,fontSize:9,fontWeight:700,color:"#64748b",textAlign:"center"}}>{t.vehicle||"-"}</td>
              <td style={{...cellS,fontSize:9,fontWeight:700,color:vn?"#1e40af":"#ccc"}}>{vn?vn.name:"-"}</td>
              <td style={{...cellS,fontFamily:"monospace",fontSize:9,fontWeight:700,color:t.plateNo?"#2563eb":"#ccc"}}>{t.plateNo||"-"}</td>
              {["b","c","j"].map((k,ki)=><td key={k} style={{...cellS,textAlign:"center"}}><span style={{fontSize:9,fontWeight:700,color:liveOpts[k]>0?"#dc2626":"#ccc"}}>{liveOpts[k]||"-"}</span></td>)}
              <td style={{...cellS,fontWeight:600,color:t.insurance==="NOC"?"#b45309":"#64748b",fontSize:9}}>{t.insurance||"-"}</td>
              <td style={{...cellS,fontSize:9}}>{t.memo||"-"}</td>
              <td style={cellS}>{t.ota?<OBadge ota={t.ota}/>:""}</td>
              <td style={{...cellS,fontFamily:"monospace",fontSize:8}} onClick={e=>e.stopPropagation()}>{t.reservationId?<span style={{display:"flex",alignItems:"center",gap:2}}><a href={"license.html?id="+encodeURIComponent(t.reservationId)+"&name="+encodeURIComponent(t.name||"")} target="_blank" style={{color:"#3b82f6",textDecoration:"underline",cursor:"pointer"}}>{t.reservationId}</a><button onClick={e=>{e.stopPropagation();navigator.clipboard.writeText(t.reservationId);const b=e.currentTarget;b.textContent="✓";setTimeout(()=>b.textContent="📋",1000);}} style={{background:"none",border:"none",cursor:"pointer",fontSize:10,padding:0}} title="コピー">📋</button></span>:""}</td>
              <td style={{...cellS,fontSize:8,color:"#f59e0b"}}>{t.typeChange||""}</td>
            </tr>;
          })}
          {filteredTasks.length===0&&<tr><td colSpan={18} style={{textAlign:"center",padding:16,color:"#94a3b8",fontSize:11}}>タスクなし</td></tr>}
        </tbody></table>
      </div></div>
      </div>;})()}
      {/* ★ 編集タブ（3階層UI） */}
      {sheetFilter==="edit"&&(()=>{
        const resolvedT=(t)=>t.timeChange||t._ssTime||t.time;
        const resolvedP=(t)=>t._placeSource==="manual"?t.place:(t._ssPlace||t.place);
        /* ---- ナビバー ---- */
        const navBar=<div style={{padding:"8px 12px",background:"#1e293b",display:"flex",alignItems:"center",gap:8}}>
          <button onClick={()=>{if(editBlock!==null){setEditBlock(null);}else if(editResId!==null){setEditResId(null);}else{setSheetFilter("master");}}} style={{padding:"4px 12px",background:"#334155",color:"#fff",border:"none",borderRadius:6,fontSize:11,fontWeight:700,cursor:"pointer"}}>← 戻る</button>
          {editResId&&<span style={{fontSize:11,color:"#94a3b8",fontWeight:600}}>{(()=>{const ft=tasks.find(x=>x.reservationId===editResId);return ft?ft.name:"";})()}</span>}
          <span style={{fontSize:10,color:"#64748b",marginLeft:"auto"}}>{editResId?"予約編集":"予約一覧"}</span>
        </div>;
        /* ---- Phase1: 予約リスト ---- */
        if(!editResId){
          const grouped={};
          tasks.filter(t=>t.reservationId&&t.type!=="洗車").forEach(t=>{
            if(!grouped[t.reservationId])grouped[t.reservationId]={resId:t.reservationId,name:t.name,ota:t.ota,vehicle:t.vehicle,people:t.people,tasks:[],hasVehicle:!!t.assignedVehicle,types:[]};
            grouped[t.reservationId].tasks.push(t);
            if(!grouped[t.reservationId].types.includes(t.type))grouped[t.reservationId].types.push(t.type);
          });
          const resList=Object.values(grouped);
          return <div>
            {navBar}
            <div style={{padding:8}}>
              <div style={{fontSize:12,fontWeight:700,color:"#1e293b",marginBottom:8}}>予約一覧 ({resList.length}件)</div>
              {resList.map(r=>{
                const delT=r.tasks.find(x=>x.type==="DEL");const colT=r.tasks.find(x=>x.type==="COL");
                const rTimeD=delT?resolvedT(delT):"";const rTimeC=colT?resolvedT(colT):"";
                return <div key={r.resId} onClick={()=>setEditResId(r.resId)} style={{background:"#fff",border:"1px solid #e2e8f0",borderRadius:10,padding:"10px 12px",marginBottom:6,cursor:"pointer",boxShadow:"0 1px 3px rgba(0,0,0,.06)"}}>
                  <div style={{display:"flex",alignItems:"center",gap:6,marginBottom:4}}>
                    {r.ota&&<OBadge ota={r.ota}/>}
                    <span style={{fontSize:13,fontWeight:700,color:"#0f172a"}}>{r.name||"名前なし"}</span>
                    <span style={{fontSize:10,color:"#64748b",marginLeft:"auto"}}>{r.people}名 / {r.vehicle||"-"}</span>
                  </div>
                  <div style={{display:"flex",gap:6,flexWrap:"wrap"}}>
                    {r.types.map(tp=>{const tm=TASK_META[tp]||TASK_META["その他"];return <span key={tp} style={{fontSize:9,fontWeight:700,color:tm.c,background:tm.bg,padding:"1px 8px",borderRadius:4}}>{tp}</span>;})}
                    {rTimeD&&<span style={{fontSize:9,color:"#2563eb"}}>DEL {rTimeD}</span>}
                    {rTimeC&&<span style={{fontSize:9,color:"#ea580c"}}>COL {rTimeC}</span>}
                    <span style={{fontSize:9,color:r.hasVehicle?"#059669":"#dc2626",fontWeight:600,marginLeft:"auto"}}>{r.hasVehicle?"配車済":"未配車"}</span>
                  </div>
                </div>;
              })}
              {resList.length===0&&<div style={{textAlign:"center",padding:32,color:"#94a3b8",fontSize:13}}>予約なし</div>}
            </div>
          </div>;
        }
        /* ---- Phase2: 予約詳細 ---- */
        if(editResId&&!editBlock){
          const resTasks=tasks.filter(t=>t.reservationId===editResId&&t.type!=="洗車");
          const delT=resTasks.find(t=>t.type==="DEL");
          const colT=resTasks.find(t=>t.type==="COL");
          const anyT=resTasks[0]||{};
          const vn=anyT.assignedVehicle?vehicles.find(x=>x.code===anyT.assignedVehicle):null;
          const rTimeD=delT?resolvedT(delT):"";const rPlaceD=delT?resolvedP(delT):"";
          const rTimeC=colT?resolvedT(colT):"";const rPlaceC=colT?resolvedP(colT):"";
          const cardStyle=(gradient)=>({background:gradient,borderRadius:12,padding:"14px 16px",marginBottom:8,cursor:"pointer",boxShadow:"0 2px 8px rgba(0,0,0,.1)"});
          return <div>
            {navBar}
            <div style={{padding:12}}>
              {/* 予約ヘッダー */}
              <div style={{background:"#fff",borderRadius:10,padding:"12px 16px",marginBottom:10,border:"1px solid #e2e8f0"}}>
                <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:4}}>
                  {anyT.ota&&<OBadge ota={anyT.ota}/>}
                  <span style={{fontSize:16,fontWeight:800,color:"#0f172a"}}>{anyT.name||"名前なし"}</span>
                </div>
                <div style={{display:"flex",gap:12,flexWrap:"wrap",fontSize:11,color:"#475569"}}>
                  <span>予約番号: {editResId.substring(0,12)}...</span>
                  <span>{anyT.people||0}名</span>
                  <span>クラス: {anyT.vehicle||"-"}</span>
                  {anyT.tel&&<span>TEL: {anyT.tel}</span>}
                </div>
              </div>
              {/* 出発カード */}
              <div onClick={()=>setEditBlock("dep")} style={cardStyle("linear-gradient(135deg,#eff6ff,#dbeafe)")}>
                <div style={{fontSize:14,fontWeight:800,color:"#1e40af",marginBottom:6}}>🚗 出発</div>
                <div style={{display:"flex",gap:12,flexWrap:"wrap",fontSize:11,color:"#1e3a5f"}}>
                  <span>タイプ: {delT?delT.type:"DEL"}{delT?.typeChange?<span style={{color:"#f59e0b",marginLeft:4}}>({delT.typeChange})</span>:""}</span>
                  <span>時間: {rTimeD||<span style={{color:"#ef4444"}}>未設定</span>}</span>
                  <span>場所: {rPlaceD||<span style={{color:"#ef4444"}}>未設定</span>}</span>
                  {delT?.flight&&<span>便: {delT.flight}</span>}
                </div>
              </div>
              {/* 返却カード */}
              <div onClick={()=>setEditBlock("ret")} style={cardStyle("linear-gradient(135deg,#fef2f2,#fecaca)")}>
                <div style={{fontSize:14,fontWeight:800,color:"#dc2626",marginBottom:6}}>🔑 返却</div>
                <div style={{display:"flex",gap:12,flexWrap:"wrap",fontSize:11,color:"#7f1d1d"}}>
                  <span>タイプ: {colT?colT.type:"COL"}{colT?.typeChange?<span style={{color:"#f59e0b",marginLeft:4}}>({colT.typeChange})</span>:""}</span>
                  <span>時間: {rTimeC||<span style={{color:"#ef4444"}}>未設定</span>}</span>
                  <span>場所: {rPlaceC||<span style={{color:"#ef4444"}}>未設定</span>}</span>
                </div>
              </div>
              {/* 配車カード */}
              <div onClick={()=>setEditBlock("common")} style={cardStyle("linear-gradient(135deg,#f8fafc,#e2e8f0)")}>
                <div style={{fontSize:14,fontWeight:800,color:"#475569",marginBottom:6}}>🚙 配車・オプション</div>
                <div style={{display:"flex",gap:12,flexWrap:"wrap",fontSize:11,color:"#334155"}}>
                  <span>車両: {vn?vn.name:<span style={{color:"#ef4444"}}>未配車</span>}</span>
                  <span>No: {anyT.plateNo||"-"}</span>
                </div>
              </div>
            </div>
          </div>;
        }
        /* ---- Phase3: ブロック編集 ---- */
        if(editResId&&editBlock){
          const resTasks=tasks.filter(t=>t.reservationId===editResId&&t.type!=="洗車");
          const anyT=resTasks[0]||{};
          const targetT=editBlock==="dep"?resTasks.find(t=>t.type==="DEL"||t.type==="来店"):editBlock==="ret"?resTasks.find(t=>t.type==="COL"||t.type==="返却"):resTasks[0];
          if(!targetT)return <div>{navBar}<div style={{padding:32,textAlign:"center",color:"#94a3b8"}}>対象タスクが見つかりません</div></div>;
          const t=targetT;
          const tOpts=t.opts||{};
          const liveOpts={b:+(tOpts.b||0),c:+(tOpts.c||0),j:+(tOpts.j||0)};
          const secS={background:"#fff",borderRadius:10,padding:"12px 16px",marginBottom:8,border:"1px solid #e2e8f0"};
          const lblS={fontSize:10,fontWeight:700,color:"#64748b",marginBottom:4};
          const valS={fontSize:13,fontWeight:700,color:"#0f172a"};
          const roValS={fontSize:11,color:"#94a3b8",fontStyle:"italic"};
          const headerColor=editBlock==="dep"?"#1e40af":editBlock==="ret"?"#dc2626":"#475569";
          const headerBg=editBlock==="dep"?"linear-gradient(135deg,#1e40af,#3b82f6)":editBlock==="ret"?"linear-gradient(135deg,#dc2626,#f87171)":"linear-gradient(135deg,#475569,#94a3b8)";
          const headerIcon=editBlock==="dep"?"🚗 出発":editBlock==="ret"?"🔑 返却":"🚙 配車・オプション";
          return <div>
            {navBar}
            {/* ヘッダー帯 */}
            <div style={{background:headerBg,padding:"10px 16px",display:"flex",alignItems:"center",gap:8}}>
              <span style={{fontSize:14,fontWeight:800,color:"#fff"}}>{headerIcon}</span>
              <span style={{fontSize:11,color:"rgba(255,255,255,.8)"}}>{t.type}</span>
              <span style={{fontSize:12,fontWeight:700,color:"#fff",marginLeft:"auto"}}>{anyT.name}</span>
              <span style={{fontSize:9,color:"rgba(255,255,255,.6)"}}>{editResId.substring(0,8)}</span>
            </div>
            <div style={{padding:12}}>
            {/* ---- dep: 出発ブロック ---- */}
            {editBlock==="dep"&&<div>
              {/* 貸出方法 */}
              <div style={secS}>
                <div style={lblS}>📋 貸出方法</div>
                <select value={t.type||"DEL"} onChange={e=>{const v=e.target.value;setTimeout(()=>{if(!window.confirm("貸出方法を「"+v+"」に変更しますか？"))return;const chain=t.typeChange?(t.typeChange+"→"+v):(t.type+"→"+v);_save(t._id,mark({...t,type:v,typeChange:chain},"type"));},50);}} style={{width:"100%",padding:"8px 12px",borderRadius:8,border:"1px solid #cbd5e1",fontSize:13,fontWeight:700,color:headerColor}}>
                  <option value="DEL">DEL（配送）</option>
                  <option value="来店">来店</option>
                </select>
              </div>
              {/* 送迎時間 3階層 */}
              <div style={secS}>
                <div style={lblS}>⏰ 送迎時間</div>
                <div style={{marginBottom:6}}>
                  <div style={roValS}>① CSV元値: {t.time||"-"}</div>
                  <div style={roValS}>② SS自動: {t._ssTime||"-"}</div>
                </div>
                <div style={{display:"flex",alignItems:"center",gap:8}}>
                  <span style={{fontSize:10,fontWeight:600,color:"#475569"}}>③ 手動変更:</span>
                  <select value={t.timeChange||""} onChange={e=>{const v=e.target.value;setTimeout(()=>{if(!window.confirm("時間を「"+(v||"取消")+"」に変更しますか？"))return;_save(t._id,mark({...t,timeChange:v},"timeChange"));},50);}} style={{flex:1,padding:"6px 10px",borderRadius:8,border:"1px solid #cbd5e1",fontSize:12,fontWeight:700,color:"#1d4ed8"}}>
                    <option value="">-- 変更なし --</option>
                    {TIME_OPTS.filter(o=>o).map(o=><option key={o} value={o}>{o}</option>)}
                  </select>
                  {t.timeChange&&<button onClick={()=>{setTimeout(()=>{if(!window.confirm("手動時間変更を取り消しますか？"))return;_save(t._id,mark({...t,timeChange:""},"timeChange"));},50);}} style={{padding:"4px 10px",background:"#fef2f2",color:"#dc2626",border:"1px solid #fca5a5",borderRadius:6,fontSize:10,fontWeight:700,cursor:"pointer"}}>取消</button>}
                </div>
                <div style={{marginTop:4,fontSize:11,fontWeight:700,color:"#1e40af"}}>確定時間: {resolvedT(t)||"-"}</div>
              </div>
              {/* 場所 3階層 */}
              <div style={secS}>
                <div style={lblS}>📍 場所</div>
                <div style={{marginBottom:6}}>
                  <div style={roValS}>① CSV元値: {t.place||"-"}</div>
                  <div style={roValS}>② SS自動: {t._ssPlace||"-"}</div>
                </div>
                <div style={{display:"flex",alignItems:"center",gap:8}}>
                  <span style={{fontSize:10,fontWeight:600,color:"#475569"}}>③ 手動変更:</span>
                  <input defaultValue={t._placeSource==="manual"?t.place:""} onBlur={e=>{const v=e.target.value.trim();if(!v)return;setTimeout(()=>{if(!window.confirm("場所を「"+v+"」に変更しますか？"))return;_save(t._id,mark({...t,place:v,_placeSource:"manual"},"place"));},50);}} onKeyDown={e=>{if(e.key==="Enter")e.target.blur();}} style={{flex:1,padding:"6px 10px",borderRadius:8,border:"1px solid #cbd5e1",fontSize:12}} placeholder="場所を入力"/>
                  {t._placeSource==="manual"&&<button onClick={()=>{setTimeout(()=>{if(!window.confirm("手動場所変更を取り消しますか？"))return;_save(t._id,mark({...t,_placeSource:""},"place"));},50);}} style={{padding:"4px 10px",background:"#fef2f2",color:"#dc2626",border:"1px solid #fca5a5",borderRadius:6,fontSize:10,fontWeight:700,cursor:"pointer"}}>取消</button>}
                </div>
                <div style={{marginTop:4,fontSize:11,fontWeight:700,color:"#1e40af"}}>確定場所: {resolvedP(t)||"-"}</div>
              </div>
              {/* 便名 */}
              <div style={secS}>
                <div style={lblS}>✈ 便名</div>
                <input defaultValue={t.flight||""} onBlur={e=>{const v=e.target.value.trim();if(v===(t.flight||""))return;setTimeout(()=>{if(!window.confirm("便名を「"+(v||"空欄")+"」に変更しますか？"))return;_save(t._id,mark({...t,flight:v},"flight"));},50);}} onKeyDown={e=>{if(e.key==="Enter")e.target.blur();}} style={{width:"100%",padding:"8px 12px",borderRadius:8,border:"1px solid #cbd5e1",fontSize:13}} placeholder="便名"/>
              </div>
              {/* メモ */}
              <div style={secS}>
                <div style={lblS}>📝 メモ</div>
                <input defaultValue={t.memo||""} onBlur={e=>{const v=e.target.value.trim();if(v===(t.memo||""))return;setTimeout(()=>{if(!window.confirm("メモを変更しますか？"))return;_save(t._id,mark({...t,memo:v},"memo"));},50);}} onKeyDown={e=>{if(e.key==="Enter")e.target.blur();}} style={{width:"100%",padding:"8px 12px",borderRadius:8,border:"1px solid #cbd5e1",fontSize:13}} placeholder="メモ"/>
              </div>
            </div>}
            {/* ---- ret: 返却ブロック ---- */}
            {editBlock==="ret"&&<div>
              {/* 返却方法 */}
              <div style={secS}>
                <div style={lblS}>📋 返却方法</div>
                <select value={t.type||"COL"} onChange={e=>{const v=e.target.value;setTimeout(()=>{if(!window.confirm("返却方法を「"+v+"」に変更しますか？"))return;const chain=t.typeChange?(t.typeChange+"→"+v):(t.type+"→"+v);_save(t._id,mark({...t,type:v,typeChange:chain},"type"));},50);}} style={{width:"100%",padding:"8px 12px",borderRadius:8,border:"1px solid #cbd5e1",fontSize:13,fontWeight:700,color:headerColor}}>
                  <option value="COL">COL（回収）</option>
                  <option value="返却">返却（来店）</option>
                  <option value="乗り捨て">乗り捨て</option>
                </select>
              </div>
              {/* 送迎時間 3階層 */}
              <div style={secS}>
                <div style={lblS}>⏰ 送迎時間</div>
                <div style={{marginBottom:6}}>
                  <div style={roValS}>① CSV元値: {t.time||"-"}</div>
                  <div style={roValS}>② SS自動: {t._ssTime||"-"}</div>
                </div>
                <div style={{display:"flex",alignItems:"center",gap:8}}>
                  <span style={{fontSize:10,fontWeight:600,color:"#475569"}}>③ 手動変更:</span>
                  <select value={t.timeChange||""} onChange={e=>{const v=e.target.value;setTimeout(()=>{if(!window.confirm("時間を「"+(v||"取消")+"」に変更しますか？"))return;_save(t._id,mark({...t,timeChange:v},"timeChange"));},50);}} style={{flex:1,padding:"6px 10px",borderRadius:8,border:"1px solid #cbd5e1",fontSize:12,fontWeight:700,color:"#dc2626"}}>
                    <option value="">-- 変更なし --</option>
                    {TIME_OPTS.filter(o=>o).map(o=><option key={o} value={o}>{o}</option>)}
                  </select>
                  {t.timeChange&&<button onClick={()=>{setTimeout(()=>{if(!window.confirm("手動時間変更を取り消しますか？"))return;_save(t._id,mark({...t,timeChange:""},"timeChange"));},50);}} style={{padding:"4px 10px",background:"#fef2f2",color:"#dc2626",border:"1px solid #fca5a5",borderRadius:6,fontSize:10,fontWeight:700,cursor:"pointer"}}>取消</button>}
                </div>
                <div style={{marginTop:4,fontSize:11,fontWeight:700,color:"#dc2626"}}>確定時間: {resolvedT(t)||"-"}</div>
              </div>
              {/* 場所 3階層 */}
              <div style={secS}>
                <div style={lblS}>📍 場所</div>
                <div style={{marginBottom:6}}>
                  <div style={roValS}>① CSV元値: {t.place||"-"}</div>
                  <div style={roValS}>② SS自動: {t._ssPlace||"-"}</div>
                </div>
                <div style={{display:"flex",alignItems:"center",gap:8}}>
                  <span style={{fontSize:10,fontWeight:600,color:"#475569"}}>③ 手動変更:</span>
                  <input defaultValue={t._placeSource==="manual"?t.place:""} onBlur={e=>{const v=e.target.value.trim();if(!v)return;setTimeout(()=>{if(!window.confirm("場所を「"+v+"」に変更しますか？"))return;_save(t._id,mark({...t,place:v,_placeSource:"manual"},"place"));},50);}} onKeyDown={e=>{if(e.key==="Enter")e.target.blur();}} style={{flex:1,padding:"6px 10px",borderRadius:8,border:"1px solid #cbd5e1",fontSize:12}} placeholder="場所を入力"/>
                  {t._placeSource==="manual"&&<button onClick={()=>{setTimeout(()=>{if(!window.confirm("手動場所変更を取り消しますか？"))return;_save(t._id,mark({...t,_placeSource:""},"place"));},50);}} style={{padding:"4px 10px",background:"#fef2f2",color:"#dc2626",border:"1px solid #fca5a5",borderRadius:6,fontSize:10,fontWeight:700,cursor:"pointer"}}>取消</button>}
                </div>
                <div style={{marginTop:4,fontSize:11,fontWeight:700,color:"#dc2626"}}>確定場所: {resolvedP(t)||"-"}</div>
              </div>
              {/* メモ */}
              <div style={secS}>
                <div style={lblS}>📝 メモ</div>
                <input defaultValue={t.memo||""} onBlur={e=>{const v=e.target.value.trim();if(v===(t.memo||""))return;setTimeout(()=>{if(!window.confirm("メモを変更しますか？"))return;_save(t._id,mark({...t,memo:v},"memo"));},50);}} onKeyDown={e=>{if(e.key==="Enter")e.target.blur();}} style={{width:"100%",padding:"8px 12px",borderRadius:8,border:"1px solid #cbd5e1",fontSize:13}} placeholder="メモ"/>
              </div>
            </div>}
            {/* ---- common: 配車・オプション ---- */}
            {editBlock==="common"&&(()=>{
              const classes=[...new Set(vehicles.map(v=>v.type))];
              return <div>
              {/* 車両配車 */}
              <div style={secS}>
                <div style={lblS}>🚗 車両配車</div>
                <select value={t.assignedVehicle||""} onChange={async e=>{const vc=e.target.value;const vn=vehicles.find(x=>x.code===vc);
                  setTimeout(async()=>{
                    if(vc&&!window.confirm("「"+(vn?vn.name+" "+vn.no:"")+"」に配車しますか？"))return;
                    if(!vc&&t.assignedVehicle&&!window.confirm("配車を解除しますか？"))return;
                    selfUpdateRef.current[selDate]=Date.now();
                    const newV=vn?vn.type:t.vehicle;const newP=vn?vn.no:"";
                    if(t.reservationId){onFleetChange(prev=>{const nf={...(typeof prev==="object"?prev:fleetRef.current)};if(vc)nf[t.reservationId]=vc;else delete nf[t.reservationId];return nf;});}
                    const updatedIds=[];
                    setTasks(ts=>{const next=ts.map(x=>{if(x.reservationId===t.reservationId){updatedIds.push(x._id);return{...x,assignedVehicle:vc,plateNo:newP,vehicle:newV};}return x;});DB._lsSave(next,selDate);return next;});
                    pendingSaves.current++;setSaveStatus("saving");
                    try{if(sb){const updates=updatedIds.map(uid=>sb.from("tasks").update({assigned_vehicle:vc,plate_no:newP,vehicle:newV}).eq("_id",uid));await Promise.all(updates);}if(t.reservationId&&newV)DB.syncToReservation(t.reservationId,{vehicle:newV});}catch(e){console.error("[vehicle assign]",e);}
                    pendingSaves.current--;setSaveStatus(pendingSaves.current>0?"saving":"ok");
                  },50);
                }} style={{width:"100%",padding:"8px 12px",borderRadius:8,border:t.assignedVehicle?"1px solid #cbd5e1":"2px solid #dc2626",fontSize:13,fontWeight:700,color:t.assignedVehicle?"#1e40af":"#dc2626",background:t.assignedVehicle?"#fff":"#fef2f2"}}>
                  <option value="">未配車</option>
                  {classes.map(cls=><optgroup key={cls} label={cls+"クラス"}>{vehicles.filter(v=>v.type===cls).map(v=>{const conflict=v.code!==t.assignedVehicle&&checkVehicleConflict(v.code,t.reservationId,reservations,fleet);return <option key={v.code} value={v.code} disabled={conflict} style={{color:conflict?"#ccc":"#111"}}>{v.name} ({v.no}){conflict?" ×":""}</option>;})}</optgroup>)}
                </select>
              </div>
              {/* オプション B/C/J */}
              <div style={secS}>
                <div style={lblS}>オプション数量</div>
                <div style={{display:"flex",gap:16}}>
                  {[{k:"b",label:"B(ベビー)"},{k:"c",label:"C(チャイルド)"},{k:"j",label:"J(ジュニア)"}].map(opt=><div key={opt.k} style={{flex:1}}>
                    <div style={{fontSize:10,color:"#64748b",marginBottom:2}}>{opt.label}</div>
                    <select value={liveOpts[opt.k]} onChange={e=>{const v=+e.target.value;const newOpts={...liveOpts,[opt.k]:v};setTimeout(()=>{_save(t._id,{...t,opts:{...tOpts,...newOpts}});},50);}} style={{width:"100%",padding:"6px",borderRadius:6,border:"1px solid #cbd5e1",fontSize:13,fontWeight:700,color:liveOpts[opt.k]>0?"#dc2626":"#94a3b8",textAlign:"center"}}>
                      <option value={0}>0</option><option value={1}>1</option><option value={2}>2</option><option value={3}>3</option>
                    </select>
                  </div>)}
                </div>
              </div>
              {/* 補償 */}
              <div style={secS}>
                <div style={lblS}>補償</div>
                <input defaultValue={t.insurance||""} onBlur={e=>{const v=e.target.value.trim();if(v===(t.insurance||""))return;setTimeout(()=>{if(!window.confirm("補償を「"+(v||"空欄")+"」に変更しますか？"))return;_save(t._id,mark({...t,insurance:v},"insurance"));},50);}} onKeyDown={e=>{if(e.key==="Enter")e.target.blur();}} style={{width:"100%",padding:"8px 12px",borderRadius:8,border:"1px solid #cbd5e1",fontSize:13}} placeholder="NOC / フル 等"/>
              </div>
              {/* チェックボックス群 */}
              <div style={secS}>
                <div style={{display:"flex",gap:16,flexWrap:"wrap"}}>
                  {[{k:"yakkan",label:"✅ 約款チェック"},{k:"line",label:"📱 LINE送信"},{k:"payment",label:"💰 決済"}].map(chk=><label key={chk.k} style={{display:"flex",alignItems:"center",gap:6,fontSize:12,fontWeight:600,color:"#334155",cursor:"pointer"}}>
                    <input type="checkbox" checked={!!t[chk.k]} onChange={e=>{const v=e.target.checked;setTimeout(()=>{_save(t._id,mark({...t,[chk.k]:v},chk.k));},50);}} style={{width:16,height:16,accentColor:"#2563eb"}}/>
                    {chk.label}
                  </label>)}
                </div>
              </div>
              </div>;
            })()}
            </div>
          </div>;
        }
        return null;
      })()}
      <TimeTable tasks={tasks} staffCount={staffCount}/>
      {/* LINE送信モーダル */}
      {lineModal&&(()=>{
        const m=lineModal;const custName=(m.name||"")+"様";
        const clipCopy=(txt)=>navigator.clipboard.writeText(txt);
        const close=()=>setLineModal(null);
        const btnS=(bg,border,color)=>({display:"block",width:"100%",padding:"14px 16px",background:bg,border:"2px solid "+border,borderRadius:12,fontSize:14,fontWeight:700,color,cursor:"pointer",marginBottom:8,textAlign:"left"});
        return <div onClick={close} style={{position:"fixed",top:0,left:0,right:0,bottom:0,background:"rgba(0,0,0,.5)",zIndex:9999,display:"flex",alignItems:"center",justifyContent:"center",padding:16}}>
          <div onClick={e=>e.stopPropagation()} style={{background:"#fff",borderRadius:16,padding:20,width:"100%",maxWidth:360,maxHeight:"90vh",overflowY:"auto",boxShadow:"0 20px 60px rgba(0,0,0,.25)"}}>
            <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:12}}>
              <div style={{fontSize:15,fontWeight:800,color:"#1e293b"}}>📱 {m.name}</div>
              <button onClick={close} style={{background:"none",border:"none",fontSize:20,color:"#94a3b8",cursor:"pointer",padding:"4px 8px"}}>✕</button>
            </div>
            <div style={{fontSize:11,color:"#64748b",marginBottom:12,padding:"6px 10px",background:"#f8fafc",borderRadius:8}}>
              {m.vehName&&<span>{m.vehName} </span>}{m.plateNo&&<span>({m.plateNo}) </span>}{m.place&&<span>📍{m.place}</span>}
            </div>
            {m.isDel?<div>
              <div style={{fontSize:11,fontWeight:700,color:"#059669",marginBottom:6}}>LINE テンプレート</div>
              <button onClick={()=>{const msg=`【車両到着のお知らせ】\n${custName}\n\nお待たせいたしました。\n只今スタッフが指定場所に到着いたしました。\n\n場所: ${m.place}\n車種: ${m.vehName}\nナンバー: ${m.plateNo}\n\nご準備整い次第、受け取り対応をお願い申し上げます。\nお手続きは全て完了しておりますので、車両の受け渡しのみスムーズにお貸出させていただきます。`;clipCopy(msg).then(()=>{alert("📋 到着メッセージをコピーしました\n\nL Messageで「"+m.name+"」を検索して貼り付け");close();});}} style={btnS("#f0fdf4","#86efac","#15803d")}>📱① 到着のお知らせ</button>
              <button onClick={()=>{const msg=`【車両位置情報のお知らせ】\n${custName}\n\n現在車両をデリバリー中です。\n詳細はマップリンクから位置情報をご確認ください。\n\n＜車両情報＞\nお届け場所: ${m.place}\n車種: ${m.vehName}\nナンバー: ${m.plateNo}\n\n＜車両位置情報＞\n`;clipCopy(msg).then(()=>{alert("📋 位置情報メッセージをコピーしました\n\nL Messageで「"+m.name+"」を検索して貼り付け");close();});}} style={btnS("#eff6ff","#93c5fd","#1d4ed8")}>📱② 位置情報のお知らせ</button>
            </div>:<div>
              <button onClick={()=>{const msg=`【ご返却場所到着のお知らせ】\n${custName}\n\n回収スタッフがご返却場所に到着致しました。\nご準備できましたら対応のほどお願い申しあげます。\n何卒よろしくお願いいたします。`;clipCopy(msg).then(()=>{alert("📋 COLメッセージをコピーしました\n\nL Messageで「"+m.name+"」を検索して貼り付け");close();});}} style={btnS("#f0fdf4","#86efac","#15803d")}>📱① 返却場所到着のお知らせ</button>
              <button onClick={()=>{const msg=`【乗り捨て対応のお願い】\n${custName}\n\nご返却時刻の混雑により、大変お手数ではございますが返却予定場所近隣駐車場に乗り捨て駐車いただきたく、ご連絡させていただきました。\nお待たせする時間回避の目的のためご協力の程何卒よろしくお願いいたします。\n\n✅駐車完了しましたら"鍵と駐車券"をダッシュボード内に格納し、鍵を開けた状態でそのままお降りくださいませ。\n✅燃料の給油とお忘れ物（ETCカード等）のないようご注意ください。\n✅駐車場所が確定しましたら詳細場所をご連絡いただけますと幸いです。\n例：駐車場看板写真/GoogleマップURL/住所/駐車場名/●階等\n\n駐車後の車両トラブルに関しては一切の責任は問いませんのでご安心くださいませ。\n万一の盗難等の際にも弊社セキュリティにて追跡可能となっております。`;clipCopy(msg).then(()=>{alert("📋 乗り捨て依頼メッセージをコピーしました\n\nL Messageで「"+m.name+"」を検索して貼り付け");close();});}} style={btnS("#fef2f2","#fca5a5","#b91c1c")}>📱② 乗り捨て依頼</button>
            </div>}
            <div style={{borderTop:"2px solid #fde68a",marginTop:8,paddingTop:10}}>
              <div style={{fontSize:11,fontWeight:700,color:"#d97706",marginBottom:6}}>🚗 CARMON 位置確認</div>
              <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:6,marginBottom:6}}>
                <button onClick={()=>{const cId=localStorage.getItem("spk_carmon_id")||"";if(cId){clipCopy(cId).then(()=>alert("📋 IDをコピーしました"));}else{const nid=prompt("CARMON IDを入力\n（次回から自動保存）");if(nid){localStorage.setItem("spk_carmon_id",nid);clipCopy(nid).then(()=>alert("📋 ID保存＆コピー完了"));}}}} style={btnS("#fffbeb","#fbbf24","#92400e")}>🔑 ID コピー</button>
                <button onClick={()=>{const cP=localStorage.getItem("spk_carmon_pas")||"";if(cP){clipCopy(cP).then(()=>alert("📋 PASSをコピーしました"));}else{const np=prompt("CARMON PASSを入力\n（次回から自動保存）");if(np){localStorage.setItem("spk_carmon_pas",np);clipCopy(np).then(()=>alert("📋 PASS保存＆コピー完了"));}}}} style={btnS("#fffbeb","#fbbf24","#92400e")}>🔑 PASS コピー</button>
              </div>
              <button onClick={()=>{window.open("https://web.carmon.alpine-srv.net/","_blank");close();}} style={{...btnS("#fef3c7","#f59e0b","#78350f"),textAlign:"center",fontSize:15}}>📍 CARMONを開く</button>
              <button onClick={()=>{localStorage.removeItem("spk_carmon_id");localStorage.removeItem("spk_carmon_pas");alert("ID/PASSをリセットしました");}} style={{display:"block",width:"100%",background:"none",border:"none",fontSize:10,color:"#94a3b8",cursor:"pointer",textAlign:"center",padding:4,marginTop:2}}>認証情報リセット</button>
            </div>
          </div>
        </div>;
      })()}
    </div>
  </div>;
}

function AddTaskForm({onAdd,onClose,activeMembers,vehicles}){
  const[type,setType]=useState("事前駐車");const[time,setTime]=useState("09:00");const[name,setName]=useState("");const[customerName,setCustomerName]=useState("");const[assignee,setAssignee]=useState("");const[vehicle,setVehicle]=useState("");const[place,setPlace]=useState("");const[memo,setMemo]=useState("");
  const classes=[...new Set(vehicles.map(v=>v.type))];
  const submit=()=>{if(!type)return;const v=vehicles.find(x=>x.code===vehicle);onAdd({_id:uid(),type,time,name:customerName||name,assignee,vehicle:v?v.type:"",place,people:0,insurance:"",done:false,memo,reservationId:"",ota:"",assignedVehicle:vehicle,plateNo:v?v.no:"",manual:true});onClose();};
  return <div className="modal-overlay" onClick={onClose}><div className="modal-box" style={{maxWidth:420,padding:20}} onClick={e=>e.stopPropagation()}>
    <h3 className="font-bold text-sm mb-3">タスク追加</h3>
    <div className="space-y-2">
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}><div><label className="text-xs text-gray-500">種別</label><select value={type} onChange={e=>setType(e.target.value)} className="input-s">{Object.keys(TASK_META).map(k=><option key={k}>{k}</option>)}</select></div><div><label className="text-xs text-gray-500">時間</label><input value={time} onChange={e=>setTime(e.target.value)} className="input-s"/></div></div>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}><div><label className="text-xs text-gray-500">予約者名</label><input value={customerName} onChange={e=>setCustomerName(e.target.value)} className="input-s" placeholder="お客様名"/></div><div><label className="text-xs text-gray-500">担当</label><select value={assignee} onChange={e=>setAssignee(e.target.value)} className="input-s"><option value="">未定</option>{activeMembers.map(m=><option key={m}>{m}</option>)}</select></div></div>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}><div><label className="text-xs text-gray-500">車両</label><select value={vehicle} onChange={e=>setVehicle(e.target.value)} className="input-s"><option value="">—</option>{classes.map(cls=><optgroup key={cls} label={cls+"クラス"}>{vehicles.filter(v=>v.type===cls).map(v=><option key={v.id} value={v.code}>{v.name}({v.no})</option>)}</optgroup>)}</select></div><div><label className="text-xs text-gray-500">場所</label><input value={place} onChange={e=>setPlace(e.target.value)} className="input-s" placeholder="新千歳空港 etc."/></div></div>
      <input value={memo} onChange={e=>setMemo(e.target.value)} className="input-s" placeholder="メモ"/>
    </div>
    <div className="flex justify-end gap-2 mt-3"><button onClick={onClose} className="btn-ghost">キャンセル</button><button onClick={submit} className="btn-primary">追加</button></div>
  </div></div>;
}

/* ==========================================
   📊 ダッシュボード
   ========================================== */


function Dashboard({data,fleet,vehicles,maintenance}){
  // ビュー切替（月別 vs 年間推移）
  const[dashView,setDashView]=useState("monthly"); // "monthly" | "annual"
  const[annTab,setAnnTab]=useState("revenue"); // 年間推移サブタブ
  // 月選択
  const allMonths=useMemo(()=>{
    const ms=new Set();
    data.forEach(r=>{if(r.lendDate)ms.add(toYM(r.lendDate));if(r.returnDate)ms.add(toYM(r.returnDate));});
    return[...ms].sort();
  },[data]);
  const curYM=toYM(new Date());
  const[selYM,setSelYM]=useState(curYM);
  const prevYM=ymOff(selYM,-1);

  // 対象月のデータ抽出（返却日が選択月に含まれる予約＝売上計上基準）
  const monthData=useMemo(()=>data.filter(r=>r.returnDate&&toYM(r.returnDate)===selYM),[data,selYM]);
  const prevMonthData=useMemo(()=>data.filter(r=>r.returnDate&&toYM(r.returnDate)===prevYM),[data,prevYM]);

  // === KPI計算 ===
  // 売上
  const totalRevenue=useMemo(()=>monthData.reduce((s,r)=>s+(Number(r.price)||0),0),[monthData]);
  const prevRevenue=useMemo(()=>prevMonthData.reduce((s,r)=>s+(Number(r.price)||0),0),[prevMonthData]);
  const revDiff=prevRevenue>0?((totalRevenue-prevRevenue)/prevRevenue*100):0;

  // 予約件数
  const totalCount=monthData.length;
  const prevCount=prevMonthData.length;

  // 平均単価
  const avgPrice=totalCount>0?Math.round(totalRevenue/totalCount):0;
  const prevAvgPrice=prevCount>0?Math.round(prevRevenue/prevCount):0;

  // OTA別売上
  const otaStats=useMemo(()=>{
    const m={};
    monthData.forEach(r=>{const k=r.ota||"?";if(!m[k])m[k]={count:0,revenue:0};m[k].count++;m[k].revenue+=(Number(r.price)||0);});
    return Object.entries(m).sort((a,b)=>b[1].revenue-a[1].revenue);
  },[monthData]);

  // 稼働率計算（配車画面と同じロジック: 日付Setで重複排除 + メンテナンス込み + 月内限定）
  const daysInMo=daysInMonth(selYM);
  const activeVehicles=vehicles.length||8;
  const totalVehDays=activeVehicles*daysInMo;
  const maint=maintenance||[];
  const curUtil=useMemo(function(){
    var dim=daysInMo;
    var parts=selYM.split("-");var yy=Number(parts[0]);var mm=Number(parts[1])-1;
    var ms=new Date(yy,mm,1);var me=new Date(yy,mm,dim);
    // 予約による稼働日（車両別Set）
    var vdm={};
    data.forEach(function(r){
      if(!r.lendDate||!r.returnDate)return;
      var vc=fleet[r.id];if(!vc)return;
      if(!vdm[vc])vdm[vc]=new Set();
      var ld=new Date(norm(r.lendDate)+"T00:00:00");var rd=new Date(norm(r.returnDate)+"T00:00:00");
      var s=ld>ms?new Date(ld):new Date(ms);var e=rd<me?new Date(rd):new Date(me);
      for(var d=new Date(s);d<=e;d.setDate(d.getDate()+1)){vdm[vc].add(toLD(d));}
    });
    // メンテナンス日（車両別Set）→ 最大稼働日数から減算用
    var maintMap={};
    maint.forEach(function(mt){
      if(!mt.vehicleCode||!mt.startDate||!mt.endDate)return;
      if(!maintMap[mt.vehicleCode])maintMap[mt.vehicleCode]=new Set();
      var ld=new Date(norm(mt.startDate)+"T00:00:00");var rd=new Date(norm(mt.endDate)+"T00:00:00");
      var s=ld>ms?new Date(ld):new Date(ms);var e=rd<me?new Date(rd):new Date(me);
      for(var d=new Date(s);d<=e;d.setDate(d.getDate()+1)){maintMap[mt.vehicleCode].add(toLD(d));}
    });
    var totalRental=0;Object.values(vdm).forEach(function(s){totalRental+=s.size;});
    var totalMaint=0;Object.values(maintMap).forEach(function(s){totalMaint+=s.size;});
    return{totalRental:totalRental,totalMaint:totalMaint,vehDayMap:vdm,maintMap:maintMap};
  },[selYM,data,fleet,maint,daysInMo]);
  const usedDays=curUtil.totalRental;
  const curVehDayMap=curUtil.vehDayMap;
  const curMaintMap=curUtil.maintMap;
  const totalMaintDays=curUtil.totalMaint;
  const availVehDays=totalVehDays-totalMaintDays;
  const utilRate=availVehDays>0?Math.round(usedDays/availVehDays*100):0;
  // 前月稼働率
  const prevDaysInMo=daysInMonth(prevYM);
  const prevTotalVehDays=activeVehicles*prevDaysInMo;
  const prevUtil=useMemo(function(){
    var dim=prevDaysInMo;
    var parts=prevYM.split("-");var yy=Number(parts[0]);var mm=Number(parts[1])-1;
    var ms=new Date(yy,mm,1);var me=new Date(yy,mm,dim);
    // 予約稼働日
    var vdm={};
    data.forEach(function(r){
      if(!r.lendDate||!r.returnDate)return;
      var vc=fleet[r.id];if(!vc)return;
      if(!vdm[vc])vdm[vc]=new Set();
      var ld=new Date(norm(r.lendDate)+"T00:00:00");var rd=new Date(norm(r.returnDate)+"T00:00:00");
      var s=ld>ms?new Date(ld):new Date(ms);var e=rd<me?new Date(rd):new Date(me);
      for(var d=new Date(s);d<=e;d.setDate(d.getDate()+1)){vdm[vc].add(toLD(d));}
    });
    // メンテ日数
    var maintTotal=0;
    maint.forEach(function(mt){
      if(!mt.vehicleCode||!mt.startDate||!mt.endDate)return;
      var mSet=new Set();
      var ld=new Date(norm(mt.startDate)+"T00:00:00");var rd=new Date(norm(mt.endDate)+"T00:00:00");
      var s=ld>ms?new Date(ld):new Date(ms);var e=rd<me?new Date(rd):new Date(me);
      for(var d=new Date(s);d<=e;d.setDate(d.getDate()+1)){mSet.add(toLD(d));}
      maintTotal+=mSet.size;
    });
    var rental=0;Object.values(vdm).forEach(function(s){rental+=s.size;});
    return{rental:rental,maintTotal:maintTotal};
  },[prevYM,data,fleet,maint,prevDaysInMo]);
  const prevUsedDays=prevUtil.rental;
  const prevAvailVehDays=prevTotalVehDays-prevUtil.maintTotal;
  const prevUtilRate=prevAvailVehDays>0?Math.round(prevUsedDays/prevAvailVehDays*100):0;

  // 車両別売上（fleet配車コードで集計 + 月内実稼働日数で計算）
  const vehStats=useMemo(function(){
    var m={};
    monthData.forEach(function(r){
      var vc=fleet[r.id]||"未配車";
      if(!m[vc])m[vc]={count:0,revenue:0,days:0};
      m[vc].count++;m[vc].revenue+=(Number(r.price)||0);
    });
    Object.keys(m).forEach(function(vc){
      if(curVehDayMap&&curVehDayMap[vc]){m[vc].days=curVehDayMap[vc].size;}
    });
    return Object.entries(m).sort(function(a,b){return b[1].revenue-a[1].revenue;});
  },[monthData,fleet,curVehDayMap]);

  // 日別売上（棒グラフ用）
  const dailyRevenue=useMemo(()=>{
    const m={};
    for(let d=1;d<=daysInMo;d++){
      const ds=selYM+"-"+String(d).padStart(2,"0");
      m[ds]=0;
    }
    monthData.forEach(r=>{
      if(!r.returnDate||!r.price)return;
      const ds=r.returnDate;if(m[ds]!==undefined)m[ds]+=(Number(r.price)||0);
    });
    return Object.entries(m).map(([d,v])=>({day:parseInt(d.split("-")[2]),value:v}));
  },[monthData,selYM,daysInMo]);
  const maxDaily=Math.max(1,...dailyRevenue.map(d=>d.value));

  // 月次推移データ（データが存在する全月を表示）
  const monthlyTrend=useMemo(()=>{
    const dataMonths=new Set();
    data.forEach(r=>{if(r.returnDate)dataMonths.add(toYM(r.returnDate));});
    dataMonths.add(curYM);
    const sorted=[...dataMonths].sort();
    const firstYM=sorted[0],lastYM=sorted[sorted.length-1];
    const months=[];let ym=firstYM;
    for(let i=0;i<36&&ym<=lastYM;i++){months.push(ym);ym=ymOff(ym,1);}
    return months.map(ym=>{
      const md=data.filter(r=>r.returnDate&&toYM(r.returnDate)===ym);
      return{ym,label:(parseInt(ym.split("-")[1]))+"月",revenue:md.reduce((s,r)=>s+(Number(r.price)||0),0),count:md.length};
    });
  },[data,curYM]);
  const maxMonthlyRev=Math.max(1,...monthlyTrend.map(m=>m.revenue));

  // 車種別稼働率（メンテ日数を最大稼働日数から減算）
  const vehUtilDetail=useMemo(()=>{
    return vehicles.map(v=>{
      const days=(curVehDayMap[v.code]||new Set()).size;
      const mDays=(curMaintMap[v.code]||new Set()).size;
      const avail=daysInMo-mDays;
      return{code:v.code,name:v.name,no:v.no,days,maintDays:mDays,availDays:avail,rate:avail>0?Math.round(days/avail*100):0};
    }).sort((a,b)=>b.rate-a.rate);
  },[vehicles,curVehDayMap,curMaintMap,daysInMo]);

  // === 年間推移 ===
  const ANN_CLASS_C={"A":"#7c3aed","B":"#0284c7","C":"#059669","S":"#d97706","F":"#db2777","H":"#64748b"};
  const annTabItems=[
    {id:"revenue",label:"売上",ico:"💰"},{id:"utilization",label:"稼働率",ico:"🚗"},
    {id:"classRev",label:"クラス売上",ico:"🏷️"},{id:"vehRev",label:"車両売上",ico:"🚙"},
    {id:"classUtil",label:"クラス稼働",ico:"📊"},{id:"vehUtil",label:"車両稼働",ico:"📅"}
  ];
  // === 年間推移データ ===
  const annualData=useMemo(function(){
    if(dashView!=="annual")return null;
    // 対象月リスト: データ全体から存在する月を取得（最大24ヶ月）
    var dataMonths=new Set();
    data.forEach(function(r){if(r.returnDate)dataMonths.add(toYM(r.returnDate));});
    dataMonths.add(curYM);
    var sorted=[].concat(Array.from(dataMonths)).sort();
    // 最初の月から最後の月まで連続的に
    var firstYM=sorted[0],lastYM=sorted[sorted.length-1];
    var months=[];var ym=firstYM;
    for(var i=0;i<36&&ym<=lastYM;i++){months.push(ym);ym=ymOff(ym,1);}

    var maint=maintenance||[];
    var codeToType={};vehicles.forEach(function(v){codeToType[v.code]=v.type;});

    var result=months.map(function(ym){
      var dim=daysInMonth(ym);
      var parts=ym.split("-");var yy=Number(parts[0]);var mm=Number(parts[1])-1;
      var moStart=new Date(yy,mm,1);var moEnd=new Date(yy,mm,dim);
      var md=data.filter(function(r){return r.returnDate&&toYM(r.returnDate)===ym;});

      // 1. グロス売上
      var grossRev=md.reduce(function(s,r){return s+(Number(r.price)||0);},0);
      var count=md.length;

      // 2. 稼働率計算（メンテ日数を最大稼働日数から減算）
      var vdm={};
      data.forEach(function(r){
        if(!r.lendDate||!r.returnDate)return;
        var vc=fleet[r.id];if(!vc)return;
        if(!vdm[vc])vdm[vc]=new Set();
        var ld=new Date(norm(r.lendDate)+"T00:00:00");var rd=new Date(norm(r.returnDate)+"T00:00:00");
        var s=ld>moStart?new Date(ld):new Date(moStart);var e=rd<moEnd?new Date(rd):new Date(moEnd);
        for(var d=new Date(s);d<=e;d.setDate(d.getDate()+1)){vdm[vc].add(toLD(d));}
      });
      // メンテ日数（車両別）
      var maintMapA={};
      maint.forEach(function(mt){
        if(!mt.vehicleCode||!mt.startDate||!mt.endDate)return;
        if(!maintMapA[mt.vehicleCode])maintMapA[mt.vehicleCode]=new Set();
        var ld=new Date(norm(mt.startDate)+"T00:00:00");var rd=new Date(norm(mt.endDate)+"T00:00:00");
        var s=ld>moStart?new Date(ld):new Date(moStart);var e=rd<moEnd?new Date(rd):new Date(moEnd);
        for(var d=new Date(s);d<=e;d.setDate(d.getDate()+1)){maintMapA[mt.vehicleCode].add(toLD(d));}
      });
      var totalUsed=0;Object.values(vdm).forEach(function(s){totalUsed+=s.size;});
      var totalMaintA=0;Object.values(maintMapA).forEach(function(s){totalMaintA+=s.size;});
      var totalPossible=vehicles.length*dim;
      var availPossible=totalPossible-totalMaintA;
      var grossRate=availPossible>0?Math.round(totalUsed/availPossible*100):0;

      // 3. クラス別売上
      var classRev={};
      INIT_CLASSES.forEach(function(cl){classRev[cl.type]={label:cl.label,revenue:0,count:0};});
      md.forEach(function(r){
        var vc=fleet[r.id];var tp=vc?codeToType[vc]:r.vehicle;
        var key=tp&&classRev[tp]?tp:"?";
        if(!classRev[key])classRev[key]={label:"不明",revenue:0,count:0};
        classRev[key].count++;classRev[key].revenue+=(Number(r.price)||0);
      });

      // 4. 車両別売上
      var vehRev={};
      md.forEach(function(r){
        var vc=fleet[r.id]||"未配車";
        if(!vehRev[vc])vehRev[vc]={revenue:0,count:0,days:0};
        vehRev[vc].count++;vehRev[vc].revenue+=(Number(r.price)||0);
      });
      Object.keys(vehRev).forEach(function(vc){
        if(vdm[vc])vehRev[vc].days=vdm[vc].size;
      });

      // 5. クラス別稼働率（メンテ日数を最大稼働日数から減算）
      var classUtil={};
      INIT_CLASSES.forEach(function(cl){classUtil[cl.type]={label:cl.label,vehCount:0,used:0,maintD:0};});
      vehicles.forEach(function(v){if(classUtil[v.type])classUtil[v.type].vehCount++;});
      vehicles.forEach(function(v){
        var tp=codeToType[v.code];if(!tp||!classUtil[tp])return;
        if(vdm[v.code]){classUtil[tp].used+=vdm[v.code].size;}
        if(maintMapA[v.code]){classUtil[tp].maintD+=maintMapA[v.code].size;}
      });
      Object.keys(classUtil).forEach(function(tp){
        var e=classUtil[tp];
        e.totalPossible=e.vehCount*dim;
        e.availDays=e.totalPossible-e.maintD;
        e.rate=e.availDays>0?Math.round(e.used/e.availDays*100):0;
      });

      // 6. 車両別稼働率（メンテ日数を最大稼働日数から減算）
      var vehUtil={};
      vehicles.forEach(function(v){
        var days=vdm[v.code]?vdm[v.code].size:0;
        var mD=maintMapA[v.code]?maintMapA[v.code].size:0;
        var avail=dim-mD;
        vehUtil[v.code]={name:v.name,no:v.no,type:v.type,days:days,maintDays:mD,availDays:avail,rate:avail>0?Math.round(days/avail*100):0};
      });

      return{ym:ym,label:(parseInt(parts[1]))+"月",grossRev:grossRev,count:count,grossRate:grossRate,
             classRev:classRev,vehRev:vehRev,classUtil:classUtil,vehUtil:vehUtil,dim:dim,totalUsed:totalUsed};
    });
    return{months:months,data:result};
  },[dashView,data,fleet,vehicles,maintenance,curYM]);

  // 年間推移の集計値
  const annSummary=useMemo(function(){
    if(!annualData)return{maxRev:1,maxRate:1,totalRev:0,totalCount:0,avgRate:0,yearLabel:""};
    var ad=annualData;
    var maxR=1;var maxRt=1;var totR=0;var totC=0;var sumRate=0;
    ad.data.forEach(function(m){if(m.grossRev>maxR)maxR=m.grossRev;if(m.grossRate>maxRt)maxRt=m.grossRate;totR+=m.grossRev;totC+=m.count;sumRate+=m.grossRate;});
    var avgR=ad.data.length>0?Math.round(sumRate/ad.data.length):0;
    var ySet={};ad.months.forEach(function(ym){ySet[ym.split("-")[0]]=1;});
    var yrs=Object.keys(ySet).sort();
    var yl=yrs.length===1?yrs[0]+"年":yrs[0]+"〜"+yrs[yrs.length-1]+"年";
    return{maxRev:maxR,maxRate:maxRt,totalRev:totR,totalCount:totC,avgRate:avgR,yearLabel:yl};
  },[annualData]);

  // フォーマットヘルパー
  const fmtY=n=>{if(n>=10000)return(n/10000).toFixed(n>=100000?0:1)+"万";return n.toLocaleString();};
  const diffBadge=(cur,prev,unit="%")=>{
    const d=cur-prev;
    if(d===0)return <span style={{fontSize:9,color:"#94a3b8"}}>±0{unit}</span>;
    return <span style={{fontSize:9,fontWeight:700,color:d>0?"#059669":"#dc2626"}}>{d>0?"▲":"▼"}{Math.abs(d).toFixed(unit==="%"?1:0)}{unit}</span>;
  };
  const cardS={background:"#fff",borderRadius:14,padding:14,border:"1px solid #e2e8f0",marginBottom:10,boxShadow:"0 1px 3px rgba(0,0,0,.05)"};
  const OTA_C={S:"#0ea5e9",J:"#ec4899",R:"#ef4444",A:"#22c55e",O:"#6366f1",RC:"#f97316"};

  return <div style={{maxWidth:640,margin:"0 auto"}}>
    {/* ビュー切替タブ */}
    <div style={{display:"flex",gap:0,marginBottom:12,background:"#f1f5f9",borderRadius:10,padding:3}}>
      <button onClick={()=>setDashView("monthly")} style={{flex:1,padding:"7px 0",borderRadius:8,fontSize:12,fontWeight:700,border:"none",cursor:"pointer",transition:"all .2s",
        background:dashView==="monthly"?"#fff":"transparent",color:dashView==="monthly"?"#1e293b":"#94a3b8",
        boxShadow:dashView==="monthly"?"0 1px 3px rgba(0,0,0,.1)":"none"}}>📊 月別</button>
      <button onClick={()=>setDashView("annual")} style={{flex:1,padding:"7px 0",borderRadius:8,fontSize:12,fontWeight:700,border:"none",cursor:"pointer",transition:"all .2s",
        background:dashView==="annual"?"#fff":"transparent",color:dashView==="annual"?"#1e293b":"#94a3b8",
        boxShadow:dashView==="annual"?"0 1px 3px rgba(0,0,0,.1)":"none"}}>📈 年間推移</button>
    </div>

    {dashView==="monthly"&&<>
    {/* 月選択 */}
    <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:12}}>
      <button onClick={()=>setSelYM(ymOff(selYM,-1))} className="btn-ghost" style={{padding:"4px 10px",fontSize:12}}>◀</button>
      <div style={{textAlign:"center"}}>
        <div style={{fontSize:18,fontWeight:900,color:"#1e293b"}}>{ymLabel(selYM)}</div>
        <div style={{fontSize:10,color:"#94a3b8"}}>ダッシュボード</div>
      </div>
      <button onClick={()=>{const maxYM=allMonths.length?allMonths[allMonths.length-1]:curYM;if(selYM<maxYM)setSelYM(ymOff(selYM,1));}} className="btn-ghost" style={{padding:"4px 10px",fontSize:12,opacity:selYM>=(allMonths.length?allMonths[allMonths.length-1]:curYM)?0.3:1}}>▶</button>
    </div>

    {/* KPIカード */}
    <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8,marginBottom:12}}>
      <div style={{...cardS,background:"linear-gradient(135deg,#eff6ff,#dbeafe)"}}>
        <div style={{fontSize:10,color:"#2563eb",fontWeight:600,marginBottom:4}}>💰 月間売上</div>
        <div style={{fontSize:22,fontWeight:900,color:"#1e40af"}}>¥{fmtY(totalRevenue)}</div>
        <div style={{marginTop:2}}>{diffBadge(totalRevenue,prevRevenue," 円")}<span style={{fontSize:8,color:"#94a3b8",marginLeft:4}}>vs 前月</span></div>
      </div>
      <div style={{...cardS,background:"linear-gradient(135deg,#ecfdf5,#d1fae5)"}}>
        <div style={{fontSize:10,color:"#059669",fontWeight:600,marginBottom:4}}>📋 予約件数</div>
        <div style={{fontSize:22,fontWeight:900,color:"#065f46"}}>{totalCount}<span style={{fontSize:12}}>件</span></div>
        <div style={{marginTop:2}}>{diffBadge(totalCount,prevCount," 件")}<span style={{fontSize:8,color:"#94a3b8",marginLeft:4}}>vs 前月</span></div>
      </div>
      <div style={{...cardS,background:"linear-gradient(135deg,#fefce8,#fef9c3)"}}>
        <div style={{fontSize:10,color:"#ca8a04",fontWeight:600,marginBottom:4}}>💵 平均単価</div>
        <div style={{fontSize:22,fontWeight:900,color:"#854d0e"}}>¥{fmtY(avgPrice)}</div>
        <div style={{marginTop:2}}>{diffBadge(avgPrice,prevAvgPrice," 円")}<span style={{fontSize:8,color:"#94a3b8",marginLeft:4}}>vs 前月</span></div>
      </div>
      <div style={{...cardS,background:"linear-gradient(135deg,#faf5ff,#ede9fe)"}}>
        <div style={{fontSize:10,color:"#7c3aed",fontWeight:600,marginBottom:4}}>🚗 稼働率</div>
        <div style={{fontSize:22,fontWeight:900,color:"#5b21b6"}}>{utilRate}<span style={{fontSize:12}}>%</span></div>
        <div style={{marginTop:2}}>{diffBadge(utilRate,prevUtilRate)}<span style={{fontSize:8,color:"#94a3b8",marginLeft:4}}>vs 前月</span></div>
      </div>
    </div>

    {/* 日別売上グラフ */}
    <div style={cardS}>
      <div style={{fontSize:12,fontWeight:800,color:"#1e293b",marginBottom:10}}>📊 日別売上</div>
      <div style={{display:"flex",alignItems:"flex-end",gap:1,height:100}}>
        {dailyRevenue.map((d,i)=>{
          const h=maxDaily>0?Math.max(2,d.value/maxDaily*90):2;
          const isToday=selYM===curYM&&d.day===new Date().getDate();
          return <div key={i} style={{flex:1,display:"flex",flexDirection:"column",alignItems:"center",gap:1}}>
            <div style={{width:"100%",height:h,background:isToday?"#2563eb":d.value>0?"#93c5fd":"#e2e8f0",borderRadius:"2px 2px 0 0",transition:"height .3s"}} title={d.day+"日: ¥"+d.value.toLocaleString()}></div>
            {(d.day===1||d.day===10||d.day===20||d.day===daysInMo)&&<div style={{fontSize:7,color:"#94a3b8"}}>{d.day}</div>}
          </div>;
        })}
      </div>
    </div>

    {/* 月次推移 */}
    <div style={cardS}>
      <div style={{fontSize:12,fontWeight:800,color:"#1e293b",marginBottom:10}}>📈 月次売上推移</div>
      <div style={{display:"flex",alignItems:"flex-end",gap:3,height:100}}>
        {monthlyTrend.map((m,i)=>{
          const h=maxMonthlyRev>0?Math.max(4,m.revenue/maxMonthlyRev*85):4;
          const isCur=m.ym===selYM;
          return <div key={i} style={{flex:1,display:"flex",flexDirection:"column",alignItems:"center",gap:2}}>
            {m.revenue>0&&<div style={{fontSize:7,color:isCur?"#1e40af":"#94a3b8",fontWeight:isCur?700:400}}>{fmtY(m.revenue)}</div>}
            <div style={{width:"100%",height:h,background:isCur?"#2563eb":"#bfdbfe",borderRadius:3,transition:"height .3s"}}></div>
            <div style={{fontSize:7,color:isCur?"#1e40af":"#94a3b8",fontWeight:isCur?700:400}}>{m.label}</div>
          </div>;
        })}
      </div>
    </div>

    {/* OTA別売上 */}
    <div style={cardS}>
      <div style={{fontSize:12,fontWeight:800,color:"#1e293b",marginBottom:10}}>🏢 OTA別売上</div>
      {otaStats.length===0&&<div style={{textAlign:"center",fontSize:11,color:"#94a3b8",padding:12}}>データなし</div>}
      {otaStats.map(([ota,st])=>{
        const pct=totalRevenue>0?Math.round(st.revenue/totalRevenue*100):0;
        const c=OTA_C[ota]||"#64748b";
        return <div key={ota} style={{marginBottom:8}}>
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:3}}>
            <div style={{display:"flex",alignItems:"center",gap:6}}>
              <span style={{display:"inline-block",padding:"1px 8px",borderRadius:6,fontSize:10,fontWeight:700,background:c+"18",color:c}}>{ota}</span>
              <span style={{fontSize:10,color:"#64748b"}}>{st.count}件</span>
            </div>
            <div style={{fontSize:12,fontWeight:700,color:"#1e293b"}}>¥{st.revenue.toLocaleString()}<span style={{fontSize:9,color:"#94a3b8",marginLeft:4}}>{pct}%</span></div>
          </div>
          <div style={{height:6,background:"#f1f5f9",borderRadius:3,overflow:"hidden"}}>
            <div style={{height:"100%",width:pct+"%",background:c,borderRadius:3,transition:"width .5s"}}></div>
          </div>
        </div>;
      })}
    </div>

    {/* 車両別売上 */}
    <div style={cardS}>
      <div style={{fontSize:12,fontWeight:800,color:"#1e293b",marginBottom:10}}>🚗 車両別売上</div>
      {vehStats.length===0&&<div style={{textAlign:"center",fontSize:11,color:"#94a3b8",padding:12}}>データなし</div>}
      <div style={{overflowX:"auto"}}>
        <table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
          <thead><tr style={{borderBottom:"2px solid #e2e8f0"}}>
            <th style={{textAlign:"left",padding:"4px 6px",fontSize:10,color:"#64748b",fontWeight:600}}>車両</th>
            <th style={{textAlign:"right",padding:"4px 6px",fontSize:10,color:"#64748b",fontWeight:600}}>件数</th>
            <th style={{textAlign:"right",padding:"4px 6px",fontSize:10,color:"#64748b",fontWeight:600}}>日数</th>
            <th style={{textAlign:"right",padding:"4px 6px",fontSize:10,color:"#64748b",fontWeight:600}}>売上</th>
            <th style={{textAlign:"right",padding:"4px 6px",fontSize:10,color:"#64748b",fontWeight:600}}>構成比</th>
          </tr></thead>
          <tbody>
            {vehStats.map(([vc,st])=>{
              const pct=totalRevenue>0?Math.round(st.revenue/totalRevenue*100):0;
              const veh=vehicles.find(v=>v.code===vc);
              const c=V_COLORS[vc]||"#64748b";
              return <tr key={vc} style={{borderBottom:"1px solid #f1f5f9"}}>
                <td style={{padding:"6px",display:"flex",alignItems:"center",gap:4}}>
                  <span style={{width:8,height:8,borderRadius:"50%",background:c,flexShrink:0}}></span>
                  <span style={{fontWeight:700}}>{vc}</span>
                  {veh&&<span style={{fontSize:9,color:"#94a3b8"}}>{veh.no}</span>}
                </td>
                <td style={{textAlign:"right",padding:"6px"}}>{st.count}</td>
                <td style={{textAlign:"right",padding:"6px"}}>{st.days}日</td>
                <td style={{textAlign:"right",padding:"6px",fontWeight:700,color:"#1e293b"}}>¥{st.revenue.toLocaleString()}</td>
                <td style={{textAlign:"right",padding:"6px"}}>
                  <div style={{display:"flex",alignItems:"center",justifyContent:"flex-end",gap:4}}>
                    <div style={{width:40,height:5,background:"#f1f5f9",borderRadius:3,overflow:"hidden"}}><div style={{height:"100%",width:pct+"%",background:c,borderRadius:3}}></div></div>
                    <span style={{fontSize:9,color:"#64748b",minWidth:24}}>{pct}%</span>
                  </div>
                </td>
              </tr>;
            })}
            <tr style={{borderTop:"2px solid #e2e8f0",fontWeight:800}}>
              <td style={{padding:"6px"}}>合計</td>
              <td style={{textAlign:"right",padding:"6px"}}>{totalCount}</td>
              <td style={{textAlign:"right",padding:"6px"}}></td>
              <td style={{textAlign:"right",padding:"6px",color:"#1e40af"}}>¥{totalRevenue.toLocaleString()}</td>
              <td style={{textAlign:"right",padding:"6px"}}>100%</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    {/* 車両別稼働率 */}
    <div style={cardS}>
      <div style={{fontSize:12,fontWeight:800,color:"#1e293b",marginBottom:10}}>📅 車両別稼働率（{ymLabel(selYM)}・{daysInMo}日間）</div>
      {vehUtilDetail.map(v=>{
        const c=V_COLORS[v.code]||"#64748b";
        return <div key={v.code} style={{marginBottom:6}}>
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:2}}>
            <div style={{display:"flex",alignItems:"center",gap:4}}>
              <span style={{width:8,height:8,borderRadius:"50%",background:c,flexShrink:0}}></span>
              <span style={{fontSize:11,fontWeight:700}}>{v.code}</span>
              <span style={{fontSize:9,color:"#94a3b8"}}>{v.name} ({v.no})</span>
            </div>
            <div style={{fontSize:11}}><span style={{fontWeight:700,color:v.rate>=70?"#059669":v.rate>=40?"#d97706":"#dc2626"}}>{v.rate}%</span><span style={{fontSize:9,color:"#94a3b8",marginLeft:4}}>{v.days}/{v.availDays}日</span>{v.maintDays>0&&<span style={{fontSize:8,color:"#2563eb",marginLeft:3}}>🔧{v.maintDays}日</span>}</div>
          </div>
          <div style={{height:6,background:"#f1f5f9",borderRadius:3,overflow:"hidden"}}>
            <div style={{height:"100%",width:v.rate+"%",background:v.rate>=70?c:v.rate>=40?"#fbbf24":"#fca5a5",borderRadius:3,transition:"width .5s"}}></div>
          </div>
        </div>;
      })}
      <div style={{marginTop:8,padding:"6px 10px",background:"#f8fafc",borderRadius:8,display:"flex",justifyContent:"space-between",alignItems:"center"}}>
        <div><span style={{fontSize:11,fontWeight:700,color:"#1e293b"}}>全体稼働率</span>{totalMaintDays>0&&<span style={{fontSize:9,color:"#2563eb",marginLeft:6}}>🔧メンテ{totalMaintDays}日除外</span>}</div>
        <span style={{fontSize:14,fontWeight:900,color:utilRate>=70?"#059669":utilRate>=40?"#d97706":"#dc2626"}}>{utilRate}%</span>
      </div>
    </div>

    {/* クラス別売上 */}
    {(()=>{
      const CLASS_C={"A":"#7c3aed","B":"#0284c7","C":"#059669","S":"#d97706","F":"#db2777","H":"#64748b"};
      // 車両コード→クラスtype マッピング
      const codeToType={};vehicles.forEach(v=>{codeToType[v.code]=v.type;});
      // クラス別集計
      const classRevMap={};
      INIT_CLASSES.forEach(cl=>{classRevMap[cl.type]={label:cl.label,count:0,revenue:0,days:0};});
      monthData.forEach(r=>{
        const vc=fleet[r.id];
        const tp=vc?codeToType[vc]:r.vehicle;
        const key=tp&&classRevMap[tp]?tp:"?";
        if(!classRevMap[key])classRevMap[key]={label:"不明",count:0,revenue:0,days:0};
        classRevMap[key].count++;classRevMap[key].revenue+=(Number(r.price)||0);
        if(r.lendDate&&r.returnDate){
          const ld=new Date(r.lendDate+"T00:00:00"),rd=new Date(r.returnDate+"T00:00:00");
          classRevMap[key].days+=Math.max(1,Math.ceil((rd-ld)/(1000*60*60*24)));
        }
      });
      // クラスごとの車両台数
      const classVehCnt={};vehicles.forEach(v=>{classVehCnt[v.type]=(classVehCnt[v.type]||0)+1;});
      const classEntries=Object.entries(classRevMap).filter(([,v])=>v.count>0).sort((a,b)=>b[1].revenue-a[1].revenue);
      const maxClassRev=Math.max(1,...classEntries.map(([,v])=>v.revenue));
      const maxPerVeh=Math.max(1,...classEntries.map(([tp,v])=>{const vc=classVehCnt[tp]||1;return Math.round(v.revenue/vc);}));
      return <div style={cardS}>
        <div style={{fontSize:12,fontWeight:800,color:"#1e293b",marginBottom:10}}>🏷️ クラス別売上</div>
        {classEntries.length===0&&<div style={{textAlign:"center",fontSize:11,color:"#94a3b8",padding:12}}>データなし</div>}
        {classEntries.map(([tp,st])=>{
          const pct=totalRevenue>0?Math.round(st.revenue/totalRevenue*100):0;
          const c=CLASS_C[tp]||"#64748b";
          const avgP=st.count>0?Math.round(st.revenue/st.count):0;
          const vehCnt=classVehCnt[tp]||1;
          const perVeh=Math.round(st.revenue/vehCnt);
          return <div key={tp} style={{marginBottom:12}}>
            <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:3}}>
              <div style={{display:"flex",alignItems:"center",gap:6}}>
                <span style={{display:"inline-flex",alignItems:"center",justifyContent:"center",width:24,height:24,borderRadius:6,background:c+"18",color:c,fontSize:12,fontWeight:900}}>{tp}</span>
                <div>
                  <div style={{fontSize:11,fontWeight:700,color:"#1e293b"}}>{st.label}</div>
                  <div style={{fontSize:9,color:"#94a3b8"}}>{st.count}件 ・{st.days}日 ・平均¥{avgP.toLocaleString()}/件</div>
                </div>
              </div>
              <div style={{textAlign:"right"}}>
                <div style={{fontSize:13,fontWeight:800,color:"#1e293b"}}>¥{st.revenue.toLocaleString()}</div>
                <div style={{fontSize:9,color:"#64748b"}}>{pct}%</div>
              </div>
            </div>
            <div style={{height:8,background:"#f1f5f9",borderRadius:4,overflow:"hidden",marginBottom:4}}>
              <div style={{height:"100%",width:Math.round(st.revenue/maxClassRev*100)+"%",background:c,borderRadius:4,transition:"width .5s"}}></div>
            </div>
            <div style={{display:"flex",alignItems:"center",gap:6,paddingLeft:30}}>
              <div style={{fontSize:9,color:"#64748b",whiteSpace:"nowrap"}}>1台あたり ({vehCnt}台)</div>
              <div style={{flex:1,height:6,background:"#f1f5f9",borderRadius:3,overflow:"hidden"}}>
                <div style={{height:"100%",width:Math.round(perVeh/maxPerVeh*100)+"%",background:c+"88",borderRadius:3,transition:"width .5s"}}></div>
              </div>
              <div style={{fontSize:10,fontWeight:700,color:c,whiteSpace:"nowrap"}}>¥{perVeh.toLocaleString()}</div>
            </div>
          </div>;
        })}
      </div>;
    })()}

    {/* クラス別稼働率 */}
    {(()=>{
      const CLASS_C={"A":"#7c3aed","B":"#0284c7","C":"#059669","S":"#d97706","F":"#db2777","H":"#64748b"};
      const codeToType={};vehicles.forEach(v=>{codeToType[v.code]=v.type;});
      // クラスごとの車両台数
      const classVehCount={};
      INIT_CLASSES.forEach(cl=>{classVehCount[cl.type]=0;});
      vehicles.forEach(v=>{if(classVehCount[v.type]!==undefined)classVehCount[v.type]++;});
      // クラスごとの稼働日＆メンテ日（curVehDayMap/curMaintMapから集約）
      const classUsedDays={};const classMaintDays={};
      INIT_CLASSES.forEach(cl=>{classUsedDays[cl.type]={};classMaintDays[cl.type]={};});
      vehicles.forEach(v=>{
        const tp=codeToType[v.code];if(!tp||!classUsedDays[tp])return;
        if(curVehDayMap[v.code]){classUsedDays[tp][v.code]=curVehDayMap[v.code];}
        if(curMaintMap[v.code]){classMaintDays[tp][v.code]=curMaintMap[v.code];}
      });
      const classUtilEntries=INIT_CLASSES.map(cl=>{
        const vehCount=classVehCount[cl.type]||0;
        const totalPossible=vehCount*daysInMo;
        let used=0;let maintD=0;
        Object.values(classUsedDays[cl.type]||{}).forEach(s=>used+=s.size);
        Object.values(classMaintDays[cl.type]||{}).forEach(s=>maintD+=s.size);
        const avail=totalPossible-maintD;
        const rate=avail>0?Math.round(used/avail*100):0;
        return{type:cl.type,label:cl.label,vehCount,used,totalPossible,availDays:avail,maintDays:maintD,rate};
      }).filter(e=>e.vehCount>0);
      return <div style={cardS}>
        <div style={{fontSize:12,fontWeight:800,color:"#1e293b",marginBottom:10}}>📅 クラス別稼働率（{ymLabel(selYM)}）</div>
        {classUtilEntries.map(e=>{
          const c=CLASS_C[e.type]||"#64748b";
          return <div key={e.type} style={{marginBottom:8}}>
            <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:2}}>
              <div style={{display:"flex",alignItems:"center",gap:6}}>
                <span style={{display:"inline-flex",alignItems:"center",justifyContent:"center",width:22,height:22,borderRadius:6,background:c+"18",color:c,fontSize:11,fontWeight:900}}>{e.type}</span>
                <div>
                  <span style={{fontSize:11,fontWeight:700}}>{e.label}</span>
                  <span style={{fontSize:9,color:"#94a3b8",marginLeft:4}}>({e.vehCount}台)</span>
                </div>
              </div>
              <div style={{fontSize:11}}>
                <span style={{fontWeight:700,color:e.rate>=70?"#059669":e.rate>=40?"#d97706":"#dc2626"}}>{e.rate}%</span>
                <span style={{fontSize:9,color:"#94a3b8",marginLeft:4}}>{e.used}/{e.availDays}日</span>{e.maintDays>0&&<span style={{fontSize:8,color:"#2563eb",marginLeft:3}}>🔧{e.maintDays}日</span>}
              </div>
            </div>
            <div style={{height:8,background:"#f1f5f9",borderRadius:4,overflow:"hidden"}}>
              <div style={{height:"100%",width:e.rate+"%",background:e.rate>=70?c:e.rate>=40?"#fbbf24":"#fca5a5",borderRadius:4,transition:"width .5s"}}></div>
            </div>
          </div>;
        })}
      </div>;
    })()}


    {/* ★ 場所分布率 */}
    {(()=>{
      const hotelKw=["ホテル","hotel","Hotel","HOTEL","inn","INN","旅館","リゾート","resort","Resort","ヒルトン","Hilton","マリオット","Marriott","APA","アパ","東急","プリンス","ルートイン","ドーミー","コンフォート","ベッセル","クロスホテル","メルキュール","Mercure","三井ガーデン","JR","グランド","京王","ラ・ジェント","ジャスマック","マイステイズ","MyStays","プレミア","モントレ","ロイトン","京阪","WBF","ネスト","Nest","テンザ","Tenza","フェアフィールド","Fairfield","ランプライト"];
      const homeKw=["自宅","マンション","アパート","自宅前","ご自宅","戸建","一軒家"];
      const commKw=["空港","新千歳","丘珠","駅","ターミナル","フェリー","港","イオン","ヨドバシ","ビック","ドンキ","ニトリ","コストコ","AEON","レンタカー","ステーション","営業所","店舗","オフィス","事務所","会社"];
      function classify(place){
        if(!place)return"その他";
        const p=place.toUpperCase();
        if(hotelKw.some(k=>p.includes(k.toUpperCase())))return"ホテル";
        if(homeKw.some(k=>p.includes(k.toUpperCase())))return"自宅";
        if(commKw.some(k=>p.includes(k.toUpperCase())))return"商業施設・交通";
        return"その他";
      }
      const md=data.filter(r=>{const ym=r.lendDate?r.lendDate.substring(0,7):"";return ym===selYM;});
      const delPlaces={};const colPlaces={};
      md.forEach(r=>{
        const dc=classify(r.delPlace);delPlaces[dc]=(delPlaces[dc]||0)+1;
        const cc=classify(r.colPlace);colPlaces[cc]=(colPlaces[cc]||0)+1;
      });
      const cats=["ホテル","自宅","商業施設・交通","その他"];
      const catC={"ホテル":"#2563eb","自宅":"#059669","商業施設・交通":"#d97706","その他":"#94a3b8"};
      const delTotal=md.length||1;const colTotal=md.length||1;
      return <div style={cardS}>
        <div style={{fontSize:12,fontWeight:800,color:"#1e293b",marginBottom:10}}>📍 場所分布率（{ymLabel(selYM)}）</div>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:12}}>
          {[{label:"DEL（お届け）",dist:delPlaces,total:delTotal},{label:"COL（回収）",dist:colPlaces,total:colTotal}].map(s=>
            <div key={s.label}>
              <div style={{fontSize:10,fontWeight:700,color:"#475569",marginBottom:6}}>{s.label}</div>
              {cats.map(c=>{const cnt=s.dist[c]||0;const pct=Math.round(cnt/s.total*100);return <div key={c} style={{marginBottom:4}}>
                <div style={{display:"flex",justifyContent:"space-between",fontSize:10,marginBottom:2}}>
                  <span style={{fontWeight:600,color:catC[c]}}>{c}</span>
                  <span style={{fontWeight:700,color:"#1e293b"}}>{cnt}件 ({pct}%)</span>
                </div>
                <div style={{height:6,background:"#f1f5f9",borderRadius:3,overflow:"hidden"}}>
                  <div style={{height:"100%",width:pct+"%",background:catC[c],borderRadius:3,transition:"width .3s"}}/>
                </div>
              </div>;})}
            </div>
          )}
        </div>
      </div>;
    })()}

    {/* ★ リソース分析（時間帯別DEL/COL） */}
    {(()=>{
      const md=data.filter(r=>{const ym=r.lendDate?r.lendDate.substring(0,7):"";return ym===selYM;});
      const hours=[];for(let h=8;h<=20;h++)hours.push(h);
      const delByH={};const colByH={};
      hours.forEach(h=>{delByH[h]=0;colByH[h]=0;});
      md.forEach(r=>{
        const lt=r.lendTime||r.delTime||"";const lh=parseInt(lt.split(":")[0]);if(!isNaN(lh)&&lh>=8&&lh<=20)delByH[lh]++;
        const rt=r.returnTime||r.colTime||"";const rh=parseInt(rt.split(":")[0]);if(!isNaN(rh)&&rh>=8&&rh<=20)colByH[rh]++;
      });
      const maxDel=Math.max(...Object.values(delByH),1);
      const maxCol=Math.max(...Object.values(colByH),1);
      return <div style={cardS}>
        <div style={{fontSize:12,fontWeight:800,color:"#1e293b",marginBottom:10}}>⏰ 時間帯別リソース分析（{ymLabel(selYM)}）</div>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:12}}>
          {[{label:"DEL（お届け）",byH:delByH,max:maxDel,c:"#2563eb"},{label:"COL（回収）",byH:colByH,max:maxCol,c:"#dc2626"}].map(s=>
            <div key={s.label}>
              <div style={{fontSize:10,fontWeight:700,color:"#475569",marginBottom:6}}>{s.label}</div>
              {hours.map(h=>{const cnt=s.byH[h];const pct=Math.round(cnt/s.max*100);const isTop=cnt===s.max&&cnt>0;return <div key={h} style={{display:"flex",alignItems:"center",gap:4,marginBottom:2}}>
                <span style={{fontSize:9,fontWeight:600,color:"#64748b",minWidth:28,textAlign:"right"}}>{h}:00</span>
                <div style={{flex:1,height:10,background:"#f1f5f9",borderRadius:3,overflow:"hidden"}}>
                  <div style={{height:"100%",width:pct+"%",background:isTop?"#f59e0b":s.c,borderRadius:3,transition:"width .3s"}}/>
                </div>
                <span style={{fontSize:9,fontWeight:isTop?800:600,color:isTop?"#f59e0b":"#1e293b",minWidth:20}}>{cnt}</span>
              </div>;})}
            </div>
          )}
        </div>
        <div style={{marginTop:10,fontSize:10,color:"#64748b",borderTop:"1px solid #f1f5f9",paddingTop:8}}>
          <span style={{fontWeight:700}}>ピーク時間帯:</span>
          {" DEL "}
          <span style={{fontWeight:700,color:"#2563eb"}}>{(()=>{let mx=0,mh="-";Object.entries(delByH).forEach(([h,c])=>{if(c>mx){mx=c;mh=h;}});return mx>0?mh+":00 ("+mx+"件)":"データなし";})()}</span>
          {" / COL "}
          <span style={{fontWeight:700,color:"#dc2626"}}>{(()=>{let mx=0,mh="-";Object.entries(colByH).forEach(([h,c])=>{if(c>mx){mx=c;mh=h;}});return mx>0?mh+":00 ("+mx+"件)":"データなし";})()}</span>
        </div>
      </div>;
    })()}

    {/* ★ 利用者エリアランキング */}
    {(()=>{
      const md=data.filter(r=>{const ym=r.lendDate?r.lendDate.substring(0,7):"";return ym===selYM;});
      const prefCount={};let total=0;
      md.forEach(r=>{if(r.prefecture){prefCount[r.prefecture]=(prefCount[r.prefecture]||0)+1;total++;}});
      const sorted=Object.entries(prefCount).sort((a,b)=>b[1]-a[1]);
      const maxC=sorted.length?sorted[0][1]:1;
      const regionMap={"北海道":["北海道"],"東北":["青森県","岩手県","宮城県","秋田県","山形県","福島県"],"関東":["茨城県","栃木県","群馬県","埼玉県","千葉県","東京都","神奈川県"],"中部":["新潟県","富山県","石川県","福井県","山梨県","長野県","岐阜県","静岡県","愛知県"],"関西":["三重県","滋賀県","京都府","大阪府","兵庫県","奈良県","和歌山県"],"中国":["鳥取県","島根県","岡山県","広島県","山口県"],"四国":["徳島県","香川県","愛媛県","高知県"],"九州・沖縄":["福岡県","佐賀県","長崎県","熊本県","大分県","宮崎県","鹿児島県","沖縄県"],"海外":["海外"]};
      const regionCount={};Object.entries(regionMap).forEach(([reg,prefs])=>{let cnt=0;prefs.forEach(p=>{cnt+=(prefCount[p]||0);});if(cnt)regionCount[reg]=cnt;});
      const regSorted=Object.entries(regionCount).sort((a,b)=>b[1]-a[1]);
      const regC={"北海道":"#2563eb","東北":"#7c3aed","関東":"#dc2626","中部":"#059669","関西":"#d97706","中国":"#0891b2","四国":"#84cc16","九州・沖縄":"#e11d48","海外":"#6b7280"};
      return <div style={cardS}>
        <div style={{fontSize:12,fontWeight:800,color:"#1e293b",marginBottom:10}}>🗾 利用者エリアランキング（{ymLabel(selYM)}）<span style={{fontSize:10,fontWeight:400,color:"#94a3b8",marginLeft:8}}>{total}件登録</span></div>
        {total===0?<div style={{fontSize:11,color:"#94a3b8",textAlign:"center",padding:16}}>都道府県データなし（免許証アップロード時 or データ編集で設定）</div>:
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:16}}>
          <div>
            <div style={{fontSize:10,fontWeight:700,color:"#475569",marginBottom:6}}>都道府県別</div>
            {sorted.slice(0,15).map(([pref,cnt],i)=>{const pct=Math.round(cnt/total*100);return <div key={pref} style={{display:"flex",alignItems:"center",gap:4,marginBottom:3}}>
              <span style={{fontSize:9,fontWeight:700,color:i<3?"#f59e0b":"#94a3b8",minWidth:16}}>{i+1}.</span>
              <span style={{fontSize:10,fontWeight:600,color:"#1e293b",minWidth:50}}>{pref}</span>
              <div style={{flex:1,height:8,background:"#f1f5f9",borderRadius:3,overflow:"hidden"}}>
                <div style={{height:"100%",width:Math.round(cnt/maxC*100)+"%",background:i<3?"#f59e0b":"#3b82f6",borderRadius:3}}/>
              </div>
              <span style={{fontSize:9,fontWeight:700,color:"#1e293b",minWidth:40,textAlign:"right"}}>{cnt}件({pct}%)</span>
            </div>;})}
          </div>
          <div>
            <div style={{fontSize:10,fontWeight:700,color:"#475569",marginBottom:6}}>地方別構成比</div>
            {regSorted.map(([reg,cnt])=>{const pct=Math.round(cnt/total*100);return <div key={reg} style={{marginBottom:6}}>
              <div style={{display:"flex",justifyContent:"space-between",fontSize:10,marginBottom:2}}>
                <span style={{fontWeight:700,color:regC[reg]||"#475569"}}>{reg}</span>
                <span style={{fontWeight:700,color:"#1e293b"}}>{cnt}件 ({pct}%)</span>
              </div>
              <div style={{height:8,background:"#f1f5f9",borderRadius:3,overflow:"hidden"}}>
                <div style={{height:"100%",width:pct+"%",background:regC[reg]||"#94a3b8",borderRadius:3}}/>
              </div>
            </div>;})}
          </div>
        </div>}
      </div>;
    })()}

    {/* ★ 場所分布ランキング */}
    {(()=>{
      const hotelKw=["ホテル","hotel","Hotel","HOTEL","inn","INN","旅館","リゾート","resort","ヒルトン","マリオット","APA","アパ","東急","プリンス","ルートイン","ドーミー","コンフォート","ベッセル","クロスホテル","メルキュール","三井ガーデン","JR","グランド","京王","ラ・ジェント","ジャスマック","マイステイズ","プレミア","モントレ","ロイトン","京阪","WBF","ネスト","テンザ","フェアフィールド","ランプライト"];
      const homeKw=["自宅","マンション","アパート","自宅前","ご自宅","戸建","一軒家"];
      const staKw=["駅","ステーション","JR","地下鉄"];
      const commKw=["空港","新千歳","丘珠","ターミナル","フェリー","港","イオン","ヨドバシ","ビック","ドンキ","ニトリ","コストコ","AEON","レンタカー","営業所","店舗","オフィス","事務所","会社"];
      function classify(place){if(!place)return"その他";const p=place.toUpperCase();if(hotelKw.some(k=>p.includes(k.toUpperCase())))return"ホテル";if(homeKw.some(k=>p.includes(k.toUpperCase())))return"自宅";if(staKw.some(k=>p.includes(k.toUpperCase())))return"駅";if(commKw.some(k=>p.includes(k.toUpperCase())))return"商業施設";return"その他";}
      const md=data.filter(r=>{const ym=r.lendDate?r.lendDate.substring(0,7):"";return ym===selYM;});
      const catCount={};const placeDet={};let total=0;
      md.forEach(r=>{
        [r.delPlace,r.colPlace].forEach(pl=>{if(!pl)return;const cat=classify(pl);catCount[cat]=(catCount[cat]||0)+1;total++;
          if(!placeDet[cat])placeDet[cat]={};placeDet[cat][pl]=(placeDet[cat][pl]||0)+1;});
      });
      const cats=["ホテル","自宅","駅","商業施設","その他"];
      const catC={"ホテル":"#2563eb","自宅":"#059669","駅":"#7c3aed","商業施設":"#d97706","その他":"#94a3b8"};
      const catIco={"ホテル":"🏨","自宅":"🏠","駅":"🚉","商業施設":"🏢","その他":"📍"};
      return <div style={cardS}>
        <div style={{fontSize:12,fontWeight:800,color:"#1e293b",marginBottom:10}}>📍 場所分布ランキング（{ymLabel(selYM)}）<span style={{fontSize:10,fontWeight:400,color:"#94a3b8",marginLeft:8}}>DEL+COL計 {total}件</span></div>
        <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(140px,1fr))",gap:8,marginBottom:12}}>
          {cats.map(c=>{const cnt=catCount[c]||0;const pct=total?Math.round(cnt/total*100):0;return <div key={c} style={{textAlign:"center",padding:10,borderRadius:10,background:catC[c]+"12",border:"1px solid "+catC[c]+"30"}}>
            <div style={{fontSize:20}}>{catIco[c]}</div>
            <div style={{fontSize:11,fontWeight:700,color:catC[c]}}>{c}</div>
            <div style={{fontSize:18,fontWeight:900,color:"#1e293b"}}>{cnt}<span style={{fontSize:10,fontWeight:400}}>件</span></div>
            <div style={{fontSize:10,fontWeight:600,color:catC[c]}}>{pct}%</div>
          </div>;})}
        </div>
        {cats.filter(c=>catCount[c]).map(c=>{const details=Object.entries(placeDet[c]||{}).sort((a,b)=>b[1]-a[1]).slice(0,5);return <div key={c} style={{marginBottom:8}}>
          <div style={{fontSize:10,fontWeight:700,color:catC[c],marginBottom:3}}>{catIco[c]} {c} TOP5</div>
          {details.map(([pl,cnt])=><div key={pl} style={{display:"flex",justifyContent:"space-between",fontSize:10,padding:"2px 0",borderBottom:"1px solid #f8fafc"}}>
            <span style={{color:"#475569",overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap",maxWidth:"70%"}}>{pl}</span>
            <span style={{fontWeight:700,color:"#1e293b"}}>{cnt}件</span>
          </div>)}
        </div>;})}
      </div>;
    })()}

    </>}

    {/* ========== 年間推移ビュー ========== */}
    {dashView==="annual"&&annualData&&<div>
        <div style={{textAlign:"center",marginBottom:12}}>
          <div style={{fontSize:18,fontWeight:900,color:"#1e293b"}}>{annSummary.yearLabel} 年間推移</div>
          <div style={{fontSize:10,color:"#94a3b8"}}>{annualData.data.length}ヶ月分のデータ</div>
        </div>

        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:6,marginBottom:12}}>
          <div style={{...cardS,textAlign:"center",padding:10}}>
            <div style={{fontSize:9,color:"#2563eb",fontWeight:600}}>年間売上</div>
            <div style={{fontSize:16,fontWeight:900,color:"#1e40af"}}>¥{fmtY(annSummary.totalRev)}</div>
          </div>
          <div style={{...cardS,textAlign:"center",padding:10}}>
            <div style={{fontSize:9,color:"#059669",fontWeight:600}}>年間件数</div>
            <div style={{fontSize:16,fontWeight:900,color:"#065f46"}}>{annSummary.totalCount}件</div>
          </div>
          <div style={{...cardS,textAlign:"center",padding:10}}>
            <div style={{fontSize:9,color:"#7c3aed",fontWeight:600}}>平均稼働率</div>
            <div style={{fontSize:16,fontWeight:900,color:"#5b21b6"}}>{annSummary.avgRate}%</div>
          </div>
        </div>

        <div style={{display:"flex",gap:0,flexWrap:"wrap",marginBottom:10,background:"#f8fafc",borderRadius:8,padding:2}}>
          {annTabItems.map(function(t){return <button key={t.id} onClick={function(){setAnnTab(t.id);}} style={{
            flex:"1 1 auto",padding:"5px 4px",borderRadius:6,fontSize:10,fontWeight:600,border:"none",cursor:"pointer",
            background:annTab===t.id?"#fff":"transparent",color:annTab===t.id?"#1e293b":"#94a3b8",
            boxShadow:annTab===t.id?"0 1px 2px rgba(0,0,0,.08)":"none",whiteSpace:"nowrap"
          }}>{t.ico} {t.label}</button>;})}
        </div>

        {annTab==="revenue"&&<div style={cardS}>
          <div style={{fontSize:12,fontWeight:800,color:"#1e293b",marginBottom:10}}>💰 月別売上推移</div>
          <div style={{display:"flex",alignItems:"flex-end",gap:3,height:120}}>
            {annualData.data.map(function(m,i){
              var h=annSummary.maxRev>0?Math.max(4,m.grossRev/annSummary.maxRev*100):4;
              return <div key={i} style={{flex:1,display:"flex",flexDirection:"column",alignItems:"center",gap:2}}>
                {m.grossRev>0&&<div style={{fontSize:7,color:"#1e40af",fontWeight:600,transform:"rotate(-45deg)",transformOrigin:"bottom center",whiteSpace:"nowrap"}}>{fmtY(m.grossRev)}</div>}
                <div style={{width:"100%",height:h,background:"#3b82f6",borderRadius:3,transition:"height .3s"}} title={m.ym+": ¥"+m.grossRev.toLocaleString()+" ("+m.count+"件)"}></div>
                <div style={{fontSize:7,color:"#64748b"}}>{m.label}</div>
              </div>;
            })}
          </div>
          <div style={{overflowX:"auto",marginTop:10}}>
            <table style={{width:"100%",borderCollapse:"collapse",fontSize:10}}>
              <thead><tr style={{borderBottom:"2px solid #e2e8f0"}}>
                <th style={{textAlign:"left",padding:"3px 4px",color:"#64748b",fontWeight:600}}>月</th>
                <th style={{textAlign:"right",padding:"3px 4px",color:"#64748b",fontWeight:600}}>売上</th>
                <th style={{textAlign:"right",padding:"3px 4px",color:"#64748b",fontWeight:600}}>件数</th>
                <th style={{textAlign:"right",padding:"3px 4px",color:"#64748b",fontWeight:600}}>平均</th>
              </tr></thead>
              <tbody>{annualData.data.map(function(m,i){
                var avg=m.count>0?Math.round(m.grossRev/m.count):0;
                return <tr key={i} style={{borderBottom:"1px solid #f1f5f9"}}>
                  <td style={{padding:"4px",fontWeight:600}}>{ymLabel(m.ym)}</td>
                  <td style={{textAlign:"right",padding:"4px",fontWeight:700,color:"#1e40af"}}>¥{m.grossRev.toLocaleString()}</td>
                  <td style={{textAlign:"right",padding:"4px"}}>{m.count}件</td>
                  <td style={{textAlign:"right",padding:"4px",color:"#64748b"}}>¥{avg.toLocaleString()}</td>
                </tr>;
              })}
              <tr style={{borderTop:"2px solid #e2e8f0",fontWeight:800}}>
                <td style={{padding:"4px"}}>合計/平均</td>
                <td style={{textAlign:"right",padding:"4px",color:"#1e40af"}}>¥{annSummary.totalRev.toLocaleString()}</td>
                <td style={{textAlign:"right",padding:"4px"}}>{annSummary.totalCount}件</td>
                <td style={{textAlign:"right",padding:"4px",color:"#64748b"}}>¥{annSummary.totalCount>0?Math.round(annSummary.totalRev/annSummary.totalCount).toLocaleString():0}</td>
              </tr></tbody>
            </table>
          </div>
        </div>}

        {annTab==="utilization"&&<div style={cardS}>
          <div style={{fontSize:12,fontWeight:800,color:"#1e293b",marginBottom:10}}>🚗 月別稼働率推移</div>
          <div style={{display:"flex",alignItems:"flex-end",gap:3,height:120,position:"relative"}}>
            <div style={{position:"absolute",left:0,right:0,bottom:50,height:1,borderBottom:"1px dashed #e2e8f0",zIndex:0}}></div>
            {annualData.data.map(function(m,i){
              var h=Math.max(4,m.grossRate);var c=m.grossRate>=70?"#059669":m.grossRate>=40?"#d97706":"#dc2626";
              return <div key={i} style={{flex:1,display:"flex",flexDirection:"column",alignItems:"center",gap:2,zIndex:1}}>
                <div style={{fontSize:8,color:c,fontWeight:700}}>{m.grossRate}%</div>
                <div style={{width:"100%",height:h,background:c,borderRadius:3,transition:"height .3s"}} title={m.ym+": "+m.grossRate+"%"}></div>
                <div style={{fontSize:7,color:"#64748b"}}>{m.label}</div>
              </div>;
            })}
          </div>
          <div style={{overflowX:"auto",marginTop:10}}>
            <table style={{width:"100%",borderCollapse:"collapse",fontSize:10}}>
              <thead><tr style={{borderBottom:"2px solid #e2e8f0"}}>
                <th style={{textAlign:"left",padding:"3px 4px",color:"#64748b",fontWeight:600}}>月</th>
                <th style={{textAlign:"right",padding:"3px 4px",color:"#64748b",fontWeight:600}}>稼働率</th>
                <th style={{textAlign:"right",padding:"3px 4px",color:"#64748b",fontWeight:600}}>稼働日</th>
                <th style={{textAlign:"right",padding:"3px 4px",color:"#64748b",fontWeight:600}}>日数</th>
              </tr></thead>
              <tbody>{annualData.data.map(function(m,i){
                var totalP=vehicles.length*m.dim;
                return <tr key={i} style={{borderBottom:"1px solid #f1f5f9"}}>
                  <td style={{padding:"4px",fontWeight:600}}>{ymLabel(m.ym)}</td>
                  <td style={{textAlign:"right",padding:"4px",fontWeight:700,color:m.grossRate>=70?"#059669":m.grossRate>=40?"#d97706":"#dc2626"}}>{m.grossRate}%</td>
                  <td style={{textAlign:"right",padding:"4px"}}>{m.totalUsed}日</td>
                  <td style={{textAlign:"right",padding:"4px",color:"#64748b"}}>{totalP}日</td>
                </tr>;
              })}</tbody>
            </table>
          </div>
        </div>}

        {annTab==="classRev"&&<div style={cardS}>
          <div style={{fontSize:12,fontWeight:800,color:"#1e293b",marginBottom:10}}>🏷️ クラス別売上推移</div>
          <div style={{overflowX:"auto"}}>
            <table style={{width:"100%",borderCollapse:"collapse",fontSize:10}}>
              <thead><tr style={{borderBottom:"2px solid #e2e8f0"}}>
                <th style={{textAlign:"left",padding:"3px 4px",color:"#64748b",fontWeight:600,position:"sticky",left:0,background:"#fff",zIndex:1}}>月</th>
                {INIT_CLASSES.map(function(cl){return <th key={cl.type} style={{textAlign:"right",padding:"3px 4px",fontWeight:700,minWidth:55}}>
                  <span style={{color:ANN_CLASS_C[cl.type]||"#64748b"}}>{cl.type}</span>
                </th>;})}
                <th style={{textAlign:"right",padding:"3px 4px",color:"#1e293b",fontWeight:700}}>合計</th>
              </tr></thead>
              <tbody>{annualData.data.map(function(m,i){
                return <tr key={i} style={{borderBottom:"1px solid #f1f5f9"}}>
                  <td style={{padding:"4px",fontWeight:600,position:"sticky",left:0,background:"#fff",zIndex:1}}>{m.label}</td>
                  {INIT_CLASSES.map(function(cl){var d=m.classRev[cl.type];return <td key={cl.type} style={{textAlign:"right",padding:"4px",color:d&&d.revenue>0?"#1e293b":"#e2e8f0"}}>{d&&d.revenue>0?"¥"+fmtY(d.revenue):"-"}</td>;})}
                  <td style={{textAlign:"right",padding:"4px",fontWeight:700,color:"#1e40af"}}>¥{fmtY(m.grossRev)}</td>
                </tr>;
              })}
              <tr style={{borderTop:"2px solid #e2e8f0",fontWeight:800}}>
                <td style={{padding:"4px",position:"sticky",left:0,background:"#fff",zIndex:1}}>合計</td>
                {INIT_CLASSES.map(function(cl){var total=annualData.data.reduce(function(s,m){var d=m.classRev[cl.type];return s+(d?d.revenue:0);},0);return <td key={cl.type} style={{textAlign:"right",padding:"4px",color:ANN_CLASS_C[cl.type]||"#64748b"}}>{total>0?"¥"+fmtY(total):"-"}</td>;})}
                <td style={{textAlign:"right",padding:"4px",color:"#1e40af"}}>¥{fmtY(annSummary.totalRev)}</td>
              </tr></tbody>
            </table>
          </div>
          <div style={{fontSize:11,fontWeight:700,color:"#1e293b",margin:"14px 0 6px"}}>📊 1台あたり売上</div>
          <div style={{overflowX:"auto"}}>
            <table style={{width:"100%",borderCollapse:"collapse",fontSize:10}}>
              <thead><tr style={{borderBottom:"2px solid #e2e8f0"}}>
                <th style={{textAlign:"left",padding:"3px 4px",color:"#64748b",fontWeight:600,position:"sticky",left:0,background:"#fff",zIndex:1}}>月</th>
                {INIT_CLASSES.filter(function(cl){return vehicles.some(function(v){return v.type===cl.type;});}).map(function(cl){var vc=vehicles.filter(function(v){return v.type===cl.type;}).length;return <th key={cl.type} style={{textAlign:"right",padding:"3px 4px",fontWeight:700,minWidth:55}}>
                  <span style={{color:ANN_CLASS_C[cl.type]||"#64748b"}}>{cl.type}</span><span style={{fontSize:7,color:"#94a3b8"}}> ({vc}台)</span>
                </th>;})}
              </tr></thead>
              <tbody>{annualData.data.map(function(m,i){
                return <tr key={i} style={{borderBottom:"1px solid #f1f5f9"}}>
                  <td style={{padding:"4px",fontWeight:600,position:"sticky",left:0,background:"#fff",zIndex:1}}>{m.label}</td>
                  {INIT_CLASSES.filter(function(cl){return vehicles.some(function(v){return v.type===cl.type;});}).map(function(cl){var d=m.classRev[cl.type];var vc=vehicles.filter(function(v){return v.type===cl.type;}).length;var pv=d&&d.revenue>0&&vc>0?Math.round(d.revenue/vc):0;return <td key={cl.type} style={{textAlign:"right",padding:"4px",color:pv>0?"#1e293b":"#e2e8f0"}}>{pv>0?"¥"+fmtY(pv):"-"}</td>;})}
                </tr>;
              })}
              <tr style={{borderTop:"2px solid #e2e8f0",fontWeight:800}}>
                <td style={{padding:"4px",position:"sticky",left:0,background:"#fff",zIndex:1}}>平均</td>
                {INIT_CLASSES.filter(function(cl){return vehicles.some(function(v){return v.type===cl.type;});}).map(function(cl){var total=annualData.data.reduce(function(s,m){var d=m.classRev[cl.type];return s+(d?d.revenue:0);},0);var vc=vehicles.filter(function(v){return v.type===cl.type;}).length;var months=annualData.data.length;var avg=vc>0&&months>0?Math.round(total/vc/months):0;return <td key={cl.type} style={{textAlign:"right",padding:"4px",color:ANN_CLASS_C[cl.type]||"#64748b"}}>{avg>0?"¥"+fmtY(avg):"-"}</td>;})}
              </tr></tbody>
            </table>
          </div>
        </div>}

        {annTab==="vehRev"&&<div style={cardS}>
          <div style={{fontSize:12,fontWeight:800,color:"#1e293b",marginBottom:10}}>🚙 車両別売上推移</div>
          <div style={{overflowX:"auto"}}>
            <table style={{width:"100%",borderCollapse:"collapse",fontSize:10}}>
              <thead><tr style={{borderBottom:"2px solid #e2e8f0"}}>
                <th style={{textAlign:"left",padding:"3px 4px",color:"#64748b",fontWeight:600,position:"sticky",left:0,background:"#fff",zIndex:1}}>月</th>
                {vehicles.map(function(v){return <th key={v.code} style={{textAlign:"right",padding:"3px 4px",fontWeight:700,minWidth:50}}><span style={{color:V_COLORS[v.code]||"#64748b"}}>{v.code}</span></th>;})}
              </tr></thead>
              <tbody>{annualData.data.map(function(m,i){
                return <tr key={i} style={{borderBottom:"1px solid #f1f5f9"}}>
                  <td style={{padding:"4px",fontWeight:600,position:"sticky",left:0,background:"#fff",zIndex:1}}>{m.label}</td>
                  {vehicles.map(function(v){var d=m.vehRev[v.code];return <td key={v.code} style={{textAlign:"right",padding:"4px",color:d&&d.revenue>0?"#1e293b":"#e2e8f0"}}>{d&&d.revenue>0?"¥"+fmtY(d.revenue):"-"}</td>;})}
                </tr>;
              })}
              <tr style={{borderTop:"2px solid #e2e8f0",fontWeight:800}}>
                <td style={{padding:"4px",position:"sticky",left:0,background:"#fff",zIndex:1}}>合計</td>
                {vehicles.map(function(v){var total=annualData.data.reduce(function(s,m){var d=m.vehRev[v.code];return s+(d?d.revenue:0);},0);return <td key={v.code} style={{textAlign:"right",padding:"4px",color:V_COLORS[v.code]||"#64748b"}}>{total>0?"¥"+fmtY(total):"-"}</td>;})}
              </tr></tbody>
            </table>
          </div>
        </div>}

        {annTab==="classUtil"&&<div style={cardS}>
          <div style={{fontSize:12,fontWeight:800,color:"#1e293b",marginBottom:10}}>📊 クラス別稼働率推移</div>
          <div style={{overflowX:"auto"}}>
            <table style={{width:"100%",borderCollapse:"collapse",fontSize:10}}>
              <thead><tr style={{borderBottom:"2px solid #e2e8f0"}}>
                <th style={{textAlign:"left",padding:"3px 4px",color:"#64748b",fontWeight:600,position:"sticky",left:0,background:"#fff",zIndex:1}}>月</th>
                {INIT_CLASSES.filter(function(cl){return vehicles.some(function(v){return v.type===cl.type;});}).map(function(cl){return <th key={cl.type} style={{textAlign:"right",padding:"3px 4px",fontWeight:700,minWidth:45}}><span style={{color:ANN_CLASS_C[cl.type]||"#64748b"}}>{cl.type}</span></th>;})}
                <th style={{textAlign:"right",padding:"3px 4px",color:"#1e293b",fontWeight:700}}>全体</th>
              </tr></thead>
              <tbody>{annualData.data.map(function(m,i){
                return <tr key={i} style={{borderBottom:"1px solid #f1f5f9"}}>
                  <td style={{padding:"4px",fontWeight:600,position:"sticky",left:0,background:"#fff",zIndex:1}}>{m.label}</td>
                  {INIT_CLASSES.filter(function(cl){return vehicles.some(function(v){return v.type===cl.type;});}).map(function(cl){var d=m.classUtil[cl.type];var r=d?d.rate:0;var c=r>=70?"#059669":r>=40?"#d97706":"#dc2626";return <td key={cl.type} style={{textAlign:"right",padding:"4px",color:d&&d.vehCount>0?c:"#e2e8f0",fontWeight:600}}>{d&&d.vehCount>0?r+"%":"-"}</td>;})}
                  <td style={{textAlign:"right",padding:"4px",fontWeight:700,color:m.grossRate>=70?"#059669":m.grossRate>=40?"#d97706":"#dc2626"}}>{m.grossRate}%</td>
                </tr>;
              })}</tbody>
            </table>
          </div>
        </div>}

        {annTab==="vehUtil"&&<div style={cardS}>
          <div style={{fontSize:12,fontWeight:800,color:"#1e293b",marginBottom:10}}>📅 車両別稼働率推移</div>
          <div style={{overflowX:"auto"}}>
            <table style={{width:"100%",borderCollapse:"collapse",fontSize:10}}>
              <thead><tr style={{borderBottom:"2px solid #e2e8f0"}}>
                <th style={{textAlign:"left",padding:"3px 4px",color:"#64748b",fontWeight:600,position:"sticky",left:0,background:"#fff",zIndex:1}}>月</th>
                {vehicles.map(function(v){return <th key={v.code} style={{textAlign:"right",padding:"3px 4px",fontWeight:700,minWidth:40}}><span style={{color:V_COLORS[v.code]||"#64748b"}}>{v.code}</span></th>;})}
              </tr></thead>
              <tbody>{annualData.data.map(function(m,i){
                return <tr key={i} style={{borderBottom:"1px solid #f1f5f9"}}>
                  <td style={{padding:"4px",fontWeight:600,position:"sticky",left:0,background:"#fff",zIndex:1}}>{m.label}</td>
                  {vehicles.map(function(v){var d=m.vehUtil[v.code];var r=d?d.rate:0;var c=r>=70?"#059669":r>=40?"#d97706":"#dc2626";return <td key={v.code} style={{textAlign:"right",padding:"4px",color:d?c:"#e2e8f0",fontWeight:600}}>{d?r+"%":"-"}</td>;})}
                </tr>;
              })}
              <tr style={{borderTop:"2px solid #e2e8f0",fontWeight:800}}>
                <td style={{padding:"4px",position:"sticky",left:0,background:"#fff",zIndex:1}}>平均</td>
                {vehicles.map(function(v){var rates=annualData.data.map(function(m){return m.vehUtil[v.code]?m.vehUtil[v.code].rate:0;});var avg=rates.length>0?Math.round(rates.reduce(function(a,b){return a+b;},0)/rates.length):0;var c=avg>=70?"#059669":avg>=40?"#d97706":"#dc2626";return <td key={v.code} style={{textAlign:"right",padding:"4px",color:c,fontWeight:700}}>{avg}%</td>;})}
              </tr></tbody>
            </table>
          </div>
        </div>}

      </div>}

  </div>;
}

/* ==========================================
   🅿️ 駐車場管理
   ========================================== */
const PARKING_DEFAULT_CARS = [
  {id:"VEL-7673",name:"VEL",plate:"7673"},{id:"NRH-5398",name:"NRH",plate:"5398"},
  {id:"DLC-6057",name:"DLC",plate:"6057"},{id:"RKY-299",name:"RKY",plate:"299"},
  {id:"CX3-4576",name:"CX3",plate:"4576"},{id:"SLO-8529",name:"SLO",plate:"8529"},
  {id:"AXL-8403",name:"AXL",plate:"8403"},{id:"HRI-5512",name:"HRI",plate:"5512"},
  {id:"CX5-8065",name:"CX5",plate:"8065"},{id:"DLC-未登録",name:"DLC",plate:"未登録"},
];
const PARKING_INIT_SPOTS = [
  {id:1,no:"221",key:179,carId:null,memo:"",restricted:null},
  {id:2,no:"260",key:180,carId:null,memo:"",restricted:null},
  {id:3,no:"234",key:181,carId:null,memo:"CX-3/ソリオ/ロッキー 専用",restricted:["CX-3-4576","ソリオ-8529","ロッキー-299"]},
  {id:4,no:"172",key:169,carId:null,memo:"",restricted:null},
  {id:5,no:"174",key:174,carId:null,memo:"",restricted:null},
  {id:6,no:"200",key:175,carId:null,memo:"",restricted:null},
  {id:7,no:"282",key:176,carId:null,memo:"",restricted:null},
];
// restricted IDの自動修正（旧略称→正式車両ID）
const RESTRICTED_FIX={"CX3-4576":"CX-3-4576","SLO-8529":"ソリオ-8529","RKY-299":"ロッキー-299"};
function fixSpotRestricted(spots){
  if(!spots)return spots;
  return spots.map(sp=>{
    if(!sp.restricted)return sp;
    const fixed=sp.restricted.map(id=>RESTRICTED_FIX[id]||id);
    const changed=fixed.some((f,i)=>f!==sp.restricted[i]);
    return changed?{...sp,restricted:fixed,memo:"CX-3/ソリオ/ロッキー 専用"}:sp;
  });
}
function canParkInSpot(spot,carId){return !spot.restricted||spot.restricted.includes(carId);}
function pCarLabel(c){return c.name+" ("+c.plate+")";}
const PARKING_VENDORS=["オートバックス","イエローハット","ディーラー","板金工場","タイヤ館","車検場","その他"];
const WASH_STATUSES=["未洗車","内洗済","洗車済"];
const washStyleLight=s=>({"未洗車":{bg:"#fef2f2",c:"#dc2626",icon:"❌"},"内洗済":{bg:"#fffbeb",c:"#d97706",icon:"🧹"},"洗車済":{bg:"#ecfdf5",c:"#059669",icon:"✨"}}[s]||{bg:"#f1f5f9",c:"#64748b",icon:"?"});

function ParkingManager({masterVehicles}){
  const s0=useRef(DB.parking.lsLoad());
  const init=s0.current;
  const[cars,setCars]=useState(init&&init.cars?init.cars:PARKING_DEFAULT_CARS);
  const getCar=id=>cars.find(c=>c.id===id)||null;
  const initWash={};cars.forEach(c=>{initWash[c.id]="未洗車";});
  const initWashTime={};cars.forEach(c=>{initWashTime[c.id]=null;});
  const[spots,setSpots]=useState(()=>fixSpotRestricted(init?init.spots:PARKING_INIT_SPOTS));
  const[pTab,setPTab]=useState("home");
  const[selectedCar,setSelectedCar]=useState(null);
  const[parkStep,setParkStep]=useState("select");
  const[doneInfo,setDoneInfo]=useState(null);
  const[history,setHistory]=useState(init?init.history:[]);
  const[modal,setModal]=useState(null);
  const[washMap,setWashMap]=useState(init?init.washMap:initWash);
  const[washTimeMap,setWashTimeMap]=useState(init?init.washTimeMap:initWashTime);
  const[maintMap,setMaintMap]=useState(init?init.maintMap:{});
  // 移動車: {carId: {staff:"名前", since:"日時"}}  倉庫車: {carId: {user:"名前", note:"備品内容"}}
  const[staffCarMap,setStaffCarMap]=useState(init?init.staffCarMap||{}:{});
  const[warehouseMap,setWarehouseMap]=useState(init?init.warehouseMap||{}:{});
  const[syncStatus,setSyncStatus]=useState("loading");
  const isRemoteUpdate=useRef(false);

  // Supabase初回読み込み＋Realtime（LS優先復旧つき）
  useEffect(()=>{
    let mounted=true;
    if(!sbParking){setSyncStatus("offline");return;}
    DB.parking.fetch().then(remote=>{
      if(!mounted)return;
      // LSバックアップとDB比較: データ消失を検知して復元
      let ls=DB.parking.lsLoad();
      // メインLSが空なら二重バックアップを試す
      const lsParkedMain=ls&&ls.spots?ls.spots.filter(s=>s.carId).length:0;
      if((!ls||!ls.cars||ls.cars.length===0||lsParkedMain===0)){
        const bk=DB.parking.lsLoadBackup();
        const bkParked=bk&&bk.spots?bk.spots.filter(s=>s.carId).length:0;
        if(bk&&bk.cars&&bk.cars.length>0&&bkParked>0){
          console.log("[Parking] Main LS empty/no parked. Using backup LS (parked:"+bkParked+")");
          ls=bk;
        }
      }
      const useRemote=remote&&remote.spots;
      const remoteCarsLen=useRemote&&remote.cars?remote.cars.length:0;
      const lsCarsLen=ls&&ls.cars?ls.cars.length:0;
      const remoteParked=useRemote?remote.spots.filter(s=>s.carId).length:0;
      const lsParked=ls&&ls.spots?ls.spots.filter(s=>s.carId).length:0;
      // 復元条件: (1)車両数が大幅減 (2)駐車中が0でLSに駐車データあり
      const shouldRestore=lsCarsLen>0&&(
        remoteCarsLen===0||
        remoteCarsLen<lsCarsLen*0.5||
        (remoteParked===0&&lsParked>0)
      );
      if(shouldRestore){
        console.warn("[Parking] Data loss detected. DB cars:"+remoteCarsLen+" parked:"+remoteParked+" / LS cars:"+lsCarsLen+" parked:"+lsParked+". Restoring.");
        if(ls.spots)setSpots(fixSpotRestricted(ls.spots));if(ls.cars)setCars(ls.cars);
        if(ls.washMap)setWashMap(ls.washMap);if(ls.washTimeMap)setWashTimeMap(ls.washTimeMap);
        if(ls.maintMap)setMaintMap(ls.maintMap);if(ls.history)setHistory(ls.history);
        if(ls.staffCarMap)setStaffCarMap(ls.staffCarMap);if(ls.warehouseMap)setWarehouseMap(ls.warehouseMap);
        DB.parking.save({...ls,savedAt:new Date().toISOString()});
        setTimeout(()=>alert("🔄 駐車場データをバックアップから復元しました（車両"+lsCarsLen+"台・駐車中"+lsParked+"台）"),500);
      }else if(useRemote){
        setSpots(fixSpotRestricted(remote.spots));if(remote.cars)setCars(remote.cars);
        if(remote.washMap)setWashMap(remote.washMap);if(remote.washTimeMap)setWashTimeMap(remote.washTimeMap);
        if(remote.maintMap)setMaintMap(remote.maintMap);if(remote.history)setHistory(remote.history);
        if(remote.staffCarMap)setStaffCarMap(remote.staffCarMap);if(remote.warehouseMap)setWarehouseMap(remote.warehouseMap);
      }
      setSyncStatus("online");
    });
    const ch=sbParking.channel("parking-rt").on("postgres_changes",{event:"UPDATE",schema:"public",table:"parking_state",filter:"id=eq.1"},payload=>{
      const d=payload.new&&payload.new.data;if(!d||!d.spots)return;
      isRemoteUpdate.current=true;
      if(d.spots)setSpots(fixSpotRestricted(d.spots));if(d.cars)setCars(d.cars);if(d.washMap)setWashMap(d.washMap);
      if(d.washTimeMap)setWashTimeMap(d.washTimeMap);if(d.maintMap)setMaintMap(d.maintMap);if(d.history)setHistory(d.history);
      if(d.staffCarMap)setStaffCarMap(d.staffCarMap);if(d.warehouseMap)setWarehouseMap(d.warehouseMap);
      setSyncStatus("online");setTimeout(()=>{isRemoteUpdate.current=false;},100);
    }).subscribe();
    return()=>{mounted=false;sbParking.removeChannel(ch);};
  },[]);

  // 定期ポーリング+タブ復帰リフレッシュ（Realtime切断時のフォールバック）
  useEffect(()=>{
    const refresh=async()=>{
      try{
        const remote=await DB.parking.fetch();
        if(!remote||!remote.spots)return;
        isRemoteUpdate.current=true;
        setSpots(fixSpotRestricted(remote.spots));if(remote.cars)setCars(remote.cars);
        if(remote.washMap)setWashMap(remote.washMap);if(remote.washTimeMap)setWashTimeMap(remote.washTimeMap);
        if(remote.maintMap)setMaintMap(remote.maintMap);if(remote.history)setHistory(remote.history);
        if(remote.staffCarMap)setStaffCarMap(remote.staffCarMap);if(remote.warehouseMap)setWarehouseMap(remote.warehouseMap);
        setSyncStatus("online");
        setTimeout(()=>{isRemoteUpdate.current=false;},100);
      }catch(e){console.error("[parking poll]",e);}
    };
    const onVis=()=>{if(document.visibilityState==="visible")refresh();};
    document.addEventListener("visibilitychange",onVis);
    const timer=setInterval(()=>{if(document.visibilityState==="visible")refresh();},15000);
    return()=>{document.removeEventListener("visibilitychange",onVis);clearInterval(timer);};
  },[]);

  // 車両マスター同期: 車両タブで追加された車両を駐車場にも追加（削除は手動のみ）
  const masterSyncedRef=useRef(false);
  useEffect(()=>{
    if(!masterVehicles||masterVehicles.length===0)return;
    // 初回ロード時のみ追加同期（削除は行わない＝駐車場データを保護）
    setCars(prev=>{
      const existingIds=new Set(prev.map(c=>c.id));
      let changed=false;let next=[...prev];
      masterVehicles.forEach(v=>{
        const id=v.name+"-"+v.no;
        if(!existingIds.has(id)){
          next.push({id,name:v.name,plate:v.no});
          setWashMap(p=>({...p,[id]:"未洗車"}));
          setWashTimeMap(p=>({...p,[id]:null}));
          changed=true;
        }
      });
      return changed?next:prev;
    });
  },[masterVehicles]);

  // 自動保存
  useEffect(()=>{
    const d={spots,cars,washMap,washTimeMap,maintMap,staffCarMap,warehouseMap,history,savedAt:new Date().toISOString()};
    DB.parking.lsSave(d);if(!isRemoteUpdate.current)DB.parking.save(d);
  },[spots,cars,washMap,washTimeMap,maintMap,staffCarMap,warehouseMap,history]);

  // 関数群
  const addCar=(name,plate)=>{const id=name+"-"+plate;if(cars.find(c=>c.id===id)){alert("同じ車両が既に登録されています");return false;}setCars(p=>[...p,{id,name,plate}]);setWashMap(p=>({...p,[id]:"未洗車"}));setWashTimeMap(p=>({...p,[id]:null}));addLog("【車両登録】"+name+" ("+plate+")");return true;};
  const removeCar=(carId)=>{const sp=spots.find(s=>s.carId===carId);if(sp)setSpots(p=>p.map(s=>s.id===sp.id?{...s,carId:null}:s));if(maintMap[carId])setMaintMap(p=>{const n={...p};delete n[carId];return n;});setCars(p=>p.filter(c=>c.id!==carId));addLog("【車両削除】"+pCarLabel(getCar(carId)));};
  const setWashStatus=(carId,st)=>{const now=new Date();const stamp=(now.getMonth()+1)+"/"+now.getDate()+" "+String(now.getHours()).padStart(2,"0")+":"+String(now.getMinutes()).padStart(2,"0");setWashMap(p=>({...p,[carId]:st}));setWashTimeMap(p=>({...p,[carId]:stamp}));addLog("【洗車】"+pCarLabel(getCar(carId))+" → "+st);};
  const registerMaint=(carId,vendor,entryDate,pickupDate)=>{setMaintMap(p=>({...p,[carId]:{vendor,entryDate,pickupDate}}));addLog("【メンテ入庫】"+pCarLabel(getCar(carId))+" → "+vendor+" ("+entryDate+"〜"+pickupDate+")");};
  const clearMaint=(carId)=>{setMaintMap(p=>{const n={...p};delete n[carId];return n;});addLog("【メンテ回収】"+pCarLabel(getCar(carId)));};
  const pTs=()=>{const d=new Date();return String(d.getHours()).padStart(2,"0")+":"+String(d.getMinutes()).padStart(2,"0");};
  const addLog=(msg)=>setHistory(h=>[...h,{time:pTs(),msg}]);
  const parkCar=(spotId,carId)=>{const sp=spots.find(s=>s.id===spotId);const car=getCar(carId);if(!sp||!car)return;if(sp.carId){alert("この枠は使用中です");return;}setSpots(p=>p.map(s=>s.id===spotId?{...s,carId}:s));addLog("【入庫】"+pCarLabel(car)+" → No."+sp.no+" (Key:"+sp.key+")");setModal(null);};
  const releaseCar=(spotId)=>{const sp=spots.find(s=>s.id===spotId);if(!sp||!sp.carId)return;const car=getCar(sp.carId);setSpots(p=>p.map(s=>s.id===spotId?{...s,carId:null}:s));addLog("【出庫】"+pCarLabel(car)+" ← No."+sp.no+" (Key:"+sp.key+")");setModal(null);};
  const swapCar=(spotId,newCarId)=>{const sp=spots.find(s=>s.id===spotId);if(!sp)return;const oldCar=getCar(sp.carId);const newCar=getCar(newCarId);setSpots(p=>p.map(s=>s.id===spotId?{...s,carId:newCarId}:s));addLog("【入替】No."+sp.no+": "+(oldCar?pCarLabel(oldCar):"空")+" → "+pCarLabel(newCar));setModal(null);};
  const updateMemo=(spotId,memo)=>setSpots(p=>p.map(s=>s.id===spotId?{...s,memo}:s));
  // 移動車
  const setStaffCar=(carId,staffName)=>{if(!staffName){setStaffCarMap(p=>{const n={...p};delete n[carId];return n;});addLog("【移動車解除】"+pCarLabel(getCar(carId)));return;}setStaffCarMap(p=>({...p,[carId]:{staff:staffName,since:new Date().toLocaleString("ja-JP",{month:"numeric",day:"numeric",hour:"2-digit",minute:"2-digit"})}}));addLog("【移動車】"+pCarLabel(getCar(carId))+" → "+staffName);};
  // 倉庫車
  const setWarehouseCar=(carId,userName,note)=>{if(!userName){setWarehouseMap(p=>{const n={...p};delete n[carId];return n;});addLog("【倉庫車解除】"+pCarLabel(getCar(carId)));return;}setWarehouseMap(p=>({...p,[carId]:{user:userName,note:note||"備品積載"}}));addLog("【倉庫車】"+pCarLabel(getCar(carId))+" → "+userName+" ("+note+")");};
  // 駐車場追加
  const addSpot=(no,key)=>{if(!no)return;const newId=spots.length>0?Math.max(...spots.map(s=>s.id))+1:1;setSpots(p=>[...p,{id:newId,no:String(no),key:Number(key)||0,carId:null,memo:"",restricted:null}]);addLog("【枠追加】No."+no+" Key:"+key);};
  const removeSpot=(spotId)=>{const sp=spots.find(s=>s.id===spotId);if(!sp)return;if(sp.carId){alert("車両が入庫中の枠は削除できません");return;}setSpots(p=>p.filter(s=>s.id!==spotId));addLog("【枠削除】No."+sp.no);};
  const exportData=()=>{const d={spots,cars,washMap,washTimeMap,maintMap,history,exportedAt:new Date().toISOString()};const json=JSON.stringify(d,null,2);if(navigator.clipboard){navigator.clipboard.writeText(json).then(()=>alert("クリップボードにコピーしました")).catch(()=>{});}};
  const importData=()=>{const input=prompt("JSONデータを貼り付け:");if(!input)return;try{const d=JSON.parse(input);if(d.spots)setSpots(d.spots);if(d.cars)setCars(d.cars);if(d.washMap)setWashMap(d.washMap);if(d.washTimeMap)setWashTimeMap(d.washTimeMap);if(d.maintMap)setMaintMap(d.maintMap);if(d.history)setHistory(d.history);alert("インポートしました");}catch(e){alert("読み込み失敗");}};
  const resetData=()=>{if(!confirm("全データを初期化しますか？"))return;setCars(PARKING_DEFAULT_CARS);setSpots(PARKING_INIT_SPOTS);const iw={};PARKING_DEFAULT_CARS.forEach(c=>{iw[c.id]="未洗車";});setWashMap(iw);const iwt={};PARKING_DEFAULT_CARS.forEach(c=>{iwt[c.id]=null;});setWashTimeMap(iwt);setMaintMap({});setHistory([]);localStorage.removeItem(DB.parking.LS_KEY);if(sbParking){sbParking.from("parking_state").update({data:{},updated_at:new Date().toISOString()}).eq("id",1).then(()=>{});}alert("初期化しました");};

  // 計算
  const parkedCarIds=useMemo(()=>spots.filter(s=>s.carId).map(s=>s.carId),[spots]);
  const outCars=useMemo(()=>cars.filter(c=>!parkedCarIds.includes(c.id)),[parkedCarIds,cars]);
  const occupied=parkedCarIds.length;
  const empty=spots.length-occupied;
  const parkedCars=useMemo(()=>cars.filter(c=>parkedCarIds.includes(c.id)),[parkedCarIds,cars]);
  const washCounts=useMemo(()=>{const ct={"未洗車":0,"内洗済":0,"洗車済":0};parkedCars.forEach(c=>{const s=washMap[c.id];if(ct[s]!==undefined)ct[s]++;});return ct;},[washMap,parkedCars]);
  const maintCars=useMemo(()=>outCars.filter(c=>maintMap[c.id]),[outCars,maintMap]);
  const staffCars=useMemo(()=>outCars.filter(c=>staffCarMap[c.id]),[outCars,staffCarMap]);
  const warehouseCars=useMemo(()=>cars.filter(c=>warehouseMap[c.id]),[cars,warehouseMap]);
  const nonMaintOutCars=useMemo(()=>outCars.filter(c=>!maintMap[c.id]&&!staffCarMap[c.id]),[outCars,maintMap,staffCarMap]);
  const alertLv=empty===0?"critical":empty===1?"warning":"safe";
  const parkableCars=useMemo(()=>outCars.filter(c=>!maintMap[c.id]),[outCars,maintMap]);
  const carStatus=useCallback(carId=>{const spot=spots.find(s=>s.carId===carId);if(spot)return{type:"parked",label:"🅿️ No."+spot.no,color:"#059669"};if(maintMap[carId])return{type:"maint",label:"🔧 "+maintMap[carId].vendor,color:"#d97706"};if(staffCarMap[carId])return{type:"staff",label:"🚗 移動車("+staffCarMap[carId].staff+")",color:"#7c3aed"};if(warehouseMap[carId])return{type:"warehouse",label:"📦 倉庫車",color:"#0891b2"};return{type:"out",label:"🚙 出庫中",color:"#dc2626"};},[spots,maintMap,staffCarMap,warehouseMap]);
  const dateOptions=useMemo(()=>{const opts=[];const today=new Date();for(let i=0;i<30;i++){const d=new Date(today);d.setDate(today.getDate()+i);const label=(d.getMonth()+1)+"/"+d.getDate()+"("+["日","月","火","水","木","金","土"][d.getDay()]+")";const val=d.getFullYear()+"-"+String(d.getMonth()+1).padStart(2,"0")+"-"+String(d.getDate()).padStart(2,"0");opts.push({label,val});}return opts;},[]);

  // スタイルヘルパー
  const cardStyle={background:"#fff",borderRadius:14,padding:16,border:"1px solid #e2e8f0",marginBottom:12,boxShadow:"0 1px 3px rgba(0,0,0,.06)"};
  const subHdr={fontSize:13,fontWeight:800,marginBottom:10,color:"#1e293b"};

  // ===== 入庫(home)タブ =====
  const homeContent=<>
    {/* ヘッダーサマリー */}
    <div style={{background:"linear-gradient(135deg,#1e40af,#2563eb)",borderRadius:14,padding:16,marginBottom:12,color:"#fff"}}>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:8}}>
        <div>
          <div style={{fontSize:15,fontWeight:800}}>🅿️ 駐車場管理</div>
          <div style={{fontSize:11,opacity:.8}}>🅿️{spots.length}枠 ／ 🚗{cars.length}台 ／ 出庫{outCars.length}台</div>
        </div>
        <div style={{display:"flex",alignItems:"center",gap:6}}>
          <span style={{width:8,height:8,borderRadius:"50%",background:syncStatus==="online"?"#4ade80":syncStatus==="loading"?"#fbbf24":"#f87171"}}></span>
          <span style={{padding:"3px 10px",borderRadius:20,fontSize:11,fontWeight:700,background:alertLv==="safe"?"rgba(255,255,255,.2)":alertLv==="warning"?"#fbbf24":"#ef4444",color:"#fff"}}>
            {alertLv==="safe"?"空き"+empty+"枠":alertLv==="warning"?"⚠️ 残1枠":"🚨 満車"}
          </span>
        </div>
      </div>
      <div style={{padding:"6px 10px",borderRadius:8,background:"rgba(255,255,255,.1)",fontSize:12}}>
        {empty>0?<><span style={{fontWeight:700}}>✅ 入庫OK</span> ・空き{empty}枠{empty===1&&<span style={{color:"#fde68a"}}> ・次の返却前に出庫を！</span>}</>:<><span style={{fontWeight:700}}>🚨 満車</span> 入庫するには先に1台出庫してください</>}
      </div>
    </div>

    {/* 倉庫車（TOP表示） */}
    {warehouseCars.length>0&&<div style={{...cardStyle,borderColor:"#06b6d4",background:"#ecfeff",borderLeft:"5px solid #06b6d4"}}>
      <div style={subHdr}>📦 倉庫車</div>
      {warehouseCars.map(c=>{const wh=warehouseMap[c.id];const st=carStatus(c.id);return <div key={c.id} style={{display:"flex",justifyContent:"space-between",alignItems:"center",padding:"8px 10px",borderRadius:8,marginBottom:4,background:"#fff"}}>
        <div><div style={{fontSize:13,fontWeight:700,color:"#0e7490"}}>{pCarLabel(c)}</div><div style={{fontSize:10,color:"#0891b2"}}>👤 {wh.user} ・ {wh.note}</div><div style={{fontSize:9,color:"#64748b"}}>{st.label}</div></div>
        <button onClick={()=>setWarehouseCar(c.id,null)} style={{padding:"4px 8px",borderRadius:6,border:"1px solid #06b6d4",background:"transparent",color:"#06b6d4",fontSize:9,cursor:"pointer"}}>解除</button>
      </div>;})}
    </div>}

    {/* 移動車 */}
    {staffCars.length>0&&<div style={{...cardStyle,borderColor:"#8b5cf6",background:"#f5f3ff",borderLeft:"5px solid #8b5cf6"}}>
      <div style={subHdr}>🚗 スタッフ移動車</div>
      {staffCars.map(c=>{const sc=staffCarMap[c.id];return <div key={c.id} style={{display:"flex",justifyContent:"space-between",alignItems:"center",padding:"8px 10px",borderRadius:8,marginBottom:4,background:"#fff"}}>
        <div><div style={{fontSize:13,fontWeight:700,color:"#6d28d9"}}>{pCarLabel(c)}</div><div style={{fontSize:10,color:"#7c3aed"}}>👤 {sc.staff} ・ {sc.since}〜</div></div>
        <button onClick={()=>setStaffCar(c.id,null)} style={{padding:"4px 8px",borderRadius:6,border:"1px solid #8b5cf6",background:"transparent",color:"#8b5cf6",fontSize:9,cursor:"pointer"}}>返却</button>
      </div>;})}
    </div>}

    {/* 入庫ウィザード */}
    {empty===0?
      <div style={{...cardStyle,textAlign:"center",borderColor:"#fca5a5",background:"#fef2f2"}}>
        <div style={{fontSize:40,marginBottom:8}}>🚨</div>
        <div style={{fontSize:18,fontWeight:900,color:"#dc2626",marginBottom:8}}>満　車</div>
        <div style={{fontSize:12,color:"#dc2626"}}>全{spots.length}枠が使用中です。</div>
        <button onClick={()=>setPTab("spots")} style={{marginTop:12,padding:"10px 24px",borderRadius:10,border:"1px solid #dc2626",background:"transparent",color:"#dc2626",fontSize:12,fontWeight:700,cursor:"pointer"}}>🅿️ ステータスで出庫する</button>
      </div>
    :
      <div style={cardStyle}>
        {parkStep==="done"&&doneInfo&&<div style={{textAlign:"center"}}>
          <div style={{fontSize:40,marginBottom:6}}>✅</div>
          <div style={{fontSize:16,fontWeight:900,color:"#059669",marginBottom:4}}>入庫完了</div>
          <div style={{fontSize:13,color:"#334155"}}>{pCarLabel(doneInfo.car)}</div>
          <div style={{fontSize:13,color:"#64748b",marginBottom:12}}>No.{doneInfo.spot.no} (Key:{doneInfo.spot.key}) に入庫</div>
          <button onClick={()=>{setParkStep("select");setSelectedCar(null);setDoneInfo(null);}} className="btn-primary" style={{padding:"10px 28px"}}>OK</button>
        </div>}
        {parkStep==="confirm"&&selectedCar&&(()=>{
          const car=getCar(selectedCar);const avail=spots.filter(s=>!s.carId&&canParkInSpot(s,selectedCar));
          if(!avail.length)return <div style={{textAlign:"center"}}><div style={{padding:12,borderRadius:10,background:"#fef2f2",border:"1px solid #fca5a5",fontSize:12,color:"#dc2626",marginBottom:10}}>この車両を入庫できる空き枠がありません</div><button onClick={()=>{setParkStep("select");setSelectedCar(null);}} className="btn-ghost">戻る</button></div>;
          const rec=avail.find(s=>s.restricted)||avail[0];
          return <div>
            <div style={{background:"#ecfdf5",borderRadius:14,border:"2px solid #10b981",padding:20,marginBottom:12,textAlign:"center"}}>
              <div style={{fontSize:36,marginBottom:4}}>📍</div>
              <div style={{fontSize:13,color:"#059669",fontWeight:700,marginBottom:6}}>こちらに駐車してください</div>
              <div style={{fontSize:36,fontWeight:900,color:"#1e293b"}}>No.{rec.no}</div>
              <div style={{fontSize:14,color:"#64748b",marginTop:4}}>キーナンバー: {rec.key}</div>
              {rec.restricted&&<div style={{fontSize:10,color:"#7c3aed",marginTop:4}}>📌 専用枠</div>}
            </div>
            <div style={{background:"#f8fafc",borderRadius:12,padding:12,marginBottom:12,textAlign:"center"}}>
              <div style={{fontSize:13,fontWeight:700,color:"#1e293b"}}>{pCarLabel(car)} を</div>
              <div style={{fontSize:14,fontWeight:800,color:"#059669"}}>No.{rec.no} に入庫しますか？</div>
            </div>
            <div style={{display:"flex",gap:8}}>
              <button onClick={()=>setParkStep("select")} className="btn-ghost" style={{flex:1,padding:12}}>戻る</button>
              <button onClick={()=>{parkCar(rec.id,selectedCar);setDoneInfo({car,spot:rec});setParkStep("done");}} className="btn-primary" style={{flex:1,padding:12}}>はい</button>
            </div>
          </div>;
        })()}
        {parkStep==="select"&&<>
          <div style={subHdr}>🚗 入庫する車両を選択</div>
          {parkableCars.length>0?<>
            <select value={selectedCar||""} onChange={ev=>setSelectedCar(ev.target.value||null)} className="input-s" style={{marginBottom:10,fontSize:14,padding:"10px 8px"}}>
              <option value="">-- 車両を選択 --</option>
              {parkableCars.map(c=><option key={c.id} value={c.id}>{pCarLabel(c)}</option>)}
            </select>
            {selectedCar&&<button onClick={()=>setParkStep("confirm")} className="btn-primary" style={{width:"100%",padding:12}}>次へ →</button>}
          </>:<div style={{padding:12,borderRadius:10,background:"#f8fafc",textAlign:"center",fontSize:12,color:"#64748b"}}>{outCars.length===0?"全車両が駐車場またはメンテ中":"入庫可能な車両なし"}</div>}
        </>}
      </div>
    }

    {/* 駐車場状況サマリー */}
    <div style={cardStyle}>
      <div style={subHdr}>🅿️ 駐車場の状況</div>
      <div style={{display:"flex",gap:6,marginBottom:10}}>
        <div style={{flex:1,background:"#ecfdf5",borderRadius:10,padding:"8px 4px",textAlign:"center"}}><div style={{fontSize:20,fontWeight:900,color:"#059669"}}>{occupied}</div><div style={{fontSize:9,color:"#64748b"}}>駐車中</div></div>
        <div style={{flex:1,background:empty===0?"#fef2f2":"#eff6ff",borderRadius:10,padding:"8px 4px",textAlign:"center"}}><div style={{fontSize:20,fontWeight:900,color:empty===0?"#dc2626":"#2563eb"}}>{empty}</div><div style={{fontSize:9,color:"#64748b"}}>空き</div></div>
        <div style={{flex:1,background:"#f8fafc",borderRadius:10,padding:"8px 4px",textAlign:"center"}}><div style={{fontSize:20,fontWeight:900,color:"#64748b"}}>{outCars.length}</div><div style={{fontSize:9,color:"#64748b"}}>出庫中</div></div>
      </div>
      {spots.map(sp=>{const car=sp.carId?getCar(sp.carId):null;return <div key={sp.id} style={{display:"flex",alignItems:"center",justifyContent:"space-between",padding:"6px 8px",borderRadius:8,marginBottom:3,background:"#f8fafc",borderLeft:"3px solid "+(car?"#10b981":"#e2e8f0")}}>
        <div style={{display:"flex",alignItems:"center",gap:6}}>
          <span style={{fontSize:11,fontWeight:800,color:car?"#1e293b":"#94a3b8",minWidth:32}}>No.{sp.no}</span>
          <span style={{fontSize:9,color:"#94a3b8"}}>Key:{sp.key}</span>
        </div>
        {car?<div style={{display:"flex",alignItems:"center",gap:4}}>
          <span style={{fontSize:11,fontWeight:700,color:"#059669"}}>{pCarLabel(car)}</span>
          <button onClick={()=>setModal({type:"moveSpot",spotId:sp.id,carId:sp.carId})} style={{padding:"2px 6px",borderRadius:4,border:"1px solid #bfdbfe",background:"transparent",color:"#2563eb",fontSize:8,cursor:"pointer"}}>変更</button>
        </div>:<span style={{fontSize:10,color:"#94a3b8",fontStyle:"italic"}}>空き{sp.restricted?" 📌":""}</span>}
      </div>;})}
    </div>

    {/* 洗車状況 */}
    <div style={cardStyle}>
      <div style={subHdr}>🚿 洗車状況</div>
      <div style={{display:"flex",gap:6,marginBottom:8}}>
        {WASH_STATUSES.map(s=>{const ws=washStyleLight(s);return <div key={s} style={{flex:1,background:ws.bg,borderRadius:10,padding:"8px 4px",textAlign:"center"}}><div style={{fontSize:14}}>{ws.icon}</div><div style={{fontSize:18,fontWeight:800,color:ws.c}}>{washCounts[s]}</div><div style={{fontSize:8,color:"#64748b"}}>{s}</div></div>;})}
      </div>
      {washCounts["未洗車"]>0&&<div style={{fontSize:10,color:"#dc2626",fontWeight:600}}>⚠️ 未洗車: {parkedCars.filter(c=>washMap[c.id]==="未洗車").map(c=>pCarLabel(c)).join(", ")}</div>}
    </div>

    {/* メンテ状況 */}
    <div style={cardStyle}>
      <div style={subHdr}>🔧 メンテナンス</div>
      {maintCars.length>0?maintCars.map(c=>{const m=maintMap[c.id];return <div key={c.id} style={{display:"flex",justifyContent:"space-between",alignItems:"center",padding:"8px 10px",borderRadius:8,marginBottom:4,background:"#fffbeb",borderLeft:"3px solid #d97706"}}>
        <div><div style={{fontSize:12,fontWeight:700,color:"#92400e"}}>{pCarLabel(c)}</div><div style={{fontSize:10,color:"#92400e"}}>🏭 {m.vendor} ({m.entryDate}〜{m.pickupDate})</div></div>
      </div>;}):<div style={{padding:10,textAlign:"center",fontSize:11,color:"#94a3b8"}}>メンテ中の車両なし</div>}
    </div>

    {/* 最近の履歴 */}
    <div style={cardStyle}>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:8}}>
        <span style={subHdr}>📋 最近の操作</span>
        {history.length>5&&<span style={{fontSize:9,color:"#94a3b8"}}>直近5件</span>}
      </div>
      {history.length>0?history.slice().reverse().slice(0,5).map((h,i)=><div key={i} style={{padding:"4px 0",fontSize:10,borderBottom:i<4?"1px solid #f1f5f9":"none"}}>
        <span style={{color:"#94a3b8",marginRight:6}}>{h.time}</span>
        <span style={{color:h.msg.includes("入庫")?"#059669":h.msg.includes("出庫")?"#dc2626":"#2563eb"}}>{h.msg}</span>
      </div>):<div style={{textAlign:"center",fontSize:11,color:"#94a3b8",padding:12}}>履歴なし</div>}
    </div>
  </>;

  // ===== ステータス(spots)タブ =====
  const spotsContent=<>
    {spots.map((sp,idx)=>{const car=sp.carId?getCar(sp.carId):null;const borderC=!car?(sp.restricted?"#8b5cf6":"#e2e8f0"):"#10b981";
      return <div key={sp.id} className="fade-in" style={{...cardStyle,borderLeft:"5px solid "+borderC,animationDelay:(idx*30)+"ms"}}>
        <div style={{display:"flex",alignItems:"center",justifyContent:"space-between"}}>
          <div style={{display:"flex",alignItems:"center",gap:10}}>
            <div style={{width:48,height:44,borderRadius:10,background:car?"#ecfdf5":"#f8fafc",border:"2px solid "+(car?"#10b981":"#e2e8f0"),display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center"}}>
              <div style={{fontSize:6,color:"#94a3b8",fontWeight:700}}>SPOT</div>
              <div style={{fontSize:16,fontWeight:800,color:car?"#1e293b":"#94a3b8"}}>{sp.no}</div>
              <div style={{fontSize:7,color:"#94a3b8"}}>Key:{sp.key}</div>
            </div>
            {car?<div><div style={{fontSize:14,fontWeight:700,color:"#1e293b"}}>{car.name}{sp.restricted&&<span style={{fontSize:8,color:"#7c3aed",marginLeft:4}}>📌専用枠</span>}</div><div style={{fontSize:11,color:"#64748b"}}>{car.plate}</div></div>
              :<div><div style={{fontSize:12,color:"#94a3b8",fontStyle:"italic"}}>— 空き —</div>{sp.restricted&&<div style={{fontSize:8,color:"#7c3aed"}}>📌 {sp.restricted.map(id=>{const c=getCar(id);return c?c.name:"";}).join("/")} 専用</div>}</div>}
          </div>
          <div style={{display:"flex",gap:4}}>
            {car?<button onClick={()=>setModal({type:"release",spotId:sp.id})} className="btn-danger" style={{padding:"6px 10px",fontSize:10}}>出庫</button>
              :<button onClick={()=>setModal({type:"park",spotId:sp.id})} className="btn-primary" style={{padding:"6px 10px",fontSize:10}}>入庫</button>}
            <button onClick={()=>setModal({type:"detail",spotId:sp.id})} className="btn-ghost" style={{padding:"6px 8px",fontSize:10}}>詳細</button>
          </div>
        </div>
        {sp.memo&&<div style={{marginTop:6,fontSize:10,color:"#64748b"}}>📝 {sp.memo}</div>}
      </div>;
    })}
    {/* 駐車場外の車両 */}
    <div style={{...cardStyle,borderColor:empty===0?"#fca5a5":"#e2e8f0",background:empty===0?"#fef2f2":"#fff"}}>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:8}}>
        <div><div style={{fontSize:13,fontWeight:700,color:empty===0?"#dc2626":"#1e293b"}}>{empty===0?"🚨 駐車できていない車両":"🚙 駐車場外の車両"}</div><div style={{fontSize:10,color:"#64748b"}}>{outCars.length}台 ／ 全{cars.length}台</div></div>
        <span style={{padding:"2px 8px",borderRadius:12,fontSize:10,fontWeight:700,background:empty===0?"#fca5a5":"#e2e8f0",color:empty===0?"#7f1d1d":"#64748b"}}>{empty===0?"満車":"空き"+empty}</span>
      </div>
      {outCars.map(c=><div key={c.id} style={{display:"flex",alignItems:"center",justifyContent:"space-between",padding:"6px 8px",borderRadius:8,marginBottom:3,background:empty===0?"#fef2f2":"#f8fafc"}}>
        <span style={{fontSize:12,fontWeight:700,color:empty===0?"#dc2626":"#1e293b"}}>{pCarLabel(c)}</span>
        {empty>0?<button onClick={()=>setModal({type:"parkChoose",carId:c.id})} style={{padding:"4px 10px",borderRadius:6,border:"none",cursor:"pointer",fontSize:9,fontWeight:700,background:"#059669",color:"#fff"}}>入庫 →</button>
          :<span style={{fontSize:9,color:"#dc2626",fontWeight:600}}>枠なし</span>}
      </div>)}
    </div>
  </>;

  // ===== メンテタブ =====
  const maintContent=<>
    <div style={cardStyle}>
      <div style={subHdr}>🔧 メンテナンス入庫</div>
      <div style={{fontSize:11,color:"#64748b",lineHeight:1.6}}>業者にメンテナンス入庫中の車両を管理します。</div>
    </div>
    {maintCars.length>0&&<div style={{marginBottom:12}}>
      <div style={{fontSize:11,fontWeight:700,color:"#d97706",marginBottom:6}}>⚙️ メンテナンス中 {maintCars.length}台</div>
      {maintCars.map(c=>{const m=maintMap[c.id];return <div key={c.id} style={{...cardStyle,borderLeft:"4px solid #d97706",background:"#fffbeb"}}>
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:6}}>
          <div style={{display:"flex",alignItems:"center",gap:8}}><span style={{fontSize:16}}>🔧</span><div><div style={{fontSize:14,fontWeight:700,color:"#92400e"}}>{c.name}</div><div style={{fontSize:11,color:"#92400e"}}>{c.plate}</div></div></div>
          <button onClick={()=>clearMaint(c.id)} style={{padding:"5px 10px",borderRadius:8,border:"none",cursor:"pointer",fontSize:10,fontWeight:700,background:"#059669",color:"#fff"}}>回収済</button>
        </div>
        <div style={{display:"flex",gap:6,flexWrap:"wrap"}}>
          <span style={{padding:"3px 8px",borderRadius:6,background:"#fef3c7",fontSize:10,color:"#92400e"}}>🏭 {m.vendor}</span>
          <span style={{padding:"3px 8px",borderRadius:6,background:"#f8fafc",fontSize:10,color:"#64748b"}}>📅 入庫: {m.entryDate}</span>
          <span style={{padding:"3px 8px",borderRadius:6,background:"#f8fafc",fontSize:10,color:"#64748b"}}>📅 回収: {m.pickupDate}</span>
        </div>
      </div>;})}
    </div>}
    {nonMaintOutCars.length>0&&<div>
      <div style={{fontSize:11,fontWeight:700,color:"#64748b",marginBottom:6}}>🚙 駐車場外 {nonMaintOutCars.length}台</div>
      {nonMaintOutCars.map(c=><div key={c.id} style={{...cardStyle,borderLeft:"4px solid #e2e8f0",display:"flex",justifyContent:"space-between",alignItems:"center"}}>
        <div style={{display:"flex",alignItems:"center",gap:8}}><span style={{fontSize:16}}>🚙</span><div><div style={{fontSize:13,fontWeight:700}}>{c.name}</div><div style={{fontSize:10,color:"#64748b"}}>{c.plate}</div></div></div>
        <button onClick={()=>setModal({type:"maint",carId:c.id})} style={{padding:"6px 12px",borderRadius:8,border:"none",cursor:"pointer",fontSize:10,fontWeight:700,background:"#d97706",color:"#fff"}}>メンテ入庫</button>
      </div>)}
    </div>}
    {outCars.length===0&&<div style={{textAlign:"center",color:"#94a3b8",padding:30}}>全車両が駐車場にあります</div>}
  </>;

  // ===== 洗車タブ =====
  const washContent=<>
    <div style={{display:"flex",gap:6,marginBottom:12}}>
      {WASH_STATUSES.map(s=>{const ws=washStyleLight(s);return <div key={s} style={{flex:1,background:ws.bg,borderRadius:12,padding:"8px 4px",textAlign:"center"}}><div style={{fontSize:16}}>{ws.icon}</div><div style={{fontSize:18,fontWeight:800,color:ws.c}}>{washCounts[s]}</div><div style={{fontSize:9,color:"#64748b"}}>{s}</div></div>;})}
    </div>
    {washCounts["未洗車"]>0&&<div style={{background:"#fef2f2",border:"1px solid #fca5a5",borderRadius:10,padding:"6px 10px",marginBottom:12,display:"flex",alignItems:"center",gap:6}}>
      <span style={{fontSize:14}}>⚠️</span><span style={{fontSize:11,color:"#dc2626",fontWeight:600}}>{washCounts["未洗車"]}台が未洗車</span>
    </div>}
    {parkedCars.length===0&&<div style={{textAlign:"center",color:"#94a3b8",padding:24,fontSize:12}}>駐車場に車両がありません</div>}
    {parkedCars.map((c,i)=>{const ws=washMap[c.id];const wst=washStyleLight(ws);const wTime=washTimeMap[c.id];const spot=spots.find(s=>s.carId===c.id);
      return <div key={c.id} className="fade-in" style={{...cardStyle,borderLeft:"4px solid "+wst.c,animationDelay:(i*25)+"ms"}}>
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:6}}>
          <div style={{display:"flex",alignItems:"center",gap:8}}>
            <span style={{fontSize:16}}>{wst.icon}</span>
            <div><span style={{fontSize:13,fontWeight:700}}>{c.name}</span><span style={{fontSize:10,color:"#64748b",marginLeft:4}}>{c.plate}</span>{spot&&<span style={{fontSize:9,color:"#94a3b8",marginLeft:4}}>📍No.{spot.no}</span>}</div>
          </div>
          <div style={{textAlign:"right"}}>
            <span style={{display:"inline-block",padding:"1px 8px",borderRadius:10,fontSize:10,fontWeight:600,background:wst.bg,color:wst.c}}>{ws}</span>
            {wTime?<div style={{fontSize:8,color:"#94a3b8",marginTop:1}}>🕐 {wTime}</div>:<div style={{fontSize:8,color:"#cbd5e1",marginTop:1}}>未変更</div>}
          </div>
        </div>
        <div style={{display:"flex",gap:4}}>
          {WASH_STATUSES.map(s=>{const active=ws===s;const sty=washStyleLight(s);return <button key={s} onClick={()=>{if(!active)setWashStatus(c.id,s);}} style={{flex:1,padding:"5px 0",borderRadius:8,border:"none",cursor:"pointer",fontSize:10,fontWeight:600,background:active?sty.c+"22":"#f8fafc",color:active?sty.c:"#94a3b8",outline:active?"2px solid "+sty.c:"none"}}>{s}</button>;})}
        </div>
      </div>;
    })}
  </>;

  // ===== 設定タブ =====
  const settingsContent=<>
    <div style={cardStyle}>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:8}}>
        <div style={subHdr}>🚗 車両一覧（{cars.length}台）</div>
        <button onClick={()=>setModal({type:"addCar"})} className="btn-primary" style={{padding:"4px 12px",fontSize:10}}>＋ 追加</button>
      </div>
      {cars.map(c=>{const st=carStatus(c.id);return <div key={c.id} style={{display:"flex",alignItems:"center",justifyContent:"space-between",padding:"6px 8px",borderRadius:8,marginBottom:3,background:"#f8fafc"}}>
        <div style={{display:"flex",alignItems:"center",gap:6}}>
          <span style={{fontSize:13,fontWeight:700}}>{c.name}</span><span style={{fontSize:10,color:"#64748b"}}>{c.plate}</span>
          <span style={{padding:"1px 6px",borderRadius:8,fontSize:7,background:st.color+"18",color:st.color}}>{st.label}</span>
        </div>
        <button onClick={()=>setModal({type:"removeCar",carId:c.id})} style={{padding:"3px 8px",borderRadius:6,border:"1px solid #fca5a5",background:"transparent",color:"#dc2626",fontSize:9,cursor:"pointer"}}>削除</button>
      </div>;})}
    </div>
    <div style={cardStyle}>
      <div style={subHdr}>📤 データ管理</div>
      <button onClick={exportData} className="btn-primary" style={{width:"100%",marginBottom:6,padding:10,fontSize:12}}>📋 データコピー</button>
      <button onClick={importData} className="btn-ghost" style={{width:"100%",marginBottom:6,padding:10,fontSize:12}}>📥 インポート</button>
      <button onClick={()=>{
        let ls=DB.parking.lsLoad();
        const lsP1=ls&&ls.spots?ls.spots.filter(s=>s.carId).length:0;
        // メインが駐車0ならBKを試す
        if(lsP1===0){const bk=DB.parking.lsLoadBackup();const bkP=bk&&bk.spots?bk.spots.filter(s=>s.carId).length:0;if(bkP>0){ls=bk;}}
        if(!ls||!ls.cars||ls.cars.length===0){alert("❌ このブラウザにバックアップデータがありません。\n以前駐車場を使っていた別のブラウザ(スマホ/PC)で試してください。");return;}
        const lsParked=ls.spots?ls.spots.filter(s=>s.carId).length:0;
        if(!window.confirm(`🔄 バックアップから復元しますか？\n車両: ${ls.cars.length}台\n駐車中: ${lsParked}台\nスポット: ${ls.spots?ls.spots.length:0}枠`))return;
        if(ls.spots)setSpots(fixSpotRestricted(ls.spots));if(ls.cars)setCars(ls.cars);
        if(ls.washMap)setWashMap(ls.washMap);if(ls.washTimeMap)setWashTimeMap(ls.washTimeMap);
        if(ls.maintMap)setMaintMap(ls.maintMap);if(ls.history)setHistory(ls.history);
        if(ls.staffCarMap)setStaffCarMap(ls.staffCarMap);if(ls.warehouseMap)setWarehouseMap(ls.warehouseMap);
        DB.parking.save({...ls,savedAt:new Date().toISOString()});
        alert("✅ バックアップから復元しました（駐車中"+lsParked+"台）");
      }} className="btn-ghost" style={{width:"100%",marginBottom:6,padding:10,fontSize:12,border:"2px solid #f59e0b",color:"#b45309"}}>🔄 ローカルバックアップから復元</button>
      <button onClick={resetData} className="btn-danger" style={{width:"100%",padding:10,fontSize:12}}>🗑️ 全リセット</button>
    </div>
  </>;

  // ===== モーダル =====
  let modalEl=null;
  if(modal){
    const sp=spots.find(s=>s.id===modal.spotId);
    const overlay={position:"fixed",inset:0,background:"rgba(0,0,0,.3)",zIndex:300,display:"flex",alignItems:"center",justifyContent:"center",padding:12};
    const sheet={background:"#fff",borderRadius:16,padding:20,width:"100%",maxWidth:420,maxHeight:"80vh",overflowY:"auto",position:"relative"};
    const closeBtn=<button onClick={()=>setModal(null)} style={{position:"absolute",top:12,right:12,background:"#f1f5f9",border:"none",borderRadius:"50%",width:28,height:28,color:"#64748b",fontSize:14,cursor:"pointer",display:"flex",alignItems:"center",justifyContent:"center"}}>✕</button>;

    if(modal.type==="park"&&sp){
      const available=outCars.filter(c=>canParkInSpot(sp,c.id));
      modalEl=<div onClick={ev=>{if(ev.target===ev.currentTarget)setModal(null);}} style={overlay}><div className="fade-in" style={sheet}>
        {closeBtn}
        <div style={{fontSize:15,fontWeight:800,marginBottom:12}}>🅿️ No.{sp.no} に入庫</div>
        <div style={{fontSize:11,color:"#64748b",marginBottom:sp.restricted?6:14}}>キーナンバー: {sp.key}</div>
        {sp.restricted&&<div style={{padding:"4px 8px",borderRadius:8,background:"#f5f3ff",border:"1px solid #c4b5fd",marginBottom:12,fontSize:10,color:"#7c3aed"}}>📌 {sp.restricted.map(id=>{const c=getCar(id);return c?c.name:"";}).join(" / ")} 専用</div>}
        {available.length>0?<>
          <div style={{fontSize:11,color:"#64748b",marginBottom:8}}>入庫する車両を選択:</div>
          <select id="park-select" defaultValue="" style={{width:"100%",padding:"10px 12px",borderRadius:10,border:"2px solid #e2e8f0",fontSize:14,fontWeight:600,marginBottom:12,background:"#f8fafc"}}>
            <option value="" disabled>-- 車両を選択 --</option>
            {available.map(c=><option key={c.id} value={c.id}>{c.name} ({c.plate})</option>)}
          </select>
          <button onClick={()=>{const sel=document.getElementById("park-select").value;if(!sel){alert("車両を選択してください");return;}parkCar(sp.id,sel);}} style={{width:"100%",padding:"12px 0",borderRadius:10,background:"#059669",color:"#fff",border:"none",fontSize:14,fontWeight:800,cursor:"pointer"}}>🚗 入庫する</button>
        </>:<div style={{textAlign:"center",padding:20,color:"#94a3b8"}}>入庫可能な車両なし</div>}
      </div></div>;
    }
    if(modal.type==="release"&&sp){
      const car=getCar(sp.carId);
      modalEl=<div onClick={ev=>{if(ev.target===ev.currentTarget)setModal(null);}} style={overlay}><div className="fade-in" style={sheet}>
        {closeBtn}
        <div style={{fontSize:15,fontWeight:800,marginBottom:12}}>🚙 出庫確認</div>
        <div style={{background:"#f8fafc",borderRadius:12,padding:14,marginBottom:14,textAlign:"center"}}>
          <div style={{fontSize:13,color:"#1e293b",marginBottom:4}}>{car?pCarLabel(car):""}</div>
          <div style={{fontSize:13,color:"#64748b"}}>No.{sp.no} を出庫しますか？</div>
        </div>
        <div style={{display:"flex",gap:8}}>
          <button onClick={()=>setModal(null)} className="btn-ghost" style={{flex:1,padding:12}}>キャンセル</button>
          <button onClick={()=>releaseCar(sp.id)} className="btn-danger" style={{flex:1,padding:12}}>出庫完了</button>
        </div>
      </div></div>;
    }
    if(modal.type==="parkChoose"){
      const car=getCar(modal.carId);const freeSpots=spots.filter(s=>!s.carId);const allowed=freeSpots.filter(s=>canParkInSpot(s,modal.carId));
      modalEl=<div onClick={ev=>{if(ev.target===ev.currentTarget)setModal(null);}} style={overlay}><div className="fade-in" style={sheet}>
        {closeBtn}
        <div style={{fontSize:15,fontWeight:800,marginBottom:4}}>🚗 {car?pCarLabel(car):""} を入庫</div>
        <div style={{fontSize:11,color:"#64748b",marginBottom:14}}>入庫先を選択:</div>
        {allowed.map(sp2=><button key={sp2.id} onClick={()=>parkCar(sp2.id,modal.carId)} style={{display:"flex",alignItems:"center",justifyContent:"space-between",width:"100%",padding:"10px 12px",borderRadius:10,border:"1px solid #e2e8f0",background:"#f8fafc",cursor:"pointer",fontSize:12,fontWeight:600,marginBottom:6}}>
          <div style={{display:"flex",alignItems:"center",gap:8}}>
            <div style={{width:40,height:36,borderRadius:8,background:"#ecfdf5",border:"2px solid #10b981",display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center"}}><div style={{fontSize:6,color:"#94a3b8"}}>SPOT</div><div style={{fontSize:12,fontWeight:800}}>{sp2.no}</div></div>
            <div style={{fontSize:10,color:"#64748b"}}>Key:{sp2.key}{sp2.restricted&&<span style={{color:"#7c3aed"}}> 📌</span>}</div>
          </div>
          <span style={{fontSize:11,color:"#059669",fontWeight:700}}>ここに入庫</span>
        </button>)}
        {allowed.length===0&&<div style={{textAlign:"center",padding:16,color:"#dc2626",fontSize:12}}>入庫できる空き枠なし</div>}
      </div></div>;
    }
    if(modal.type==="moveSpot"){
      const fromSpot=spots.find(s=>s.id===modal.spotId);const car=getCar(modal.carId);const freeSpots=spots.filter(s=>!s.carId&&canParkInSpot(s,modal.carId));
      modalEl=<div onClick={ev=>{if(ev.target===ev.currentTarget)setModal(null);}} style={overlay}><div className="fade-in" style={sheet}>
        {closeBtn}
        <div style={{fontSize:15,fontWeight:800,marginBottom:4}}>🔄 駐車場所の変更</div>
        <div style={{fontSize:11,color:"#64748b",marginBottom:14}}>{car?pCarLabel(car):""} ・現在 No.{fromSpot?fromSpot.no:""}</div>
        {freeSpots.map(sp2=><button key={sp2.id} onClick={()=>{setSpots(p=>p.map(s=>{if(s.id===modal.spotId)return{...s,carId:null};if(s.id===sp2.id)return{...s,carId:modal.carId};return s;}));addLog("【移動】"+pCarLabel(car)+" No."+(fromSpot?fromSpot.no:"")+" → No."+sp2.no);setModal(null);}} style={{display:"flex",alignItems:"center",justifyContent:"space-between",width:"100%",padding:"10px 12px",borderRadius:10,border:"1px solid #e2e8f0",background:"#f8fafc",cursor:"pointer",marginBottom:6}}>
          <div style={{display:"flex",alignItems:"center",gap:8}}><div style={{width:40,height:36,borderRadius:8,background:"#ecfdf5",border:"2px solid #10b981",display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center"}}><div style={{fontSize:6,color:"#94a3b8"}}>SPOT</div><div style={{fontSize:12,fontWeight:800}}>{sp2.no}</div></div><span style={{fontSize:10,color:"#64748b"}}>Key:{sp2.key}</span></div>
          <span style={{fontSize:11,color:"#059669",fontWeight:700}}>ここに移動</span>
        </button>)}
        {freeSpots.length===0&&<div style={{textAlign:"center",padding:16,color:"#dc2626",fontSize:12}}>移動先なし</div>}
      </div></div>;
    }
    if(modal.type==="maint"){
      const car=getCar(modal.carId);const todayVal=dateOptions[0]?.val;const weekVal=dateOptions.length>7?dateOptions[7].val:dateOptions[dateOptions.length-1].val;
      modalEl=<div onClick={ev=>{if(ev.target===ev.currentTarget)setModal(null);}} style={overlay}><div className="fade-in" style={sheet}>
        {closeBtn}
        <div style={{fontSize:15,fontWeight:800,marginBottom:4}}>🔧 メンテナンス入庫</div>
        <div style={{fontSize:11,color:"#64748b",marginBottom:14}}>{car?pCarLabel(car):""}</div>
        <div style={{marginBottom:10}}><div style={{fontSize:11,color:"#64748b",marginBottom:4,fontWeight:600}}>🏭 業者</div>
          <select id="pk-maint-vendor" defaultValue={PARKING_VENDORS[0]} className="input-s">{PARKING_VENDORS.map(v=><option key={v} value={v}>{v}</option>)}</select></div>
        <div style={{marginBottom:10}}><div style={{fontSize:11,color:"#64748b",marginBottom:4,fontWeight:600}}>📅 入庫日</div>
          <select id="pk-maint-entry" defaultValue={todayVal} className="input-s">{dateOptions.map(d=><option key={d.val} value={d.val}>{d.label}</option>)}</select></div>
        <div style={{marginBottom:14}}><div style={{fontSize:11,color:"#64748b",marginBottom:4,fontWeight:600}}>📅 回収予定日</div>
          <select id="pk-maint-pickup" defaultValue={weekVal} className="input-s">{dateOptions.map(d=><option key={d.val} value={d.val}>{d.label}</option>)}</select></div>
        <div style={{display:"flex",gap:8}}>
          <button onClick={()=>setModal(null)} className="btn-ghost" style={{flex:1,padding:12}}>キャンセル</button>
          <button onClick={()=>{const v=document.getElementById("pk-maint-vendor").value;const e=document.getElementById("pk-maint-entry");const p=document.getElementById("pk-maint-pickup");registerMaint(modal.carId,v,e.options[e.selectedIndex].text,p.options[p.selectedIndex].text);setModal(null);}} style={{flex:1,padding:12,borderRadius:8,border:"none",background:"#d97706",color:"#fff",fontSize:13,fontWeight:700,cursor:"pointer"}}>登録</button>
        </div>
      </div></div>;
    }
    if(modal.type==="detail"&&sp){
      const car=sp.carId?getCar(sp.carId):null;
      modalEl=<div onClick={ev=>{if(ev.target===ev.currentTarget)setModal(null);}} style={overlay}><div className="fade-in" style={sheet}>
        {closeBtn}
        <div style={{fontSize:15,fontWeight:800,marginBottom:12}}>🅿️ No.{sp.no} 詳細</div>
        <div style={{background:"#f8fafc",borderRadius:12,padding:12,marginBottom:12}}>
          <div style={{display:"flex",justifyContent:"space-between",marginBottom:6}}><span style={{fontSize:11,color:"#64748b"}}>駐車場No</span><span style={{fontSize:13,fontWeight:700}}>{sp.no}</span></div>
          <div style={{display:"flex",justifyContent:"space-between",marginBottom:6}}><span style={{fontSize:11,color:"#64748b"}}>キーナンバー</span><span style={{fontSize:13,fontWeight:700}}>{sp.key}</span></div>
          <div style={{display:"flex",justifyContent:"space-between"}}><span style={{fontSize:11,color:"#64748b"}}>状態</span>{car?<span style={{fontSize:13,fontWeight:700,color:"#059669"}}>使用中: {pCarLabel(car)}</span>:<span style={{fontSize:13,color:"#94a3b8"}}>空き</span>}</div>
        </div>
        {sp.restricted&&<div style={{padding:"4px 8px",borderRadius:8,background:"#f5f3ff",border:"1px solid #c4b5fd",marginBottom:12,fontSize:10,color:"#7c3aed"}}>📌 専用枠: {sp.restricted.map(id=>{const c=getCar(id);return c?c.name:"";}).join(" / ")}</div>}
        {car&&<div style={{marginBottom:12}}><div style={{fontSize:11,color:"#64748b",marginBottom:4,fontWeight:600}}>🔄 車両入替</div>
          <select value={sp.carId} onChange={ev=>{if(ev.target.value!==sp.carId)swapCar(sp.id,ev.target.value);}} className="input-s">
            <option value={sp.carId}>{pCarLabel(car)} (現在)</option>
            {outCars.filter(c=>canParkInSpot(sp,c.id)).map(c=><option key={c.id} value={c.id}>{pCarLabel(c)}</option>)}
          </select></div>}
        <div style={{marginBottom:12}}><div style={{fontSize:11,color:"#64748b",marginBottom:4,fontWeight:600}}>📝 メモ</div>
          <textarea value={sp.memo} onChange={ev=>updateMemo(sp.id,ev.target.value)} placeholder="メモ..." rows={3} className="input-s" style={{resize:"vertical",fontFamily:"inherit"}}/></div>
        <button onClick={()=>setModal(null)} className="btn-primary" style={{width:"100%",padding:12}}>閉じる</button>
      </div></div>;
    }
    if(modal.type==="addCar"){
      modalEl=<div onClick={ev=>{if(ev.target===ev.currentTarget)setModal(null);}} style={overlay}><div className="fade-in" style={sheet}>
        {closeBtn}
        <div style={{fontSize:15,fontWeight:800,marginBottom:14}}>🚗 新しい車両を登録</div>
        <div style={{marginBottom:10}}><div style={{fontSize:11,color:"#64748b",marginBottom:4}}>車名（例: VEL, CX3）</div><input id="pk-add-name" placeholder="車名" className="input-s"/></div>
        <div style={{marginBottom:14}}><div style={{fontSize:11,color:"#64748b",marginBottom:4}}>ナンバー（例: 7673）</div><input id="pk-add-plate" placeholder="ナンバー" className="input-s"/></div>
        <div style={{display:"flex",gap:8}}>
          <button onClick={()=>setModal(null)} className="btn-ghost" style={{flex:1,padding:12}}>キャンセル</button>
          <button onClick={()=>{const n=document.getElementById("pk-add-name").value.trim();const p=document.getElementById("pk-add-plate").value.trim();if(!n||!p){alert("車名とナンバーを入力");return;}if(addCar(n,p))setModal(null);}} className="btn-primary" style={{flex:1,padding:12}}>登録</button>
        </div>
      </div></div>;
    }
    if(modal.type==="removeCar"){
      const car=getCar(modal.carId);
      modalEl=<div onClick={ev=>{if(ev.target===ev.currentTarget)setModal(null);}} style={overlay}><div className="fade-in" style={sheet}>
        {closeBtn}
        <div style={{fontSize:15,fontWeight:800,marginBottom:8}}>🗑️ 車両削除</div>
        <div style={{fontSize:13,color:"#dc2626",marginBottom:14}}>{car?pCarLabel(car)+"を削除しますか？":""}</div>
        <div style={{fontSize:11,color:"#64748b",marginBottom:14}}>駐車中・メンテ中の場合は自動で解除されます。</div>
        <div style={{display:"flex",gap:8}}>
          <button onClick={()=>setModal(null)} className="btn-ghost" style={{flex:1,padding:12}}>キャンセル</button>
          <button onClick={()=>{removeCar(modal.carId);setModal(null);}} className="btn-danger" style={{flex:1,padding:12}}>削除</button>
        </div>
      </div></div>;
    }
  }

  // ===== 内部タブ =====
  // ===== 管理タブ（移動車・倉庫車・駐車場追加）=====
  const[mgrStaff,setMgrStaff]=useState("");const[mgrCar,setMgrCar]=useState("");
  const[whCar,setWhCar]=useState("");const[whUser,setWhUser]=useState("");const[whNote,setWhNote]=useState("備品積載");
  const[newSpotNo,setNewSpotNo]=useState("");const[newSpotKey,setNewSpotKey]=useState("");
  const manageContent=<>
    {/* スタッフ移動車 */}
    <div style={cardStyle}>
      <div style={subHdr}>🚗 スタッフ移動車の設定</div>
      <div style={{fontSize:11,color:"#64748b",marginBottom:8}}>出庫中の車両をスタッフの移動車として登録します</div>
      <div style={{display:"flex",gap:6,marginBottom:10,flexWrap:"wrap"}}>
        <select value={mgrCar} onChange={e=>setMgrCar(e.target.value)} className="input-s" style={{flex:1,minWidth:120}}>
          <option value="">-- 車両を選択 --</option>
          {nonMaintOutCars.filter(c=>!staffCarMap[c.id]).map(c=><option key={c.id} value={c.id}>{pCarLabel(c)}</option>)}
        </select>
        <input value={mgrStaff} onChange={e=>setMgrStaff(e.target.value)} placeholder="スタッフ名" className="input-s" style={{flex:1,minWidth:100}}/>
        <button onClick={()=>{if(mgrCar&&mgrStaff.trim()){setStaffCar(mgrCar,mgrStaff.trim());setMgrCar("");setMgrStaff("");}}} className="btn-primary" style={{padding:"6px 14px"}}>登録</button>
      </div>
      {Object.keys(staffCarMap).length>0?<div>
        <div style={{fontSize:11,fontWeight:600,marginBottom:4}}>現在の移動車:</div>
        {Object.entries(staffCarMap).map(([cid,v])=>{const c=getCar(cid);if(!c)return null;return <div key={cid} style={{display:"flex",justifyContent:"space-between",alignItems:"center",padding:"6px 8px",borderRadius:6,marginBottom:3,background:"#f5f3ff",borderLeft:"3px solid #8b5cf6"}}>
          <div><span style={{fontWeight:700,color:"#6d28d9"}}>{pCarLabel(c)}</span><span style={{fontSize:10,color:"#7c3aed",marginLeft:8}}>👤 {v.staff} ({v.since}〜)</span></div>
          <button onClick={()=>setStaffCar(cid,null)} style={{fontSize:9,color:"#dc2626",background:"none",border:"none",cursor:"pointer"}}>解除</button>
        </div>;})}
      </div>:<div style={{fontSize:11,color:"#94a3b8",textAlign:"center",padding:8}}>移動車なし</div>}
    </div>

    {/* 倉庫車 */}
    <div style={cardStyle}>
      <div style={subHdr}>📦 倉庫車の設定</div>
      <div style={{fontSize:11,color:"#64748b",marginBottom:8}}>備品を積載している車両を登録します（TOP画面に常時表示）</div>
      <div style={{display:"flex",gap:6,marginBottom:10,flexWrap:"wrap"}}>
        <select value={whCar} onChange={e=>setWhCar(e.target.value)} className="input-s" style={{flex:1,minWidth:120}}>
          <option value="">-- 車両を選択 --</option>
          {cars.filter(c=>!warehouseMap[c.id]).map(c=><option key={c.id} value={c.id}>{pCarLabel(c)}</option>)}
        </select>
        <input value={whUser} onChange={e=>setWhUser(e.target.value)} placeholder="使用者名" className="input-s" style={{flex:1,minWidth:80}}/>
        <input value={whNote} onChange={e=>setWhNote(e.target.value)} placeholder="備品内容" className="input-s" style={{flex:1,minWidth:80}}/>
        <button onClick={()=>{if(whCar&&whUser.trim()){setWarehouseCar(whCar,whUser.trim(),whNote||"備品積載");setWhCar("");setWhUser("");setWhNote("備品積載");}}} className="btn-primary" style={{padding:"6px 14px"}}>登録</button>
      </div>
      {Object.keys(warehouseMap).length>0?<div>
        <div style={{fontSize:11,fontWeight:600,marginBottom:4}}>現在の倉庫車:</div>
        {Object.entries(warehouseMap).map(([cid,v])=>{const c=getCar(cid);if(!c)return null;return <div key={cid} style={{display:"flex",justifyContent:"space-between",alignItems:"center",padding:"6px 8px",borderRadius:6,marginBottom:3,background:"#ecfeff",borderLeft:"3px solid #06b6d4"}}>
          <div><span style={{fontWeight:700,color:"#0e7490"}}>{pCarLabel(c)}</span><span style={{fontSize:10,color:"#0891b2",marginLeft:8}}>👤 {v.user} ・ {v.note}</span></div>
          <button onClick={()=>setWarehouseCar(cid,null)} style={{fontSize:9,color:"#dc2626",background:"none",border:"none",cursor:"pointer"}}>解除</button>
        </div>;})}
      </div>:<div style={{fontSize:11,color:"#94a3b8",textAlign:"center",padding:8}}>倉庫車なし</div>}
    </div>

    {/* 駐車場追加 */}
    <div style={cardStyle}>
      <div style={subHdr}>🅿️ 駐車場の追加・削除</div>
      <div style={{fontSize:11,color:"#64748b",marginBottom:8}}>現在 {spots.length}枠</div>
      <div style={{display:"flex",gap:6,marginBottom:10}}>
        <input value={newSpotNo} onChange={e=>setNewSpotNo(e.target.value)} placeholder="駐車場No" className="input-s" style={{width:100}}/>
        <input value={newSpotKey} onChange={e=>setNewSpotKey(e.target.value)} placeholder="キーNo" className="input-s" style={{width:100}} type="number"/>
        <button onClick={()=>{if(newSpotNo.trim()){addSpot(newSpotNo.trim(),newSpotKey);setNewSpotNo("");setNewSpotKey("");}}} className="btn-primary" style={{padding:"6px 14px"}}>追加</button>
      </div>
      <div style={{maxHeight:300,overflowY:"auto"}}>
        {spots.map(sp=>{const car=sp.carId?getCar(sp.carId):null;return <div key={sp.id} style={{display:"flex",justifyContent:"space-between",alignItems:"center",padding:"6px 8px",borderRadius:6,marginBottom:3,background:car?"#f0fdf4":"#f8fafc",borderLeft:"3px solid "+(car?"#10b981":"#e2e8f0")}}>
          <div style={{display:"flex",alignItems:"center",gap:8}}>
            <span style={{fontSize:12,fontWeight:700}}>No.{sp.no}</span>
            <span style={{fontSize:10,color:"#94a3b8"}}>Key:{sp.key}</span>
            {car&&<span style={{fontSize:10,color:"#059669",fontWeight:600}}>{pCarLabel(car)}</span>}
          </div>
          {!car&&<button onClick={()=>removeSpot(sp.id)} style={{fontSize:9,color:"#dc2626",background:"none",border:"none",cursor:"pointer"}}>削除</button>}
        </div>;})}
      </div>
    </div>
  </>;

  const pTabs=[
    {id:"home",icon:"🚗",label:"入庫"},
    {id:"spots",icon:"🅿️",label:"ステータス"},
    {id:"maint",icon:"🔧",label:"メンテ",badge:maintCars.length},
    {id:"wash",icon:"🚿",label:"洗車",badge:washCounts["未洗車"]},
    {id:"manage",icon:"📋",label:"管理",badge:staffCars.length+warehouseCars.length},
    {id:"settings",icon:"⚙️",label:"設定"},
  ];

  return <div style={{display:"flex",flexDirection:"column",height:"100%"}}>
    {/* 内部タブバー */}
    <div style={{display:"flex",gap:2,padding:"8px 4px",background:"#f8fafc",borderBottom:"1px solid #e2e8f0",flexShrink:0,overflowX:"auto"}}>
      {pTabs.map(t=><button key={t.id} onClick={()=>setPTab(t.id)} style={{flex:"0 0 auto",padding:"6px 12px",borderRadius:8,border:"none",cursor:"pointer",fontSize:11,fontWeight:600,background:pTab===t.id?"#2563eb":"transparent",color:pTab===t.id?"#fff":"#64748b",position:"relative",display:"flex",alignItems:"center",gap:3}}>
        <span style={{fontSize:14}}>{t.icon}</span>{t.label}
        {t.badge>0&&<span style={{background:"#dc2626",color:"#fff",fontSize:8,fontWeight:700,borderRadius:10,padding:"1px 4px",minWidth:14,textAlign:"center"}}>{t.badge}</span>}
      </button>)}
    </div>
    {/* コンテンツ */}
    <div style={{flex:1,overflow:"auto",padding:12}} className="fade-in">
      {pTab==="home"&&homeContent}
      {pTab==="spots"&&spotsContent}
      {pTab==="maint"&&maintContent}
      {pTab==="wash"&&washContent}
      {pTab==="manage"&&manageContent}
      {pTab==="settings"&&settingsContent}
    </div>
    {/* モーダル */}
    {modalEl}
  </div>;
}

/* ==========================================
   会計モジュール
   ========================================== */
// ========================================
// === 定数 + AccountingPanel Component ===
// ========================================

const ACCT_CASH_CATEGORIES={
  income:["現金売上","小口現金追加","前受金入金","預り金入金","雑収入","その他入金"],
  expense:["燃料費","車両整備費","保険料","駐車場代","消耗品費","広告宣伝費","通信費","水道光熱費","旅費交通費","給与手当","外注費","支払手数料","租税公課","雑費","その他出金"]
};
const ACCT_EXTRA_CATEGORIES=["延長料金","追加オプション","免責補償","サイト外紹介","現地飛込み","法人直接","電話予約","その他"];
const ACCT_PAYMENT_METHODS=["現金","クレジットカード","電子マネー","QRコード決済","銀行振込","決済リンク","その他"];

function AccountingPanel({staff}){
  const[records,setRecords]=useState([]);
  const[acctTab,setAcctTab]=useState("cash"); // cash|extra|advance|card_pay|personal_adv|summary
  const[viewPeriod,setViewPeriod]=useState("monthly"); // monthly|yearly
  const[selectedYM,setSelectedYM]=useState(()=>{const d=new Date();return d.getFullYear()+"-"+String(d.getMonth()+1).padStart(2,"0");});
  const[selectedYear,setSelectedYear]=useState(()=>String(new Date().getFullYear()));
  const[showForm,setShowForm]=useState(false);
  const[editRec,setEditRec]=useState(null);
  const[loading,setLoading]=useState(true);
  // 期首残高（localStorage永続化）
  const _OB_KEY="spk_opening_balance";
  const[openingBalances,setOpeningBalances]=useState(()=>{try{return JSON.parse(localStorage.getItem(_OB_KEY)||"{}");}catch(e){return{};}});
  const saveOB=(ob)=>{setOpeningBalances(ob);try{localStorage.setItem(_OB_KEY,JSON.stringify(ob));}catch(e){}};
  const currentOBKey=viewPeriod==="monthly"?selectedYM:selectedYear;
  const currentOB=openingBalances[currentOBKey]||0;

  useEffect(()=>{(async()=>{setLoading(true);const d=await DB.fetchAccounting();setRecords(d||[]);setLoading(false);})();},[]);
  // FIX-3: 他端末の会計変更を反映（タブ復帰+30秒ポーリング）
  useEffect(()=>{
    const refresh=async()=>{try{const d=await DB.fetchAccounting();if(d&&d.length)setRecords(d);}catch(e){}};
    const onVis=()=>{if(document.visibilityState==="visible")refresh();};
    document.addEventListener("visibilitychange",onVis);
    const timer=setInterval(()=>{if(document.visibilityState==="visible")refresh();},30000);
    return()=>{document.removeEventListener("visibilitychange",onVis);clearInterval(timer);};
  },[]);

  const staffNames=useMemo(()=>(staff||[]).map(s=>s.name),[staff]);

  // 新規/編集フォーム
  const[fDate,setFDate]=useState("");
  const[fType,setFType]=useState("cash_in");
  const[fCategory,setFCategory]=useState("");
  const[fSubCat,setFSubCat]=useState("");
  const[fDesc,setFDesc]=useState("");
  const[fAmount,setFAmount]=useState("");
  const[fInputBy,setFInputBy]=useState("");
  const[fMemo,setFMemo]=useState("");
  const[fPayMethod,setFPayMethod]=useState("現金");
  const[fResvNo,setFResvNo]=useState("");
  const[fUrl,setFUrl]=useState("");
  const[fPaid,setFPaid]=useState(false);
  const[fStaffName,setFStaffName]=useState("");
  const[fUserName,setFUserName]=useState("");
  const[fPayee,setFPayee]=useState("");
  const[fPayContent,setFPayContent]=useState("");
  // 個人立替: スタッフフィルター・ソート
  const[padvFilterStaff,setPadvFilterStaff]=useState("all");
  const[padvSort,setPadvSort]=useState("date"); // date|staff|amount|paid

  const openNew=(type)=>{
    const today=new Date().toISOString().slice(0,10);
    setEditRec(null);setFDate(today);setFType(type);setFCategory("");setFSubCat("");setFDesc("");setFAmount("");setFInputBy("");setFMemo("");setFPayMethod("現金");setFResvNo("");setFUrl("");setFPaid(false);setFStaffName("");setFUserName("");setFPayee("");setFPayContent("");setShowForm(true);
  };
  const openEdit=(r)=>{
    setEditRec(r);setFDate(r.date);setFType(r.type);setFCategory(r.category);setFSubCat(r.subCategory||"");setFDesc(r.description);setFAmount(String(r.amount));setFInputBy(r.inputBy);setFMemo(r.memo);setFPayMethod(r.payMethod||"現金");setFResvNo(r.resvNo||"");setFUrl(r.url||"");setFPaid(!!r.paid);setFStaffName(r.staffName||"");setFUserName(r.userName||"");setFPayee(r.payee||"");setFPayContent(r.payContent||"");setShowForm(true);
  };
  const togglePaid=async(r)=>{
    if(!confirm((r.paid?"未確認に戻し":"支払い確認済みにし")+"てよろしいですか？"))return;
    const updated={...r,paid:!r.paid};
    await DB.saveAccounting(updated);
    setRecords(prev=>prev.map(x=>x.id===r.id?updated:x));
  };
  const saveForm=async()=>{
    if(!fDate||!fCategory||!fAmount){alert("日付・科目・金額は必須です");return;}
    const label=editRec?"編集内容を保存":"新規登録";
    if(!confirm(label+"してよろしいですか？"))return;
    const rec={id:editRec?editRec.id:("acct_"+Date.now()+"_"+Math.random().toString(36).slice(2,6)),date:fDate,type:fType,category:fCategory,subCategory:fSubCat,description:fDesc,amount:parseInt(fAmount)||0,inputBy:fInputBy,memo:fMemo,payMethod:fPayMethod,resvNo:fResvNo,url:fUrl,paid:fPaid,staffName:fStaffName,userName:fUserName,payee:fPayee,payContent:fPayContent};
    await DB.saveAccounting(rec);
    setRecords(prev=>{const idx=prev.findIndex(r=>r.id===rec.id);if(idx>=0){const n=[...prev];n[idx]=rec;return n;}return[rec,...prev];});
    setShowForm(false);
  };
  const cancelForm=()=>{if(!confirm("入力内容を破棄してよろしいですか？"))return;setShowForm(false);};
  const deleteRec=async(id)=>{if(!confirm("この記録を削除してよろしいですか？"))return;await DB.deleteAccounting(id);setRecords(prev=>prev.filter(r=>r.id!==id));};

  // CSVダウンロード
  const downloadCSV=(rows,filename)=>{
    const BOM="\uFEFF";
    const header=["日付","区分","科目","補助科目","摘要","決済方法","金額","入力者","備考"];
    const lines=[header.join(",")];
    rows.forEach(r=>{
      const type=r.type==="cash_in"?"入金":r.type==="cash_out"?"出金":"予約外売上";
      lines.push([r.date,type,r.category||"",r.subCategory||"",'"'+(r.description||"").replace(/"/g,'""')+'"',r.payMethod||"",r.amount||0,r.inputBy||"",'"'+(r.memo||"").replace(/"/g,'""')+'"'].join(","));
    });
    const blob=new Blob([BOM+lines.join("\n")],{type:"text/csv;charset=utf-8"});
    const url=URL.createObjectURL(blob);
    const a=document.createElement("a");a.href=url;a.download=filename;a.click();URL.revokeObjectURL(url);
  };

  // フィルタリング
  const filtered=useMemo(()=>{
    return records.filter(r=>{
      if(acctTab==="cash"){if(r.type!=="cash_in"&&r.type!=="cash_out")return false;}
      else if(acctTab==="extra"){if(r.type!=="extra_sales")return false;}
      else if(acctTab==="advance"){if(r.type!=="advance")return false;}
      else if(acctTab==="card_pay"){if(r.type!=="card_pay")return false;}
      else if(acctTab==="personal_adv"){if(r.type!=="personal_adv")return false;}
      else return true;
      if(viewPeriod==="monthly")return r.date&&r.date.startsWith(selectedYM);
      return r.date&&r.date.startsWith(selectedYear);
    }).sort((a,b)=>b.date.localeCompare(a.date));
  },[records,acctTab,viewPeriod,selectedYM,selectedYear]);

  // 個人立替: フィルタ＆ソート済みリスト
  const padvFiltered=useMemo(()=>{
    let list=filtered;
    if(acctTab==="personal_adv"&&padvFilterStaff!=="all")list=list.filter(r=>r.staffName===padvFilterStaff);
    if(acctTab==="personal_adv"){
      list=[...list].sort((a,b)=>{
        if(padvSort==="staff")return(a.staffName||"").localeCompare(b.staffName||"")||b.date.localeCompare(a.date);
        if(padvSort==="amount")return b.amount-a.amount;
        if(padvSort==="paid")return(a.paid?1:0)-(b.paid?1:0)||b.date.localeCompare(a.date);
        return b.date.localeCompare(a.date);
      });
    }
    return list;
  },[filtered,acctTab,padvFilterStaff,padvSort]);
  // 個人立替: スタッフ別集計
  const padvByStaff=useMemo(()=>{
    if(acctTab!=="personal_adv")return[];
    const m={};
    filtered.forEach(r=>{
      const k=r.staffName||"未設定";
      if(!m[k])m[k]={name:k,total:0,paid:0,unpaid:0,count:0};
      m[k].total+=r.amount;m[k].count++;
      if(r.paid)m[k].paid+=r.amount;else m[k].unpaid+=r.amount;
    });
    return Object.values(m).sort((a,b)=>b.total-a.total);
  },[filtered,acctTab]);

  // 集計
  const summary=useMemo(()=>{
    let totalIn=0,totalOut=0;
    if(acctTab==="cash"){
      filtered.forEach(r=>{if(r.type==="cash_in")totalIn+=r.amount;else if(r.type==="cash_out")totalOut+=r.amount;});
    } else if(acctTab==="extra"){
      filtered.forEach(r=>{if(r.type==="extra_sales")totalIn+=r.amount;});
    } else if(acctTab==="advance"||acctTab==="card_pay"||acctTab==="personal_adv"){
      filtered.forEach(r=>{totalIn+=r.amount;});
    }
    // 消し込み集計（advance, card_pay, personal_adv共通）
    let advTotal=0,advPaid=0,advUnpaid=0;
    let cardTotal=0,cardPaid=0,cardUnpaid=0;
    let padvTotal=0,padvPaid=0,padvUnpaid=0;
    filtered.forEach(r=>{
      if(r.type==="advance"){advTotal+=r.amount;if(r.paid)advPaid+=r.amount;else advUnpaid+=r.amount;}
      if(r.type==="card_pay"){cardTotal+=r.amount;if(r.paid)cardPaid+=r.amount;else cardUnpaid+=r.amount;}
      if(r.type==="personal_adv"){padvTotal+=r.amount;if(r.paid)padvPaid+=r.amount;else padvUnpaid+=r.amount;}
    });
    // 集計タブ用
    const periodKey=viewPeriod==="monthly"?selectedYM:selectedYear;
    const periodRecords=records.filter(r=>r.date&&r.date.startsWith(periodKey));
    let cashIn=0,cashOut=0,salesTotal=0,advanceTotal=0,advancePaid=0,advanceUnpaid=0,cardPayTotal=0,cardPayPaid=0,padvAllTotal=0,padvAllPaid=0;
    periodRecords.forEach(r=>{
      if(r.type==="cash_in"){
        cashIn+=r.amount;
        if(r.category==="現金売上"||r.category==="雑収入")salesTotal+=r.amount;
      }
      else if(r.type==="cash_out")cashOut+=r.amount;
      else if(r.type==="extra_sales"){salesTotal+=r.amount;if(r.payMethod==="現金")cashIn+=r.amount;}
      else if(r.type==="advance"){advanceTotal+=r.amount;if(r.paid)advancePaid+=r.amount;else advanceUnpaid+=r.amount;}
      else if(r.type==="card_pay"){cardPayTotal+=r.amount;if(r.paid)cardPayPaid+=r.amount;}
      else if(r.type==="personal_adv"){padvAllTotal+=r.amount;if(r.paid)padvAllPaid+=r.amount;}
    });
    const totalExpense=cashOut+cardPayTotal+padvAllTotal;
    return{totalIn,totalOut,balance:totalIn-totalOut,count:filtered.length,cashIn,cashOut,cashBalance:cashIn-cashOut,salesTotal,advTotal,advPaid,advUnpaid,advanceTotal,advancePaid,advanceUnpaid,cardTotal,cardPaid,cardUnpaid,cardPayTotal,cardPayPaid,padvTotal,padvPaid,padvUnpaid,padvAllTotal,padvAllPaid,totalExpense};
  },[filtered,acctTab,records,viewPeriod,selectedYM,selectedYear]);

  // 年度集計
  const yearlySummary=useMemo(()=>{
    const ym={};
    records.filter(r=>r.date&&r.date.startsWith(selectedYear)).forEach(r=>{
      const m=r.date.substring(0,7);
      if(!ym[m])ym[m]={cashIn:0,cashOut:0,salesTotal:0,advTotal:0,advPaid:0,cardTotal:0,cardPaid:0,padvTotal:0,padvPaid:0,count:0};
      if(r.type==="cash_in"){ym[m].cashIn+=r.amount;if(r.category==="現金売上"||r.category==="雑収入")ym[m].salesTotal+=r.amount;}
      else if(r.type==="cash_out")ym[m].cashOut+=r.amount;
      else if(r.type==="extra_sales"){ym[m].salesTotal+=r.amount;if(r.payMethod==="現金")ym[m].cashIn+=r.amount;}
      else if(r.type==="advance"){ym[m].advTotal+=r.amount;if(r.paid)ym[m].advPaid+=r.amount;}
      else if(r.type==="card_pay"){ym[m].cardTotal+=r.amount;if(r.paid)ym[m].cardPaid+=r.amount;}
      else if(r.type==="personal_adv"){ym[m].padvTotal+=r.amount;if(r.paid)ym[m].padvPaid+=r.amount;}
      ym[m].count++;
    });
    return Object.entries(ym).sort((a,b)=>a[0].localeCompare(b[0]));
  },[records,selectedYear]);

  const sel={padding:"5px 8px",border:"1px solid #d1d5db",borderRadius:6,fontSize:11,background:"#fff"};
  const inp={padding:"6px 10px",border:"1px solid #d1d5db",borderRadius:6,fontSize:11,width:"100%"};
  const tBtn=(id,label)=><button type="button" onClick={()=>{setAcctTab(id);setShowForm(false);}} style={{padding:"6px 16px",borderRadius:8,border:"1px solid "+(acctTab===id?"#2563eb":"#d1d5db"),background:acctTab===id?"#2563eb":"#fff",color:acctTab===id?"#fff":"#374151",fontSize:11,fontWeight:600,cursor:"pointer"}}>{label}</button>;

  // 利用可能年リスト
  const availYears=useMemo(()=>{const s=new Set();records.forEach(r=>{if(r.date)s.add(r.date.substring(0,4));});s.add(String(new Date().getFullYear()));return[...s].sort().reverse();},[records]);
  const availMonths=useMemo(()=>{const y=selectedYear||selectedYM.substring(0,4);return Array.from({length:12},(_,i)=>y+"-"+String(i+1).padStart(2,"0"));},[selectedYM,selectedYear]);

  if(loading)return <div style={{textAlign:"center",padding:40,color:"#94a3b8"}}>読込中...</div>;

  return <div style={{maxWidth:900,margin:"0 auto"}}>
    {/* ヘッダー */}
    <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:12,flexWrap:"wrap",gap:8}}>
      <div style={{display:"flex",gap:5,flexWrap:"wrap"}}>{tBtn("cash","💰 出納帳")}{tBtn("extra","📝 予約外")}{tBtn("advance","🧾 立替金")}{tBtn("card_pay","💳 カード")}{tBtn("personal_adv","👤 個人立替")}{tBtn("summary","📊 集計")}</div>
      <div style={{display:"flex",gap:6,alignItems:"center"}}>
        <select value={viewPeriod} onChange={e=>setViewPeriod(e.target.value)} style={sel}>
          <option value="monthly">月次</option><option value="yearly">年次</option>
        </select>
        {viewPeriod==="monthly"&&<input type="month" value={selectedYM} onChange={e=>setSelectedYM(e.target.value)} style={sel}/>}
        {viewPeriod==="yearly"&&<select value={selectedYear} onChange={e=>setSelectedYear(e.target.value)} style={sel}>{availYears.map(y=><option key={y} value={y}>{y}年</option>)}</select>}
      </div>
    </div>

    {/* 月初残高 + 集計バー — 出納帳 */}
    {acctTab==="cash"&&<div style={{marginBottom:12}}>
      <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:8}}>
        <div style={{fontSize:10,fontWeight:600,color:"#64748b"}}>月初残高:</div>
        <input type="number" value={currentOB||""} onChange={e=>{const v=parseInt(e.target.value)||0;saveOB({...openingBalances,[currentOBKey]:v});}} placeholder="0" style={{width:130,padding:"4px 8px",border:"1px solid #d1d5db",borderRadius:6,fontSize:12,fontWeight:700,textAlign:"right"}}/>
        <div style={{fontSize:10,color:"#64748b"}}>円</div>
      </div>
      <div style={{display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:8}}>
        <div style={{padding:"10px 14px",borderRadius:10,background:"#f0fdf4",border:"1px solid #bbf7d0"}}>
          <div style={{fontSize:9,color:"#166534",fontWeight:600}}>現金入金</div>
          <div style={{fontSize:18,fontWeight:800,color:"#059669"}}>¥{summary.totalIn.toLocaleString()}</div>
        </div>
        <div style={{padding:"10px 14px",borderRadius:10,background:"#fef2f2",border:"1px solid #fecaca"}}>
          <div style={{fontSize:9,color:"#991b1b",fontWeight:600}}>出金</div>
          <div style={{fontSize:18,fontWeight:800,color:"#dc2626"}}>¥{summary.totalOut.toLocaleString()}</div>
        </div>
        <div style={{padding:"10px 14px",borderRadius:10,background:"#f8fafc",border:"1px solid #e2e8f0"}}>
          <div style={{fontSize:9,color:"#64748b",fontWeight:600}}>当月収支</div>
          <div style={{fontSize:18,fontWeight:800,color:summary.balance>=0?"#2563eb":"#dc2626"}}>¥{summary.balance.toLocaleString()}</div>
        </div>
        <div style={{padding:"10px 14px",borderRadius:10,background:"#eff6ff",border:"1px solid #bfdbfe"}}>
          <div style={{fontSize:9,color:"#1e40af",fontWeight:600}}>現金残高</div>
          <div style={{fontSize:18,fontWeight:800,color:(currentOB+summary.balance)>=0?"#2563eb":"#dc2626"}}>¥{(currentOB+summary.balance).toLocaleString()}</div>
          <div style={{fontSize:8,color:"#6b7280",marginTop:2}}>月初+当月収支</div>
        </div>
      </div>
    </div>}
    {/* 集計バー — 予約外売上 */}
    {acctTab==="extra"&&<div style={{display:"grid",gridTemplateColumns:"1fr",gap:8,marginBottom:12,maxWidth:300}}>
      <div style={{padding:"10px 14px",borderRadius:10,background:"#f5f3ff",border:"1px solid #ddd6fe"}}>
        <div style={{fontSize:9,color:"#5b21b6",fontWeight:600}}>予約外売上合計</div>
        <div style={{fontSize:18,fontWeight:800,color:"#7c3aed"}}>¥{summary.totalIn.toLocaleString()}</div>
      </div>
    </div>}
    {/* 集計バー — 立替金 */}
    {acctTab==="advance"&&<div style={{display:"grid",gridTemplateColumns:"repeat(3,1fr)",gap:8,marginBottom:12}}>
      <div style={{padding:"10px 14px",borderRadius:10,background:"#fefce8",border:"1px solid #fde68a"}}>
        <div style={{fontSize:9,color:"#92400e",fontWeight:600}}>立替金総額</div>
        <div style={{fontSize:18,fontWeight:800,color:"#d97706"}}>¥{summary.advTotal.toLocaleString()}</div>
      </div>
      <div style={{padding:"10px 14px",borderRadius:10,background:"#f0fdf4",border:"1px solid #bbf7d0"}}>
        <div style={{fontSize:9,color:"#166534",fontWeight:600}}>回収済み</div>
        <div style={{fontSize:18,fontWeight:800,color:"#059669"}}>¥{summary.advPaid.toLocaleString()}</div>
      </div>
      <div style={{padding:"10px 14px",borderRadius:10,background:"#fef2f2",border:"1px solid #fecaca"}}>
        <div style={{fontSize:9,color:"#991b1b",fontWeight:600}}>未回収</div>
        <div style={{fontSize:18,fontWeight:800,color:"#dc2626"}}>¥{summary.advUnpaid.toLocaleString()}</div>
      </div>
    </div>}
    {/* 集計バー — カード支払い */}
    {acctTab==="card_pay"&&<div style={{display:"grid",gridTemplateColumns:"repeat(3,1fr)",gap:8,marginBottom:12}}>
      <div style={{padding:"10px 14px",borderRadius:10,background:"#eff6ff",border:"1px solid #bfdbfe"}}>
        <div style={{fontSize:9,color:"#1e40af",fontWeight:600}}>カード支払総額</div>
        <div style={{fontSize:18,fontWeight:800,color:"#2563eb"}}>¥{summary.cardTotal.toLocaleString()}</div>
      </div>
      <div style={{padding:"10px 14px",borderRadius:10,background:"#f0fdf4",border:"1px solid #bbf7d0"}}>
        <div style={{fontSize:9,color:"#166534",fontWeight:600}}>処理済み</div>
        <div style={{fontSize:18,fontWeight:800,color:"#059669"}}>¥{summary.cardPaid.toLocaleString()}</div>
      </div>
      <div style={{padding:"10px 14px",borderRadius:10,background:"#fef2f2",border:"1px solid #fecaca"}}>
        <div style={{fontSize:9,color:"#991b1b",fontWeight:600}}>未処理</div>
        <div style={{fontSize:18,fontWeight:800,color:"#dc2626"}}>¥{summary.cardUnpaid.toLocaleString()}</div>
      </div>
    </div>}
    {/* 集計バー — 個人立替金 */}
    {acctTab==="personal_adv"&&<div style={{marginBottom:12}}>
      <div style={{display:"grid",gridTemplateColumns:"repeat(3,1fr)",gap:8,marginBottom:10}}>
        <div style={{padding:"10px 14px",borderRadius:10,background:"#fdf4ff",border:"1px solid #f0abfc"}}>
          <div style={{fontSize:9,color:"#86198f",fontWeight:600}}>個人立替総額</div>
          <div style={{fontSize:18,fontWeight:800,color:"#a21caf"}}>¥{summary.padvTotal.toLocaleString()}</div>
        </div>
        <div style={{padding:"10px 14px",borderRadius:10,background:"#f0fdf4",border:"1px solid #bbf7d0"}}>
          <div style={{fontSize:9,color:"#166534",fontWeight:600}}>精算済み</div>
          <div style={{fontSize:18,fontWeight:800,color:"#059669"}}>¥{summary.padvPaid.toLocaleString()}</div>
        </div>
        <div style={{padding:"10px 14px",borderRadius:10,background:"#fef2f2",border:"1px solid #fecaca"}}>
          <div style={{fontSize:9,color:"#991b1b",fontWeight:600}}>未精算</div>
          <div style={{fontSize:18,fontWeight:800,color:"#dc2626"}}>¥{summary.padvUnpaid.toLocaleString()}</div>
        </div>
      </div>
      {/* スタッフ別サマリー */}
      {padvByStaff.length>0&&<div style={{marginBottom:10}}>
        <div style={{fontSize:10,fontWeight:700,color:"#1e293b",marginBottom:6}}>スタッフ別</div>
        <div style={{display:"flex",gap:6,flexWrap:"wrap"}}>
          {padvByStaff.map(s=><div key={s.name} onClick={()=>setPadvFilterStaff(padvFilterStaff===s.name?"all":s.name)} style={{padding:"8px 12px",borderRadius:8,border:"2px solid "+(padvFilterStaff===s.name?"#a21caf":"#e2e8f0"),background:padvFilterStaff===s.name?"#fdf4ff":"#fff",cursor:"pointer",minWidth:100}}>
            <div style={{fontSize:11,fontWeight:700,color:"#1e293b"}}>{s.name}</div>
            <div style={{fontSize:13,fontWeight:800,color:"#a21caf"}}>¥{s.total.toLocaleString()}</div>
            <div style={{fontSize:9,color:s.unpaid>0?"#dc2626":"#059669",fontWeight:600}}>{s.unpaid>0?"未精算 ¥"+s.unpaid.toLocaleString():"全額精算済"}</div>
            <div style={{fontSize:8,color:"#94a3b8"}}>{s.count}件</div>
          </div>)}
        </div>
      </div>}
      {/* ソート・フィルターUI */}
      <div style={{display:"flex",gap:8,alignItems:"center",marginBottom:6}}>
        <div style={{fontSize:9,color:"#64748b",fontWeight:600}}>並替:</div>
        {[["date","日付"],["staff","名前"],["amount","金額"],["paid","精算状況"]].map(([k,l])=><button key={k} type="button" onClick={()=>setPadvSort(k)} style={{fontSize:9,padding:"2px 8px",borderRadius:4,border:"1px solid "+(padvSort===k?"#a21caf":"#d1d5db"),background:padvSort===k?"#fdf4ff":"#fff",color:padvSort===k?"#a21caf":"#6b7280",cursor:"pointer",fontWeight:600}}>{l}</button>)}
        {padvFilterStaff!=="all"&&<button type="button" onClick={()=>setPadvFilterStaff("all")} style={{fontSize:9,padding:"2px 8px",borderRadius:4,border:"1px solid #dc2626",background:"#fef2f2",color:"#dc2626",cursor:"pointer",fontWeight:600}}>フィルター解除</button>}
        <div style={{fontSize:9,color:"#94a3b8",marginLeft:"auto"}}>{padvFiltered.length}件</div>
      </div>
    </div>}
    {/* 集計バー — 集計タブ */}
    {acctTab==="summary"&&<div style={{marginBottom:12}}>
      <div style={{display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:8,marginBottom:8}}>
        <div style={{padding:"10px 14px",borderRadius:10,background:"#f0fdf4",border:"1px solid #bbf7d0"}}>
          <div style={{fontSize:9,color:"#166534",fontWeight:600}}>現金入金</div>
          <div style={{fontSize:18,fontWeight:800,color:"#059669"}}>¥{summary.cashIn.toLocaleString()}</div>
          <div style={{fontSize:8,color:"#6b7280",marginTop:2}}>出納帳+予約外(現金)</div>
        </div>
        <div style={{padding:"10px 14px",borderRadius:10,background:"#fef2f2",border:"1px solid #fecaca"}}>
          <div style={{fontSize:9,color:"#991b1b",fontWeight:600}}>出金(出納帳)</div>
          <div style={{fontSize:18,fontWeight:800,color:"#dc2626"}}>¥{summary.cashOut.toLocaleString()}</div>
        </div>
        <div style={{padding:"10px 14px",borderRadius:10,background:"#eff6ff",border:"1px solid #bfdbfe"}}>
          <div style={{fontSize:9,color:"#1e40af",fontWeight:600}}>現金残高</div>
          <div style={{fontSize:18,fontWeight:800,color:summary.cashBalance>=0?"#2563eb":"#dc2626"}}>¥{summary.cashBalance.toLocaleString()}</div>
        </div>
        <div style={{padding:"10px 14px",borderRadius:10,background:"#f5f3ff",border:"1px solid #ddd6fe"}}>
          <div style={{fontSize:9,color:"#5b21b6",fontWeight:600}}>売上合計</div>
          <div style={{fontSize:18,fontWeight:800,color:"#7c3aed"}}>¥{summary.salesTotal.toLocaleString()}</div>
          <div style={{fontSize:8,color:"#6b7280",marginTop:2}}>現金売上+雑収入+予約外</div>
        </div>
      </div>
      <div style={{display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:8}}>
        <div style={{padding:"10px 14px",borderRadius:10,background:"#fef2f2",border:"2px solid #fca5a5"}}>
          <div style={{fontSize:9,color:"#991b1b",fontWeight:700}}>当月支出合計</div>
          <div style={{fontSize:20,fontWeight:800,color:"#dc2626"}}>¥{summary.totalExpense.toLocaleString()}</div>
          <div style={{fontSize:8,color:"#6b7280",marginTop:2}}>出納帳+カード+個人立替</div>
        </div>
        <div style={{padding:"10px 14px",borderRadius:10,background:"#eff6ff",border:"1px solid #bfdbfe"}}>
          <div style={{fontSize:9,color:"#1e40af",fontWeight:600}}>カード支払</div>
          <div style={{fontSize:16,fontWeight:800,color:"#2563eb"}}>¥{summary.cardPayTotal.toLocaleString()}</div>
          <div style={{fontSize:8,color:"#6b7280",marginTop:2}}>処理済 ¥{summary.cardPayPaid.toLocaleString()}</div>
        </div>
        <div style={{padding:"10px 14px",borderRadius:10,background:"#fdf4ff",border:"1px solid #f0abfc"}}>
          <div style={{fontSize:9,color:"#86198f",fontWeight:600}}>個人立替</div>
          <div style={{fontSize:16,fontWeight:800,color:"#a21caf"}}>¥{summary.padvAllTotal.toLocaleString()}</div>
          <div style={{fontSize:8,color:"#6b7280",marginTop:2}}>精算済 ¥{summary.padvAllPaid.toLocaleString()}</div>
        </div>
        <div style={{padding:"10px 14px",borderRadius:10,background:"#fefce8",border:"1px solid #fde68a"}}>
          <div style={{fontSize:9,color:"#92400e",fontWeight:600}}>立替金(未回収)</div>
          <div style={{fontSize:16,fontWeight:800,color:"#d97706"}}>¥{summary.advanceUnpaid.toLocaleString()}</div>
          <div style={{fontSize:8,color:"#6b7280",marginTop:2}}>総額 ¥{summary.advanceTotal.toLocaleString()}</div>
        </div>
      </div>
    </div>}

    {/* CSVダウンロード + 明細テーブル */}
    {acctTab!=="summary"&&filtered.length>0&&<div style={{display:"flex",justifyContent:"flex-end",marginBottom:4}}>
      <button type="button" onClick={()=>{const label=acctTab==="cash"?"出納帳":"予約外売上";const period=viewPeriod==="monthly"?selectedYM:selectedYear;downloadCSV(filtered,label+"_"+period+".csv");}} style={{fontSize:9,padding:"3px 10px",borderRadius:5,border:"1px solid #d1d5db",background:"#fff",color:"#475569",cursor:"pointer",fontWeight:600}}>CSV出力</button>
    </div>}
    {acctTab!=="summary"&&<table style={{width:"100%",fontSize:10,borderCollapse:"collapse",marginBottom:12}}>
      {acctTab==="cash"&&<thead><tr style={{background:"#f1f5f9"}}>{["日付","区分","科目","予約番号","ユーザー","摘要","金額","入力者",""].map((h,i)=><th key={i} style={{padding:"4px 6px",textAlign:i===6?"right":"left",fontWeight:600,fontSize:9,borderBottom:"1px solid #e2e8f0"}}>{h}</th>)}</tr></thead>}
      {acctTab==="extra"&&<thead><tr style={{background:"#f1f5f9"}}>{["日付","科目","予約番号","ユーザー","摘要","決済","金額","支払","請求URL","入力者",""].map((h,i)=><th key={i} style={{padding:"4px 6px",textAlign:i===6?"right":"left",fontWeight:600,fontSize:9,borderBottom:"1px solid #e2e8f0"}}>{h}</th>)}</tr></thead>}
      {acctTab==="advance"&&<thead><tr style={{background:"#f1f5f9"}}>{["日付","科目","予約番号","ユーザー","摘要","金額","担当","支払","発行URL",""].map((h,i)=><th key={i} style={{padding:"4px 6px",textAlign:i===5?"right":"left",fontWeight:600,fontSize:9,borderBottom:"1px solid #e2e8f0"}}>{h}</th>)}</tr></thead>}
      {acctTab==="card_pay"&&<thead><tr style={{background:"#f1f5f9"}}>{["日付","科目","支払先","内容","予約番号","金額","処理","URL","入力者",""].map((h,i)=><th key={i} style={{padding:"4px 6px",textAlign:i===5?"right":"left",fontWeight:600,fontSize:9,borderBottom:"1px solid #e2e8f0"}}>{h}</th>)}</tr></thead>}
      {acctTab==="personal_adv"&&<thead><tr style={{background:"#f1f5f9"}}>{["日付","科目","支払先","内容","予約番号","金額","立替者","精算","URL",""].map((h,i)=><th key={i} style={{padding:"4px 6px",textAlign:i===5?"right":"left",fontWeight:600,fontSize:9,borderBottom:"1px solid #e2e8f0"}}>{h}</th>)}</tr></thead>}
      <tbody>{(acctTab==="personal_adv"?padvFiltered:filtered).map((r,i)=>{
        const bg=i%2===0?"#fff":"#f9fafb";
        const editDel=<td style={{padding:"4px 6px"}}>
          <button type="button" onClick={()=>openEdit(r)} style={{fontSize:9,padding:"1px 5px",borderRadius:3,border:"1px solid #d1d5db",background:"#fff",cursor:"pointer",marginRight:3}}>✏️</button>
          <button type="button" onClick={()=>deleteRec(r.id)} style={{fontSize:9,padding:"1px 5px",borderRadius:3,border:"1px solid #fecaca",background:"#fff",color:"#dc2626",cursor:"pointer"}}>🗑</button>
        </td>;
        const paidBadge=(paid)=><span onClick={()=>togglePaid(r)} style={{padding:"1px 6px",borderRadius:4,fontSize:9,fontWeight:600,cursor:"pointer",background:paid?"#f0fdf4":"#fef2f2",color:paid?"#059669":"#dc2626",border:"1px solid "+(paid?"#bbf7d0":"#fecaca")}}>{paid?"済":"未"}</span>;
        if(acctTab==="cash")return <tr key={r.id} style={{background:bg,borderBottom:"1px solid #f1f5f9"}}>
          <td style={{padding:"4px 6px"}}>{r.date}</td>
          <td style={{padding:"4px 6px"}}><span style={{padding:"1px 6px",borderRadius:4,fontSize:9,fontWeight:600,background:r.type==="cash_out"?"#fef2f2":"#f0fdf4",color:r.type==="cash_out"?"#dc2626":"#059669"}}>{r.type==="cash_in"?"入金":"出金"}</span></td>
          <td style={{padding:"4px 6px",fontWeight:600}}>{r.category}{r.subCategory?" / "+r.subCategory:""}</td>
          <td style={{padding:"4px 6px",fontSize:9}}>{r.resvNo||"-"}</td>
          <td style={{padding:"4px 6px",fontSize:9}}>{r.userName||"-"}</td>
          <td style={{padding:"4px 6px",color:"#64748b",maxWidth:120,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{r.description||"-"}</td>
          <td style={{padding:"4px 6px",textAlign:"right",fontWeight:700,color:r.type==="cash_out"?"#dc2626":"#059669"}}>¥{(r.amount||0).toLocaleString()}</td>
          <td style={{padding:"4px 6px",fontSize:9}}>{r.inputBy||"-"}</td>
          {editDel}
        </tr>;
        if(acctTab==="extra")return <tr key={r.id} style={{background:bg,borderBottom:"1px solid #f1f5f9"}}>
          <td style={{padding:"4px 6px"}}>{r.date}</td>
          <td style={{padding:"4px 6px",fontWeight:600}}>{r.category}</td>
          <td style={{padding:"4px 6px",fontSize:9}}>{r.resvNo||"-"}</td>
          <td style={{padding:"4px 6px",fontSize:9}}>{r.userName||"-"}</td>
          <td style={{padding:"4px 6px",color:"#64748b",maxWidth:100,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{r.description||"-"}</td>
          <td style={{padding:"4px 6px",fontSize:9}}>{r.payMethod||"-"}</td>
          <td style={{padding:"4px 6px",textAlign:"right",fontWeight:700,color:"#7c3aed"}}>¥{(r.amount||0).toLocaleString()}</td>
          <td style={{padding:"4px 6px"}}>{paidBadge(r.paid)}</td>
          <td style={{padding:"4px 6px",fontSize:9}}>{r.url?<a href={r.url} target="_blank" rel="noopener noreferrer" style={{color:"#2563eb"}}>URL</a>:"-"}</td>
          <td style={{padding:"4px 6px",fontSize:9}}>{r.inputBy||"-"}</td>
          {editDel}
        </tr>;
        if(acctTab==="advance")return <tr key={r.id} style={{background:r.paid?(bg==="#fff"?"#f0fdf4":"#ecfdf5"):bg,borderBottom:"1px solid #f1f5f9",opacity:r.paid?0.7:1}}>
          <td style={{padding:"4px 6px"}}>{r.date}</td>
          <td style={{padding:"4px 6px",fontWeight:600}}>{r.category}</td>
          <td style={{padding:"4px 6px",fontSize:9}}>{r.resvNo||"-"}</td>
          <td style={{padding:"4px 6px",fontSize:9}}>{r.userName||"-"}</td>
          <td style={{padding:"4px 6px",color:"#64748b",maxWidth:100,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{r.description||"-"}</td>
          <td style={{padding:"4px 6px",textAlign:"right",fontWeight:700,color:"#d97706"}}>¥{(r.amount||0).toLocaleString()}</td>
          <td style={{padding:"4px 6px",fontSize:9}}>{r.staffName||"-"}</td>
          <td style={{padding:"4px 6px"}}>{paidBadge(r.paid)}</td>
          <td style={{padding:"4px 6px",fontSize:9}}>{r.url?<a href={r.url} target="_blank" rel="noopener noreferrer" style={{color:"#2563eb"}}>URL</a>:"-"}</td>
          {editDel}
        </tr>;
        if(acctTab==="card_pay")return <tr key={r.id} style={{background:r.paid?(bg==="#fff"?"#eff6ff":"#e0f2fe"):bg,borderBottom:"1px solid #f1f5f9",opacity:r.paid?0.7:1}}>
          <td style={{padding:"4px 6px"}}>{r.date}</td>
          <td style={{padding:"4px 6px",fontWeight:600}}>{r.category}</td>
          <td style={{padding:"4px 6px",fontSize:9}}>{r.payee||"-"}</td>
          <td style={{padding:"4px 6px",fontSize:9,color:"#64748b",maxWidth:80,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{r.payContent||"-"}</td>
          <td style={{padding:"4px 6px",fontSize:9}}>{r.resvNo||"-"}</td>
          <td style={{padding:"4px 6px",textAlign:"right",fontWeight:700,color:"#2563eb"}}>¥{(r.amount||0).toLocaleString()}</td>
          <td style={{padding:"4px 6px"}}>{paidBadge(r.paid)}</td>
          <td style={{padding:"4px 6px",fontSize:9}}>{r.url?<a href={r.url} target="_blank" rel="noopener noreferrer" style={{color:"#2563eb"}}>URL</a>:"-"}</td>
          <td style={{padding:"4px 6px",fontSize:9}}>{r.inputBy||"-"}</td>
          {editDel}
        </tr>;
        if(acctTab==="personal_adv")return <tr key={r.id} style={{background:r.paid?(bg==="#fff"?"#fdf4ff":"#fae8ff"):bg,borderBottom:"1px solid #f1f5f9",opacity:r.paid?0.7:1}}>
          <td style={{padding:"4px 6px"}}>{r.date}</td>
          <td style={{padding:"4px 6px",fontWeight:600}}>{r.category}</td>
          <td style={{padding:"4px 6px",fontSize:9}}>{r.payee||"-"}</td>
          <td style={{padding:"4px 6px",fontSize:9,color:"#64748b",maxWidth:80,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{r.payContent||"-"}</td>
          <td style={{padding:"4px 6px",fontSize:9}}>{r.resvNo||"-"}</td>
          <td style={{padding:"4px 6px",textAlign:"right",fontWeight:700,color:"#a21caf"}}>¥{(r.amount||0).toLocaleString()}</td>
          <td style={{padding:"4px 6px",fontSize:9}}>{r.staffName||"-"}</td>
          <td style={{padding:"4px 6px"}}>{paidBadge(r.paid)}</td>
          <td style={{padding:"4px 6px",fontSize:9}}>{r.url?<a href={r.url} target="_blank" rel="noopener noreferrer" style={{color:"#2563eb"}}>URL</a>:"-"}</td>
          {editDel}
        </tr>;
        return null;
      })}</tbody>
    </table>}
    {acctTab!=="summary"&&filtered.length===0&&<div style={{textAlign:"center",padding:24,color:"#94a3b8",fontSize:12,marginBottom:12}}>この期間のデータはありません</div>}

    {/* 新規登録ボタン（出納帳・予約外売上のみ）*/}
    {acctTab!=="summary"&&!showForm&&<div style={{textAlign:"center",marginBottom:10}}>
      <button type="button" onClick={function(){const m={cash:"cash_in",extra:"extra_sales",advance:"advance",card_pay:"card_pay",personal_adv:"personal_adv"};openNew(m[acctTab]||"cash_in");}} style={{padding:"8px 24px",borderRadius:8,border:"1px dashed #94a3b8",background:"#fff",color:"#475569",fontSize:12,fontWeight:600,cursor:"pointer"}}>+ 新規登録</button>
    </div>}

    {/* 入力フォーム（集計タブでは非表示） */}
    {showForm&&acctTab!=="summary"&&<div style={{padding:16,borderRadius:12,border:"1px solid #e2e8f0",background:"#f8fafc",marginBottom:12}}>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:10}}>
        <div style={{fontSize:12,fontWeight:700,color:"#1e293b"}}>{editRec?"編集":"新規登録"}</div>
        {acctTab==="cash"&&!editRec&&<div style={{display:"flex",gap:4}}>
          <button type="button" onClick={()=>setFType("cash_in")} style={{padding:"4px 12px",borderRadius:6,border:"1px solid "+(fType==="cash_in"?"#059669":"#d1d5db"),background:fType==="cash_in"?"#f0fdf4":"#fff",color:fType==="cash_in"?"#059669":"#6b7280",fontSize:10,fontWeight:600,cursor:"pointer"}}>入金</button>
          <button type="button" onClick={()=>setFType("cash_out")} style={{padding:"4px 12px",borderRadius:6,border:"1px solid "+(fType==="cash_out"?"#dc2626":"#d1d5db"),background:fType==="cash_out"?"#fef2f2":"#fff",color:fType==="cash_out"?"#dc2626":"#6b7280",fontSize:10,fontWeight:600,cursor:"pointer"}}>出金</button>
        </div>}
      </div>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
        <div><label style={{fontSize:9,color:"#64748b",fontWeight:600}}>日付 *</label><input type="date" value={fDate} onChange={e=>setFDate(e.target.value)} style={inp}/></div>
        <div><label style={{fontSize:9,color:"#64748b",fontWeight:600}}>入力者</label><select value={fInputBy} onChange={e=>setFInputBy(e.target.value)} style={{...inp}}>
          <option value="">選択</option>{staffNames.map(n=><option key={n} value={n}>{n}</option>)}
        </select></div>
        {/* 科目: 立替金は手動入力、他はプルダウン */}
        {(fType==="advance"||fType==="card_pay"||fType==="personal_adv")?<div><label style={{fontSize:9,color:"#64748b",fontWeight:600}}>科目 *</label><input value={fCategory} onChange={e=>setFCategory(e.target.value)} placeholder="科目を入力" style={inp}/></div>
        :<div><label style={{fontSize:9,color:"#64748b",fontWeight:600}}>科目 *</label><select value={fCategory} onChange={e=>setFCategory(e.target.value)} style={{...inp}}>
          <option value="">選択</option>
          {fType==="cash_in"&&ACCT_CASH_CATEGORIES.income.map(c=><option key={c}>{c}</option>)}
          {fType==="cash_out"&&ACCT_CASH_CATEGORIES.expense.map(c=><option key={c}>{c}</option>)}
          {fType==="extra_sales"&&ACCT_EXTRA_CATEGORIES.map(c=><option key={c}>{c}</option>)}
        </select></div>}
        <div><label style={{fontSize:9,color:"#64748b",fontWeight:600}}>金額 *</label><input type="number" value={fAmount} onChange={e=>setFAmount(e.target.value)} placeholder="0" style={inp}/></div>
        {fType==="extra_sales"&&<div><label style={{fontSize:9,color:"#64748b",fontWeight:600}}>決済方法</label><select value={fPayMethod} onChange={e=>setFPayMethod(e.target.value)} style={{...inp}}>
          {ACCT_PAYMENT_METHODS.map(m=><option key={m}>{m}</option>)}
        </select></div>}
        {(fType==="cash_in"||fType==="cash_out")&&<div><label style={{fontSize:9,color:"#64748b",fontWeight:600}}>補助科目</label><input value={fSubCat} onChange={e=>setFSubCat(e.target.value)} placeholder="補助科目" style={inp}/></div>}
        {/* 全タブ共通: 予約番号・ユーザー名 */}
        <div><label style={{fontSize:9,color:"#64748b",fontWeight:600}}>予約番号</label><input value={fResvNo} onChange={e=>setFResvNo(e.target.value)} placeholder="予約番号" style={inp}/></div>
        <div><label style={{fontSize:9,color:"#64748b",fontWeight:600}}>ユーザー名</label><input value={fUserName} onChange={e=>setFUserName(e.target.value)} placeholder="利用者名" style={inp}/></div>
        {/* 立替金・個人立替金: 担当/立替者 */}
        {(fType==="advance"||fType==="personal_adv")&&<div><label style={{fontSize:9,color:"#64748b",fontWeight:600}}>{fType==="personal_adv"?"立替者":"担当"}</label><select value={fStaffName} onChange={e=>setFStaffName(e.target.value)} style={{...inp}}>
          <option value="">選択</option>{staffNames.map(n=><option key={n} value={n}>{n}</option>)}
        </select></div>}
        {/* カード・個人立替: 支払い先・支払い内容 */}
        {(fType==="card_pay"||fType==="personal_adv")&&<div><label style={{fontSize:9,color:"#64748b",fontWeight:600}}>支払い先</label><input value={fPayee} onChange={e=>setFPayee(e.target.value)} placeholder="支払い先" style={inp}/></div>}
        {(fType==="card_pay"||fType==="personal_adv")&&<div><label style={{fontSize:9,color:"#64748b",fontWeight:600}}>支払い内容</label><input value={fPayContent} onChange={e=>setFPayContent(e.target.value)} placeholder="支払い内容" style={inp}/></div>}
        {/* 予約外売上・立替金: URL */}
        {(fType==="extra_sales"||fType==="advance"||fType==="card_pay"||fType==="personal_adv")&&<div style={{gridColumn:"1/3"}}><label style={{fontSize:9,color:"#64748b",fontWeight:600}}>{fType==="advance"?"発行URL":fType==="card_pay"?"明細URL":fType==="personal_adv"?"領収書URL":"請求URL"}</label><input value={fUrl} onChange={e=>setFUrl(e.target.value)} placeholder="https://..." style={inp}/></div>}
        {/* 支払い確認 */}
        {(fType==="extra_sales"||fType==="advance"||fType==="card_pay"||fType==="personal_adv")&&<div><label style={{fontSize:9,color:"#64748b",fontWeight:600}}>{fType==="card_pay"?"処理確認":fType==="personal_adv"?"精算確認":"支払い確認"}</label><div style={{display:"flex",gap:6,marginTop:4}}>
          <button type="button" onClick={()=>setFPaid(false)} style={{padding:"3px 10px",borderRadius:5,border:"1px solid "+(fPaid?"#d1d5db":"#dc2626"),background:fPaid?"#fff":"#fef2f2",color:fPaid?"#6b7280":"#dc2626",fontSize:10,fontWeight:600,cursor:"pointer"}}>未確認</button>
          <button type="button" onClick={()=>setFPaid(true)} style={{padding:"3px 10px",borderRadius:5,border:"1px solid "+(fPaid?"#059669":"#d1d5db"),background:fPaid?"#f0fdf4":"#fff",color:fPaid?"#059669":"#6b7280",fontSize:10,fontWeight:600,cursor:"pointer"}}>確認済</button>
        </div></div>}
        <div style={{gridColumn:"1/3"}}><label style={{fontSize:9,color:"#64748b",fontWeight:600}}>摘要</label><input value={fDesc} onChange={e=>setFDesc(e.target.value)} placeholder="取引の内容" style={inp}/></div>
        <div style={{gridColumn:"1/3"}}><label style={{fontSize:9,color:"#64748b",fontWeight:600}}>備考</label><input value={fMemo} onChange={e=>setFMemo(e.target.value)} placeholder="備考" style={inp}/></div>
      </div>
      <div style={{display:"flex",gap:8,marginTop:10,justifyContent:"flex-end"}}>
        <button type="button" onClick={cancelForm} style={{padding:"6px 16px",borderRadius:8,border:"1px solid #d1d5db",background:"#fff",fontSize:11,cursor:"pointer"}}>キャンセル</button>
        <button type="button" onClick={saveForm} style={{padding:"6px 16px",borderRadius:8,border:"none",background:"#2563eb",color:"#fff",fontSize:11,fontWeight:600,cursor:"pointer"}}>保存</button>
      </div>
    </div>}

    {/* 年次集計テーブル */}
    {acctTab==="summary"&&<div>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:8}}>
        <div style={{fontSize:12,fontWeight:700,color:"#1e293b"}}>📊 {selectedYear}年 月別推移</div>
        <button type="button" onClick={()=>{const allPeriod=records.filter(r=>r.date&&r.date.startsWith(selectedYear));downloadCSV(allPeriod,"会計全データ_"+selectedYear+".csv");}} style={{fontSize:9,padding:"3px 10px",borderRadius:5,border:"1px solid #d1d5db",background:"#fff",color:"#475569",cursor:"pointer",fontWeight:600}}>CSV出力(全データ)</button>
      </div>
      <table style={{width:"100%",fontSize:10,borderCollapse:"collapse"}}>
        <thead><tr style={{background:"#f1f5f9"}}>{["月","現金入金","出金","現金残高","売上合計","支出合計","立替(未回収)"].map((h,i)=><th key={i} style={{padding:"6px 8px",textAlign:i===0?"left":"right",fontWeight:600,fontSize:9,borderBottom:"1px solid #e2e8f0"}}>{h}</th>)}</tr></thead>
        <tbody>
          {yearlySummary.map(([ym,d])=>{const te=d.cashOut+d.cardTotal+d.padvTotal;return <tr key={ym} style={{borderBottom:"1px solid #f1f5f9"}}>
            <td style={{padding:"6px 8px",fontWeight:600}}>{ym}</td>
            <td style={{padding:"6px 8px",textAlign:"right",color:"#059669",fontWeight:600}}>¥{d.cashIn.toLocaleString()}</td>
            <td style={{padding:"6px 8px",textAlign:"right",color:"#dc2626",fontWeight:600}}>¥{d.cashOut.toLocaleString()}</td>
            <td style={{padding:"6px 8px",textAlign:"right",fontWeight:700,color:(d.cashIn-d.cashOut)>=0?"#2563eb":"#dc2626"}}>¥{(d.cashIn-d.cashOut).toLocaleString()}</td>
            <td style={{padding:"6px 8px",textAlign:"right",color:"#7c3aed",fontWeight:600}}>¥{d.salesTotal.toLocaleString()}</td>
            <td style={{padding:"6px 8px",textAlign:"right",color:"#dc2626",fontWeight:700}}>¥{te.toLocaleString()}</td>
            <td style={{padding:"6px 8px",textAlign:"right",color:"#d97706",fontWeight:600}}>¥{(d.advTotal-d.advPaid).toLocaleString()}</td>
          </tr>;})}
          {yearlySummary.length>0&&(()=>{const t=yearlySummary.reduce((a,[,d])=>({ci:a.ci+d.cashIn,co:a.co+d.cashOut,st:a.st+d.salesTotal,at:a.at+d.advTotal,ap:a.ap+d.advPaid,ct:a.ct+d.cardTotal,pt:a.pt+d.padvTotal}),{ci:0,co:0,st:0,at:0,ap:0,ct:0,pt:0});return <tr style={{background:"#f8fafc",fontWeight:700,borderTop:"2px solid #e2e8f0"}}>
            <td style={{padding:"6px 8px"}}>合計</td>
            <td style={{padding:"6px 8px",textAlign:"right",color:"#059669"}}>¥{t.ci.toLocaleString()}</td>
            <td style={{padding:"6px 8px",textAlign:"right",color:"#dc2626"}}>¥{t.co.toLocaleString()}</td>
            <td style={{padding:"6px 8px",textAlign:"right",color:(t.ci-t.co)>=0?"#2563eb":"#dc2626"}}>¥{(t.ci-t.co).toLocaleString()}</td>
            <td style={{padding:"6px 8px",textAlign:"right",color:"#7c3aed"}}>¥{t.st.toLocaleString()}</td>
            <td style={{padding:"6px 8px",textAlign:"right",color:"#dc2626"}}>¥{(t.co+t.ct+t.pt).toLocaleString()}</td>
            <td style={{padding:"6px 8px",textAlign:"right",color:"#d97706"}}>¥{(t.at-t.ap).toLocaleString()}</td>
          </tr>;})()}
        </tbody>
      </table>
      {yearlySummary.length===0&&<div style={{textAlign:"center",padding:24,color:"#94a3b8",fontSize:12}}>データなし</div>}
      {/* 支出内容の総括（出納帳出金＋カード＋個人立替） */}
      {(()=>{
        const yearRecs=records.filter(r=>r.date&&r.date.startsWith(selectedYear));
        const expenseRecs=yearRecs.filter(r=>r.type==="cash_out"||r.type==="card_pay"||r.type==="personal_adv");
        if(expenseRecs.length===0)return null;
        // 支出先別（type別）集計
        const bySource={cash_out:{label:"現金出金",items:{},total:0},card_pay:{label:"カード支払い",items:{},total:0},personal_adv:{label:"個人立替",items:{},total:0}};
        expenseRecs.forEach(r=>{
          const src=bySource[r.type];if(!src)return;
          const cat=r.category||"未分類";
          if(!src.items[cat])src.items[cat]={amount:0,count:0};
          src.items[cat].amount+=r.amount;src.items[cat].count++;src.total+=r.amount;
        });
        // 科目横断集計
        const allCats={};
        expenseRecs.forEach(r=>{
          const cat=r.category||"未分類";
          if(!allCats[cat])allCats[cat]={amount:0,count:0,sources:{}};
          allCats[cat].amount+=r.amount;allCats[cat].count++;
          const sl=bySource[r.type]?bySource[r.type].label:r.type;
          if(!allCats[cat].sources[sl])allCats[cat].sources[sl]=0;
          allCats[cat].sources[sl]+=r.amount;
        });
        const catEntries=Object.entries(allCats).sort((a,b)=>b[1].amount-a[1].amount);
        const grandTotal=expenseRecs.reduce((s,r)=>s+r.amount,0);
        return <div style={{marginTop:20}}>
          <div style={{fontSize:13,fontWeight:800,marginBottom:10,color:"#991b1b",borderBottom:"2px solid #dc2626",paddingBottom:4}}>💸 支出内容の総括（{selectedYear}年）</div>
          {/* 支出源別サマリー */}
          <div style={{display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:8,marginBottom:12}}>
            {Object.entries(bySource).filter(([,v])=>v.total>0).map(([k,v])=><div key={k} style={{padding:"8px 10px",borderRadius:8,background:"#fef2f2",border:"1px solid #fecaca"}}>
              <div style={{fontSize:9,color:"#991b1b",fontWeight:600}}>{v.label}</div>
              <div style={{fontSize:16,fontWeight:800,color:"#dc2626"}}>¥{v.total.toLocaleString()}</div>
            </div>)}
            <div style={{padding:"8px 10px",borderRadius:8,background:"#1e293b",border:"1px solid #334155"}}>
              <div style={{fontSize:9,color:"#94a3b8",fontWeight:600}}>支出総額</div>
              <div style={{fontSize:16,fontWeight:800,color:"#fff"}}>¥{grandTotal.toLocaleString()}</div>
            </div>
          </div>
          {/* 科目別内訳テーブル */}
          <table style={{width:"100%",fontSize:10,borderCollapse:"collapse"}}>
            <thead><tr style={{background:"#fef2f2"}}>{["科目","現金出金","カード","個人立替","合計","件数","構成比"].map((h,i)=><th key={i} style={{padding:"6px 8px",textAlign:i===0?"left":"right",fontWeight:700,fontSize:9,borderBottom:"2px solid #fecaca",color:"#991b1b"}}>{h}</th>)}</tr></thead>
            <tbody>
              {catEntries.map(([cat,d])=><tr key={cat} style={{borderBottom:"1px solid #f1f5f9"}}>
                <td style={{padding:"6px 8px",fontWeight:700}}>{cat}</td>
                <td style={{padding:"6px 8px",textAlign:"right",color:"#dc2626"}}>¥{(d.sources["現金出金"]||0).toLocaleString()}</td>
                <td style={{padding:"6px 8px",textAlign:"right",color:"#2563eb"}}>¥{(d.sources["カード支払い"]||0).toLocaleString()}</td>
                <td style={{padding:"6px 8px",textAlign:"right",color:"#d97706"}}>¥{(d.sources["個人立替"]||0).toLocaleString()}</td>
                <td style={{padding:"6px 8px",textAlign:"right",fontWeight:800,color:"#1e293b"}}>¥{d.amount.toLocaleString()}</td>
                <td style={{padding:"6px 8px",textAlign:"right",color:"#64748b"}}>{d.count}件</td>
                <td style={{padding:"6px 8px",textAlign:"right",fontWeight:600,color:"#475569"}}>{grandTotal>0?Math.round(d.amount/grandTotal*1000)/10:0}%</td>
              </tr>)}
              <tr style={{background:"#1e293b",fontWeight:800,color:"#fff"}}>
                <td style={{padding:"6px 8px"}}>合計</td>
                <td style={{padding:"6px 8px",textAlign:"right"}}>{Object.values(bySource).filter(v=>v.total>0).length>0?("¥"+(bySource.cash_out.total).toLocaleString()):"-"}</td>
                <td style={{padding:"6px 8px",textAlign:"right"}}>¥{bySource.card_pay.total.toLocaleString()}</td>
                <td style={{padding:"6px 8px",textAlign:"right"}}>¥{bySource.personal_adv.total.toLocaleString()}</td>
                <td style={{padding:"6px 8px",textAlign:"right"}}>¥{grandTotal.toLocaleString()}</td>
                <td style={{padding:"6px 8px",textAlign:"right"}}>{expenseRecs.length}件</td>
                <td style={{padding:"6px 8px",textAlign:"right"}}>100%</td>
              </tr>
            </tbody>
          </table>
        </div>;
      })()}
      {/* 収入科目別集計 */}
      {(()=>{
        const incomeRecs=records.filter(r=>r.date&&r.date.startsWith(selectedYear)&&(r.type==="cash_in"||r.type==="extra_sales"));
        if(incomeRecs.length===0)return null;
        const cats={};
        incomeRecs.forEach(r=>{
          const prefix=r.type==="cash_in"?"[現金] ":"[予約外] ";
          const k=prefix+r.category;
          if(!cats[k])cats[k]={amount:0,count:0,type:r.type};cats[k].amount+=r.amount;cats[k].count++;
        });
        const entries=Object.entries(cats).sort((a,b)=>b[1].amount-a[1].amount);
        return <div style={{marginTop:16}}>
          <div style={{fontSize:12,fontWeight:700,marginBottom:8,color:"#166534"}}>💰 収入 科目別集計</div>
          <table style={{width:"100%",fontSize:10,borderCollapse:"collapse"}}>
            <thead><tr style={{background:"#f0fdf4"}}>{["科目","金額","件数"].map((h,i)=><th key={i} style={{padding:"6px 8px",textAlign:i===0?"left":"right",fontWeight:600,borderBottom:"1px solid #bbf7d0",color:"#166534"}}>{h}</th>)}</tr></thead>
            <tbody>{entries.map(([k,d])=><tr key={k} style={{borderBottom:"1px solid #f1f5f9"}}>
              <td style={{padding:"6px 8px",fontWeight:600}}>{k}</td>
              <td style={{padding:"6px 8px",textAlign:"right",color:"#059669",fontWeight:600}}>¥{d.amount.toLocaleString()}</td>
              <td style={{padding:"6px 8px",textAlign:"right",color:"#64748b"}}>{d.count}件</td>
            </tr>)}</tbody>
          </table>
        </div>;
      })()}
      {/* その他売上（予約外）詳細 */}
      {(()=>{
        const extra=records.filter(r=>r.date&&r.date.startsWith(selectedYear)&&r.type==="extra_sales"&&r.payMethod!=="現金");
        if(extra.length===0)return null;
        return <div style={{marginTop:16}}>
          <div style={{fontSize:12,fontWeight:700,marginBottom:8,color:"#5b21b6"}}>予約外売上 詳細</div>
          <table style={{width:"100%",fontSize:10,borderCollapse:"collapse"}}>
            <thead><tr style={{background:"#f5f3ff"}}>{["日付","科目","摘要","予約番号","決済","金額","支払"].map((h,i)=><th key={i} style={{padding:"4px 6px",textAlign:i===5?"right":"left",fontWeight:600,fontSize:9,borderBottom:"1px solid #ddd6fe"}}>{h}</th>)}</tr></thead>
            <tbody>{extra.sort((a,b)=>b.date.localeCompare(a.date)).map((r,i)=><tr key={r.id} style={{borderBottom:"1px solid #f1f5f9",background:i%2===0?"#fff":"#faf5ff"}}>
              <td style={{padding:"4px 6px"}}>{r.date}</td>
              <td style={{padding:"4px 6px",fontWeight:600}}>{r.category}</td>
              <td style={{padding:"4px 6px",color:"#64748b"}}>{r.description||"-"}</td>
              <td style={{padding:"4px 6px",fontSize:9}}>{r.resvNo||"-"}</td>
              <td style={{padding:"4px 6px",fontSize:9}}>{r.payMethod}</td>
              <td style={{padding:"4px 6px",textAlign:"right",fontWeight:700,color:"#7c3aed"}}>¥{(r.amount||0).toLocaleString()}</td>
              <td style={{padding:"4px 6px"}}><span style={{padding:"1px 6px",borderRadius:4,fontSize:9,fontWeight:600,background:r.paid?"#f0fdf4":"#fef2f2",color:r.paid?"#059669":"#dc2626"}}>{r.paid?"済":"未"}</span></td>
            </tr>)}</tbody>
          </table>
        </div>;
      })()}
      {/* 立替金 未回収一覧 */}
      {(()=>{
        const unpaid=records.filter(r=>r.date&&r.date.startsWith(selectedYear)&&r.type==="advance"&&!r.paid);
        if(unpaid.length===0)return null;
        return <div style={{marginTop:16}}>
          <div style={{fontSize:12,fontWeight:700,marginBottom:8,color:"#92400e"}}>立替金 未回収一覧</div>
          <table style={{width:"100%",fontSize:10,borderCollapse:"collapse"}}>
            <thead><tr style={{background:"#fefce8"}}>{["日付","科目","摘要","金額","担当","発行URL"].map((h,i)=><th key={i} style={{padding:"4px 6px",textAlign:i===3?"right":"left",fontWeight:600,fontSize:9,borderBottom:"1px solid #fde68a"}}>{h}</th>)}</tr></thead>
            <tbody>{unpaid.sort((a,b)=>b.date.localeCompare(a.date)).map((r,i)=><tr key={r.id} style={{borderBottom:"1px solid #f1f5f9",background:i%2===0?"#fff":"#fffbeb"}}>
              <td style={{padding:"4px 6px"}}>{r.date}</td>
              <td style={{padding:"4px 6px",fontWeight:600}}>{r.category}</td>
              <td style={{padding:"4px 6px",color:"#64748b"}}>{r.description||"-"}</td>
              <td style={{padding:"4px 6px",textAlign:"right",fontWeight:700,color:"#d97706"}}>¥{(r.amount||0).toLocaleString()}</td>
              <td style={{padding:"4px 6px",fontSize:9}}>{r.staffName||"-"}</td>
              <td style={{padding:"4px 6px",fontSize:9}}>{r.url?<a href={r.url} target="_blank" rel="noopener noreferrer" style={{color:"#2563eb"}}>URL</a>:"-"}</td>
            </tr>)}</tbody>
          </table>
        </div>;
      })()}
    </div>}

    {/* (明細テーブルは集計バーの直下に移動済み) */}
  </div>;
}

/* ==========================================
   過去タスク
   ========================================== */
function PastTasksTable({today}){
  const[tasks,setTasks]=useState([]);const[loading,setLoading]=useState(false);
  const[search,setSearch]=useState("");const[typeFilter,setTypeFilter]=useState("all");
  // デフォルト: 過去7日
  const[fromDate,setFromDate]=useState(()=>{const d=new Date();d.setDate(d.getDate()-7);return toLD(d);});
  const[toDate,setToDate]=useState(()=>{const d=new Date();d.setDate(d.getDate()-1);return toLD(d);});
  const loadPast=async()=>{setLoading(true);try{const t=await DB.fetchTasksRange(fromDate,toDate);setTasks(t);}catch(e){console.error(e);}setLoading(false);};
  useEffect(()=>{loadPast();},[fromDate,toDate]);
  const types=[...new Set(tasks.map(t=>t.type))].sort();
  const filtered=useMemo(()=>tasks.filter(t=>{
    if(typeFilter!=="all"&&t.type!==typeFilter)return false;
    if(search&&!t.name?.includes(search)&&!t.reservationId?.includes(search)&&!t.place?.includes(search)&&!t.memo?.includes(search))return false;
    return true;
  }),[tasks,search,typeFilter]);
  // 日付ごとにグループ化
  const grouped=useMemo(()=>{const m={};filtered.forEach(t=>{const d=t._date||"不明";if(!m[d])m[d]=[];m[d].push(t);});return Object.entries(m).sort((a,b)=>b[0].localeCompare(a[0]));},[filtered]);
  const WK=["日","月","火","水","木","金","土"];
  const fmtDate=(d)=>{const dt=new Date(d+"T00:00:00");return `${dt.getMonth()+1}/${dt.getDate()}(${WK[dt.getDay()]})`;};
  return <div className="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div className="p-3 border-b border-gray-200 flex items-center gap-2 flex-wrap">
      <span style={{fontSize:11,fontWeight:600,color:"#374151"}}>期間:</span>
      <input type="date" value={fromDate} onChange={e=>setFromDate(e.target.value)} style={{fontSize:11,padding:"2px 6px",borderRadius:6,border:"1px solid #d1d5db"}}/>
      <span style={{fontSize:11,color:"#9ca3af"}}>〜</span>
      <input type="date" value={toDate} onChange={e=>setToDate(e.target.value)} style={{fontSize:11,padding:"2px 6px",borderRadius:6,border:"1px solid #d1d5db"}}/>
      <input value={search} onChange={e=>setSearch(e.target.value)} placeholder="検索（名前/予約番号）" className="input-s" style={{width:140}}/>
      <div className="flex gap-1"><button onClick={()=>setTypeFilter("all")} className={`px-2 py-1 rounded text-xs font-semibold ${typeFilter==="all"?"bg-gray-800 text-white":"bg-gray-100 text-gray-600"}`}>All</button>{types.map(tp=><button key={tp} onClick={()=>setTypeFilter(tp)} className="px-2 py-1 rounded text-xs font-semibold" style={{background:typeFilter===tp?(TASK_META[tp]||{}).c||"#6b7280":"#f3f4f6",color:typeFilter===tp?"#fff":(TASK_META[tp]||{}).c||"#6b7280"}}>{tp}</button>)}</div>
      <span className="ml-auto text-xs text-gray-500">{loading?"読込中...":filtered.length+"件"}</span>
    </div>
    <div style={{overflowX:"auto",maxHeight:"70vh"}}>
      {grouped.map(([date,items])=><div key={date}>
        <div style={{background:"#f8fafc",padding:"4px 10px",borderBottom:"1px solid #e5e7eb",fontWeight:700,fontSize:12,color:"#374151",position:"sticky",top:0,zIndex:1}}>{fmtDate(date)} <span style={{fontWeight:400,color:"#9ca3af",fontSize:10}}>— {items.length}件</span></div>
        <table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}><thead className="bg-gray-50"><tr>{["種別","時間","予約者","車種","ナンバー","担当","場所","メモ","完了"].map(h=><th key={h} className="px-2 py-1 text-left font-semibold text-gray-600 border-b border-gray-200" style={{fontSize:10}}>{h}</th>)}</tr></thead><tbody>
          {items.map((t,i)=><tr key={t._id||i} className="border-b border-gray-100 hover:bg-blue-50" style={{opacity:t.done?0.5:1}}>
            <td className="px-2 py-1"><span style={{background:(TASK_META[t.type]||{}).bg||"#f3f4f6",color:(TASK_META[t.type]||{}).c||"#374151",padding:"1px 5px",borderRadius:4,fontSize:10,fontWeight:600}}>{t.type}</span></td>
            <td className="px-2 py-1" style={{fontSize:10}}>{t.time||"-"}</td>
            <td className="px-2 py-1 font-medium">{t.name||"-"}</td>
            <td className="px-2 py-1">{t.vehicle||"-"}</td>
            <td className="px-2 py-1 font-mono" style={{fontSize:9}}>{t.plateNo||"-"}</td>
            <td className="px-2 py-1">{t.assignee||"-"}</td>
            <td className="px-2 py-1" style={{fontSize:9,maxWidth:120,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{t.place||t.colPlace||"-"}</td>
            <td className="px-2 py-1" style={{fontSize:9,color:"#6b7280",maxWidth:100,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{t.memo||"-"}</td>
            <td className="px-2 py-1 text-center">{t.done?"✅":"—"}</td>
          </tr>)}
        </tbody></table>
      </div>)}
      {!loading&&grouped.length===0&&<div style={{padding:24,textAlign:"center",color:"#9ca3af",fontSize:13}}>該当する過去タスクがありません</div>}
    </div>
  </div>;
}

/* ==========================================
   統合データ
   ========================================== */
function AnalyticsTab({data,sheetPlaces}){
  const[selYM,setSelYM]=useState(toLD(new Date()).substring(0,7));
  const months=useMemo(()=>{const s=new Set();data.forEach(r=>{if(r.lendDate)s.add(r.lendDate.substring(0,7));});return [...s].sort();},[data]);
  const years=useMemo(()=>{const s=new Set();data.forEach(r=>{if(r.lendDate)s.add(r.lendDate.substring(0,4));});return [...s].sort();},[data]);
  const ymLabel=(ym)=>{if(ym==="all")return"全期間";if(ym.length===4)return ym+"年";const[y,m]=ym.split("-");return y+"年"+parseInt(m)+"月";};
  const cardS={background:"#fff",borderRadius:12,padding:16,boxShadow:"0 1px 4px rgba(0,0,0,.06)",border:"1px solid #e2e8f0",marginBottom:12};
  const md=useMemo(()=>data.filter(r=>{if(!r.lendDate)return false;if(selYM==="all")return true;if(selYM.length===4)return r.lendDate.substring(0,4)===selYM;return r.lendDate.substring(0,7)===selYM;}),[data,selYM]);

  // ① 利用者エリアランキング
  const prefData=useMemo(()=>{
    const prefCount={};let total=0;
    md.forEach(r=>{if(r.prefecture){prefCount[r.prefecture]=(prefCount[r.prefecture]||0)+1;total++;}});
    const sorted=Object.entries(prefCount).sort((a,b)=>b[1]-a[1]);
    const regionMap={"北海道":["北海道"],"東北":["青森県","岩手県","宮城県","秋田県","山形県","福島県"],"関東":["茨城県","栃木県","群馬県","埼玉県","千葉県","東京都","神奈川県"],"中部":["新潟県","富山県","石川県","福井県","山梨県","長野県","岐阜県","静岡県","愛知県"],"関西":["三重県","滋賀県","京都府","大阪府","兵庫県","奈良県","和歌山県"],"中国":["鳥取県","島根県","岡山県","広島県","山口県"],"四国":["徳島県","香川県","愛媛県","高知県"],"九州・沖縄":["福岡県","佐賀県","長崎県","熊本県","大分県","宮崎県","鹿児島県","沖縄県"],"海外":["海外"]};
    const regionCount={};Object.entries(regionMap).forEach(([reg,prefs])=>{let cnt=0;prefs.forEach(p=>{cnt+=(prefCount[p]||0);});if(cnt)regionCount[reg]=cnt;});
    const regSorted=Object.entries(regionCount).sort((a,b)=>b[1]-a[1]);
    return{sorted,total,regSorted};
  },[md]);

  // ② 場所分布ランキング
  const placeData=useMemo(()=>{
    const hotelKw=["ホテル","hotel","Hotel","HOTEL","inn","旅館","リゾート","resort","ヒルトン","マリオット","APA","アパ","東急","プリンス","ルートイン","ドーミー","コンフォート","ベッセル","クロスホテル","メルキュール","三井ガーデン","グランド","京王","ラ・ジェント","ジャスマック","マイステイズ","プレミア","モントレ","ロイトン","京阪","WBF","ネスト","テンザ","フェアフィールド","ランプライト"];
    const homeKw=["自宅","マンション","アパート","自宅前","ご自宅","戸建","一軒家"];
    const staKw=["駅","ステーション","地下鉄"];
    const commKw=["空港","新千歳","丘珠","ターミナル","フェリー","港","イオン","ヨドバシ","ビック","ドンキ","ニトリ","コストコ","AEON","レンタカー","営業所","店舗","オフィス","事務所","会社"];
    function classify(place){if(!place)return"その他";const p=place.toUpperCase();if(hotelKw.some(k=>p.includes(k.toUpperCase())))return"ホテル";if(homeKw.some(k=>p.includes(k.toUpperCase())))return"自宅";if(staKw.some(k=>p.includes(k.toUpperCase())))return"駅";if(commKw.some(k=>p.includes(k.toUpperCase())))return"商業施設";return"その他";}
    const catCount={};const placeDet={};let total=0;
    md.forEach(r=>{const sp=(sheetPlaces||{})[r.id]||{};const dp=sp.delPlace||r.delPlace;const cp=sp.colPlace||r.colPlace;[dp,cp].forEach(pl=>{if(!pl)return;const cat=classify(pl);catCount[cat]=(catCount[cat]||0)+1;total++;if(!placeDet[cat])placeDet[cat]={};placeDet[cat][pl]=(placeDet[cat][pl]||0)+1;});});
    return{catCount,placeDet,total};
  },[md]);

  const cats=["ホテル","自宅","駅","商業施設","その他"];
  const catC={"ホテル":"#2563eb","自宅":"#059669","駅":"#7c3aed","商業施設":"#d97706","その他":"#94a3b8"};
  const catIco={"ホテル":"🏨","自宅":"🏠","駅":"🚉","商業施設":"🏢","その他":"📍"};
  const regC={"北海道":"#2563eb","東北":"#7c3aed","関東":"#dc2626","中部":"#059669","関西":"#d97706","中国":"#0891b2","四国":"#84cc16","九州・沖縄":"#e11d48","海外":"#6b7280"};

  return <div style={{maxWidth:700,margin:"0 auto"}}>
    <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:16,flexWrap:"wrap"}}>
      <span style={{fontSize:14,fontWeight:800,color:"#1e293b"}}>🔬 解析</span>
      <div style={{display:"flex",gap:4,flexWrap:"wrap"}}>
        <button onClick={()=>setSelYM("all")} style={{padding:"4px 10px",borderRadius:8,border:selYM==="all"?"2px solid #dc2626":"1px solid #e2e8f0",background:selYM==="all"?"#dc2626":"#fff",color:selYM==="all"?"#fff":"#475569",fontSize:11,fontWeight:700,cursor:"pointer"}}>全期間</button>
        {years.map(y=><button key={y} onClick={()=>setSelYM(y)} style={{padding:"4px 10px",borderRadius:8,border:selYM===y?"2px solid #059669":"1px solid #e2e8f0",background:selYM===y?"#059669":"#fff",color:selYM===y?"#fff":"#475569",fontSize:11,fontWeight:700,cursor:"pointer"}}>{y}年</button>)}
        {months.map(ym=><button key={ym} onClick={()=>setSelYM(ym)} style={{padding:"4px 10px",borderRadius:8,border:ym===selYM?"2px solid #7c3aed":"1px solid #e2e8f0",background:ym===selYM?"#7c3aed":"#fff",color:ym===selYM?"#fff":"#475569",fontSize:11,fontWeight:600,cursor:"pointer"}}>{ymLabel(ym)}</button>)}
      </div>
      <span style={{fontSize:11,color:"#94a3b8"}}>{md.length}件</span>
    </div>

    {/* 利用者エリアランキング */}
    <div style={cardS}>
      <div style={{fontSize:13,fontWeight:800,color:"#1e293b",marginBottom:12}}>🗾 利用者エリアランキング<span style={{fontSize:10,fontWeight:400,color:"#94a3b8",marginLeft:8}}>{prefData.total}件登録</span></div>
      {prefData.total===0?<div style={{fontSize:11,color:"#94a3b8",textAlign:"center",padding:20}}>都道府県データなし<br/><span style={{fontSize:10}}>免許証アップロード時 or データ編集で設定</span></div>:
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:16}}>
        <div>
          <div style={{fontSize:10,fontWeight:700,color:"#475569",marginBottom:6}}>都道府県別</div>
          {prefData.sorted.slice(0,15).map(([pref,cnt],i)=>{const pct=Math.round(cnt/prefData.total*100);const maxC=prefData.sorted[0][1];return <div key={pref} style={{display:"flex",alignItems:"center",gap:4,marginBottom:3}}>
            <span style={{fontSize:9,fontWeight:700,color:i<3?"#f59e0b":"#94a3b8",minWidth:16}}>{i+1}.</span>
            <span style={{fontSize:10,fontWeight:600,color:"#1e293b",minWidth:50}}>{pref}</span>
            <div style={{flex:1,height:8,background:"#f1f5f9",borderRadius:3,overflow:"hidden"}}><div style={{height:"100%",width:Math.round(cnt/maxC*100)+"%",background:i<3?"#f59e0b":"#3b82f6",borderRadius:3}}/></div>
            <span style={{fontSize:9,fontWeight:700,color:"#1e293b",minWidth:45,textAlign:"right"}}>{cnt}件({pct}%)</span>
          </div>;})}
        </div>
        <div>
          <div style={{fontSize:10,fontWeight:700,color:"#475569",marginBottom:6}}>地方別構成比</div>
          {prefData.regSorted.map(([reg,cnt])=>{const pct=Math.round(cnt/prefData.total*100);return <div key={reg} style={{marginBottom:6}}>
            <div style={{display:"flex",justifyContent:"space-between",fontSize:10,marginBottom:2}}>
              <span style={{fontWeight:700,color:regC[reg]||"#475569"}}>{reg}</span>
              <span style={{fontWeight:700,color:"#1e293b"}}>{cnt}件 ({pct}%)</span>
            </div>
            <div style={{height:8,background:"#f1f5f9",borderRadius:3,overflow:"hidden"}}><div style={{height:"100%",width:pct+"%",background:regC[reg]||"#94a3b8",borderRadius:3}}/></div>
          </div>;})}
        </div>
      </div>}
    </div>

    {/* 場所分布ランキング */}
    <div style={cardS}>
      <div style={{fontSize:13,fontWeight:800,color:"#1e293b",marginBottom:12}}>📍 場所分布ランキング<span style={{fontSize:10,fontWeight:400,color:"#94a3b8",marginLeft:8}}>DEL+COL計 {placeData.total}件</span></div>
      <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(120px,1fr))",gap:8,marginBottom:12}}>
        {cats.map(c=>{const cnt=placeData.catCount[c]||0;const pct=placeData.total?Math.round(cnt/placeData.total*100):0;return <div key={c} style={{textAlign:"center",padding:10,borderRadius:10,background:catC[c]+"12",border:"1px solid "+catC[c]+"30"}}>
          <div style={{fontSize:20}}>{catIco[c]}</div>
          <div style={{fontSize:11,fontWeight:700,color:catC[c]}}>{c}</div>
          <div style={{fontSize:18,fontWeight:900,color:"#1e293b"}}>{cnt}<span style={{fontSize:10,fontWeight:400}}>件</span></div>
          <div style={{fontSize:10,fontWeight:600,color:catC[c]}}>{pct}%</div>
        </div>;})}
      </div>
      {cats.filter(c=>placeData.catCount[c]).map(c=>{const details=Object.entries(placeData.placeDet[c]||{}).sort((a,b)=>b[1]-a[1]).slice(0,5);return <div key={c} style={{marginBottom:8}}>
        <div style={{fontSize:10,fontWeight:700,color:catC[c],marginBottom:3}}>{catIco[c]} {c} TOP5</div>
        {details.map(([pl,cnt])=><div key={pl} style={{display:"flex",justifyContent:"space-between",fontSize:10,padding:"2px 0",borderBottom:"1px solid #f8fafc"}}>
          <span style={{color:"#475569",overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap",maxWidth:"70%"}}>{pl}</span>
          <span style={{fontWeight:700,color:"#1e293b"}}>{cnt}件</span>
        </div>)}
      </div>;})}
    </div>

    {/* ③ 時間帯別タスク分析 */}
    {(()=>{
      const hours=[];for(let h=7;h<=21;h++)hours.push(h);
      const delByH={},colByH={};hours.forEach(h=>{delByH[h]=0;colByH[h]=0;});
      let delTotal=0,colTotal=0;
      md.forEach(r=>{
        const dt=r.delTime||r.lendTime;const ct=r.colTime||r.returnTime;
        if(dt){const hh=parseInt(dt.split(":")[0]);if(!isNaN(hh)&&hh>=7&&hh<=21){delByH[hh]++;delTotal++;}}
        if(ct){const hh=parseInt(ct.split(":")[0]);if(!isNaN(hh)&&hh>=7&&hh<=21){colByH[hh]++;colTotal++;}}
      });
      const maxDel=Math.max(...Object.values(delByH),1);
      const maxCol=Math.max(...Object.values(colByH),1);
      const maxAll=Math.max(maxDel,maxCol,1);
      const peakDel=hours.reduce((a,b)=>delByH[a]>=delByH[b]?a:b,7);
      const peakCol=hours.reduce((a,b)=>colByH[a]>=colByH[b]?a:b,7);
      return <div style={cardS}>
        <div style={{fontSize:13,fontWeight:800,color:"#1e293b",marginBottom:4}}>⏰ 時間帯別タスク分析<span style={{fontSize:10,fontWeight:400,color:"#94a3b8",marginLeft:8}}>DEL {delTotal}件 / COL {colTotal}件</span></div>
        <div style={{fontSize:10,color:"#64748b",marginBottom:12}}>
          ピーク ▶ <span style={{fontWeight:700,color:"#dc2626"}}>DEL {peakDel}:00</span>({delByH[peakDel]}件) / <span style={{fontWeight:700,color:"#2563eb"}}>COL {peakCol}:00</span>({colByH[peakCol]}件)
        </div>
        <div style={{display:"flex",gap:2}}>
          {hours.map(h=>{
            const dCnt=delByH[h],cCnt=colByH[h];
            const dPct=Math.round(dCnt/maxAll*100);
            const cPct=Math.round(cCnt/maxAll*100);
            const isDPeak=h===peakDel&&dCnt>0;
            const isCPeak=h===peakCol&&cCnt>0;
            return <div key={h} style={{flex:1,textAlign:"center",minWidth:0}}>
              <div style={{height:80,display:"flex",flexDirection:"column",justifyContent:"flex-end",gap:1}}>
                <div style={{height:dPct*0.7+"%",background:isDPeak?"#dc2626":"#fca5a5",borderRadius:"3px 3px 0 0",minHeight:dCnt?3:0,transition:"height .3s"}}/>
                <div style={{height:cPct*0.7+"%",background:isCPeak?"#2563eb":"#93c5fd",borderRadius:"0 0 3px 3px",minHeight:cCnt?3:0,transition:"height .3s"}}/>
              </div>
              <div style={{fontSize:8,color:"#94a3b8",marginTop:2}}>{h}</div>
              {(dCnt>0||cCnt>0)&&<div style={{fontSize:7,color:"#64748b"}}>{dCnt}/{cCnt}</div>}
            </div>;
          })}
        </div>
        <div style={{display:"flex",gap:12,justifyContent:"center",marginTop:8}}>
          <span style={{fontSize:9,color:"#dc2626"}}>■ DEL(配達)</span>
          <span style={{fontSize:9,color:"#2563eb"}}>■ COL(回収)</span>
        </div>
        {/* 構成比テーブル */}
        <div style={{marginTop:12,display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
          <div>
            <div style={{fontSize:10,fontWeight:700,color:"#dc2626",marginBottom:4}}>🚗 DEL構成比</div>
            {hours.filter(h=>delByH[h]>0).sort((a,b)=>delByH[b]-delByH[a]).map(h=>{const pct=delTotal?Math.round(delByH[h]/delTotal*100):0;return <div key={h} style={{display:"flex",alignItems:"center",gap:4,marginBottom:2}}>
              <span style={{fontSize:9,minWidth:28,color:"#475569"}}>{h}:00</span>
              <div style={{flex:1,height:6,background:"#fef2f2",borderRadius:3,overflow:"hidden"}}><div style={{height:"100%",width:pct+"%",background:h===peakDel?"#dc2626":"#fca5a5",borderRadius:3}}/></div>
              <span style={{fontSize:8,fontWeight:700,color:"#1e293b",minWidth:36,textAlign:"right"}}>{delByH[h]}件({pct}%)</span>
            </div>;})}
          </div>
          <div>
            <div style={{fontSize:10,fontWeight:700,color:"#2563eb",marginBottom:4}}>📦 COL構成比</div>
            {hours.filter(h=>colByH[h]>0).sort((a,b)=>colByH[b]-colByH[a]).map(h=>{const pct=colTotal?Math.round(colByH[h]/colTotal*100):0;return <div key={h} style={{display:"flex",alignItems:"center",gap:4,marginBottom:2}}>
              <span style={{fontSize:9,minWidth:28,color:"#475569"}}>{h}:00</span>
              <div style={{flex:1,height:6,background:"#eff6ff",borderRadius:3,overflow:"hidden"}}><div style={{height:"100%",width:pct+"%",background:h===peakCol?"#2563eb":"#93c5fd",borderRadius:3}}/></div>
              <span style={{fontSize:8,fontWeight:700,color:"#1e293b",minWidth:36,textAlign:"right"}}>{colByH[h]}件({pct}%)</span>
            </div>;})}
          </div>
        </div>
      </div>;
    })()}
  </div>;
}

function DataTable({data,fleet,vehicles,sheetPlaces,onUpdatePlaces,jalanPay,onUpdateReservation,onCancelReservation,onRestoreReservation}){
  const today=toLD(new Date());
  const[s,setS]=useState("");const[f,setF]=useState("all");const[plLoading,setPlLoading]=useState(false);
  const[licStatus,setLicStatus]=useState({});
  const[statusF,setStatusF]=useState("active"); // "active", "cancelled", "all"
  const[periodMode,setPeriodMode]=useState("future"); // "future","month","year","all"
  const[selMonth,setSelMonth]=useState(()=>{const d=new Date();return d.getFullYear()+"-"+String(d.getMonth()+1).padStart(2,"0");});
  const[selYear,setSelYear]=useState(()=>String(new Date().getFullYear()));
  const[sortKey,setSortKey]=useState("lendDate");const[sortAsc,setSortAsc]=useState(true);
  const handleSort=(k)=>{if(sortKey===k)setSortAsc(!sortAsc);else{setSortKey(k);setSortAsc(true);}};
  const sortIcon=(k)=>sortKey===k?(sortAsc?"▲":"▼"):"";
  const[editRow,setEditRow]=useState(null);const[editForm,setEditForm]=useState({});const[saving,setSaving]=useState(false);
  const{months,years}=useMemo(()=>{const ms=new Set();const ys=new Set();data.forEach(r=>{if(r.lendDate){ms.add(r.lendDate.slice(0,7));ys.add(r.lendDate.slice(0,4));}});return{months:[...ms].sort(),years:[...ys].sort()};},[data]);
  const cxlCount=useMemo(()=>data.filter(r=>r.status==="cancelled").length,[data]);
  const list=useMemo(()=>{
    let filtered=data.filter(r=>{
      if(statusF==="active"&&r.status==="cancelled")return false;
      if(statusF==="cancelled"&&r.status!=="cancelled")return false;
      if(f!=="all"&&r.ota!==f)return false;
      if(s&&!r.name.includes(s)&&!r.id.includes(s))return false;
      if(periodMode==="future")return r.lendDate>=today||r.returnDate>=today;
      if(periodMode==="month")return r.lendDate&&r.lendDate.startsWith(selMonth);
      if(periodMode==="year")return r.lendDate&&r.lendDate.startsWith(selYear);
      return true;
    });
    filtered.sort((a,b)=>{const va=a[sortKey]||"";const vb=b[sortKey]||"";if(va<vb)return sortAsc?-1:1;if(va>vb)return sortAsc?1:-1;return 0;});
    return filtered;
  },[data,f,s,statusF,periodMode,selMonth,selYear,today,sortKey,sortAsc]);
  const openEdit=(row)=>{setEditRow(row);setEditForm({name:row.name||"",lendDate:row.lendDate||"",lendTime:row.lendTime||"",returnDate:row.returnDate||"",returnTime:row.returnTime||"",vehicle:row.vehicle||"",insurance:row.insurance||"",people:row.people||0,price:row.price||0,tel:row.tel||"",mail:row.mail||"",flight:row.flight||"",delPlace:row.delPlace||"",colPlace:row.colPlace||"",delTime:row.delTime||"",colTime:row.colTime||"",visitType:row.visitType||"",returnType:row.returnType||"",optB:row.optB||0,optC:row.optC||0,optJ:row.optJ||0,prefecture:row.prefecture||""});};
  const saveEdit=async()=>{if(!editRow||!onUpdateReservation)return;setSaving(true);const ok=await onUpdateReservation(editRow.id,editForm);setSaving(false);if(ok){setEditRow(null);}};
  const doFetchPlaces=async()=>{
    const resIds=list.map(r=>r.id);
    if(!resIds.length){alert("表示中の予約データがありません");return;}
    setPlLoading(true);
    try{
      const placeMap=await fetchPlaceData(resIds);
      const matched=Object.keys(placeMap).length;
      if(!matched){setPlLoading(false);alert("該当する予約番号がスプレッドシートに見つかりませんでした");return;}
      onUpdatePlaces({...sheetPlaces,...placeMap});
      alert(`${matched}件の場所情報を取得しました`);
    }catch(e){alert("場所データ取得エラー: "+e.message);}
    setPlLoading(false);
  };
  const getPlace=(resId)=>sheetPlaces[resId]||{};
  const getVehicle=(resId)=>{const code=fleet&&fleet[resId];if(!code)return null;return(vehicles||[]).find(v=>v.code===code);};
  // 免許証ステータス一括チェック（並列バッチ）
  useEffect(()=>{
    const ids=[...new Set(data.map(r=>r.id))];
    if(!ids.length)return;
    let cancelled=false;
    const check=async()=>{
      const SUPABASE_URL_L="https://ckrxttbnawkclshczsia.supabase.co";
      const SUPABASE_KEY_L="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImNrcnh0dGJuYXdrY2xzaGN6c2lhIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzE4Nzg1NTAsImV4cCI6MjA4NzQ1NDU1MH0.kDC_UDVWvcrS97wzqQ3NXP79ewjgYwF4vSFdV7y06S8";
      const BATCH=10;
      const res={};
      for(let i=0;i<ids.length;i+=BATCH){
        if(cancelled)return;
        const batch=ids.slice(i,i+BATCH);
        const results=await Promise.all(batch.map(rid=>
          fetch(SUPABASE_URL_L+"/storage/v1/object/list/licenses",{method:"POST",headers:{"apikey":SUPABASE_KEY_L,"Authorization":"Bearer "+SUPABASE_KEY_L,"Content-Type":"application/json"},body:JSON.stringify({prefix:rid,limit:1})})
          .then(r=>r.ok?r.json():null).then(files=>({rid,has:files&&files.length>0})).catch(()=>({rid,has:false}))
        ));
        results.forEach(({rid,has})=>{res[rid]=has;});
      }
      if(!cancelled)setLicStatus(res);
    };
    check();
    return()=>{cancelled=true;};
  },[data.length]);
  return <div style={{background:"#fff",borderRadius:12,border:"1px solid #e2e8f0",overflow:"hidden",boxShadow:"0 1px 3px rgba(0,0,0,.06)"}}>
    {/* ★ ヘッダー: 期間切替 + 検索 + OTAフィルタ + ステータスフィルタ */}
    <div style={{padding:"8px 10px",borderBottom:"1px solid #e2e8f0",display:"flex",flexDirection:"column",gap:6}}>
      <div style={{display:"flex",gap:3,alignItems:"center",flexWrap:"wrap"}}>
        {[{k:"future",l:"未来"},{k:"month",l:"月別"},{k:"year",l:"年別"},{k:"all",l:"全件"}].map(p=>
          <button key={p.k} onClick={()=>setPeriodMode(p.k)} style={{padding:"4px 10px",borderRadius:6,border:"none",fontSize:10,fontWeight:700,cursor:"pointer",background:periodMode===p.k?"#1e293b":"#f1f5f9",color:periodMode===p.k?"#fff":"#475569"}}>{p.l}</button>
        )}
        {periodMode==="month"&&<select value={selMonth} onChange={e=>setSelMonth(e.target.value)} style={{border:"1px solid #d1d5db",borderRadius:6,padding:"3px 6px",fontSize:10,fontWeight:600}}>
          {months.map(m=><option key={m} value={m}>{m}</option>)}
        </select>}
        {periodMode==="year"&&<select value={selYear} onChange={e=>setSelYear(e.target.value)} style={{border:"1px solid #d1d5db",borderRadius:6,padding:"3px 6px",fontSize:10,fontWeight:600}}>
          {years.map(y=><option key={y} value={y}>{y}</option>)}
        </select>}
        <span style={{marginLeft:"auto",fontSize:10,fontWeight:700,color:"#475569"}}>{list.length}件</span>
      </div>
      <div style={{display:"flex",gap:4,alignItems:"center",flexWrap:"wrap"}}>
        <input value={s} onChange={e=>setS(e.target.value)} placeholder="予約者名・予約番号" style={{border:"1px solid #d1d5db",borderRadius:6,padding:"4px 8px",fontSize:10,width:150}}/>
        <div style={{display:"flex",gap:2}}>
          <button onClick={()=>setF("all")} style={{padding:"3px 7px",borderRadius:4,border:"none",fontSize:9,fontWeight:700,cursor:"pointer",background:f==="all"?"#1e293b":"#f1f5f9",color:f==="all"?"#fff":"#64748b"}}>All</button>
          {Object.keys(OTA).map(k=><button key={k} onClick={()=>setF(k)} style={{padding:"3px 7px",borderRadius:4,border:"none",fontSize:9,fontWeight:700,cursor:"pointer",background:f===k?OTA[k].c:OTA[k].bg,color:f===k?"#fff":OTA[k].c}}>{k}</button>)}
        </div>
        <button onClick={doFetchPlaces} disabled={plLoading} style={{padding:"3px 8px",borderRadius:6,border:"none",fontSize:9,fontWeight:700,cursor:"pointer",background:plLoading?"#94a3b8":"#fbbf24",color:"#78350f"}}>{plLoading?"取得中...":"📍場所取得"}</button>
        <div style={{display:"flex",gap:2,marginLeft:4,borderLeft:"1px solid #e2e8f0",paddingLeft:4}}>
          {[{k:"active",l:"有効",bg:"#dcfce7",c:"#166534"},{k:"cancelled",l:"CXL"+(cxlCount>0?" ("+cxlCount+")":""),bg:"#fee2e2",c:"#991b1b"},{k:"all",l:"全件",bg:"#f1f5f9",c:"#475569"}].map(p=>
            <button key={p.k} onClick={()=>setStatusF(p.k)} style={{padding:"3px 7px",borderRadius:4,border:"none",fontSize:9,fontWeight:700,cursor:"pointer",background:statusF===p.k?p.c:p.bg,color:statusF===p.k?"#fff":p.c}}>{p.l}</button>
          )}
        </div>
      </div>
    </div>
    {/* ★ テーブル */}
    <div style={{overflowX:"auto",maxHeight:"75vh"}}><table style={{width:"100%",borderCollapse:"collapse",fontSize:10,whiteSpace:"nowrap"}}><thead><tr style={{background:"#f1f5f9"}}>
      {[{h:"状態",w:44},{h:"OTA",w:30,k:"ota"},{h:"予約者",w:100,k:"name"},{h:"貸出日",w:70,k:"lendDate"},{h:"DEL時",w:45},{h:"返却日",w:70,k:"returnDate"},{h:"COL時",w:45},{h:"クラス",w:48,k:"vehicle"},{h:"配車",w:60},{h:"No.",w:52},{h:"人数",w:30,k:"people"},{h:"B",w:22},{h:"C",w:22},{h:"J",w:22},{h:"補償",w:36,k:"insurance"},{h:"DEL場所",w:120},{h:"COL場所",w:120},{h:"料金",w:60,k:"price"},{h:"決済",w:44},{h:"🪪",w:28},{h:"予約番号",w:120,k:"id"}].map((col,ci)=>{
        const sticky=ci<=2;
        return <th key={ci} onClick={col.k?()=>handleSort(col.k):undefined} style={{position:sticky?"sticky":"static",left:ci===0?0:ci===1?44:ci===2?74:undefined,zIndex:sticky?3:1,background:sortKey===col.k?"#dbeafe":"#f1f5f9",padding:"4px 3px",textAlign:"center",fontWeight:600,fontSize:8,color:col.k?"#1d4ed8":"#475569",borderBottom:"2px solid #cbd5e1",borderRight:sticky&&ci===2?"2px solid #cbd5e1":"1px solid #e2e8f0",minWidth:col.w,maxWidth:col.w,cursor:col.k?"pointer":"default",userSelect:"none"}}>{col.h}{col.k?<span style={{fontSize:7,marginLeft:1}}>{sortIcon(col.k)}</span>:""}</th>;
      })}
    </tr></thead><tbody>
      {list.map((t,i)=>{
        const pl=getPlace(t.id);const vn=getVehicle(t.id);const isCxl=t.status==="cancelled";const isFuture=t.lendDate>=today;const isPast=t.returnDate<today;
        const rowBg=isCxl?"#f1f1f1":isPast?"#f9fafb":i%2===0?"#fff":"#fafbfc";
        const cellR=(ci)=>({position:ci<=2?"sticky":"static",left:ci===0?0:ci===1?44:ci===2?74:undefined,zIndex:ci<=2?2:0,background:rowBg,padding:"3px 4px",borderBottom:"1px solid #f1f5f9",borderRight:ci===2?"2px solid #cbd5e1":"1px solid #f1f5f9",opacity:isCxl?0.5:isPast?0.4:1,verticalAlign:"middle",fontSize:9});
        return <tr key={t.id+i} style={{cursor:"pointer"}}>
          <td style={{...cellR(0),textAlign:"center",padding:"2px"}}>{isCxl?
            <button onClick={e=>{e.stopPropagation();if(window.confirm(t.name+" 様のキャンセルを復元しますか？"))onRestoreReservation(t.id);}} style={{background:"#fbbf24",color:"#78350f",border:"none",borderRadius:4,fontSize:7,fontWeight:800,padding:"2px 4px",cursor:"pointer",lineHeight:1}}>復元</button>
            :<button onClick={e=>{e.stopPropagation();if(window.confirm(t.name+" 様の予約をキャンセルしますか？\n\n予約番号: "+t.id+"\n貸出: "+t.lendDate+" "+t.lendTime+"\n返却: "+t.returnDate+" "+t.returnTime+"\n\nOPシートはCXL表示、配車表から除外されます"))onCancelReservation(t.id);}} style={{background:"#fee2e2",color:"#dc2626",border:"none",borderRadius:4,fontSize:7,fontWeight:800,padding:"2px 4px",cursor:"pointer",lineHeight:1}}>CXL</button>
          }</td>
          <td onClick={()=>{if(!isCxl)openEdit(t);}} style={{...cellR(1),textAlign:"center"}}><OBadge ota={t.ota}/></td>
          <td onClick={()=>{if(!isCxl)openEdit(t);}} style={{...cellR(2),fontWeight:600,color:isCxl?"#9ca3af":"#0f172a",textDecoration:isCxl?"line-through":"none"}}>{t.name||"-"}</td>
          <td style={{...cellR(3),fontWeight:700,color:t.lendDate===today?"#dc2626":"#1e293b"}}>{t.lendDate||"-"}</td>
          <td style={cellR(4)}>{t.delTime||t.lendTime||"-"}</td>
          <td style={{...cellR(5),fontWeight:700}}>{t.returnDate||"-"}</td>
          <td style={cellR(6)}>{t.colTime||t.returnTime||"-"}</td>
          <td style={{...cellR(7),fontWeight:700,color:"#2563eb"}}>{t.vehicle||"-"}</td>
          <td style={{...cellR(8),fontWeight:700,color:vn?"#1e40af":"#dc2626"}}>{vn?vn.name:fleet&&fleet[t.id]?"("+fleet[t.id]+")":"未配車"}</td>
          <td style={{...cellR(9),fontFamily:"monospace",fontWeight:700,color:vn?"#2563eb":"#ccc"}}>{vn?vn.no:"-"}</td>
          <td style={{...cellR(10),textAlign:"center",fontWeight:700}}>{t.people||""}</td>
          <td style={{...cellR(11),textAlign:"center",fontWeight:700,color:+(t.optB||0)>0?"#2563eb":"#ddd"}}>{+(t.optB||0)||"-"}</td>
          <td style={{...cellR(12),textAlign:"center",fontWeight:700,color:+(t.optC||0)>0?"#2563eb":"#ddd"}}>{+(t.optC||0)||"-"}</td>
          <td style={{...cellR(13),textAlign:"center",fontWeight:700,color:+(t.optJ||0)>0?"#2563eb":"#ddd"}}>{+(t.optJ||0)||"-"}</td>
          <td style={{...cellR(14),fontWeight:600,color:t.insurance==="NOC"?"#b45309":"#64748b"}}>{t.insurance||"-"}</td>
          <td style={{...cellR(15),fontSize:8,color:pl.delPlace||t.delPlace?"#059669":"#94a3b8",fontWeight:600}}>{pl.delPlace||t.delPlace||"-"}</td>
          <td style={{...cellR(16),fontSize:8,color:pl.colPlace||t.colPlace?"#059669":"#94a3b8",fontWeight:600}}>{pl.colPlace||t.colPlace||"-"}</td>
          <td style={{...cellR(17),fontWeight:600,color:"#1e293b"}}>¥{(t.price||0).toLocaleString()}</td>
          <td style={{...cellR(18),textAlign:"center"}}>{t.ota==="J"?(()=>{const jp=jalanPay&&jalanPay[t.id];const done=jp&&jp.payStatus==="完了";return <span style={{fontSize:8,fontWeight:700,padding:"1px 4px",borderRadius:3,background:done?"#dcfce7":"#fef2f2",color:done?"#16a34a":"#dc2626"}}>{done?"済":"未"}</span>;})():"-"}</td>
          <td style={{...cellR(19),textAlign:"center"}}>{licStatus[t.id]?<span style={{fontSize:9}}>✅</span>:<a href={"license.html?id="+encodeURIComponent(t.id)+"&name="+encodeURIComponent(t.name||"")} target="_blank" style={{fontSize:9,textDecoration:"none"}} onClick={e=>e.stopPropagation()}>⬜</a>}</td>
          <td style={{...cellR(20),fontFamily:"monospace",fontSize:8,color:"#64748b"}}>{t.id}</td>
        </tr>;
      })}
    </tbody></table></div>
    {/* ========== 編集モーダル ========== */}
    {editRow&&<div style={{position:"fixed",inset:0,background:"rgba(0,0,0,.5)",zIndex:9999,display:"flex",alignItems:"center",justifyContent:"center",padding:16}} onClick={()=>setEditRow(null)}><div style={{background:"#fff",borderRadius:16,padding:24,width:"100%",maxWidth:520,maxHeight:"90vh",overflowY:"auto",boxShadow:"0 8px 32px rgba(0,0,0,.2)"}} onClick={e=>e.stopPropagation()}>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:16}}>
        <div><div style={{fontSize:16,fontWeight:800,color:"#1e293b"}}>{editRow.name}</div><div style={{fontSize:11,color:"#64748b"}}><OBadge ota={editRow.ota}/> {editRow.id}</div></div>
        <button onClick={()=>setEditRow(null)} style={{background:"none",border:"none",fontSize:20,cursor:"pointer",color:"#94a3b8"}}>✕</button>
      </div>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10}}>
        <label style={{fontSize:11,fontWeight:600,color:"#475569"}}>予約者名<input value={editForm.name} onChange={e=>setEditForm({...editForm,name:e.target.value})} style={{width:"100%",padding:8,borderRadius:8,border:"1px solid #d1d5db",fontSize:13,marginTop:2}}/></label>
        <label style={{fontSize:11,fontWeight:600,color:"#475569"}}>料金<input type="number" value={editForm.price} onChange={e=>setEditForm({...editForm,price:e.target.value})} style={{width:"100%",padding:8,borderRadius:8,border:"1px solid #d1d5db",fontSize:13,marginTop:2}}/></label>
        <label style={{fontSize:11,fontWeight:600,color:"#475569"}}>貸出日<input type="date" value={editForm.lendDate} onChange={e=>setEditForm({...editForm,lendDate:e.target.value})} style={{width:"100%",padding:8,borderRadius:8,border:"1px solid #d1d5db",fontSize:13,marginTop:2}}/></label>
        <label style={{fontSize:11,fontWeight:600,color:"#475569"}}>貸出時間<input type="time" value={editForm.lendTime} onChange={e=>setEditForm({...editForm,lendTime:e.target.value})} style={{width:"100%",padding:8,borderRadius:8,border:"1px solid #d1d5db",fontSize:13,marginTop:2}}/></label>
        <label style={{fontSize:11,fontWeight:600,color:"#475569"}}>返却日<input type="date" value={editForm.returnDate} onChange={e=>setEditForm({...editForm,returnDate:e.target.value})} style={{width:"100%",padding:8,borderRadius:8,border:"1px solid #d1d5db",fontSize:13,marginTop:2}}/></label>
        <label style={{fontSize:11,fontWeight:600,color:"#475569"}}>返却時間<input type="time" value={editForm.returnTime} onChange={e=>setEditForm({...editForm,returnTime:e.target.value})} style={{width:"100%",padding:8,borderRadius:8,border:"1px solid #d1d5db",fontSize:13,marginTop:2}}/></label>
        <label style={{fontSize:11,fontWeight:600,color:"#475569"}}>クラス<select value={editForm.vehicle} onChange={e=>setEditForm({...editForm,vehicle:e.target.value})} style={{width:"100%",padding:8,borderRadius:8,border:"1px solid #d1d5db",fontSize:13,marginTop:2}}><option value="A">A</option><option value="B">B</option><option value="C">C</option><option value="S">S</option><option value="F">F</option><option value="H">H</option></select></label>
        <label style={{fontSize:11,fontWeight:600,color:"#475569"}}>補償<select value={editForm.insurance} onChange={e=>setEditForm({...editForm,insurance:e.target.value})} style={{width:"100%",padding:8,borderRadius:8,border:"1px solid #d1d5db",fontSize:13,marginTop:2}}><option value="免責">免責</option><option value="NOC">NOC</option><option value="なし">なし</option></select></label>
        <label style={{fontSize:11,fontWeight:600,color:"#475569"}}>人数<input type="number" value={editForm.people} onChange={e=>setEditForm({...editForm,people:e.target.value})} style={{width:"100%",padding:8,borderRadius:8,border:"1px solid #d1d5db",fontSize:13,marginTop:2}}/></label>
        <label style={{fontSize:11,fontWeight:600,color:"#475569"}}>フライト<input value={editForm.flight} onChange={e=>setEditForm({...editForm,flight:e.target.value})} style={{width:"100%",padding:8,borderRadius:8,border:"1px solid #d1d5db",fontSize:13,marginTop:2}}/></label>
        <label style={{fontSize:11,fontWeight:600,color:"#475569"}}>都道府県<select value={editForm.prefecture||""} onChange={e=>setEditForm({...editForm,prefecture:e.target.value})} style={{width:"100%",padding:8,borderRadius:8,border:"1px solid #d1d5db",fontSize:13,marginTop:2}}><option value="">未設定</option>{["北海道","青森県","岩手県","宮城県","秋田県","山形県","福島県","茨城県","栃木県","群馬県","埼玉県","千葉県","東京都","神奈川県","新潟県","富山県","石川県","福井県","山梨県","長野県","岐阜県","静岡県","愛知県","三重県","滋賀県","京都府","大阪府","兵庫県","奈良県","和歌山県","鳥取県","島根県","岡山県","広島県","山口県","徳島県","香川県","愛媛県","高知県","福岡県","佐賀県","長崎県","熊本県","大分県","宮崎県","鹿児島県","沖縄県","海外"].map(p=><option key={p} value={p}>{p}</option>)}</select></label>
        <label style={{fontSize:11,fontWeight:600,color:"#475569"}}>TEL<input value={editForm.tel} onChange={e=>setEditForm({...editForm,tel:e.target.value})} style={{width:"100%",padding:8,borderRadius:8,border:"1px solid #d1d5db",fontSize:13,marginTop:2}}/></label>
        <label style={{fontSize:11,fontWeight:600,color:"#475569"}}>MAIL<input value={editForm.mail} onChange={e=>setEditForm({...editForm,mail:e.target.value})} style={{width:"100%",padding:8,borderRadius:8,border:"1px solid #d1d5db",fontSize:13,marginTop:2}}/></label>
      </div>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10,marginTop:10}}>
        <label style={{fontSize:11,fontWeight:600,color:"#475569"}}>DEL場所<input value={editForm.delPlace} onChange={e=>setEditForm({...editForm,delPlace:e.target.value})} style={{width:"100%",padding:8,borderRadius:8,border:"1px solid #d1d5db",fontSize:13,marginTop:2}}/></label>
        <label style={{fontSize:11,fontWeight:600,color:"#475569"}}>COL場所<input value={editForm.colPlace} onChange={e=>setEditForm({...editForm,colPlace:e.target.value})} style={{width:"100%",padding:8,borderRadius:8,border:"1px solid #d1d5db",fontSize:13,marginTop:2}}/></label>
        <label style={{fontSize:11,fontWeight:600,color:"#475569"}}>DEL時間<input type="time" value={editForm.delTime} onChange={e=>setEditForm({...editForm,delTime:e.target.value})} style={{width:"100%",padding:8,borderRadius:8,border:"1px solid #d1d5db",fontSize:13,marginTop:2}}/></label>
        <label style={{fontSize:11,fontWeight:600,color:"#475569"}}>COL時間<input type="time" value={editForm.colTime} onChange={e=>setEditForm({...editForm,colTime:e.target.value})} style={{width:"100%",padding:8,borderRadius:8,border:"1px solid #d1d5db",fontSize:13,marginTop:2}}/></label>
      </div>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:10,marginTop:10}}>
        <label style={{fontSize:11,fontWeight:600,color:"#475569"}}>B(ベビー)<input type="number" min="0" max="9" value={editForm.optB} onChange={e=>setEditForm({...editForm,optB:e.target.value})} style={{width:"100%",padding:8,borderRadius:8,border:"1px solid #d1d5db",fontSize:13,marginTop:2}}/></label>
        <label style={{fontSize:11,fontWeight:600,color:"#475569"}}>C(チャイルド)<input type="number" min="0" max="9" value={editForm.optC} onChange={e=>setEditForm({...editForm,optC:e.target.value})} style={{width:"100%",padding:8,borderRadius:8,border:"1px solid #d1d5db",fontSize:13,marginTop:2}}/></label>
        <label style={{fontSize:11,fontWeight:600,color:"#475569"}}>J(ジュニア)<input type="number" min="0" max="9" value={editForm.optJ} onChange={e=>setEditForm({...editForm,optJ:e.target.value})} style={{width:"100%",padding:8,borderRadius:8,border:"1px solid #d1d5db",fontSize:13,marginTop:2}}/></label>
      </div>
      <div style={{display:"flex",gap:8,marginTop:20}}>
        <button onClick={()=>setEditRow(null)} style={{flex:1,padding:12,borderRadius:10,border:"1px solid #d1d5db",background:"#fff",fontSize:14,fontWeight:600,cursor:"pointer",color:"#475569"}}>閉じる</button>
        <button onClick={saveEdit} disabled={saving} style={{flex:1,padding:12,borderRadius:10,border:"none",background:saving?"#94a3b8":"#2563eb",color:"#fff",fontSize:14,fontWeight:700,cursor:saving?"not-allowed":"pointer"}}>{saving?"保存中...":"保存"}</button>
      </div>
      {editRow.status!=="cancelled"&&onCancelReservation&&<button onClick={()=>{if(window.confirm(editRow.name+" 様の予約をキャンセルしますか？\n\n予約番号: "+editRow.id+"\nOPシートはCXL表示、配車表から除外されます")){onCancelReservation(editRow.id);setEditRow(null);}}} style={{width:"100%",padding:10,borderRadius:10,border:"none",background:"#fef2f2",color:"#dc2626",fontSize:13,fontWeight:700,cursor:"pointer",marginTop:12}}>この予約をキャンセル</button>}
    </div></div>}
  </div>;
}

/* ==========================================
   NoticesPage
   ========================================== */
function NoticesPage({store}){
  const[notices,setNotices]=useState([]);const[loading,setLoading]=useState(true);const[error,setError]=useState(null);
  const load=useCallback(async()=>{setLoading(true);setError(null);try{const{data:rows,error:err}=await sb.from("notices").select("*").eq("store",store).order("created_at",{ascending:false}).limit(100);if(err)throw err;setNotices(rows||[]);}catch(e){setError(e.message);}setLoading(false);},[store]);
  useEffect(()=>{load();},[load]);
  const catIco={transport:"🚗",task:"📋",reservation:"📅",vehicle:"🔧",event:"🎉"};
  const impColor={HIGH:"#dc2626",MED:"#d97706",LOW:"#64748b"};
  const grouped=useMemo(()=>{const g={};notices.forEach(n=>{const d=n.date||(n.created_at?n.created_at.slice(0,10):"");if(!g[d])g[d]=[];g[d].push(n);});return Object.entries(g).sort((a,b)=>b[0].localeCompare(a[0]));},[notices]);
  const fmtTime=t=>{try{return new Date(t).toLocaleTimeString("ja-JP",{hour:"2-digit",minute:"2-digit"});}catch(e){return "";}};
  if(loading)return <div style={{padding:40,textAlign:"center",color:"#94a3b8",fontSize:13}}>読み込み中...</div>;
  if(error)return <div style={{padding:20,color:"#dc2626",fontSize:12}}>エラー: {error}<button onClick={load} style={{marginLeft:12,padding:"4px 10px",fontSize:11,background:"#f1f5f9",border:"1px solid #e2e8f0",borderRadius:6,cursor:"pointer"}}>再試行</button></div>;
  return(
    <div style={{maxWidth:640,margin:"0 auto",padding:"0 4px"}}>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:12}}>
        <div style={{fontWeight:700,fontSize:15,color:"#1e293b"}}>📢 お知らせ</div>
        <button onClick={load} style={{padding:"4px 12px",fontSize:11,background:"#f1f5f9",border:"1px solid #e2e8f0",borderRadius:6,cursor:"pointer",color:"#64748b"}}>🔄 更新</button>
      </div>
      {!notices.length&&<div style={{padding:40,textAlign:"center"}}><div style={{fontSize:48,marginBottom:12}}>📭</div><div style={{color:"#94a3b8",fontSize:14}}>お知らせはまだありません</div></div>}
      {grouped.map(([date,items])=>(
        <div key={date} style={{marginBottom:20}}>
          <div style={{fontSize:11,fontWeight:700,color:"#64748b",padding:"4px 0",borderBottom:"1px solid #e2e8f0",marginBottom:8}}>{date}</div>
          {items.map(n=>(
            <div key={n.id} style={{background:"#fff",borderRadius:10,padding:"10px 14px",marginBottom:8,boxShadow:"0 1px 3px rgba(0,0,0,.06)",borderLeft:`3px solid ${impColor[n.impact]||"#94a3b8"}`}}>
              <div style={{display:"flex",alignItems:"center",gap:6,marginBottom:4}}>
                <span style={{fontSize:14}}>{catIco[n.category]||"📌"}</span>
                {n.title&&<span style={{fontWeight:700,fontSize:12,color:"#1e293b"}}>{n.title}</span>}
                <span style={{fontSize:9,padding:"1px 6px",borderRadius:10,background:impColor[n.impact]||"#94a3b8",color:"#fff",fontWeight:700,marginLeft:"auto",flexShrink:0}}>{n.impact}</span>
              </div>
              <div style={{fontSize:12,color:"#374151",whiteSpace:"pre-wrap",lineHeight:1.6}}>{n.content}</div>
              <div style={{fontSize:10,color:"#94a3b8",marginTop:4}}>{fmtTime(n.created_at)}</div>
            </div>
          ))}
        </div>
      ))}
    </div>
  );
}

/* ==========================================
   App
   ========================================== */
function App(){
  const[data,setData]=useState([]);const[tab,setTab_]=useState("top");const[tabHistory,setTabHistory]=useState([]);const[highlightVehicle,setHighlightVehicle]=useState(null);const[taskSumOpen,setTaskSumOpen]=useState(false);const[tomSumOpen,setTomSumOpen]=useState(false);
  const setTab=useCallback((newTab)=>{setTab_(prev=>{if(prev&&prev!==newTab){setTabHistory(h=>[...h,prev].slice(-20));}return newTab;});},[]);
  const goBack=useCallback(()=>{setTabHistory(h=>{if(h.length===0)return h;const prev=h[h.length-1];setTab_(prev);return h.slice(0,-1);});},[]);
  const today=toLD(new Date());const importingRef=useRef(false);
  // ★ キャンセル済み予約ID追跡（silentRefresh/Realtimeでの復活を防止）
  const cancelledIdsRef=useRef(new Set());
  const markCancelled=(id)=>{cancelledIdsRef.current.add(id);setTimeout(()=>cancelledIdsRef.current.delete(id),120000);};
  const rtRetryRef=useRef(0);
  const[isOnline,setIsOnline]=useState(navigator.onLine);
  // --- オフライン検知+保存キュー ---
  const offlineQueueRef=useRef([]);
  useEffect(()=>{
    const on=()=>{setIsOnline(true);console.log("[Network] online復帰");
      // オフライン中の保留保存をフラッシュ
      const q=[...offlineQueueRef.current];offlineQueueRef.current=[];
      if(q.length){console.log("[Network] "+q.length+"件の保留保存を実行");q.forEach(fn=>fn());silentRefresh();}
    };
    const off=()=>{setIsOnline(false);console.warn("[Network] offline検知");};
    window.addEventListener("online",on);window.addEventListener("offline",off);
    return()=>{window.removeEventListener("online",on);window.removeEventListener("offline",off);};
  },[]);
  const[fleet,setFleet_]=useState({});const[unassignedReasons,setUnassignedReasons]=useState({});
  const setFleet=React.useCallback((v)=>{
    const val=typeof v==="function"?v:()=>v;
    setFleet_(prev=>{const next=val(prev);
      if(next._unassignedReasons){const r={...next._unassignedReasons};delete next._unassignedReasons;setUnassignedReasons(r);return next;}
      return next;
    });
  },[]);
  const[maintenance,setMaintenance]=useState([]);const[shifts,setShifts]=useState({});const[showOP,setShowOP]=useState(false);const[showFloatFleet,setShowFloatFleet]=useState(false);const[floatFleetSize,setFloatFleetSize]=useState("half");const[jalanPay,setJalanPay]=useState({});
  const[staff,setStaff]=useState(INIT_STAFF);
  const[attendance,setAttendance]=useState({});
  const[vehicles,setVehicles]=useState(INIT_VEHICLES);
  const vehicleClasses=INIT_CLASSES;
  // --- HANDYMAN Fleet state ---
  const[hmCars,setHmCars]=useState([]);const[hmCarData,setHmCarData]=useState([]);const[hmLogs,setHmLogs]=useState([]);const[hmClasses,setHmClasses]=useState([]);
  const hmReload=async()=>{const[c,cd,l,cl]=await Promise.all([DB.hm.fetchCars(),DB.hm.fetchCarData(),DB.hm.fetchLogs(),DB.hm.fetchClasses()]);setHmCars(c);setHmCarData(cd);setHmLogs(l);setHmClasses(cl);};
  const[pendingPlaces,setPendingPlaces]=useState(null);
  const[sheetPlaces,setSheetPlaces]=useState(()=>{try{return JSON.parse(localStorage.getItem("spk_sheet_places")||"{}}");}catch(e){return{};}});
  const saveSheetPlaces=(p)=>{setSheetPlaces(p);try{localStorage.setItem("spk_sheet_places",JSON.stringify(p));}catch(e){}};
  // オプション情報をlocalStorageで管理（DB非依存）
  const[resOpts,setResOpts]=useState(()=>{try{return JSON.parse(localStorage.getItem("spk_res_opts")||"{}}");}catch(e){return{};}});
  const saveResOpts=(newOpts)=>{setResOpts(newOpts);try{localStorage.setItem("spk_res_opts",JSON.stringify(newOpts));}catch(e){} DB.saveResOpts(newOpts);};
  // FIX-5: resOpts初回DB読み込み（端末間同期）
  useEffect(()=>{DB.fetchResOpts().then(dbOpts=>{if(dbOpts&&Object.keys(dbOpts).length){setResOpts(prev=>{const merged={...dbOpts,...prev};try{localStorage.setItem("spk_res_opts",JSON.stringify(merged));}catch(e){} return merged;});}});},[]);
  const[csvFiles,setCsvFiles]=useState({});const[csvLogs,setCsvLogs]=useState([]);const[csvPlaceLogs,setCsvPlaceLogs]=useState([]);
  const[importDiag,setImportDiag]=useState(null); // インポート売上診断
  const[sbConnected,setSbConnected]=useState(false);
  const[dbLoaded,setDbLoaded]=useState(!SB_ENABLED);
  // ★ 当日タスク（個人別サマリー用）+ 翌日タスク
  const[todayTasks,setTodayTasks]=useState([]);
  // ★ 個人別サマリーのアコーディオン開閉状態（再レンダーで消えないようrefで管理）
  const[personAccOpen,setPersonAccOpen]=useState({"本日":{},"翌日":{}});
  const[tomorrowTasks,setTomorrowTasks]=useState([]);
  const refreshTopTasks=useCallback(async()=>{
    if(!SB_ENABLED||!sb)return;
    const tmr=dOff(today,1);
    try{
      const[todayRes,tmrRes]=await Promise.all([
        sb.from("tasks").select("*").eq("date",today),
        sb.from("tasks").select("*").eq("date",tmr)
      ]);
      if(todayRes.data)setTodayTasks(todayRes.data.map(DB._fromDbTask));
      if(tmrRes.data)setTomorrowTasks(tmrRes.data.map(DB._fromDbTask));
    }catch(e){console.log("[refreshTopTasks] error",e);}
  },[today]);
  useEffect(()=>{
    if(!SB_ENABLED||!dbLoaded)return;
    refreshTopTasks();
    // 30秒ごとにTOPタスクも自動更新
    const timer=setInterval(()=>{if(document.visibilityState==="visible")refreshTopTasks();},30000);
    return()=>clearInterval(timer);
  },[today,dbLoaded,refreshTopTasks]);

  // 同期状態トラッキング: 各カテゴリの最終DB同期時刻 + ローカル最終変更時刻
  const[syncStatus,setSyncStatus]=useState({
    reservations:{dbTime:null,localTime:null,count:0,dbCount:0},
    fleet:{dbTime:null,localTime:null},
    staff:{dbTime:null,localTime:null,count:0,dbCount:0},
    vehicles:{dbTime:null,localTime:null,count:0,dbCount:0},
    shifts:{dbTime:null,localTime:null},
    maintenance:{dbTime:null,localTime:null},
  });
  const markLocalChange=(cat)=>setSyncStatus(p=>({...p,[cat]:{...p[cat],localTime:Date.now()}}));
  const markDbSync=(cat,extra={})=>setSyncStatus(p=>({...p,[cat]:{...p[cat],dbTime:Date.now(),...extra}}));
  // ★ ローカル変更が未同期かどうかをrefで参照（silentRefresh内で使用）
  const syncStatusRef=React.useRef(syncStatus);syncStatusRef.current=syncStatus;

  // --- Supabase 初期ロード（那覇店方式: キャッシュ即表示 + 2.5秒タイムアウト + Phase分離） ---
  const[bgLoading,setBgLoading]=useState(false);
  useEffect(()=>{
    if(!SB_ENABLED)return;
    // ★ キャッシュ即時表示: 前回の成功データがあれば即UI表示
    try{
      const cached=JSON.parse(localStorage.getItem("spk_cached_init")||"null");
      if(cached&&cached.res&&cached.res.length>0){
        console.log("[init] キャッシュ即時表示: "+cached.res.length+"件");
        setData(cached.res);
        if(cached.staff&&cached.staff.length)setStaff(cached.staff);
        if(cached.vehicles&&cached.vehicles.length)setVehicles(cached.vehicles);
        if(cached.shifts)setShifts(cached.shifts);
        if(cached.fleet&&Object.keys(cached.fleet).length)setFleet(cached.fleet);
        if(cached.maintenance&&cached.maintenance.length)setMaintenance(cached.maintenance);
        setDbLoaded(true);
        setBgLoading(true);
      }
    }catch(e){}
    // ★ 2.5秒タイムアウト: キャッシュなし時の通信遅延フォールバック
    const loadTimeout=setTimeout(()=>{
      setDbLoaded(prev=>{
        if(!prev){console.warn("[init] 2.5秒タイムアウト → 強制UI表示");setSbConnected(false);}
        return true;
      });
    },2500);
    // ★ changed_jsonカラムチェックはバックグラウンド（UIロードをブロックしない）
    if(sb&&!window._changedColChecked){
      window._changedColChecked=true;
      (async()=>{try{
        const{data:test,error:testErr}=await sb.from("tasks").select("changed_json").limit(1);
        if(testErr||test===null){
          DB._hasChangedCol=false;
          try{await sb.rpc("exec_sql",{sql:"ALTER TABLE tasks ADD COLUMN IF NOT EXISTS changed_json text DEFAULT '{}'"});DB._hasChangedCol=true;}catch(e2){}
        }else{DB._hasChangedCol=true;}
      }catch(e){DB._hasChangedCol=false;}})();
    }
    (async()=>{
      try{
        console.log("[init] DB読込開始...");
        // ★ Phase1: 必須3テーブルを先行取得 → 即UI表示
        const[resDB,flDB,stDB]=await Promise.all([
          DB.fetchReservations(),DB.fetchFleet(),DB.fetchStaff()
        ]);
        console.log("[init] Phase1完了: 予約="+resDB.length+"件");
        let useRes=resDB;
        if(!useRes||!useRes.length){
          try{
            const backup=JSON.parse(localStorage.getItem("spk_reservations_backup")||"[]");
            if(backup.length>0){console.log(`[init] DB空 → LSバックアップ(${backup.length}件)を使用`);useRes=backup;}
          }catch(e){}
        }
        // ★ 破損データ除去
        if(useRes.length){
          const seen=new Set();
          useRes=useRes.filter(r=>{
            if(r.id&&r.id.includes('：'))return false;
            if(r.name&&r.name.startsWith('：'))return false;
            if(seen.has(r.id))return false;
            seen.add(r.id);
            return true;
          });
        }
        if(useRes.length)setData(useRes);
        if(Object.keys(flDB).length)setFleet(flDB);
        if(stDB&&stDB.length)setStaff(stDB);
        // ★ Phase1完了 → 即UIを表示
        clearTimeout(loadTimeout);
        setSbConnected(true);
        setDbLoaded(true);
        console.log("[init] Phase1完了 → UI表示");
        // ★ Phase2: 残りテーブルをバックグラウンド取得
        setBgLoading(true);
        const[vhDB,shDB,mtDB,plDB]=await Promise.all([
          DB.fetchVehicles(),DB.fetchShifts(),DB.fetchMaintenance(),DB.fetchPlaces()
        ]);
        console.log("[init] Phase2完了");
        if(vhDB&&vhDB.length)setVehicles(vhDB);
        if(shDB)setShifts(shDB);
        if(mtDB&&mtDB.length)setMaintenance(mtDB);
        if(plDB&&Object.keys(plDB).length){
          setSheetPlaces(prev=>{const merged={...prev,...plDB};try{localStorage.setItem("spk_sheet_places",JSON.stringify(merged));}catch(e){}return merged;});
        }
        // ★ キャッシュ保存（次回即時表示用）
        try{localStorage.setItem("spk_cached_init",JSON.stringify({
          res:useRes.slice(0,500),staff:stDB,vehicles:vhDB,
          shifts:shDB,fleet:flDB,maintenance:mtDB,ts:Date.now()
        }));}catch(e){}
        setBgLoading(false);
      }catch(e){console.error("DB load error:",e);clearTimeout(loadTimeout);setDbLoaded(true);setBgLoading(false);}
      console.log("[init] 全データ読込完了");
      // --- 以下はバックグラウンドで非同期読込（UIをブロックしない） ---
      (async()=>{
        try{const attDB=await DB.fetchAttendance();if(attDB&&Object.keys(attDB).length)setAttendance(attDB);}catch(e){console.warn("[att]",e);}
      })();
      (async()=>{
        try{
          const jpDB=await DB.fetchJalanPayment()||{};
          try{
            const jRes=(data||[]).filter(r=>r.ota==="J").map(r=>r.id);
            if(jRes.length){
              const controller=new AbortController();
              const timeoutId=setTimeout(()=>controller.abort(),8000);
              try{
                const gasData=await fetchJalanPaySheetData(jRes);
                clearTimeout(timeoutId);
                const merged={...jpDB,...gasData};
                Object.entries(gasData).forEach(([rid,pd])=>{
                  if(!jpDB[rid]||jpDB[rid].payStatus!==pd.payStatus){
                    DB.saveJalanPayment(rid,{...(jpDB[rid]||{}),...pd});
                  }
                });
                setJalanPay(merged);
                console.log("[jalanPay] GAS自動取得:",Object.keys(gasData).length+"件反映");
              }catch(ge){
                clearTimeout(timeoutId);
                console.warn("[jalanPay GAS] タイムアウトまたはエラー:",ge);
                if(Object.keys(jpDB).length)setJalanPay(jpDB);
              }
            }else{if(Object.keys(jpDB).length)setJalanPay(jpDB);}
          }catch(ge){console.warn("[jalanPay GAS]",ge);if(Object.keys(jpDB).length)setJalanPay(jpDB);}
        }catch(e){console.warn("[jalanPay]",e);}
      })();
      (async()=>{
        try{await hmReload();console.log("[HM] reload完了");}catch(e){console.error("[HM] reload error:",e);}
        try{
          var chk=await sb.from("car_data").select("id",{count:"exact",head:true});
          if(chk.error)console.warn("[HM] car_data:",chk.error.message);
        }catch(e){}
      })();
      // 初期ロード完了 → 全カテゴリ同期済み
      const now=Date.now();
      setSyncStatus({
        reservations:{dbTime:now,localTime:null,count:0,dbCount:0},
        fleet:{dbTime:now,localTime:null},
        staff:{dbTime:now,localTime:null,count:0,dbCount:0},
        vehicles:{dbTime:now,localTime:null,count:0,dbCount:0},
        shifts:{dbTime:now,localTime:null},
        maintenance:{dbTime:now,localTime:null},
      });
    })();
  },[]);

  // --- 手動リロード（スマホ用） ---
  const[reloading,setReloading]=useState(0); // 0=idle, 1=loading, 2=done
  const reloadAll=async()=>{
    if(!SB_ENABLED||reloading===1||importingRef.current)return;
    setReloading(1);
    try{
      const[resDB,flDB,stDB,vhDB,shDB,mtDB]=await Promise.all([
        DB.fetchReservations(),DB.fetchFleet(),DB.fetchStaff(),DB.fetchVehicles(),DB.fetchShifts(),DB.fetchMaintenance()
      ]);
      // ★ DB優先（LSバックアップはDBが空の場合のみ）
      let useRes=resDB||[];
      if(!useRes.length){try{const bk=JSON.parse(localStorage.getItem("spk_reservations_backup")||"[]");if(bk.length)useRes=bk;}catch(e){}}
      // ★ 破損データ除去
      if(useRes.length){const seen=new Set();useRes=useRes.filter(r=>{if(r.id&&r.id.includes('：'))return false;if(r.name&&r.name.startsWith('：'))return false;if(seen.has(r.id))return false;seen.add(r.id);return true;});}
      if(useRes.length)setData(useRes);
      if(flDB)setFleet(flDB);
      if(stDB)setStaff(stDB);
      if(vhDB)setVehicles(vhDB);
      if(shDB)setShifts(shDB);
      if(mtDB)setMaintenance(mtDB);
      try{await hmReload();}catch(e){}
      // 全カテゴリ同期完了
      const now=Date.now();
      setSyncStatus({
        reservations:{dbTime:now,localTime:null,count:useRes.length,dbCount:useRes.length},
        fleet:{dbTime:now,localTime:null},
        staff:{dbTime:now,localTime:null,count:stDB?stDB.length:0,dbCount:stDB?stDB.length:0},
        vehicles:{dbTime:now,localTime:null,count:vhDB?vhDB.length:0,dbCount:vhDB?vhDB.length:0},
        shifts:{dbTime:now,localTime:null},
        maintenance:{dbTime:now,localTime:null},
      });
    }catch(e){console.error("reload error:",e);}
    setReloading(2);
    setTimeout(()=>setReloading(0),1200);
  };
  // --- タブ復帰時+定期ポーリングでDB再読み込み（Realtime未受信の変更を補完）---
  const silentRefresh=React.useCallback(async()=>{
    if(!SB_ENABLED||importingRef.current||reloading===1)return;
    try{
      const[resDB,flDB,stDB,vhDB,shDB,mtDB]=await Promise.all([
        DB.fetchReservations(),DB.fetchFleet(),DB.fetchStaff(),DB.fetchVehicles(),DB.fetchShifts(),DB.fetchMaintenance()
      ]);
      if(importingRef.current)return;
      // ★ reservations: ローカル変更が未同期なら上書きしない（新規予約/キャンセル保護）
      const resSS=syncStatusRef.current.reservations;
      const resHasPendingLocal=resSS.localTime&&(!resSS.dbTime||resSS.localTime>resSS.dbTime);
      if(resHasPendingLocal){
        console.log("[silentRefresh] reservations skip: pending local change (local="+resSS.localTime+" db="+resSS.dbTime+")");
      } else {
        let useRes=resDB||[];
        try{const bk=JSON.parse(localStorage.getItem("spk_reservations_backup")||"[]");if(bk.length>useRes.length)useRes=bk;}catch(e){}
        // ★ キャンセル済み予約をフィルタ（ローカルで消した予約がDBから復活するのを防止）
        const cancelled=cancelledIdsRef.current;
        if(cancelled.size){
          useRes=useRes.filter(r=>!cancelled.has(r.id));
          console.log("[silentRefresh] cancelled filter: "+cancelled.size+"件除外");
        }
        // 現在のdata stateにあってDB/LSに無い予約（手動追加直後など）を保護
        setData(prev=>{
          if(!useRes.length)return prev;
          const dbIds=new Set(useRes.map(r=>r.id));
          const localOnly=prev.filter(r=>!dbIds.has(r.id)&&!cancelled.has(r.id));
          if(localOnly.length){
            console.log("[silentRefresh] "+localOnly.length+"件のローカル専用予約を保護:",localOnly.map(r=>r.id).join(","));
            return[...useRes,...localOnly];
          }
          return useRes;
        });
      }
      // ★ fleet: ローカル変更がDB同期より新しい場合は上書きしない（車両変更保護）
      if(flDB&&Object.keys(flDB).length){
        const ss=syncStatusRef.current.fleet;
        const hasPendingLocal=ss.localTime&&(!ss.dbTime||ss.localTime>ss.dbTime);
        if(hasPendingLocal){console.log("[silentRefresh] fleet skip: pending local change");}
        else{setFleet(flDB);fleetRefApp.current=flDB;}
      }
      if(stDB&&stDB.length)setStaff(stDB);
      if(vhDB&&vhDB.length)setVehicles(vhDB);
      if(shDB)setShifts(shDB);
      if(mtDB&&mtDB.length)setMaintenance(mtDB);
      try{const attDB=await DB.fetchAttendance();if(attDB&&Object.keys(attDB).length)setAttendance(attDB);}catch(e){}
      // FIX-6: 場所データを他端末から同期
      try{const plDB=await DB.fetchPlaces();if(plDB&&Object.keys(plDB).length){setSheetPlaces(prev=>{const merged={...prev,...plDB};try{localStorage.setItem("spk_sheet_places",JSON.stringify(merged));}catch(e){}return merged;});}}catch(e){}
      try{await hmReload();}catch(e){}
      // 同期ステータス更新
      const now=Date.now();
      setSyncStatus(p=>({...p,
        reservations:resHasPendingLocal?p.reservations:{dbTime:now,localTime:p.reservations.localTime,count:data.length,dbCount:resDB?resDB.length:0},
        fleet:{dbTime:now,localTime:p.fleet.localTime},
        staff:{dbTime:now,localTime:p.staff.localTime,count:staff.length,dbCount:stDB?stDB.length:0},
        vehicles:{dbTime:now,localTime:p.vehicles.localTime,count:vehicles.length,dbCount:vhDB?vhDB.length:0},
        shifts:{dbTime:now,localTime:p.shifts.localTime},
        maintenance:{dbTime:now,localTime:p.maintenance.localTime},
      }));
    }catch(e){console.error("[silentRefresh]",e);}
  },[reloading]);
  useEffect(()=>{
    if(!SB_ENABLED)return;
    // タブ復帰時に即時リフレッシュ
    const onVis=()=>{if(document.visibilityState==="visible")silentRefresh();};
    document.addEventListener("visibilitychange",onVis);
    // Realtime接続時は60秒、切断時は10秒でポーリング
    let timer=null;
    const startPoll=()=>{if(timer)clearInterval(timer);const iv=sbConnected?60000:5000;timer=setInterval(()=>{if(document.visibilityState==="visible")silentRefresh();},iv);};
    startPoll();
    return()=>{document.removeEventListener("visibilitychange",onVis);if(timer)clearInterval(timer);};
  },[silentRefresh,sbConnected]);

  // --- Supabase Realtime ---
  useEffect(()=>{
    if(!sb)return;
    const ch=sb.channel("spk-realtime")
      .on("postgres_changes",{event:"*",schema:"public",table:"reservations"},payload=>{
        if(importingRef.current)return;
        // ★ ローカル変更が未同期の場合、RTからの上書きをスキップ（編集値が戻る問題の防止）
        const resSS=syncStatusRef.current.reservations;
        if(resSS.localTime&&Date.now()-resSS.localTime<3000){console.log("[RT reservations] skip: local change within 3s");return;}
        // ★ キャンセル済み予約のINSERT/UPDATEを無視（DB反映遅延で復活するのを防止）
        if(cancelledIdsRef.current.has(payload.new?.id||payload.old?.id)){console.log("[RT reservations] cancelled ID ignored:",payload.new?.id||payload.old?.id);return;}
        if(payload.eventType==="INSERT"||payload.eventType==="UPDATE"){
          const r=DB._fromDbRes(payload.new);
          setData(prev=>{
            const idx=prev.findIndex(x=>x.id===r.id);
            if(idx>=0){
              const n=[...prev];
              if(!r.price&&prev[idx].price){console.warn(`[RT] price保護: ${r.id} DB=0 → メモリ=${prev[idx].price}`);r.price=prev[idx].price;}
              n[idx]=r;return n;
            }
            return[...prev,r];
          });
        }else if(payload.eventType==="DELETE"){
          setData(prev=>prev.filter(x=>x.id!==payload.old.id));
        }
        markDbSync("reservations");
      })
      .on("postgres_changes",{event:"*",schema:"public",table:"fleet"},payload=>{
        if(importingRef.current)return;
        // ★ ローカル変更が未同期の場合、RTからの上書きをスキップ
        const ss=syncStatusRef.current.fleet;
        if(ss.localTime&&(!ss.dbTime||ss.localTime>ss.dbTime)){console.log("[RT fleet] skip: pending local");return;}
        if(payload.eventType==="DELETE"){
          setFleet(prev=>{const n={...prev};delete n[payload.old.reservation_id];return n;});
        }else{
          setFleet(prev=>{const n={...prev,[payload.new.reservation_id]:payload.new.vehicle_code};fleetRefApp.current=n;return n;});
        }
        markDbSync("fleet");
      })
      .on("postgres_changes",{event:"*",schema:"public",table:"tasks"},()=>{clearTimeout(window._taskRtDebounce);window._taskRtDebounce=setTimeout(()=>{refreshTopTasks();},1000);})
      .on("postgres_changes",{event:"INSERT",schema:"public",table:"shifts"},payload=>{
        const s=payload.new;if(!s||!s.date)return;
        setShifts(prev=>{const n={...prev};if(!n[s.date])n[s.date]=[];const arr=n[s.date].filter(x=>x.name!==s.staff_name);arr.push({name:s.staff_name,symbol:s.symbol,start:s.start_time,end:s.end_time,memo:s.memo});n[s.date]=arr;return{...n};});
        markDbSync("shifts");
      })
      .on("postgres_changes",{event:"UPDATE",schema:"public",table:"shifts"},payload=>{
        const s=payload.new;if(!s||!s.date)return;
        setShifts(prev=>{const n={...prev};if(!n[s.date])n[s.date]=[];const arr=n[s.date].filter(x=>x.name!==s.staff_name);arr.push({name:s.staff_name,symbol:s.symbol,start:s.start_time,end:s.end_time,memo:s.memo});n[s.date]=arr;return{...n};});
        markDbSync("shifts");
      })
      .on("postgres_changes",{event:"DELETE",schema:"public",table:"shifts"},payload=>{
        const s=payload.old;if(!s||!s.date)return;
        setShifts(prev=>{const n={...prev};if(n[s.date]){n[s.date]=n[s.date].filter(x=>x.name!==s.staff_name);}return{...n};});
        markDbSync("shifts");
      })
      .on("postgres_changes",{event:"*",schema:"public",table:"staff"},async()=>{
        const st=await DB.fetchStaff();if(st&&st.length)setStaff(st);markDbSync("staff");
      })
      .on("postgres_changes",{event:"*",schema:"public",table:"vehicles"},async()=>{
        // ローカル変更直後(2秒以内)は無視（自分のupsertで発火したイベント）
        const ss=syncStatusRef.current.vehicles;
        if(ss&&ss.localTime&&Date.now()-ss.localTime<2000){markDbSync("vehicles");return;}
        const vh=await DB.fetchVehicles();if(vh&&vh.length)setVehicles(vh);markDbSync("vehicles");
      })
      .on("postgres_changes",{event:"*",schema:"public",table:"attendance"},async()=>{
        try{const attDB=await DB.fetchAttendance();if(attDB&&Object.keys(attDB).length)setAttendance(attDB);}catch(e){}
      })
      .subscribe((status,err)=>{
        console.log("[Realtime]",status,err||"");
        setSbConnected(status==="SUBSCRIBED");
        if(status==="SUBSCRIBED"){rtRetryRef.current=0;}
        if(status==="CHANNEL_ERROR"||status==="TIMED_OUT"){
          const attempt=rtRetryRef.current++;
          const delay=Math.min(3000*Math.pow(2,attempt),60000);
          console.warn(`[Realtime] 接続エラー→${delay/1000}秒後に再接続(試行${attempt+1})`);
          setTimeout(()=>{try{sb.removeChannel(ch);const nch=sb.channel("spk-realtime");nch.subscribe();}catch(e){console.error("[Realtime] reconnect fail",e);}},delay);
        }
      });
    return()=>{sb.removeChannel(ch);};
  },[]);

  // --- Supabase連携ラッパー（DB呼び出しをsetState外で実行）---
  const setStaffSync=useCallback((fn)=>{
    const next=typeof fn==="function"?fn(staff):fn;
    setStaff(next);markLocalChange("staff");
    DB.saveStaff(next).then(()=>markDbSync("staff")).catch(e=>console.error("saveStaff error:",e));
  },[staff]);
  const setVehiclesSync=useCallback((fn)=>{
    const next=typeof fn==="function"?fn(vehicles):fn;
    // 全フィールドDB保存（localStorage不要）
    setVehicles(next);markLocalChange("vehicles");
    DB.saveVehicles(next).then(()=>markDbSync("vehicles")).catch(e=>console.error("saveVehicles error:",e));
  },[vehicles]);
  const setShiftsSync=useCallback((fn)=>{
    const next=typeof fn==="function"?fn(shifts):fn;
    setShifts(next);markLocalChange("shifts");
  },[shifts]);
  // 給与画面からの強制同期用
  window.__spkForceShifts=setShifts;
  const fleetRefApp=React.useRef(fleet);fleetRefApp.current=fleet;
  const setFleetSync=useCallback((nextFleet)=>{
    const resolved=typeof nextFleet==="function"?nextFleet(fleetRefApp.current):nextFleet;
    setFleet(resolved);fleetRefApp.current=resolved;markLocalChange("fleet");
    DB.upsertFleet(resolved).then(()=>markDbSync("fleet")).catch(e=>console.error("upsertFleet error:",e));
  },[]);

  // 配車変更 + OPシートタスク同時更新
  const reassignVehicle=useCallback(async(resId,newVc)=>{
    const nextFleet={...fleetRefApp.current,[resId]:newVc};
    fleetRefApp.current=nextFleet;
    setFleet(nextFleet);markLocalChange("fleet");
    try{await DB.upsertFleet(nextFleet);markDbSync("fleet");}catch(e){console.error("upsertFleet error:",e);}
    const vn=vehicles.find(x=>x.code===newVc);
    // ★ reservations.vehicleも同期（クラス変更を反映）
    if(vn)try{await DB.syncToReservation(resId,{vehicle:vn.type});}catch(e){console.error("syncToRes error:",e);}
    if(!SB_ENABLED||!vn)return;
    // OPシートの該当タスクも更新（全日分チェック）
    const res=data.find(r=>r.id===resId);if(!res)return;
    const ld=norm(res.lendDate),rd=norm(res.returnDate);
    // 貸出日のタスクを更新（該当タスクのみ個別保存）
    try{
      const _updateResTask=async(date)=>{
        const tasks=await DB.fetchTasks(date);
        if(!tasks||!tasks.length)return;
        const promises=tasks.filter(t=>t.reservationId===resId).map(t=>{
          const up={...t,assignedVehicle:newVc,plateNo:vn.no||"",vehicle:vn.type||t.vehicle};
          return DB.updateTask(up,date);
        });
        await Promise.all(promises);
      };
      await _updateResTask(ld);
      if(rd!==ld)await _updateResTask(rd);
      // 前日の洗車タスクも更新 + 不足していれば新規生成
      const prevDay=dOff(ld,-1);
      const tasks3=await DB.fetchTasks(prevDay);
      if(tasks3&&tasks3.length){
        const prevPromises=tasks3.filter(t=>t.reservationId===resId).map(t=>{
          const up={...t,assignedVehicle:newVc,plateNo:vn.no||"",vehicle:vn.type||t.vehicle};
          return DB.updateTask(up,prevDay);
        });
        await Promise.all(prevPromises);
        // ★ 洗車タスクが存在しなければ追加
        const hasWash=tasks3.find(t=>t.type==="洗車"&&t.reservationId===resId);
        if(!hasWash){
          const washTask={_id:"w-"+resId,type:"洗車",time:"",name:`翌日出発: ${res.name}`,people:0,place:"",vehicle:vn.type,insurance:"",flight:"",reservationId:resId,ota:res.ota||"",tel:"",mail:"",done:false,assignee:"",memo:`${fmtD(ld)} DEL ${res.lendTime||""} ${res.name}`,assignedVehicle:newVc,plateNo:vn.no,insuranceChange:"",opts:{},yakkan:false,line:false,payment:false,returnDate:"",returnTime:"",returnType:"",colPlace:""};
          await DB.updateTask(washTask,prevDay);
          console.log("[reassign] 前日洗車タスク追加:",newVc,res.name,prevDay);
        }
      }
    }catch(e){console.error("task vehicle update error:",e);}
  },[fleet,vehicles,data]);

  const imp=useCallback(async(d)=>{
    importingRef.current=true; // ★ 全てのDB再読込・RT更新をブロック
    // ★ 全priceをNumber型に正規化
    let imported=d.map(r=>({...r,price:Number(r.price)||0}));
    if(pendingPlaces&&Object.keys(pendingPlaces).length>0){
      imported=imported.map(r=>{const p=pendingPlaces[r.id];if(p)return{...r,delPlace:p.delPlace||r.delPlace,colPlace:p.colPlace||r.colPlace};return r;});
    }
    // ★ 重複ID解消: 同じIDが複数OTAに存在する場合、price>0の方を優先
    const dedupMap=new Map();
    imported.forEach(r=>{const ex=dedupMap.get(r.id);if(ex){if((Number(r.price)||0)>(Number(ex.price)||0))dedupMap.set(r.id,r);else{/* 既存の方がprice高い→既存のpriceを現在のに反映 */if(!r.price&&ex.price){r.price=ex.price;}}}else dedupMap.set(r.id,r);});
    imported=[...dedupMap.values()];
    // 既存データとマージ: インポートしたOTAの予約はCSV内容で置換、他OTAはそのまま
    const importedOTAs=new Set(imported.map(r=>r.ota));
    const importedIds=new Set(imported.map(r=>r.id));
    const kept=data.filter(r=>!importedOTAs.has(r.ota)||importedIds.has(r.id));
    const map=new Map(kept.map(r=>[r.id,r]));
    // ★ マージ時もprice>0優先
    imported.forEach(r=>{const ex=map.get(r.id);if(ex&&!r.price&&ex.price){r.price=ex.price;}map.set(r.id,r);});
    const allData=[...map.values()].map(r=>({...r,price:Number(r.price)||0})); // 全データのprice正規化
    // ★ localStorageにもバックアップ保存（DB障害時の保険）
    try{localStorage.setItem("spk_reservations_backup",JSON.stringify(allData));}catch(e){}
    setData(allData);
    // 配車データ
    const allIds=new Set(allData.map(r=>r.id));
    const cleanFleet={};Object.entries(fleet).forEach(([rid,vc])=>{if(allIds.has(rid))cleanFleet[rid]=vc;});
    const newFleet=autoAssign(allData,vehicles,cleanFleet,maintenance);
    // ★ 配車重複チェック（既存配車の日程変更による重複も検出）
    const fleetConflicts=[];
    const assignedEntries=Object.entries(newFleet).filter(([k])=>k!=="_unassignedReasons");
    assignedEntries.forEach(([rid,vc])=>{
      const res=allData.find(r=>r.id===rid);if(!res)return;
      const ld=norm(res.lendDate),rd=norm(res.returnDate);
      assignedEntries.forEach(([rid2,vc2])=>{
        if(rid>=rid2||vc!==vc2)return;// 同車両のみ、重複カウント防止
        const res2=allData.find(r=>r.id===rid2);if(!res2)return;
        const ld2=norm(res2.lendDate),rd2=norm(res2.returnDate);
        if(ld<=rd2&&rd>=ld2){
          const vn=vehicles.find(v=>v.code===vc);
          fleetConflicts.push({vc,vName:vn?vn.name+" ("+vn.no+")":vc,res1:res,res2:res2,
            period1:fmtD(ld)+"~"+fmtD(rd),period2:fmtD(ld2)+"~"+fmtD(rd2)});
        }
      });
    });
    // 重複があればalert + 2台目の配車を解除
    if(fleetConflicts.length>0){
      const lines=fleetConflicts.map((c,i)=>
        `${i+1}. ${c.vName}\n   ${c.res1.name} (${c.period1})\n   ${c.res2.name} (${c.period2})`
      ).join("\n\n");
      alert(`⚠️ 配車重複が ${fleetConflicts.length}件 見つかりました！\n配車表で確認・修正してください。\n\n${lines}`);
      // 後の予約の配車を解除（先の予約を優先）
      fleetConflicts.forEach(c=>{
        const r1Start=norm(c.res1.lendDate),r2Start=norm(c.res2.lendDate);
        const removeId=r1Start<=r2Start?c.res2.id:c.res1.id;
        delete newFleet[removeId];
        if(!newFleet._unassignedReasons)newFleet._unassignedReasons={};
        newFleet._unassignedReasons[removeId]=`重複検出: ${c.vName}は既に使用中`;
      });
    }
    setFleet(newFleet);
    setTab("fleet");
    // オプション情報をlocalStorageに保存
    const newResOpts={...resOpts};
    imported.forEach(r=>{newResOpts[r.id]={b:+(r.optB||0),c:+(r.optC||0),j:+(r.optJ||0),usb:!!r.optUSB,parasol:!!r.optParasol};});
    saveResOpts(newResOpts);
    // ★ DB保存（バックグラウンド・エラー時はalert）
    const removedIds=data.filter(r=>importedOTAs.has(r.ota)&&!importedIds.has(r.id)).map(r=>r.id);
    (async()=>{
      try{
        if(removedIds.length){
          await DB.deleteReservations(removedIds);removedIds.forEach(id=>DB.deleteFleetOne(id));
          // ★ キャンセル予約に紐づくタスクもDBから削除
          if(sb){
            for(const rid of removedIds){
              const{data:orphanTasks}=await sb.from("tasks").select("_id").eq("reservation_id",rid);
              if(orphanTasks&&orphanTasks.length){
                const ids=orphanTasks.map(t=>t._id);
                await sb.from("tasks").delete().in("_id",ids);
                dbLog("deleteOrphanTasks",true,rid+": "+ids.length+"件");
              }
            }
          }
        }
        // 30件ずつバッチupsert
        for(let i=0;i<imported.length;i+=30){
          const chunk=imported.slice(i,i+30);
          await DB.upsertReservations(chunk);
        }
        await DB.upsertFleet(newFleet);
      }catch(e){
        console.error("[imp] DB保存エラー:",e);
        alert("⚠️ DB保存でエラーが発生しました: "+e.message+"\nページをリロードしないでください。データはメモリ上に保持されています。");
      }
      // ★ DB保存完了後もしばらくガードを維持（RTイベントの遅延対策）
      setTimeout(()=>{importingRef.current=false;},15000);
    })();
    // ★ インポート結果をalertで通知（件数＋売上＋差分詳細）
    try{
    // --- 前回との差分を検出 ---
    const prevIds=new Set(data.map(r=>r.id));
    const newIds=new Set(allData.map(r=>r.id));
    const addedRes=allData.filter(r=>!prevIds.has(r.id));
    const removedRes=data.filter(r=>importedOTAs.has(r.ota)&&!newIds.has(r.id));
    // 既存予約で内容が変わったもの（price/日付/車種など）
    const changedRes=[];
    allData.forEach(r=>{
      if(!prevIds.has(r.id))return;
      const old=data.find(o=>o.id===r.id);if(!old)return;
      const diffs=[];
      if(old.lendDate!==r.lendDate)diffs.push(`貸出日:${old.lendDate}→${r.lendDate}`);
      if(old.returnDate!==r.returnDate)diffs.push(`返却日:${old.returnDate}→${r.returnDate}`);
      if(old.lendTime!==r.lendTime)diffs.push(`貸出時間:${old.lendTime}→${r.lendTime}`);
      if(old.returnTime!==r.returnTime)diffs.push(`返却時間:${old.returnTime}→${r.returnTime}`);
      if((Number(old.price)||0)!==(Number(r.price)||0))diffs.push(`金額:¥${(Number(old.price)||0).toLocaleString()}→¥${(Number(r.price)||0).toLocaleString()}`);
      if(old.vehicle!==r.vehicle)diffs.push(`車種:${old.vehicle}→${r.vehicle}`);
      if(old.name!==r.name)diffs.push(`名前:${old.name}→${r.name}`);
      if(old.insurance!==r.insurance)diffs.push(`補償:${old.insurance}→${r.insurance}`);
      if(diffs.length)changedRes.push({r,diffs});
    });
    // --- OTA別サマリー ---
    const impOtaSum={};imported.forEach(r=>{const k=r.ota||"?";if(!impOtaSum[k])impOtaSum[k]={cnt:0,sum:0,z:0};impOtaSum[k].cnt++;impOtaSum[k].sum+=(Number(r.price)||0);if(!r.price)impOtaSum[k].z++;});
    const impOtaStr=Object.entries(impOtaSum).map(([k,v])=>`  ${k}: ${v.cnt}件 ¥${v.sum.toLocaleString()}${v.z?` (${v.z}件=0)`:""}`).join("\n");
    // --- OTA別 新規/キャンセル/変更 集計 ---
    const otaAdd={};addedRes.forEach(r=>{const k=r.ota||"?";if(!otaAdd[k])otaAdd[k]={cnt:0,sum:0};otaAdd[k].cnt++;otaAdd[k].sum+=(Number(r.price)||0);});
    const otaRem={};removedRes.forEach(r=>{const k=r.ota||"?";if(!otaRem[k])otaRem[k]={cnt:0,sum:0};otaRem[k].cnt++;otaRem[k].sum+=(Number(r.price)||0);});
    const otaChg={};changedRes.forEach(({r})=>{const k=r.ota||"?";otaChg[k]=(otaChg[k]||0)+1;});
    const allOtaKeys=new Set([...Object.keys(impOtaSum),...Object.keys(otaAdd),...Object.keys(otaRem),...Object.keys(otaChg)]);
    const otaDiffLines=[];
    allOtaKeys.forEach(k=>{
      const cur=impOtaSum[k]||{cnt:0,sum:0};
      const a=otaAdd[k];const r=otaRem[k];const c=otaChg[k]||0;
      const parts=[`${cur.cnt}件 ¥${cur.sum.toLocaleString()}`];
      const diffParts=[];
      if(a)diffParts.push(`新規${a.cnt}件(+¥${a.sum.toLocaleString()})`);
      if(r)diffParts.push(`キャンセル${r.cnt}件(-¥${r.sum.toLocaleString()})`);
      if(c)diffParts.push(`変更${c}件`);
      if(diffParts.length)parts.push(diffParts.join(" / "));
      else parts.push("変更なし");
      otaDiffLines.push(`  ${k}: ${parts.join(" → ")}`);
    });
    const otaDiffStr=otaDiffLines.join("\n");
    // --- 全体の月別サマリー ---
    const mBreak={};allData.forEach(r=>{const ym=r.returnDate?r.returnDate.substring(0,7):"?";if(!mBreak[ym])mBreak[ym]={cnt:0,sum:0,zeros:[]};mBreak[ym].cnt++;mBreak[ym].sum+=(Number(r.price)||0);if(!r.price)mBreak[ym].zeros.push(r);});
    const mStr=Object.entries(mBreak).sort(([a],[b])=>a.localeCompare(b)).map(([k,v])=>`${k}: ${v.cnt}件 ¥${v.sum.toLocaleString()}${v.zeros.length?` ⚠️${v.zeros.length}件price=0`:""}`).join("\n");
    const totalSum=allData.reduce((s,r)=>s+(Number(r.price)||0),0);
    const prevTotalSum=data.filter(r=>importedOTAs.has(r.ota)).reduce((s,r)=>s+(Number(r.price)||0),0);
    const totalDiff=totalSum-prevTotalSum;
    const zeroAll=allData.filter(r=>!r.price);
    const zeroDetail=zeroAll.length>0?`\n\n⚠️ price=0: ${zeroAll.length}件\n`+zeroAll.slice(0,10).map(r=>`  ${r.ota}/${r.id}/${r.name}`).join("\n")+(zeroAll.length>10?`\n  ...他${zeroAll.length-10}件`:""):"";
    // --- 差分詳細テキスト ---
    let diffStr="";
    if(addedRes.length){
      diffStr+=`\n\n🆕 新規追加 ${addedRes.length}件:\n`;
      diffStr+=addedRes.slice(0,15).map(r=>`  [${r.ota}] ${r.id} ${r.name} ${fmtD(r.lendDate)}~${fmtD(r.returnDate)} ¥${(Number(r.price)||0).toLocaleString()}`).join("\n");
      if(addedRes.length>15)diffStr+=`\n  ...他${addedRes.length-15}件`;
    }
    if(removedRes.length){
      diffStr+=`\n\n❌ キャンセル/削除 ${removedRes.length}件:\n`;
      diffStr+=removedRes.slice(0,15).map(r=>`  [${r.ota}] ${r.id} ${r.name} ${fmtD(r.lendDate)}~${fmtD(r.returnDate)}`).join("\n");
      if(removedRes.length>15)diffStr+=`\n  ...他${removedRes.length-15}件`;
    }
    if(changedRes.length){
      diffStr+=`\n\n📝 変更 ${changedRes.length}件:\n`;
      diffStr+=changedRes.slice(0,10).map(({r,diffs})=>`  [${r.ota}] ${r.id} ${r.name}: ${diffs.join(", ")}`).join("\n");
      if(changedRes.length>10)diffStr+=`\n  ...他${changedRes.length-10}件`;
    }
    if(!addedRes.length&&!removedRes.length&&!changedRes.length)diffStr="\n\n✅ 前回からの変更なし";
    // ★ 画面上に売上診断バナーを表示
    const diagOta={};allData.forEach(r=>{const k=r.ota||"?";if(!diagOta[k])diagOta[k]={cnt:0,sum:0,z:0};diagOta[k].cnt++;diagOta[k].sum+=(Number(r.price)||0);if(!r.price)diagOta[k].z++;});
    setImportDiag({ts:new Date().toLocaleTimeString(),total:allData.length,totalSum,mBreak,diagOta,zeroAll:zeroAll.slice(0,20),added:addedRes,removed:removedRes,changed:changedRes,otaDiffLines});
    alert(`✅ ${allData.length}件取込完了 / 総売上¥${totalSum.toLocaleString()}\n\n【OTA別 増減サマリー】\n${otaDiffStr}\n${diffStr}\n\n【全体 月別内訳】\n${mStr}${zeroDetail}\n\n※ 画面右上「v${APP_VERSION}」表示を確認\n※DB保存中です。15秒間お待ちください。`);
    }catch(alertErr){console.error("[imp] alert構築エラー:",alertErr);alert("✅ 取込完了（詳細表示でエラー: "+alertErr.message+"）");}
    // インポート後、既存タスクのオプション情報を強制更新
    (async()=>{
      const rOptsMap={};imported.forEach(r=>{rOptsMap[r.id]={b:+(r.optB||0),c:+(r.optC||0),j:+(r.optJ||0),usb:!!r.optUSB,parasol:!!r.optParasol};});
      const affDates=new Set();
      imported.forEach(r=>{
        if(r.lendDate){affDates.add(r.lendDate);affDates.add(dOff(r.lendDate,-1));}
        if(r.returnDate)affDates.add(r.returnDate);
      });
      for(const d of affDates){
        try{
          const ts=await DB.fetchTasks(d);
          if(!ts||!ts.length)continue;
          let ch=false;
          const upd=ts.map(t=>{
            const ro=rOptsMap[t.reservationId];if(!ro)return t;
            const co=t.opts||{};
            if(ro.b!==!!co.b||ro.c!==!!co.c||ro.j!==!!co.j||ro.usb!==!!co.usb||ro.parasol!==!!co.parasol){ch=true;return{...t,opts:{...ro}};}
            return t;
          });
          if(ch){DB._lsSave(upd,d);upd.filter((u,i)=>{const o=ts[i];return o&&JSON.stringify(u.opts)!==JSON.stringify(o.opts);}).forEach(u=>DB.updateTask(u,d));}
        }catch(e){}
      }
    })();
  },[data,vehicles,fleet,pendingPlaces,maintenance]);

  const addReservation=useCallback((r,vehicleCode)=>{
    // ★ setData(prev=>...)で最新stateを使う（stale closure防止）
    let latestData;
    setData(prev=>{
      latestData=[...prev,r];
      try{localStorage.setItem("spk_reservations_backup",JSON.stringify(latestData));}catch(e){}
      return latestData;
    });
    markLocalChange("reservations");
    DB.upsertReservations([r]).then(()=>markDbSync("reservations"));
    if(vehicleCode){
      setFleet(prev=>({...prev,[r.id]:vehicleCode}));
      markLocalChange("fleet");
      DB.updateFleetOne(r.id,vehicleCode).then(()=>markDbSync("fleet"));
    }else{
      // 自動配車（最新のdata+fleetを使用）
      setFleet(prev=>{
        const newFleet=autoAssign(latestData||[r],vehicles,prev,maintenance);
        DB.upsertFleet(newFleet).catch(e=>console.error("upsertFleet error:",e));
        return newFleet;
      });
      markLocalChange("fleet");
    }
  },[vehicles,maintenance]);

  const bulkAddReservation=useCallback(async(rArr,fl)=>{
    const ids=new Set(data.map(r=>r.id));
    const newOnes=rArr.filter(r=>!ids.has(r.id));
    setData(prev=>[...prev,...newOnes]);
    setFleet(prev=>({...prev,...fl}));
    try{await DB.upsertReservations(newOnes);await DB.upsertFleet(fl);}catch(e){console.error("bulkAdd error:",e);}
  },[data]);

  const cancelReservation=useCallback(async(id)=>{
    // ★ ソフトキャンセル: status="cancelled" に変更（削除しない）
    const res=data.find(r=>r.id===id);if(!res)return;
    markCancelled(id);
    setData(prev=>{
      const next=prev.map(r=>r.id===id?{...r,status:"cancelled"}:r);
      try{localStorage.setItem("spk_reservations_backup",JSON.stringify(next));}catch(e){}
      return next;
    });
    markLocalChange("reservations");
    // 配車解除
    setFleet(prev=>{const nf={...prev};delete nf[id];return nf;});
    markLocalChange("fleet");
    DB.deleteFleetOne(id);markDbSync("fleet");
    // DB: statusをcancelledに更新
    await DB.updateReservationField(id,{status:"cancelled"});
    // ★ 関連タスクをCXLに変更（削除ではなくグレー表示）
    try{const _cxl=async(d)=>{if(!d)return;const tks=DB._lsLoad(d);if(!tks)return;const updated=tks.map(tk=>tk.reservationId===id?{...tk,type:"CXL",done:true,assignee:"",assignedVehicle:"",plateNo:""}:tk);if(JSON.stringify(updated)!==JSON.stringify(tks)){DB._lsSave(updated,d);await DB.upsertTasks(updated,d);}};const ld=norm(res.lendDate),rd=norm(res.returnDate);await _cxl(ld);if(rd!==ld)await _cxl(rd);await _cxl(dOff(ld,-1));}catch(e){console.error("[cancel task CXL]",e);}
  },[data]);
  // ★ キャンセル復元
  const restoreReservation=useCallback(async(id)=>{
    setData(prev=>{
      const next=prev.map(r=>r.id===id?{...r,status:"confirmed"}:r);
      try{localStorage.setItem("spk_reservations_backup",JSON.stringify(next));}catch(e){}
      return next;
    });
    markLocalChange("reservations");
    await DB.updateReservationField(id,{status:"confirmed"});
    // タスクのCXL状態を解除
    const res=data.find(r=>r.id===id);
    if(res){try{const rd=norm(res.returnDate);const _restore=async(d)=>{if(!d)return;const tks=DB._lsLoad(d);if(!tks||!tks.length)return;const updated=tks.map(t=>t.reservationId===id&&t.type==="CXL"?{...t,type:d===rd?"COL":"DEL",done:false}:t);if(JSON.stringify(updated)!==JSON.stringify(tks)){DB._lsSave(updated,d);await DB.upsertTasks(updated,d);}};const ld=norm(res.lendDate);await _restore(ld);if(rd!==ld)await _restore(rd);await _restore(dOff(ld,-1));}catch(e){console.error("[restore task]",e);}}
  },[data]);

  // 予約情報を部分更新（配車表モーダル/データタブから）
  const updateReservation=useCallback(async(id,changes)=>{
    const prev=data;
    const next=prev.map(r=>r.id===id?{...r,...changes}:r);
    const updated=next.find(r=>r.id===id);
    setData(next);
    try{localStorage.setItem("spk_reservations_backup",JSON.stringify(next));}catch(e){}
    markLocalChange("reservations");
    // ★ DB保存（awaitで確実に完了確認）
    try{
      if(updated)await DB.upsertReservations([updated]);
    }catch(e){console.error("[updateRes] DB save error",e);return false;}
    // ★ OPシートタスクにも連動（time/place/insurance/opts/vehicle）
    if(updated){
      const syncFields={};
      if(changes.delTime!==undefined)syncFields.delTime=changes.delTime;
      if(changes.delPlace!==undefined)syncFields.delPlace=changes.delPlace;
      if(changes.colTime!==undefined)syncFields.colTime=changes.colTime;
      if(changes.colPlace!==undefined)syncFields.colPlace=changes.colPlace;
      if(changes.insurance!==undefined)syncFields.insurance=changes.insurance;
      if(changes.vehicle!==undefined)syncFields.vehicle=changes.vehicle;
      if(changes.name!==undefined)syncFields.name=changes.name;
      if(changes.people!==undefined)syncFields.people=changes.people;
      if(changes.optB!==undefined||changes.optC!==undefined||changes.optJ!==undefined)syncFields.opts={b:+(changes.optB??updated.optB??0),c:+(changes.optC??updated.optC??0),j:+(changes.optJ??updated.optJ??0)};
      if(Object.keys(syncFields).length){
        const _syncTasksForRes=async(date)=>{
          const tks=await DB.fetchTasks(date);if(!tks||!tks.length)return;
          const promises=tks.filter(tk=>tk.reservationId===id).map(tk=>{
            const upd={...tk};
            if(syncFields.name!==undefined)upd.name=syncFields.name;
            if(syncFields.people!==undefined)upd.people=syncFields.people;
            if(syncFields.insurance!==undefined)upd.insurance=syncFields.insurance;
            if(syncFields.vehicle!==undefined)upd.vehicle=syncFields.vehicle;
            if(syncFields.opts)upd.opts=syncFields.opts;
            if(tk.type==="DEL"||tk.type==="PU"){if(syncFields.delTime!==undefined&&!tk._manualTime)upd.time=syncFields.delTime;if(syncFields.delPlace!==undefined&&!tk._manualPlace)upd.place=syncFields.delPlace;}
            if(tk.type==="COL"){if(syncFields.colTime!==undefined&&!tk._manualTime)upd.time=syncFields.colTime;if(syncFields.colPlace!==undefined&&!tk._manualPlace)upd.place=syncFields.colPlace;}
            return DB.updateTask(upd,date);
          });
          await Promise.all(promises);
        };
        const ld=norm(updated.lendDate),rd=norm(updated.returnDate);
        try{await _syncTasksForRes(ld);if(rd!==ld)await _syncTasksForRes(rd);}catch(e){console.error("[updateRes→tasks sync]",e);}
      }
    }
    return true;
  },[data]);

  const updatePlaces=useCallback((places)=>{
    let matched=0;
    const updated=data.map(r=>{
      const p=places[r.id];
      if(p){matched++;return{...r,delPlace:p.delPlace||r.delPlace,colPlace:p.colPlace||r.colPlace};}
      return r;
    });
    setData(updated);
    const unmatched=Object.keys(places).length-matched;
    // DB保存
    DB.upsertPlaces(places);
    const changed=updated.filter(r=>places[r.id]);
    if(changed.length)DB.upsertReservations(changed);
    return{matched,unmatched};
  },[data]);

  const oc=useMemo(()=>{const c={};data.forEach(t=>{c[t.ota]=(c[t.ota]||0)+1;});return c;},[data]);
  const navItems=[{id:"top",ico:"🏠",l:"TOP"},{id:"notices",ico:"📢",l:"お知らせ"},{id:"import",ico:"📁",l:"CSV"},{id:"staff",ico:"👥",l:"スタッフ"},{id:"shift",ico:"📅",l:"出勤簿"},{id:"attendance",ico:"⏰",l:"給与"},{id:"fleet",ico:"🚗",l:"配車"},{id:"jalanpay",ico:"💳",l:"決済"},{id:"vehicle",ico:"🔧",l:"車両"},{id:"parking",ico:"🅿️",l:"駐車場"},{id:"accounting",ico:"💰",l:"会計"},{id:"customer",ico:"👑",l:"顧客"},{id:"dashboard",ico:"📊",l:"売上"},{id:"data",ico:"📋",l:"データ"},{id:"history",ico:"📜",l:"過去"},{id:"license",ico:"🪪",l:"免許証",external:true}];

  const repeaterInfo=useMemo(()=>buildRepeaterMap(data),[data]);

  if(!dbLoaded)return <div onClick={()=>setDbLoaded(true)} style={{minHeight:"100vh",display:"flex",alignItems:"center",justifyContent:"center",background:"#f3f4f6",cursor:"pointer"}}><div style={{textAlign:"center"}}><div style={{width:48,height:48,border:"4px solid #e5e7eb",borderTopColor:"#2563eb",borderRadius:"50%",animation:"spin 1s linear infinite",margin:"0 auto 12px"}}></div><p style={{color:"#64748b",fontSize:13}}>データ読込中...</p><p style={{color:"#94a3b8",fontSize:11,marginTop:8}}>タップでスキップ</p></div></div>;

  return <div style={{height:"100vh",display:"flex",flexDirection:"column",overflow:"hidden"}}>
    {SB_ENABLED&&<div className="sync-desktop"><SyncBadge connected={sbConnected} online={isOnline}/></div>}
    {!isOnline&&<div style={{background:"#dc2626",color:"#fff",padding:"6px 12px",fontSize:12,fontWeight:700,textAlign:"center",zIndex:9999}}>⚠️ オフライン — 変更は復帰後に自動保存されます</div>}
    {showOP&&<OPScreen reservations={data} today={today} shifts={shifts} fleet={fleet} onFleetChange={setFleetSync} onClose={()=>{setShowOP(false);refreshTopTasks();}} onGoFleet={()=>setShowFloatFleet(f=>!f)} vehicles={vehicles} staff={staff} resOpts={resOpts} sheetPlaces={sheetPlaces} onUpdateSheetPlaces={saveSheetPlaces} repeaterMap={repeaterInfo.isRepeater} jalanPay={jalanPay} cancelledIdsRef={cancelledIdsRef} onCancelReservation={cancelReservation} onTaskChange={refreshTopTasks}/>}
    {/* ★ フローティング配車表パネル */}
    {showFloatFleet&&<div style={{position:"fixed",bottom:0,right:0,width:floatFleetSize==="full"?"100%":"50%",height:floatFleetSize==="full"?"70vh":"45vh",zIndex:250,background:"#fff",borderTop:"3px solid #059669",borderLeft:floatFleetSize!=="full"?"3px solid #059669":"none",boxShadow:"0 -4px 20px rgba(0,0,0,.2)",display:"flex",flexDirection:"column",borderRadius:floatFleetSize==="full"?"12px 12px 0 0":"12px 0 0 0"}}>
      <div style={{display:"flex",alignItems:"center",padding:"6px 12px",background:"#059669",gap:6,flexShrink:0,borderRadius:floatFleetSize==="full"?"9px 9px 0 0":"9px 0 0 0"}}>
        <span style={{fontSize:12,fontWeight:800,color:"#fff"}}>🚗 配車表</span>
        <button onClick={()=>setFloatFleetSize(s=>s==="half"?"full":"half")} style={{background:"rgba(255,255,255,.2)",border:"none",color:"#fff",fontSize:10,fontWeight:700,padding:"2px 8px",borderRadius:4,cursor:"pointer",marginLeft:"auto"}}>{floatFleetSize==="full"?"↘ 縮小":"↗ 拡大"}</button>
        <button onClick={()=>setShowFloatFleet(false)} style={{background:"rgba(255,255,255,.2)",border:"none",color:"#fff",fontSize:12,fontWeight:800,padding:"2px 8px",borderRadius:4,cursor:"pointer"}}>✕</button>
      </div>
      <div style={{flex:1,overflow:"hidden"}}>
        <FleetTimeline data={data} fleet={fleet} onFleetChange={setFleetSync} today={today} maintenance={maintenance} onMaintenanceChange={setMaintenance} vehicles={vehicles} vehicleClasses={vehicleClasses} onAddReservation={addReservation} onBulkAddReservation={bulkAddReservation} onCancelReservation={cancelReservation} onReassignVehicle={reassignVehicle} onUpdateReservation={updateReservation} unassignedReasons={unassignedReasons} onVehicleDetail={(code)=>{setHighlightVehicle(code);setTab("vehicle");setTimeout(()=>setHighlightVehicle(null),3000);}}/>
      </div>
    </div>}
    <div style={{display:showOP?"none":"flex",flex:1,overflow:"hidden",flexDirection:"column"}}>
      <div className={"top-nav"+(tab==="top"?" hide-on-top":"")}>
        {navItems.filter(n=>{const always=["top","notices","import","vehicle","staff","shift","attendance","parking","accounting","fleet","jalanpay","history","customer","license"];return always.includes(n.id)||data.length>0;}).map(n=><button key={n.id} onClick={()=>{if(n.external){window.open("license.html","_blank");}else{setTab(n.id);}}} className={tab===n.id?"active":""}><span className="ico">{n.ico}</span>{n.l}</button>)}
        {data.length>0&&<button onClick={()=>setShowOP(true)} style={{color:"#60a5fa"}}><span className="ico">📋</span>OP</button>}
        {SB_ENABLED&&<button onClick={reloadAll} disabled={reloading===1} style={{background:reloading===2?"#d1fae5":"none",border:"none",cursor:reloading===1?"wait":"pointer",fontSize:14,padding:"2px 4px",borderRadius:6,opacity:reloading===1?0.5:1,transition:"background .3s"}}>{reloading===1?"⏳":reloading===2?"✅":"🔄"}</button>}
        {SB_ENABLED&&<SyncBadge connected={sbConnected} inline={true} online={isOnline}/>}
      </div>
      <div style={{display:"flex",flex:1,overflow:"hidden"}}>
      <div className={"sidebar"+(tab==="top"?" hide-on-top":"")}>
        <div style={{width:36,height:36,borderRadius:8,background:"linear-gradient(135deg,#3b82f6,#1d4ed8)",display:"flex",alignItems:"center",justifyContent:"center",color:"#fff",fontWeight:800,fontSize:14,marginBottom:8}}>S</div>
        {navItems.filter(n=>{const always=["top","notices","import","vehicle","staff","shift","attendance","parking","accounting","fleet","jalanpay","history","customer","license"];return always.includes(n.id)||data.length>0;}).map(n=><button key={n.id} onClick={()=>{if(n.external){window.open("license.html","_blank");}else{setTab(n.id);}}} className={tab===n.id?"active":""}><span className="ico">{n.ico}</span>{n.l}</button>)}
        {data.length>0&&<button onClick={()=>setShowOP(true)} style={{marginTop:4,background:"linear-gradient(135deg,#1e40af,#2563eb)",color:"#fff",borderRadius:10}}><span className="ico">📋</span><span style={{fontSize:8}}>OP</span></button>}
      </div>
      <div className="main-area" style={{flex:1,overflow:tab==="fleet"||tab==="parking"?"hidden":"auto",padding:tab==="fleet"||tab==="parking"?0:12,display:"flex",flexDirection:"column"}}>
        {tab!=="top"&&tabHistory.length>0&&(tab==="fleet"||tab==="parking"?
          <div style={{padding:"6px 10px",flexShrink:0,background:"#f8fafc",borderBottom:"1px solid #e2e8f0"}}>
            <button onClick={goBack} style={{display:"inline-flex",alignItems:"center",gap:4,padding:"4px 12px",fontSize:12,fontWeight:600,color:"#3b82f6",background:"#eff6ff",border:"1px solid #bfdbfe",borderRadius:8,cursor:"pointer"}}>← 前ページに戻る</button>
          </div>
        :
          <div style={{marginBottom:4,flexShrink:0}}>
            <button onClick={goBack} style={{display:"inline-flex",alignItems:"center",gap:4,padding:"4px 12px",fontSize:12,fontWeight:600,color:"#3b82f6",background:"#eff6ff",border:"1px solid #bfdbfe",borderRadius:8,cursor:"pointer"}}>← 前ページに戻る</button>
          </div>
        )}
        {tab!=="fleet"&&tab!=="parking"&&tab!=="top"&&<div style={{marginBottom:8,display:"flex",alignItems:"center",justifyContent:"space-between",flexWrap:"wrap",gap:8,flexShrink:0}}>
          <div className="flex items-center gap-2"><div style={{width:28,height:28,borderRadius:6,background:"linear-gradient(135deg,#3b82f6,#1d4ed8)",display:"flex",alignItems:"center",justifyContent:"center",color:"#fff",fontWeight:800,fontSize:12}}>S</div><div><div className="font-bold text-sm text-gray-900">札幌店 タスク管理</div>{data.length>0&&<div className="text-xs text-gray-500 flex items-center gap-1">{data.length}件{Object.entries(oc).map(([k,v])=><span key={k}><OBadge ota={k}/>{v}</span>)}</div>}</div></div>
          {data.length>0&&<button onClick={()=>setShowOP(true)} className="px-3 py-1.5 rounded-lg text-xs font-bold text-white shadow" style={{background:"linear-gradient(135deg,#1e40af,#2563eb)"}}>📋 OPシート</button>}
        </div>}
        <div className="fade-in" style={{flex:1,minHeight:0,display:(tab==="fleet"||tab==="parking")?"flex":"block",flexDirection:"column"}}>
          {tab==="top"&&(()=>{
            const sections=[
              {title:"日常業務",color:"#2563eb",items:[
                {id:"fleet",ico:"🚗",l:"配車",desc:"予約の車両配車・タイムライン",badge:data.length>0?data.length+"件":null},
                {id:"parking",ico:"🅿️",l:"駐車場",desc:"入出庫・洗車・メンテ管理"},
                {id:"jalanpay",ico:"💳",l:"じゃらん決済",desc:"じゃらん予約の決済確認",badge:(()=>{const j=data.filter(r=>r.ota==="J");const undone=j.filter(r=>!jalanPay[r.id]||jalanPay[r.id].payStatus!=="完了").length;return undone>0?undone+"件未完了":null;})()},
                {id:"import",ico:"📁",l:"CSV取込",desc:"OTA予約CSVインポート"},
                {id:"accounting",ico:"💰",l:"会計",desc:"現金出納帳・予約外売上・立替金"},
              ]},
              {title:"スタッフ管理",color:"#059669",items:[
                {id:"shift",ico:"📅",l:"出勤簿",desc:"シフト表の作成・編集"},
                {id:"attendance",ico:"⏰",l:"給与",desc:"予算・実績・給与明細"},
                {id:"staff",ico:"👥",l:"スタッフ",desc:"スタッフ情報・時給設定"},
              ]},
              {title:"データ・分析",color:"#7c3aed",items:[
                {id:"dashboard",ico:"📊",l:"売上",desc:"売上・稼働率ダッシュボード",badge:data.length>0?"データあり":null},
                {id:"analytics",ico:"🔬",l:"解析",desc:"エリア分析・場所分布ランキング"},
                {id:"customer",ico:"👑",l:"顧客",desc:"リピーター分析"},
                {id:"data",ico:"📋",l:"データ",desc:"予約データ一覧・検索"},
                {id:"history",ico:"📜",l:"過去タスク",desc:"過去のタスク履歴"},
              ]},
              {title:"設定",color:"#64748b",items:[
                {id:"vehicle",ico:"🔧",l:"車両",desc:"車両マスタ・クラス管理"},
                {id:"license",ico:"🪪",l:"免許証",desc:"免許証画像アップロード",external:true},
              ]},
            ];
            return <div style={{maxWidth:700,margin:"0 auto",paddingBottom:20}}>
              <div style={{textAlign:"center",marginBottom:20,paddingTop:8}}>
                <div style={{display:"inline-flex",alignItems:"center",justifyContent:"center",width:56,height:56,borderRadius:16,background:"linear-gradient(135deg,#3b82f6,#1d4ed8)",marginBottom:10}}>
                  <span style={{color:"#fff",fontWeight:900,fontSize:24}}>S</span>
                </div>
                <div style={{fontSize:20,fontWeight:900,color:"#1e293b"}}>札幌店 タスク管理</div>
                <div style={{fontSize:10,color:"#94a3b8",marginTop:2}}>{APP_VERSION} ・ {data.length>0?data.length+"件の予約データ":"データ未読込"}{SB_ENABLED&&sbConnected?" ・ 🟢 同期中":SB_ENABLED?" ・ 🔴 未接続":""}</div>
                {data.length>0&&<button onClick={()=>setShowOP(true)} style={{marginTop:10,padding:"8px 20px",borderRadius:12,border:"none",cursor:"pointer",background:"linear-gradient(135deg,#1e40af,#2563eb)",color:"#fff",fontSize:13,fontWeight:700,boxShadow:"0 2px 8px rgba(37,99,235,.3)"}}>📋 OPシートを開く</button>}
              </div>
              {/* 協議中アラート */}
              {(()=>{
                const kyogiList=Object.values(attendance).filter(r=>r.memo&&r.memo.startsWith("協議中"));
                if(!kyogiList.length)return null;
                return <div style={{marginBottom:16}}>
                  {kyogiList.map((r,i)=>{
                    const detail=r.memo.replace(/^協議中:/,"");
                    return <div key={i} style={{display:"flex",alignItems:"flex-start",gap:10,padding:"12px 14px",borderRadius:12,background:"rgba(251,191,36,.12)",border:"1px solid rgba(251,191,36,.3)",marginBottom:8}}>
                      <span style={{fontSize:20,flexShrink:0}}>⚠️</span>
                      <div style={{flex:1}}>
                        <div style={{fontSize:13,fontWeight:900,color:"#b45309"}}>{r.name}さんより修正リクエストを受けています</div>
                        <div style={{fontSize:11,color:"#92400e",marginTop:2}}>{r.date}　{detail}</div>
                      </div>
                    </div>;
                  })}
                </div>;
              })()}
              <MemoBox today={today}/>
              {/* ★ 個人別タスクサマリー（折りたたみ） */}
              <div style={{marginBottom:8}}>
                <div onClick={()=>setTaskSumOpen(o=>!o)} style={{display:"flex",alignItems:"center",gap:8,padding:"10px 14px",borderRadius:12,background:"#f8fafc",border:"1px solid #e2e8f0",cursor:"pointer",userSelect:"none",boxShadow:"0 1px 3px rgba(0,0,0,.05)"}}>
                  <span style={{fontSize:16}}>👤</span>
                  <span style={{fontSize:12,fontWeight:800,color:"#1e293b"}}>個人別タスクサマリー</span>
                  <span style={{marginLeft:"auto",fontSize:11,color:"#94a3b8",fontWeight:700}}>{taskSumOpen?"▲":"▼"}</span>
                </div>
              </div>
              {taskSumOpen&&[{label:"本日",date:today,tasks:todayTasks,border:"#3b82f6"},{label:"翌日",date:dOff(today,1),tasks:tomorrowTasks,border:"#f59e0b"}].map(sec=>{
                if(!sec.tasks.length)return null;
                const byPerson={};
                sec.tasks.forEach(t=>{const who=t.assignee||"未割当";if(!byPerson[who])byPerson[who]=[];byPerson[who].push(t);});
                Object.values(byPerson).forEach(arr=>arr.sort((a,b)=>(a.timeChange||a._ssTime||a.time||"99:99").localeCompare(b.timeChange||b._ssTime||b.time||"99:99")));
                const persons=Object.keys(byPerson).sort((a,b)=>a==="未割当"?1:b==="未割当"?-1:a.localeCompare(b));
                if(!persons.length)return null;
                const dt=new Date(sec.date);const WK=["日","月","火","水","木","金","土"];
                const dateLabel=(dt.getMonth()+1)+"/"+dt.getDate()+"("+WK[dt.getDay()]+")";
                const dayShifts=(shifts[sec.date]||[]).filter(s=>s.type==="アルバイト"||s.symbol==="●");
                const done=sec.tasks.filter(t=>t.done).length;
                const openSet=personAccOpen[sec.label]||{};
                const toggle=(p)=>setPersonAccOpen(prev=>({...prev,[sec.label]:{...(prev[sec.label]||{}),[p]:!(prev[sec.label]||{})[p]}}));
                const remaining=sec.tasks.length-done;
                return <div key={sec.label} style={{marginBottom:12,background:"#fff",borderRadius:12,border:"1px solid #e2e8f0",overflow:"hidden"}}>
                    {/* ヘッダー */}
                    <div style={{padding:"10px 14px",background:sec.label==="本日"?"#eff6ff":"#fffbeb",borderBottom:"1px solid #e2e8f0",display:"flex",justifyContent:"space-between",alignItems:"center"}}>
                      <div style={{fontSize:13,fontWeight:800,color:"#1e293b"}}>{sec.label}（{dateLabel}）</div>
                      <div style={{display:"flex",gap:8,alignItems:"center"}}>
                        <span style={{fontSize:10,color:"#64748b"}}>{dayShifts.length}名出勤</span>
                        <span style={{fontSize:11,fontWeight:700,color:remaining>0?"#dc2626":"#059669"}}>{remaining>0?remaining+"件残":"全完了"}</span>
                      </div>
                    </div>
                    {/* 担当者リスト */}
                    <div style={{padding:"6px 0"}}>
                    {persons.map(person=>{
                      const tasks=byPerson[person];
                      const isOpen=!!openSet[person];
                      const isUnassigned=person==="未割当";
                      const sh=dayShifts.find(s=>s.name===person);
                      const pDone=tasks.filter(t=>t.done).length;const pAll=tasks.length;const pRem=pAll-pDone;
                      return <div key={person}>
                        <div onClick={()=>toggle(person)} style={{display:"flex",justifyContent:"space-between",alignItems:"center",padding:"8px 14px",cursor:"pointer",userSelect:"none",background:isOpen?"#f8fafc":"transparent"}}>
                          <div style={{display:"flex",alignItems:"center",gap:6}}>
                            <span style={{fontSize:9,color:"#94a3b8",width:12}}>{isOpen?"▼":"▶"}</span>
                            <span style={{fontSize:13,fontWeight:700,color:isUnassigned?"#94a3b8":"#1e293b"}}>{person}</span>
                            {sh&&<span style={{fontSize:9,color:"#94a3b8"}}>{sh.start||"09:00"}-{sh.end||"18:00"}</span>}
                          </div>
                          <div style={{display:"flex",alignItems:"center",gap:4}}>
                            <span style={{fontSize:10,color:"#94a3b8"}}>{pDone}/{pAll}</span>
                            {pRem>0&&<span style={{fontSize:10,fontWeight:700,color:"#dc2626"}}>{pRem}件残</span>}
                            {pRem===0&&<span style={{fontSize:10,color:"#059669",fontWeight:600}}>完了</span>}
                          </div>
                        </div>
                        {isOpen&&<div style={{padding:"0 14px 8px 32px"}}>
                          {tasks.map(t=>{
                            const typeMeta={DEL:{bg:"#dbeafe",c:"#1d4ed8",label:"DEL"},COL:{bg:"#fee2e2",c:"#dc2626",label:"COL"},"洗車":{bg:"#fef3c7",c:"#92400e",label:"洗車"}};
                            const tm=typeMeta[t.type]||{bg:"#f1f5f9",c:"#475569",label:t.type};
                            const isDel=t.type==="DEL";const isCOL=t.type==="COL";
                            const veh=(t.assignedVehicle||t.assigned_vehicle)?vehicles.find(v=>v.code===(t.assignedVehicle||t.assigned_vehicle)):null;
                            const vehName=veh?veh.name+" "+veh.no:"";
                            const toggleDone=async(e)=>{e.stopPropagation();try{if(sb){await sb.from("tasks").update({done:!t.done}).eq("_id",t._id);}refreshTopTasks();}catch(err){console.error("[TOP toggleDone]",err);}};
                            return <div key={t._id} style={{padding:"6px 0",borderBottom:"1px solid #f1f5f9",opacity:t.done?.5:1}}>
                              {/* メイン行: チェック + タイプ + 時間 + 名前 */}
                              <div style={{display:"flex",alignItems:"center",gap:6}}>
                                <span onClick={toggleDone} style={{fontSize:14,cursor:"pointer",flexShrink:0}}>{t.done?"✅":"⬜"}</span>
                                <span style={{fontSize:9,fontWeight:700,padding:"2px 6px",borderRadius:4,background:tm.bg,color:tm.c,flexShrink:0}}>{tm.label}</span>
                                {(()=>{const rT=t.timeChange||t._ssTime||t.time||"--:--";const orig=t.time||"";const changed=rT!==orig;return <span style={{fontSize:12,fontWeight:700,color:changed?"#dc2626":"#334155",flexShrink:0,fontFamily:"monospace"}}>{rT}{changed&&orig&&<span style={{fontSize:8,color:"#9ca3af",marginLeft:2}}>({orig})</span>}</span>;})()}
                                <span style={{fontSize:12,fontWeight:600,color:t.done?"#9ca3af":"#1e293b",textDecoration:t.done?"line-through":"none",overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{t.name}</span>
                                {t.ota&&<OBadge ota={t.ota}/>}
                              </div>
                              {/* サブ情報: 車両 + 場所（1行にまとめる） */}
                              {!t.done&&(vehName||t.place)&&<div style={{display:"flex",gap:6,alignItems:"center",marginTop:2,paddingLeft:26,flexWrap:"wrap"}}>
                                {vehName&&<span style={{fontSize:9,fontWeight:600,color:"#1d4ed8",background:"#eff6ff",padding:"1px 5px",borderRadius:3}}>{vehName}</span>}
                                {t.vehicle&&<span style={{fontSize:9,color:"#94a3b8"}}>{t.vehicle}クラス</span>}
                                {t.insurance&&<span style={{fontSize:8,fontWeight:700,padding:"1px 4px",borderRadius:3,background:t.insurance==="NOC"?"#fef3c7":"#fef2f2",color:t.insurance==="NOC"?"#92400e":"#dc2626"}}>{t.insurance}</span>}
                                {(()=>{const rP=(t._placeSource==="manual"?t.place:(t._ssPlace||t.place))||"";if(!rP)return null;return <a href={mapsUrl(rP)} target="_blank" rel="noopener" style={{fontSize:9,color:"#059669",textDecoration:"none"}}>📍{rP.length>20?rP.slice(0,20)+"...":rP}</a>;})()}
                              </div>}
                              {/* アクションボタン（未完了のDEL/COLのみ） */}
                              {(isDel||isCOL)&&!t.done&&<div style={{display:"flex",gap:3,marginTop:4,paddingLeft:26}}>
                                {isDel&&<button onClick={(e)=>{e.stopPropagation();const cn=(t.name||"")+"様";const msg=`【車両到着のお知らせ】\n${cn}\n\nお待たせいたしました。\n只今スタッフが指定場所に到着いたしました。\n\n場所: ${t.place||""}\n車種: ${veh?veh.name:""}\nナンバー: ${veh?veh.no:t.plateNo||t.plate_no||""}\n\nご準備整い次第、受け取り対応をお願い申し上げます。`;navigator.clipboard.writeText(msg).then(()=>alert("コピーしました"));}} style={{fontSize:8,fontWeight:600,padding:"3px 8px",borderRadius:6,background:"#f1f5f9",color:"#475569",border:"none",cursor:"pointer"}}>📱到着</button>}
                                {isDel&&<button onClick={(e)=>{e.stopPropagation();const cn=(t.name||"")+"様";const msg=`【車両位置情報のお知らせ】\n${cn}\n\n現在車両をデリバリー中です。\n詳細はマップリンクから位置情報をご確認ください。\n\n＜車両情報＞\nお届け場所: ${t.place||""}\n車種: ${veh?veh.name:""}\nナンバー: ${veh?veh.no:t.plateNo||t.plate_no||""}\n\n＜車両位置情報＞\n`;navigator.clipboard.writeText(msg).then(()=>alert("コピーしました"));}} style={{fontSize:8,fontWeight:600,padding:"3px 8px",borderRadius:6,background:"#f1f5f9",color:"#475569",border:"none",cursor:"pointer"}}>📱位置</button>}
                                {isCOL&&<button onClick={(e)=>{e.stopPropagation();const cn=(t.name||"")+"様";const msg=`【ご返却場所到着のお知らせ】\n${cn}\n\n回収スタッフがご返却場所に到着致しました。\nご準備できましたら対応のほどお願い申しあげます。\n何卒よろしくお願いいたします。`;navigator.clipboard.writeText(msg).then(()=>alert("コピーしました"));}} style={{fontSize:8,fontWeight:600,padding:"3px 8px",borderRadius:6,background:"#f1f5f9",color:"#475569",border:"none",cursor:"pointer"}}>📱到着</button>}
                                {isCOL&&<button onClick={(e)=>{e.stopPropagation();const cn=(t.name||"")+"様";const msg=`【乗り捨て対応のお願い】\n${cn}\n\nご返却時刻の混雑により、大変お手数ではございますが返却予定場所近隣駐車場に乗り捨て駐車いただきたく、ご連絡させていただきました。\nお待たせする時間回避の目的のためご協力の程何卒よろしくお願いいたします。\n\n✅駐車完了しましたら"鍵と駐車券"をダッシュボード内に格納し、鍵を開けた状態でそのままお降りくださいませ。\n✅燃料の給油とお忘れ物（ETCカード等）のないようご注意ください。\n✅駐車場所が確定しましたら詳細場所をご連絡いただけますと幸いです。\n例：駐車場看板写真/GoogleマップURL/住所/駐車場名/●階等\n\n駐車後の車両トラブルに関しては一切の責任は問いませんのでご安心くださいませ。\n万一の盗難等の際にも弊社セキュリティにて追跡可能となっております。`;navigator.clipboard.writeText(msg).then(()=>alert("コピーしました"));}} style={{fontSize:8,fontWeight:600,padding:"3px 8px",borderRadius:6,background:"#f1f5f9",color:"#475569",border:"none",cursor:"pointer"}}>📱乗捨</button>}
                                <button onClick={(e)=>{e.stopPropagation();window.open("https://web.carmon.alpine-srv.net/","_blank");}} style={{fontSize:8,fontWeight:600,padding:"3px 8px",borderRadius:6,background:"#f1f5f9",color:"#475569",border:"none",cursor:"pointer"}}>📍CARMON</button>
                                {(t.reservationId||t.reservation_id)&&<button onClick={(e)=>{e.stopPropagation();window.open("license.html?id="+encodeURIComponent(t.reservationId||t.reservation_id)+"&name="+encodeURIComponent(t.name||""),"_blank");}} style={{fontSize:8,fontWeight:600,padding:"3px 8px",borderRadius:6,background:"#f1f5f9",color:"#475569",border:"none",cursor:"pointer"}}>🪪免許証</button>}
                              </div>}
                            </div>;
                          })}
                        </div>}
                      </div>;
                    })}
                    </div>
                  </div>;
              })}
              {/* ★ 本日スケジュール（折りたたみ式） */}
              {todayTasks.length>0&&(()=>{
                const isMob=window.innerWidth<=768;
                const timedWash=todayTasks.filter(t=>t.type==="洗車"&&t.time);
                const untimedWash=todayTasks.filter(t=>t.type==="洗車"&&!t.time);
                const allSchedule=[...todayTasks.filter(t=>t.type!=="洗車"&&t.type!=="CXL"),...timedWash].sort((a,b)=>{const ta=a.timeChange||a._ssTime||a.time||"99:99";const tb=b.timeChange||b._ssTime||b.time||"99:99";return ta.localeCompare(tb);});
                const typeStyle=(tp)=>({DEL:{bg:"#dbeafe",c:"#1d4ed8",border:"#60a5fa"},COL:{bg:"#ffedd5",c:"#9a3412",border:"#fdba74"},"洗車":{bg:"#FFFDE7",c:"#795548",border:"#FFD54F"},"その他":{bg:"#f1f5f9",c:"#475569",border:"#cbd5e1"},CXL:{bg:"#f1f5f9",c:"#9ca3af",border:"#d1d5db"}})[tp]||{bg:"#f1f5f9",c:"#475569",border:"#cbd5e1"};
                const totalCnt=allSchedule.length+(untimedWash.length>0?" + 時間未定洗車"+untimedWash.length+"件":"");
                return <div style={{marginBottom:8}}>
                  <div onClick={()=>setTomSumOpen(o=>!o)} style={{display:"flex",alignItems:"center",gap:8,padding:"10px 14px",borderRadius:12,background:"#f8fafc",border:"1px solid #e2e8f0",cursor:"pointer",userSelect:"none",boxShadow:"0 1px 3px rgba(0,0,0,.05)"}}>
                    <span style={{fontSize:16}}>🗓</span>
                    <span style={{fontSize:13,fontWeight:900,color:"#1e293b"}}>本日スケジュール</span>
                    <span style={{marginLeft:"auto",fontSize:11,fontWeight:700,color:"#94a3b8"}}>{allSchedule.length}件　{tomSumOpen?"▲":"▼"}</span>
                  </div>
                  {tomSumOpen&&<div style={{marginTop:6,background:"#fff",borderRadius:12,border:"1px solid #e2e8f0",overflow:"hidden",boxShadow:"0 1px 3px rgba(0,0,0,.06)"}}>
                    {allSchedule.map(t=>{
                      const ppl=parseInt(t.people)||0;
                      const resolvedT=t.timeChange||t._ssTime||t.time||"--:--";
                      const resolvedP=(t._placeSource==="manual"?t.place:(t._ssPlace||t.place))||"";
                      const ts=typeStyle(t.type);
                      const vn=t.assignedVehicle?vehicles.find(v=>v.code===t.assignedVehicle):null;
                      const fleetVc=!vn&&t.reservationId?fleet[t.reservationId]:null;
                      const fleetVeh=fleetVc?vehicles.find(v=>v.code===fleetVc):null;
                      const dispVn=vn||fleetVeh;
                      return <div key={t._id} onClick={()=>{if(t.reservationId){setShowOP(true);}}} style={{display:"flex",alignItems:"stretch",gap:0,borderBottom:"1px solid #e2e8f0",cursor:t.reservationId?"pointer":"default",opacity:t.done?.5:1,background:t.done?"#fafafa":"#fff"}}>
                        <div style={{width:isMob?56:52,flexShrink:0,display:"flex",alignItems:"center",justifyContent:"center",fontWeight:800,fontSize:isMob?13:12,color:"#334155",fontFamily:"monospace",background:"#f8fafc",borderRight:"1px solid #e2e8f0"}}>{resolvedT}</div>
                        <div style={{width:isMob?48:44,flexShrink:0,display:"flex",alignItems:"center",justifyContent:"center",background:ts.bg,borderRight:"2px solid "+ts.border}}>
                          <span style={{fontSize:isMob?11:10,fontWeight:800,color:ts.c}}>{t.type}</span>
                        </div>
                        <div style={{flex:1,padding:isMob?"6px 10px":"5px 10px",minWidth:0}}>
                          <div style={{display:"flex",alignItems:"center",gap:6}}>
                            <span style={{fontWeight:700,fontSize:isMob?13:12,color:"#0f172a",overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{t.type==="洗車"?(t.name||"洗車"):(t.name||"名前なし")}</span>
                            {t.type==="洗車"&&t.memo&&<span style={{fontSize:isMob?10:9,color:"#795548",fontWeight:600,flexShrink:0}}>{t.memo}</span>}
                            {t.type!=="洗車"&&ppl>0&&<span style={{fontSize:isMob?11:10,fontWeight:700,color:"#7c3aed",flexShrink:0}}>{ppl}名</span>}
                            {t.done&&<span style={{flexShrink:0}}>✅</span>}
                          </div>
                          <div style={{display:"flex",alignItems:"center",gap:6,marginTop:2,flexWrap:"wrap"}}>
                            {resolvedP&&<span style={{fontSize:isMob?10:9,color:"#475569",fontWeight:600}}>📍{resolvedP}</span>}
                            {t.flight&&<span style={{fontSize:isMob?10:9,color:"#1565c0",fontWeight:600}}>✈{t.flight}</span>}
                            {dispVn&&<span style={{fontSize:isMob?10:9,color:"#059669",fontWeight:600}}>🚗{dispVn.name}({dispVn.no})</span>}
                            {!dispVn&&t.type!=="洗車"&&t.type!=="その他"&&<span style={{fontSize:isMob?9:8,color:"#dc2626",fontWeight:700}}>未配車</span>}
                            {t.assignee&&<span style={{fontSize:isMob?10:9,background:"#ede9fe",color:"#6d28d9",fontWeight:700,padding:"1px 6px",borderRadius:4}}>👤{t.assignee}</span>}
                            {!t.assignee&&t.type!=="洗車"&&<span style={{fontSize:isMob?9:8,color:"#f59e0b",fontWeight:700}}>担当未定</span>}
                          </div>
                        </div>
                      </div>;
                    })}
                    {untimedWash.length>0&&<div>
                      <div style={{background:"#f8fafc",padding:"4px 12px",borderBottom:"1px solid #e2e8f0",display:"flex",alignItems:"center",gap:6}}>
                        <span style={{fontSize:isMob?14:13,fontWeight:900,color:"#64748b"}}>🧽 洗車（時間未定）</span>
                        <span style={{fontSize:9,color:"#94a3b8",fontWeight:600}}>{untimedWash.length}件</span>
                        <div style={{flex:1,height:1,background:"#e2e8f0"}}/>
                      </div>
                      {untimedWash.map(t=>{
                        const vn=t.assignedVehicle?vehicles.find(v=>v.code===t.assignedVehicle):null;
                        return <div key={t._id} style={{display:"flex",alignItems:"center",gap:8,padding:isMob?"6px 12px":"4px 12px",borderBottom:"1px solid #f5f5f5",opacity:t.done?.5:1,fontSize:isMob?11:10}}>
                          <span style={{fontWeight:600,color:"#64748b",flex:1}}>{t.memo||t.name||""}</span>
                          {vn&&<span style={{color:"#059669",fontWeight:600,fontSize:isMob?10:9}}>🚗{vn.name}({vn.no})</span>}
                          {t.assignee&&<span style={{color:"#6d28d9",fontWeight:600,fontSize:isMob?10:9}}>👤{t.assignee}</span>}
                          {t.done&&<span>✅</span>}
                        </div>;
                      })}
                    </div>}
                  </div>}
                </div>;
              })()}
              {sections.map(function(sec){return <div key={sec.title} style={{marginBottom:16}}>
                <div style={{fontSize:11,fontWeight:800,color:sec.color,textTransform:"uppercase",letterSpacing:1,marginBottom:8,paddingLeft:4}}>{sec.title}</div>
                <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(200px,1fr))",gap:8}}>
                  {sec.items.map(function(item){return <button key={item.id} onClick={function(){if(item.external){window.open("license.html","_blank");}else{setTab(item.id);}}} style={{
                    display:"flex",alignItems:"center",gap:12,padding:"14px 16px",borderRadius:14,border:"1px solid #e2e8f0",
                    background:"#fff",cursor:"pointer",textAlign:"left",transition:"all .15s",boxShadow:"0 1px 3px rgba(0,0,0,.04)"
                  }} onMouseOver={function(e){e.currentTarget.style.borderColor=sec.color;e.currentTarget.style.boxShadow="0 2px 8px rgba(0,0,0,.08)";}}
                     onMouseOut={function(e){e.currentTarget.style.borderColor="#e2e8f0";e.currentTarget.style.boxShadow="0 1px 3px rgba(0,0,0,.04)";}}>
                    <div style={{width:42,height:42,borderRadius:12,background:sec.color+"12",display:"flex",alignItems:"center",justifyContent:"center",fontSize:22,flexShrink:0}}>{item.ico}</div>
                    <div style={{flex:1,minWidth:0}}>
                      <div style={{fontSize:14,fontWeight:700,color:"#1e293b"}}>{item.l}</div>
                      <div style={{fontSize:10,color:"#94a3b8",marginTop:1,lineHeight:1.3}}>{item.desc}</div>
                    </div>
                    {item.badge&&<span style={{padding:"2px 8px",borderRadius:10,fontSize:9,fontWeight:700,background:sec.color+"18",color:sec.color,flexShrink:0}}>{item.badge}</span>}
                  </button>;})}
                </div>
              </div>;})}
              {/* 同期ステータスパネル（最下部） */}
              {SB_ENABLED&&(()=>{
                const now=Date.now();
                const cats=[
                  {key:"reservations",label:"予約",ico:"📁"},
                  {key:"fleet",label:"配車",ico:"🚗"},
                  {key:"staff",label:"スタッフ",ico:"👥"},
                  {key:"vehicles",label:"車両",ico:"🔧"},
                  {key:"shifts",label:"出勤簿",ico:"📅"},
                  {key:"maintenance",label:"整備",ico:"🔩"},
                ];
                const getStatus=(cat)=>{
                  const s=syncStatus[cat.key];
                  if(!s||!s.dbTime)return{status:"unknown",label:"未同期",color:"#94a3b8",bg:"#f1f5f9"};
                  const age=now-s.dbTime;
                  const hasUnsaved=s.localTime&&s.localTime>s.dbTime;
                  if(hasUnsaved)return{status:"unsaved",label:"未保存あり",color:"#dc2626",bg:"#fef2f2"};
                  if(!sbConnected&&age>60000)return{status:"stale",label:Math.floor(age/60000)+"分前",color:"#f59e0b",bg:"#fffbeb"};
                  if(age<5000)return{status:"fresh",label:"同期済",color:"#059669",bg:"#f0fdf4"};
                  if(age<60000)return{status:"ok",label:Math.floor(age/1000)+"秒前",color:"#059669",bg:"#f0fdf4"};
                  if(age<300000)return{status:"ok",label:Math.floor(age/60000)+"分前",color:"#64748b",bg:"#f8fafc"};
                  return{status:"old",label:Math.floor(age/60000)+"分前",color:"#f59e0b",bg:"#fffbeb"};
                };
                const hasIssue=cats.some(c=>{const st=getStatus(c);return st.status==="unsaved"||st.status==="stale"||st.status==="unknown";});
                return <div style={{marginTop:16,padding:"10px 14px",borderRadius:12,border:"1px solid "+(hasIssue?"#fde68a":"#d1fae5"),background:hasIssue?"#fffbeb":"#f0fdf4"}}>
                  <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:8}}>
                    <div style={{fontSize:11,fontWeight:700,color:hasIssue?"#92400e":"#166534"}}>
                      {hasIssue?"⚠️ 同期状態に注意":"✅ 全カテゴリ同期済み"}
                    </div>
                    <button onClick={reloadAll} disabled={reloading===1} style={{padding:"4px 12px",borderRadius:8,border:"1px solid #d1d5db",background:"#fff",fontSize:11,fontWeight:600,color:"#374151",cursor:reloading===1?"wait":"pointer"}}>
                      {reloading===1?"同期中...":"🔄 今すぐ同期"}
                    </button>
                    <button onClick={()=>{if(confirm("ローカルキャッシュを削除してDBから再取得します。よろしいですか？")){Object.keys(localStorage).filter(k=>k.startsWith("spk_")).forEach(k=>localStorage.removeItem(k));location.reload();}}} style={{padding:"4px 12px",borderRadius:8,border:"1px solid #fca5a5",background:"#fff",fontSize:11,fontWeight:600,color:"#dc2626",cursor:"pointer"}}>
                      🗑 キャッシュクリア
                    </button>
                  </div>
                  <div style={{display:"grid",gridTemplateColumns:"repeat(3,1fr)",gap:6}}>
                    {cats.map(cat=>{
                      const st=getStatus(cat);
                      return <div key={cat.key} style={{display:"flex",alignItems:"center",gap:6,padding:"6px 8px",borderRadius:8,background:st.bg,border:"1px solid "+st.color+"30"}}>
                        <span style={{fontSize:14}}>{cat.ico}</span>
                        <div style={{flex:1,minWidth:0}}>
                          <div style={{fontSize:10,fontWeight:700,color:"#374151"}}>{cat.label}</div>
                          <div style={{fontSize:9,color:st.color,fontWeight:600}}>{st.label}</div>
                        </div>
                        <div style={{width:8,height:8,borderRadius:4,background:st.status==="fresh"||st.status==="ok"?"#22c55e":st.status==="unsaved"?"#ef4444":st.status==="stale"?"#f59e0b":"#94a3b8",flexShrink:0}}></div>
                      </div>;
                    })}
                  </div>
                  {!sbConnected&&<div style={{marginTop:8,padding:"6px 10px",borderRadius:8,background:"#fef2f2",border:"1px solid #fecaca",fontSize:10,color:"#dc2626",fontWeight:600}}>
                    🔴 リアルタイム接続が切断されています。「今すぐ同期」で最新データを取得してください。
                  </div>}
                </div>;
              })()}
            </div>;
          })()}
          {tab==="customer"&&<CustomerList data={data}/>}
          {tab==="import"&&<CSVPanel onImport={imp} onUpdatePlaces={updatePlaces} dataCount={data.length} pendingPlaces={pendingPlaces} onSetPendingPlaces={setPendingPlaces} files={csvFiles} setFiles={setCsvFiles} logs={csvLogs} setLogs={setCsvLogs} placeLogs={csvPlaceLogs} setPlaceLogs={setCsvPlaceLogs}/>}
          {tab==="staff"&&<PASGuard label="スタッフ情報"><StaffManager staff={staff} onStaffChange={setStaffSync} onDeleteStaff={async(name)=>{try{await DB.deleteStaff(name);/* 旧名シフト・勤怠を清掃 */if(sb){sb.from("shifts").delete().eq("staff_name",name).then(()=>console.log("[staff] shifts清掃:",name));sb.from("spk_attendance").delete().eq("staff_name",name).then(()=>console.log("[staff] attendance清掃:",name));}}catch(e){console.error("deleteStaff error:",e);}}}/></PASGuard>}
          {tab==="shift"&&<ShiftCalendar shifts={shifts} onShiftsChange={setShiftsSync} today={today} staff={staff} sbSaveShift={DB.saveShift} reservations={data}/>}
          {tab==="attendance"&&<PASGuard label="給与計算"><AttendanceManager shifts={shifts} staff={staff} today={today} attendance={attendance} onAttendanceChange={setAttendance}/></PASGuard>}
          {tab==="fleet"&&<FleetTimeline data={data} fleet={fleet} onFleetChange={setFleetSync} today={today} maintenance={maintenance} onMaintenanceChange={setMaintenance} vehicles={vehicles} vehicleClasses={vehicleClasses} onAddReservation={addReservation} onBulkAddReservation={bulkAddReservation} onCancelReservation={cancelReservation} onReassignVehicle={reassignVehicle} onUpdateReservation={updateReservation} unassignedReasons={unassignedReasons} onVehicleDetail={(code)=>{setHighlightVehicle(code);setTab("vehicle");setTimeout(()=>setHighlightVehicle(null),3000);}}/>}
          {tab==="vehicle"&&<VehicleTab vehicles={vehicles} onVehiclesChange={setVehiclesSync} vehicleClasses={vehicleClasses} onDeleteVehicle={(code)=>{DB.deleteVehicle(code);/* 車両削除→fleet残留エントリ除去 */const nf={...fleetRefApp.current};let cleaned=false;Object.entries(nf).forEach(([rid,vc])=>{if(vc===code){delete nf[rid];cleaned=true;}});if(cleaned){setFleet(nf);fleetRefApp.current=nf;markLocalChange("fleet");DB.upsertFleet(nf).catch(e=>console.error("fleet cleanup error:",e));}}} hmCars={hmCars} hmCarData={hmCarData} hmLogs={hmLogs} hmClasses={hmClasses} hmReload={hmReload} highlightVehicle={highlightVehicle}/>}
          {tab==="parking"&&<ParkingManager masterVehicles={vehicles}/>}
          {tab==="accounting"&&<PASGuard label="会計管理"><AccountingPanel staff={staff}/></PASGuard>}
          {tab==="jalanpay"&&<JalanPayment data={data} jalanPay={jalanPay} onJalanPayChange={(id,d)=>{setJalanPay(p=>({...p,[id]:d}));DB.saveJalanPayment(id,d);}}/>}
          {tab==="dashboard"&&data.length>0&&<>
            {importDiag&&(()=>{const hz=importDiag.zeroAll.length>0;const ha=importDiag.added?.length||0;const hr=importDiag.removed?.length||0;const hc=importDiag.changed?.length||0;return <div style={{background:hz?"#fef3c7":"#f0fdf4",border:`1px solid ${hz?"#f59e0b":"#86efac"}`,borderRadius:10,padding:"8px 12px",marginBottom:10,fontSize:11}}>
              <div style={{display:"flex",justifyContent:"space-between",alignItems:"center"}}>
                <span style={{fontWeight:700,color:hz?"#92400e":"#15803d"}}>✅ {importDiag.total}件 ¥{importDiag.totalSum.toLocaleString()}{hz?` (⚠️${importDiag.zeroAll.length}件price=0)`:""}</span>
                <button onClick={()=>setImportDiag(null)} style={{background:"none",border:"none",cursor:"pointer",fontSize:12,color:"#94a3b8"}}>✕</button>
              </div>
              {(ha>0||hr>0||hc>0)&&<div style={{marginTop:4}}>
                <div style={{display:"flex",gap:8,flexWrap:"wrap",marginBottom:2}}>
                  {ha>0&&<span style={{color:"#059669",fontWeight:600}}>🆕 新規{ha}件</span>}
                  {hr>0&&<span style={{color:"#dc2626",fontWeight:600}}>❌ キャンセル{hr}件</span>}
                  {hc>0&&<span style={{color:"#2563eb",fontWeight:600}}>📝 変更{hc}件</span>}
                </div>
              </div>}
              {importDiag.otaDiffLines&&importDiag.otaDiffLines.length>0&&<div style={{marginTop:4,fontSize:10,color:"#475569"}}>{importDiag.otaDiffLines.map((l,i)=><div key={i}>{l}</div>)}</div>}
            </div>;})()}
            <Dashboard data={data} fleet={fleet} vehicles={vehicles} maintenance={maintenance}/>
          </>}
          {tab==="data"&&data.length>0&&<DataTable data={data} fleet={fleet} vehicles={vehicles} sheetPlaces={sheetPlaces} onUpdatePlaces={saveSheetPlaces} jalanPay={jalanPay} onUpdateReservation={async(id,updates)=>{return await updateReservation(id,updates);}} onCancelReservation={cancelReservation} onRestoreReservation={restoreReservation}/>}
          {tab==="analytics"&&<AnalyticsTab data={data} sheetPlaces={sheetPlaces}/>}
          {tab==="history"&&<PastTasksTable today={today}/>}
          {tab==="notices"&&<NoticesPage store="SPK"/>}
        </div>
      </div>
    </div>
    </div>
  </div>;
}

const APP_VERSION="v4.5.2";
// バージョンチェック: 古いキャッシュを検出したら強制リロード
(function(){
  const stored=localStorage.getItem("spk_app_version");
  if(stored&&stored!==APP_VERSION){
    localStorage.setItem("spk_app_version",APP_VERSION);
    console.log("[SPK] Version changed: "+stored+" → "+APP_VERSION+", reloading...");
    location.reload(true);
  }else{
    localStorage.setItem("spk_app_version",APP_VERSION);
  }
})();
function Root(){
  const[auth,setAuth]=useState(!SB_ENABLED||localStorage.getItem("spk_auth")==="1");
  if(!auth)return <LoginScreen onLogin={()=>setAuth(true)}/>;
  return <><App/><div style={{position:"fixed",bottom:2,right:8,fontSize:11,color:"#64748b",fontWeight:700,zIndex:9999,pointerEvents:"none",background:"rgba(255,255,255,.8)",padding:"1px 6px",borderRadius:4}}>{APP_VERSION}</div></>;
}
ReactDOM.render(<Root/>,document.getElementById("root"));
// ★ React描画完了 → スプラッシュを非表示
if(typeof window.hideSplash==='function') window.hideSplash();
</script>
</body>
</html>
